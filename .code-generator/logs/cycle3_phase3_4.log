363	@given(st.booleans())
364	@settings(max_examples=10)
365	def test_when_neutral_flag_is_any_boolean_then_it_round_trips_through_features(
366	    neutral: bool,
367	) -> None:
368	    """Round-trip invariant: the NEUTRAL bool is preserved exactly in the output column.
369	
370	    Derived from criterion: 'Neutral flag round-trips exactly from the input NEUTRAL column.'
371	    """
372	    m = _matches([{
373	        "home": "Brazil", "away": "Germany",
374	        "home_goals": 1, "away_goals": 0, "neutral": neutral,
375	    }])
376	    result = FeatureBuilder(_DEFAULT_CFG).build(m, _elo([{}]), _BRA_GER)
377	    assert bool(result.iloc[0]["neutral"]) == neutral
