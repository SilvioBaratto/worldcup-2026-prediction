261	@given(n=st.integers(min_value=1, max_value=6))
262	@settings(max_examples=20)
263	def test_when_any_count_of_unplayed_wc_rows_then_goals_are_always_na(n: int) -> None:
264	    """
265	    Invariant: for ANY number of unplayed FIFA World Cup rows passed to
266	    wc2026_features, every row in the output has home_goals and away_goals
267	    equal to <NA>.
268	
269	    Derived from criterion: 'returns those rows … with home_goals/away_goals as <NA>.'
270	    """
271	    from worldcup_playoff.features.wc2026 import wc2026_features
272	
273	    team_pairs = [(f"Home{i}", f"Away{i}") for i in range(n)]
274	    all_teams = [t for pair in team_pairs for t in pair]
275	
276	    rows = [
277	        {
278	            "home": home,
279	            "away": away,
280	            "tournament": "FIFA World Cup",
281	            "date": f"2026-07-{i + 1:02d}",
282	        }
283	        for i, (home, away) in enumerate(team_pairs)
284	    ]
285	    m = _matches(rows)
286	    elo = _elo([{}] * n)
287	    result = wc2026_features(m, elo, _abilities(*all_teams))
288	
289	    assert result["home_goals"].isna().all(), "home_goals must be NA for all unplayed WC fixtures"
290	    assert result["away_goals"].isna().all(), "away_goals must be NA for all unplayed WC fixtures"
