42	def _frame(*rows: tuple) -> pd.DataFrame:
43	    """Build a minimal matches DataFrame from (home, away, date_or_None, hg_or_None, ag_or_None)."""
44	    return pd.DataFrame([
45	        {
46	            "HOME_TEAM": home,
47	            "AWAY_TEAM": away,
48	            "DATE": pd.to_datetime(d) if d is not None else pd.NaT,
49	            "HOME_GOALS": hg,
50	            "AWAY_GOALS": ag,
51	            "TOURNAMENT": "Friendly",
52	            "NEUTRAL": False,
53	        }
54	        for home, away, d, hg, ag in rows
55	    ])
56	
57	
58	# ---------------------------------------------------------------------------
59	# Criterion 1 — sort_chronological
60	# ---------------------------------------------------------------------------
61	
62	
63	class TestSortChronological:
64	    """sort_chronological sorts ascending, puts NaT last, and resets the index."""
65	
66	    def test_when_dates_are_mixed_then_result_is_sorted_ascending(self) -> None:
67	        df = _frame(
68	            ("Brazil", "Germany", "2018-07-15", 1, 1),
69	            ("France", "Croatia", "2018-07-10", 4, 2),
70	            ("England", "Belgium", "2018-07-14", 0, 2),
71	        )
72	        result = sort_chronological(df)
73	        dates = result["DATE"].dropna().tolist()
74	        assert dates == sorted(dates)
75	
76	    def test_when_nat_date_present_then_nat_row_is_last(self) -> None:
77	        df = _frame(
78	            ("Brazil", "Germany", None, 1, 1),
79	            ("France", "Croatia", "2018-07-10", 4, 2),
80	            ("England", "Belgium", "2018-07-14", 0, 2),
81	        )
82	        result = sort_chronological(df)
83	        assert pd.isna(result["DATE"].iloc[-1])
84	
85	    def test_when_sorted_then_index_is_reset_to_zero_based_range(self) -> None:
86	        df = _frame(
87	            ("France", "Croatia", "2018-07-10", 4, 2),
88	            ("Brazil", "Germany", "2018-07-05", 1, 1),
89	        )
90	        result = sort_chronological(df)
91	        assert list(result.index) == list(range(len(result)))
92	
93	    def test_when_dates_equal_then_sort_is_stable_on_team_name(self) -> None:
94	        """Same date: sort falls through to HOME_TEAM alphabetically ('A' < 'C')."""
95	        df = _frame(
96	            ("A", "B", "2020-01-01", 1, 0),
97	            ("C", "D", "2020-01-01", 2, 1),
98	        )
99	        result = sort_chronological(df)
100	        homes = list(result["HOME_TEAM"])
101	        assert homes.index("A") < homes.index("C")
102	
103	    def test_when_compared_to_elo_sort_then_frames_are_byte_identical(self) -> None:
104	        """sort_chronological must reproduce the Elo engine's sort exactly.
105	
106	        Any divergence here would misalign the sorted frame with
107	        EloResult.match_diffs and silently corrupt downstream features.
108	        """
109	        df = _frame(
110	            ("Brazil", "Germany", "2018-07-15", 1, 1),
111	            ("France", "Croatia", "2018-07-10", 4, 2),
112	            ("England", "Belgium", "2018-07-14", 0, 2),
113	            ("Spain", "Portugal", None, 0, 0),
114	        )
115	        expected = (
116	            df.assign(_d=pd.to_datetime(df["DATE"], errors="coerce"))
117	            .sort_values(SORT_COLS, kind="stable", na_position="last")
118	            .drop(columns=["_d"])
119	            .reset_index(drop=True)
120	        )
121	        pd.testing.assert_frame_equal(sort_chronological(df), expected)
122	
