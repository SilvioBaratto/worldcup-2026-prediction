321	@settings(max_examples=100)
322	def test_when_sort_applied_twice_then_result_is_idempotent(rows: list) -> None:
323	    """sort_chronological(sort_chronological(df)) == sort_chronological(df)."""
324	    df = pd.DataFrame([
325	        {"HOME_TEAM": h, "AWAY_TEAM": a, "DATE": pd.Timestamp(d.isoformat()),
326	         "HOME_GOALS": 1, "AWAY_GOALS": 0, "TOURNAMENT": "Friendly", "NEUTRAL": False}
327	        for h, a, d in rows
328	    ])
329	    once = sort_chronological(df)
330	    twice = sort_chronological(once)
331	    pd.testing.assert_frame_equal(once.reset_index(drop=True), twice.reset_index(drop=True))
332	
333	
334	@given(
335	    rows=st.lists(
336	        st.tuples(
337	            st.sampled_from(["Germany", "Brazil", "TeamX"]),
338	            st.sampled_from(["France", "Spain", "TeamY"]),
339	            _DATE_STRAT,
340	            st.integers(min_value=0, max_value=5),
341	            st.integers(min_value=0, max_value=5),
342	        ),
343	        min_size=3,
344	        max_size=15,
345	    )
346	)
347	@settings(max_examples=80)
348	def test_when_future_row_appended_then_form_at_earlier_cutoff_is_unchanged(rows: list) -> None:
349	    """No-leakage invariant holds for any frame and any valid before_idx."""
350	    df = pd.DataFrame([
351	        {"HOME_TEAM": h, "AWAY_TEAM": a, "DATE": pd.Timestamp(d.isoformat()),
352	         "HOME_GOALS": hg, "AWAY_GOALS": ag, "TOURNAMENT": "Friendly", "NEUTRAL": False}
353	        for h, a, d, hg, ag in rows
354	    ])
355	    cutoff = max(1, len(df) // 2)
356	    form_original = recent_form("Germany", cutoff, df, window=5, half_life_days=365.0)
357	
358	    extra = pd.DataFrame([{
359	        "HOME_TEAM": "Germany", "AWAY_TEAM": "Spain",
360	        "DATE": pd.Timestamp("2099-06-01"),
361	        "HOME_GOALS": 5, "AWAY_GOALS": 0, "TOURNAMENT": "Friendly", "NEUTRAL": False,
362	    }])
363	    df_ext = pd.concat([df, extra], ignore_index=True)
364	    form_extended = recent_form("Germany", cutoff, df_ext, window=5, half_life_days=365.0)
365	
366	    assert form_original == pytest.approx(form_extended)
