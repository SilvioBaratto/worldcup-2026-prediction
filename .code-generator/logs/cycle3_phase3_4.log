124	# ---------------------------------------------------------------------------
125	# Criterion 2 — recent_form
126	# ---------------------------------------------------------------------------
127	
128	
129	class TestRecentForm:
130	    """recent_form returns 0.0 neutral default or decay-weighted PPG."""
131	
132	    def test_when_no_prior_matches_then_recent_form_is_zero(self) -> None:
133	        df = _frame(("Brazil", "Germany", "2022-12-18", 3, 0))
134	        assert recent_form("Brazil", 0, df, window=5, half_life_days=365.0) == 0.0
135	
136	    def test_when_single_win_then_recent_form_is_positive(self) -> None:
137	        df = _frame(
138	            ("Brazil", "Germany", "2022-12-10", 3, 0),   # idx 0 — win
139	            ("Brazil", "France",  "2022-12-18", 0, 1),   # idx 1 — current
140	        )
141	        assert recent_form("Brazil", 1, df, window=5, half_life_days=365.0) > 0.0
142	
143	    def test_when_single_three_nil_win_then_ppg_equals_three(self) -> None:
144	        """With one prior match, weighted_sum / sum_of_weights = 3·w / w = 3.0."""
145	        df = _frame(
146	            ("Argentina", "England", "2022-12-10", 3, 0),  # idx 0 — win
147	            ("Argentina", "France",  "2022-12-18", 1, 0),  # idx 1 — current
148	        )
149	        assert recent_form("Argentina", 1, df, window=5, half_life_days=365.0) == pytest.approx(3.0)
150	
151	    def test_when_prior_match_is_draw_then_ppg_equals_one(self) -> None:
152	        df = _frame(
153	            ("England", "France", "2022-12-10", 1, 1),   # idx 0 — draw
154	            ("England", "Spain",  "2022-12-18", 0, 0),   # idx 1 — current
155	        )
156	        assert recent_form("England", 1, df, window=5, half_life_days=365.0) == pytest.approx(1.0)
157	
158	    def test_when_prior_match_is_loss_then_ppg_equals_zero(self) -> None:
159	        df = _frame(
160	            ("England", "Brazil", "2022-12-10", 0, 3),   # idx 0 — loss
161	            ("England", "Spain",  "2022-12-18", 0, 0),   # idx 1 — current
162	        )
163	        assert recent_form("England", 1, df, window=5, half_life_days=365.0) == pytest.approx(0.0)
164	
