256	            {"home": "Brazil", "away": "Germany", "home_goals": 2, "away_goals": 1},
257	            {"home": "France",  "away": "Spain",  "home_goals": 0, "away_goals": 0},
258	        ])
259	        short_elo = _elo([{}])       # 1 row vs 2 matches
260	        with pytest.raises(ValueError):
261	            FeatureBuilder(_DEFAULT_CFG).build(m, short_elo, _BRA_GER_FRA_ESP)
262	
263	    def test_when_elo_df_longer_than_matches_then_value_error_is_raised(self) -> None:
264	        m = _matches([{"home": "Brazil", "away": "Germany", "home_goals": 2, "away_goals": 1}])
265	        long_elo = _elo([{}, {}])    # 2 rows vs 1 match
266	        with pytest.raises(ValueError):
267	            FeatureBuilder(_DEFAULT_CFG).build(m, long_elo, _BRA_GER)
268	
