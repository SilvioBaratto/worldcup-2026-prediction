38	from worldcup_playoff.config import FeatureBuildConfig
39	from worldcup_playoff.features.build import TeamAbilities
40	
41	# ---------------------------------------------------------------------------
42	# Shared helpers — derived from data contracts in requirements.md
43	# ---------------------------------------------------------------------------
44	
45	_CFG = FeatureBuildConfig(random_seed=42)
46	
47	
48	def _matches(rows: list[dict]) -> pd.DataFrame:
49	    """Build a results DataFrame in the martj42 uppercase internal schema."""
50	    return pd.DataFrame({
51	        "DATE":       pd.to_datetime([r.get("date", "2026-06-20") for r in rows]),
52	        "HOME_TEAM":  [r["home"] for r in rows],
53	        "AWAY_TEAM":  [r["away"] for r in rows],
54	        "HOME_GOALS": pd.array([r.get("home_goals", pd.NA) for r in rows], dtype="Int64"),
55	        "AWAY_GOALS": pd.array([r.get("away_goals", pd.NA) for r in rows], dtype="Int64"),
56	        "TOURNAMENT": [r.get("tournament", "Friendly") for r in rows],
57	        "NEUTRAL":    [r.get("neutral", True) for r in rows],
58	    })
59	
60	
61	def _elo(rows: list[dict]) -> pd.DataFrame:
62	    """Pre-computed Elo DataFrame aligned row-for-row with the matches."""
63	    return pd.DataFrame({
64	        "home_elo": [float(r.get("home_elo", 1500)) for r in rows],
65	        "away_elo": [float(r.get("away_elo", 1500)) for r in rows],
66	    })
67	
68	
69	def _abilities(*team_names: str) -> TeamAbilities:
70	    """Build a uniform TeamAbilities for the named teams."""
71	    return TeamAbilities(
72	        attack={t: 1.3 for t in team_names},
73	        defence={t: 0.9 for t in team_names},
74	        home_adv=0.0,
75	        rho=-0.1,
76	        intercept=0.0,
77	    )
78	
79	
80	def _mixed_frame_and_elo():
81	    """Full frame: historical rows + played WC rows + two unplayed WC fixtures."""
82	    rows = [
83	        {
84	            "home": "Argentina", "away": "El Salvador",
85	            "tournament": "Friendly",
86	            "home_goals": 3, "away_goals": 0,
87	            "date": "2024-03-20", "neutral": False,
88	        },
89	        {
90	            "home": "Brazil", "away": "Mexico",
91	            "tournament": "Friendly",
92	            "home_goals": 2, "away_goals": 1,
93	            "date": "2024-06-10", "neutral": False,
94	        },
95	        {
96	            "home": "Mexico", "away": "Canada",
97	            "tournament": "FIFA World Cup",
98	            "home_goals": 2, "away_goals": 0,
99	            "date": "2026-06-11",
100	        },
101	        # unplayed WC2026 fixtures — HOME_GOALS/AWAY_GOALS default to pd.NA
102	        {"home": "Argentina", "away": "France", "tournament": "FIFA World Cup", "date": "2026-06-15"},
103	        {"home": "Brazil",    "away": "Spain",  "tournament": "FIFA World Cup", "date": "2026-06-16"},
104	    ]
105	    m = _matches(rows)
106	    elo = _elo([{}, {}, {}, {}, {}])
107	    return m, elo
108	
109	
110	_ALL_TEAMS = ("Argentina", "El Salvador", "Brazil", "Mexico", "Canada", "France", "Spain")
111	
112	
113	# ---------------------------------------------------------------------------
114	# Criterion 1a — row filtering: only unplayed WC fixtures appear in output
115	# ---------------------------------------------------------------------------
