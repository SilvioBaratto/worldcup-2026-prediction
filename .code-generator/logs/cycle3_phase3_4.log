315	        m = _matches([{"home": "Brazil", "away": "Germany", "home_goals": 2, "away_goals": 1}])
316	        result = FeatureBuilder(_DEFAULT_CFG).build(
317	            m, _elo([{}]), _BRA_GER, ranking_df=None
318	        )
