"""
Tests for worldcup_playoff.features public API — issue #11.

All tests are authored from acceptance criteria only (source-blind TDD).
No implementation file was read to produce these tests.
"""
import importlib
import pandas as pd
import pytest
from hypothesis import given, strategies as st

# ── Criterion 1: all names in __all__ are importable ──────────────────────────

def test_when_all_names_imported_then_no_ImportError():
    """Every name in worldcup_playoff.features.__all__ must be importable."""
    import worldcup_playoff.features as pkg
    for name in pkg.__all__:
        assert hasattr(pkg, name), (
            f"Name '{name}' listed in __all__ but not accessible on the package"
        )

# ── Criterion 2: __all__ is sorted and exposes only the intended surface ──────

def test_when_all_inspected_then_it_is_sorted():
    """__all__ must be in ascending lexicographic order."""
    import worldcup_playoff.features as pkg
    assert list(pkg.__all__) == sorted(pkg.__all__), (
        "__all__ is not sorted; expected sorted order"
    )

@given(st.just(None))
def test_when_all_sorted_property_then_invariant_holds(_):
    """Property: __all__ equals its own sorted version (sortedness invariant)."""
    import worldcup_playoff.features as pkg
    assert list(pkg.__all__) == sorted(pkg.__all__)

def test_when_all_inspected_then_no_private_names_leak():
    """No name starting with '_' should appear in __all__."""
    import worldcup_playoff.features as pkg
    private = [n for n in pkg.__all__ if n.startswith("_")]
    assert private == [], f"Internal names leaked into __all__: {private}"

def test_when_all_inspected_then_expected_groups_present():
    """
    __all__ must cover the four intended symbol groups:
    confederation, time-aware, build, and wc2026 symbols.
    
    Choice: we check that at least one symbol exists from each group by
    looking for any name containing the group keyword (case-insensitive).
    This is the simplest behaviour consistent with the criterion text.
    """
    import worldcup_playoff.features as pkg
    all_lower = [n.lower() for n in pkg.__all__]
    groups = ["confederation", "elo", "build", "wc2026"]
    for keyword in groups:
        found = any(keyword in name for name in all_lower)
        assert found, (
            f"No symbol matching group keyword '{keyword}' found in __all__: "
            f"{list(pkg.__all__)}"
        )

# ── Criterion 3: No-key integration smoke test ────────────────────────────────

def _make_martj42_history() -> pd.DataFrame:
    """
    Build a minimal martj42-shaped match history DataFrame entirely in-process.
    Includes a couple of unplayed FIFA World Cup rows (NaN scores).
    No network calls are made.
    """
    played = pd.DataFrame({
        "date": pd.to_datetime(["2022-11-20", "2022-11-21", "2018-06-14",
                                 "2018-06-15", "2014-06-12"]),
        "home_team": ["Qatar", "England", "Russia", "Spain", "Brazil"],
        "away_team": ["Ecuador", "Iran", "Saudi Arabia", "Portugal", "Croatia"],
        "home_score": [0, 6, 5, 3, 3],
        "away_score": [2, 2, 0, 3, 1],
        "tournament": ["FIFA World Cup"] * 5,
        "neutral": [True, True, True, True, True],
    })
    unplayed = pd.DataFrame({
        "date": pd.to_datetime(["2026-06-11", "2026-06-12"]),
        "home_team": ["USA", "Mexico"],
        "away_team": ["Canada", "Argentina"],
        "home_score": [float("nan"), float("nan")],
        "away_score": [float("nan"), float("nan")],
        "tournament": ["FIFA World Cup", "FIFA World Cup"],
        "neutral": [True, True],
    })
    return pd.concat([played, unplayed], ignore_index=True)

def test_when_smoke_test_run_then_historical_and_wc2026_share_same_columns():
    """
    No-key integration smoke test (criterion 3).

    Builds a small martj42-shaped history, calls compute_elo and fit_dixon_coles,
    passes both into the historical builder and wc2026_features, then asserts:
    - The two output DataFrames share the SAME column set.
    - The WC2026 frame's rows are a subset of the historical frame's rows
      (by index or by content, depending on the builder's contract).

    Runs entirely in-process: no network, no API keys required.
    """
    from worldcup_playoff.features import (
        compute_elo,
        fit_dixon_coles,
        build_historical_features,  # name inferred from criterion description
        wc2026_features,
    )

    history = _make_martj42_history()

    elo_ratings = compute_elo(history)
    dixon_coles = fit_dixon_coles(history)

    historical_df = build_historical_features(history, elo_ratings, dixon_coles)
    wc2026_df = wc2026_features(history, elo_ratings, dixon_coles)

    # Assert same column set
    assert set(historical_df.columns) == set(wc2026_df.columns), (
        "historical and wc2026 feature frames must share the same column set; "
        f"historical has {set(historical_df.columns)}, "
        f"wc2026 has {set(wc2026_df.columns)}"
    )

    # Assert WC2026 rows are a subset of historical rows
    # (each WC2026 row must appear in historical_df)
    for _, wc_row in wc2026_df.iterrows():
        mask = (historical_df == wc_row).all(axis=1)
        assert mask.any(), (
            f"WC2026 row not found in historical frame:\n{wc_row}"
        )
