59	def _abilities(teams: dict[str, dict[str, float]]) -> TeamAbilities:
60	    """Build a hand-crafted TeamAbilities from {team: {"attack": f, "defence": f}}."""
61	    return TeamAbilities(
62	        attack={name: v["attack"] for name, v in teams.items()},
63	        defence={name: v["defence"] for name, v in teams.items()},
64	        home_adv=0.0,
65	        rho=-0.1,
66	        intercept=0.0,
67	    )
