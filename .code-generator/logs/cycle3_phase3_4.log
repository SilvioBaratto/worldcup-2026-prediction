274	@settings(max_examples=100)
275	def test_sort_chronological_is_idempotent(rows: list) -> None:
276	    """Applying sort_chronological twice yields the same result as applying it once.
277	
278	    Invariant: sort(sort(df)) ≡ sort(df).
279	    """
280	    df = pd.DataFrame([
281	        {
282	            "HOME_TEAM": h,
283	            "AWAY_TEAM": a,
284	            "DATE": pd.Timestamp(d.isoformat()),
285	            "HOME_GOALS": 1,
286	            "AWAY_GOALS": 0,
287	        }
288	        for h, a, d in rows
289	    ])
290	    once = sort_chronological(df)
291	    twice = sort_chronological(once)
292	    pd.testing.assert_frame_equal(
293	        once.reset_index(drop=True),
294	        twice.reset_index(drop=True),
295	        check_like=False,
296	    )
297	
298	
299	@given(
300	    rows=st.lists(
301	        st.tuples(
302	            _HOME_TEAMS,
303	            _AWAY_TEAMS,
304	            _DATE_STRAT,
305	            st.integers(min_value=0, max_value=5),  # HOME_GOALS
306	            st.integers(min_value=0, max_value=5),  # AWAY_GOALS
307	        ),
308	        min_size=3,
309	        max_size=15,
310	    )
311	)
312	@settings(max_examples=80)
313	def test_no_leakage_invariant(rows: list) -> None:
314	    """No-leakage property: appending a row after the cutoff never changes recent_form at that cutoff.
315	
316	    Formally: for any df and cutoff i in [1, len(df)],
317	        recent_form(team, df, before_idx=i) == recent_form(team, df ++ [extra_row], before_idx=i)
318	    where extra_row has an index > i and a date far in the future.
319	    """
320	    df = pd.DataFrame([
321	        {
322	            "HOME_TEAM": h,
323	            "AWAY_TEAM": a,
324	            "DATE": pd.Timestamp(d.isoformat()),
325	            "HOME_GOALS": hg,
326	            "AWAY_GOALS": ag,
327	        }
328	        for h, a, d, hg, ag in rows
329	    ])
330	    cutoff = max(1, len(df) // 2)
331	
332	    form_original = recent_form("Germany", df, before_idx=cutoff)
333	
334	    extra = pd.DataFrame([{
335	        "HOME_TEAM": "Germany",
336	        "AWAY_TEAM": "Spain",
337	        "DATE": pd.Timestamp("2099-06-01"),  # far future, never inside any cutoff window
338	        "HOME_GOALS": 5,
339	        "AWAY_GOALS": 0,
340	    }])
341	    df_extended = pd.concat([df, extra], ignore_index=True)
342	    form_extended = recent_form("Germany", df_extended, before_idx=cutoff)
343	
344	    assert form_original == pytest.approx(form_extended), (
345	        f"recent_form(before_idx={cutoff}) changed after appending a future row: "
346	        f"{form_original!r} → {form_extended!r}"
347	    )
