117	
118	class TestWc2026FeatureRowFiltering:
119	    """wc2026_features must return exactly the unplayed FIFA World Cup rows."""
120	
121	    def test_when_mixed_frame_given_then_only_unplayed_wc_rows_are_returned(self) -> None:
122	        from worldcup_playoff.features.wc2026 import wc2026_features
123	
124	        m, elo = _mixed_frame_and_elo()
125	        result = wc2026_features(m, elo, _abilities(*_ALL_TEAMS))
126	
127	        assert len(result) == 2
128	
129	    def test_when_wc2026_features_called_then_non_wc_rows_are_absent(self) -> None:
130	        from worldcup_playoff.features.wc2026 import wc2026_features
131	
132	        m, elo = _mixed_frame_and_elo()
133	        result = wc2026_features(m, elo, _abilities(*_ALL_TEAMS))
134	
135	        assert "Friendly" not in result["tournament"].values
136	
137	    def test_when_wc2026_features_called_then_played_wc_rows_are_absent(self) -> None:
138	        """Played WC matches (goals not NA) must be excluded from the output."""
139	        from worldcup_playoff.features.wc2026 import wc2026_features
140	
141	        rows = [
142	            {
143	                "home": "Mexico", "away": "Canada",
144	                "tournament": "FIFA World Cup",
145	                "home_goals": 2, "away_goals": 0,
146	                "date": "2026-06-11",
147	            },
148	            {"home": "Brazil", "away": "Spain", "tournament": "FIFA World Cup", "date": "2026-06-16"},
149	        ]
150	        m = _matches(rows)
151	        elo = _elo([{}, {}])
152	        result = wc2026_features(m, elo, _abilities("Mexico", "Canada", "Brazil", "Spain"))
153	
154	        assert len(result) == 1
155	        assert result.iloc[0]["home_team"] == "Brazil"
156	
157	    def test_when_no_wc_rows_in_frame_then_result_is_empty_dataframe(self) -> None:
158	        from worldcup_playoff.features.wc2026 import wc2026_features
159	
160	        m = _matches([{
161	            "home": "Germany", "away": "England",
162	            "tournament": "Friendly",
163	            "home_goals": 1, "away_goals": 0,
164	            "neutral": False,
165	        }])
166	        result = wc2026_features(m, _elo([{}]), _abilities("Germany", "England"))
167	
168	        assert isinstance(result, pd.DataFrame)
169	        assert len(result) == 0
170	
171	    def test_when_only_played_wc_rows_then_result_is_empty_dataframe(self) -> None:
172	        """A frame where all WC rows are already played must produce an empty output."""
173	        from worldcup_playoff.features.wc2026 import wc2026_features
174	
175	        m = _matches([{
176	            "home": "France", "away": "Germany",
177	            "tournament": "FIFA World Cup",
178	            "home_goals": 1, "away_goals": 0,
179	            "date": "2026-06-14",
180	        }])
181	        result = wc2026_features(m, _elo([{}]), _abilities("France", "Germany"))
182	
183	        assert len(result) == 0
