307	_DATE_STRAT = st.dates(min_value=date(2000, 1, 1), max_value=date(2030, 12, 31))
308	
309	
310	@given(
311	    rows=st.lists(
312	        st.tuples(
313	            st.sampled_from(["Germany", "Brazil", "France"]),
314	            st.sampled_from(["Spain", "England", "Argentina"]),
315	            _DATE_STRAT,
316	        ),
317	        min_size=1,
318	        max_size=20,
319	    )
