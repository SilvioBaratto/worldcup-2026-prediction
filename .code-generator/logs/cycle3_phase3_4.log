38	def _matches(rows: list[dict]) -> pd.DataFrame:
39	    """Minimal matches DataFrame in the martj42-derived internal schema."""
40	    return pd.DataFrame({
41	        "DATE":       pd.to_datetime([r.get("date", "2026-01-01") for r in rows]),
42	        "HOME_TEAM":  [r["home"] for r in rows],
43	        "AWAY_TEAM":  [r["away"] for r in rows],
44	        "HOME_GOALS": pd.array([r.get("home_goals", pd.NA) for r in rows], dtype="Int64"),
45	        "AWAY_GOALS": pd.array([r.get("away_goals", pd.NA) for r in rows], dtype="Int64"),
46	        "TOURNAMENT": [r.get("tournament", "Friendly") for r in rows],
47	        "NEUTRAL":    [r.get("neutral", False) for r in rows],
48	    })
49	
50	
51	def _elo(rows: list[dict]) -> pd.DataFrame:
52	    """Pre-computed Elo DataFrame aligned row-for-row with the matches."""
53	    return pd.DataFrame({
54	        "home_elo": [float(r.get("home_elo", 1500)) for r in rows],
55	        "away_elo": [float(r.get("away_elo", 1500)) for r in rows],
56	    })
