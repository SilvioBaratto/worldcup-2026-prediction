333	# ---------------------------------------------------------------------------
334	# Criterion 6 — deterministic given FeatureBuildConfig.random_seed
335	# ---------------------------------------------------------------------------
336	
337	
338	class TestDeterminism:
339	    """FeatureBuilder output is byte-identical when FeatureBuildConfig.random_seed is fixed."""
340	
341	    def test_when_same_seed_then_build_produces_identical_frames(self) -> None:
342	        m = _matches([
343	            {"home": "Brazil", "away": "Germany", "home_goals": 2, "away_goals": 1},
344	            {"home": "France",  "away": "Spain",  "home_goals": 0, "away_goals": 0},
345	        ])
346	        elo = _elo([{"home_elo": 1600.0, "away_elo": 1400.0},
347	                    {"home_elo": 1550.0, "away_elo": 1580.0}])
348	
349	        cfg_a = FeatureBuildConfig(random_seed=42)
350	        cfg_b = FeatureBuildConfig(random_seed=42)
351	
352	        result_a = FeatureBuilder(cfg_a).build(m, elo, _BRA_GER_FRA_ESP)
353	        result_b = FeatureBuilder(cfg_b).build(m, elo, _BRA_GER_FRA_ESP)
354	
355	        pd.testing.assert_frame_equal(result_a, result_b)
356	
