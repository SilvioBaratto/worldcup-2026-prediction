247	
248	class TestNAGoalsSkipped:
249	    """Unplayed fixtures (<NA> goals) are excluded from form / goal-difference."""
250	
251	    def test_when_only_prior_is_unplayed_then_recent_form_is_zero(self) -> None:
252	        df = _frame(
253	            ("Spain", "Germany", "2022-12-01", None, None),  # idx 0 — unplayed
254	            ("Spain", "Brazil",  "2022-12-18", 1, 0),         # idx 1 — current
255	        )
256	        assert recent_form("Spain", 1, df, window=5, half_life_days=365.0) == 0.0
257	
258	    def test_when_only_prior_is_unplayed_then_goal_difference_is_zero(self) -> None:
259	        df = _frame(
260	            ("Spain", "Germany", "2022-12-01", None, None),
261	            ("Spain", "Brazil",  "2022-12-18", 1, 0),
262	        )
263	        assert goal_difference("Spain", 1, df, window=5) == 0.0
264	
265	    def test_when_na_goals_prior_exists_then_rest_days_does_not_raise(self) -> None:
