322	    def test_when_same_input_run_twice_then_confederation_output_is_identical(self) -> None:
323	        """Determinism: same input always yields the same confederation encoding."""
324	        m = _matches([{"home": "Brazil", "away": "Argentina", "home_goals": 1, "away_goals": 0}])
325	        ab = _abilities({"Brazil":    {"attack": 1.5, "defence": 0.8},
326	                         "Argentina": {"attack": 1.6, "defence": 0.7}})
327	        r1 = FeatureBuilder(_DEFAULT_CFG).build(m, _elo([{}]), ab)
328	        r2 = FeatureBuilder(_DEFAULT_CFG).build(m, _elo([{}]), ab)
329	        assert r1.iloc[0]["home_confederation"] == r2.iloc[0]["home_confederation"]
330	        assert r1.iloc[0]["away_confederation"] == r2.iloc[0]["away_confederation"]
