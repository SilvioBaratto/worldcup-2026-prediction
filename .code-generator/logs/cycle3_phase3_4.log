521	def _make_group_match(match_id: int, status: str) -> dict:
522	    return {
523	        "id": match_id,
524	        "utcDate": "2026-06-20T12:00:00Z",
525	        "status": status,
526	        "stage": "GROUP_STAGE",
527	        "group": "GROUP_A",
528	        "matchday": 1,
529	        "homeTeam": {"id": 1, "name": "TeamA"},
530	        "awayTeam": {"id": 2, "name": "TeamB"},
531	        "score": {
532	            "winner": "HOME_TEAM" if status == "FINISHED" else None,
533	            "duration": "REGULAR",
534	            "fullTime": (
535	                {"home": 1, "away": 0} if status == "FINISHED" else {"home": None, "away": None}
536	            ),
537	            "halfTime": (
538	                {"home": 0, "away": 0} if status == "FINISHED" else {"home": None, "away": None}
539	            ),
540	        },
541	    }
542	
543	
544	@given(
545	    statuses=st.lists(
546	        st.sampled_from(["FINISHED", "SCHEDULED", "TIMED"]),
547	        min_size=0,
548	        max_size=8,
549	    )
550	)
551	@settings(max_examples=40)
552	def test_when_group_stage_matches_have_mixed_statuses_then_partition_covers_all_of_them(
553	    statuses: list,
554	) -> None:
555	    """
556	    Invariant from AC2: played ∪ remaining_group_fixtures must cover every group-stage
557	    match exactly once — no match may be silently dropped from TournamentState.
558	    """
559	    from worldcup_playoff.data.live import LiveTournamentAdapter
560	
561	    group_matches = [_make_group_match(i, status) for i, status in enumerate(statuses)]
562	    matches_json = {**_MATCHES_JSON, "matches": group_matches}
563	
564	    client = MagicMock()
565	    client.get.side_effect = [matches_json, _STANDINGS_JSON]
566	
567	    state = LiveTournamentAdapter(client, competition="WC").tournament_state()
568	    total_partitioned = len(state.played) + len(state.remaining_group_fixtures)
569	    assert total_partitioned == len(group_matches)
