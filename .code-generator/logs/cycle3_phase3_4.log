93	def _make_standings_json(n_groups: int = 12) -> dict:
94	    """Return a standings payload with *n_groups* groups (default 12 for WC2026)."""
95	    groups = [f"GROUP_{chr(65 + i)}" for i in range(n_groups)]
96	    return {
97	        "standings": [
98	            {
99	                "stage": "GROUP_STAGE",
100	                "type": "TOTAL",
101	                "group": group,
102	                "table": [
103	                    {
104	                        "position": 1,
105	                        "team": {"id": idx * 4 + 1, "name": f"Team_{group}_1"},
106	                        "playedGames": 1,
107	                        "form": "W",
108	                        "won": 1,
109	                        "draw": 0,
110	                        "lost": 0,
111	                        "points": 3,
112	                        "goalsFor": 2,
113	                        "goalsAgainst": 0,
114	                        "goalDifference": 2,
115	                    }
116	                ],
117	            }
118	            for idx, group in enumerate(groups)
119	        ]
120	    }
121	
122	
123	_STANDINGS_JSON = _make_standings_json(12)
