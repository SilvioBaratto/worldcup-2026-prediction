166	# ---------------------------------------------------------------------------
167	# Criterion 3 — no-leakage
168	# ---------------------------------------------------------------------------
169	
170	
171	class TestNoLeakage:
172	    """recent_form(before_idx=i) must not change when a later row is appended."""
173	
174	    def test_when_later_match_appended_then_form_at_earlier_cutoff_is_unchanged(self) -> None:
175	        base = [
176	            ("Germany", "Brazil", "2022-12-01", 1, 0),   # idx 0
177	            ("Germany", "France", "2022-12-10", 0, 1),   # idx 1
178	            ("Germany", "Spain",  "2022-12-18", 2, 0),   # idx 2  ← cut-off
179	        ]
180	        df_original = _frame(*base)
181	        form_before = recent_form("Germany", 2, df_original, window=5, half_life_days=365.0)
182	
183	        extended = base + [("Germany", "Italy", "2022-12-25", 3, 2)]
184	        df_extended = _frame(*extended)
185	        form_after = recent_form("Germany", 2, df_extended, window=5, half_life_days=365.0)
186	
187	        assert form_before == pytest.approx(form_after)
188	
