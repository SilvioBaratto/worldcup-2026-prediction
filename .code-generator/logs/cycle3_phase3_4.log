280	class TestGoalDifference:
281	    """goal_difference computes windowed net GD from team's perspective."""
282	
283	    def test_when_no_prior_matches_then_goal_difference_is_zero(self) -> None:
284	        df = _frame(("France", "Brazil", "2022-12-18", 2, 1))
285	        assert goal_difference("France", 0, df, window=5) == 0.0
286	
287	    def test_when_home_win_three_nil_then_goal_difference_is_three(self) -> None:
288	        df = _frame(
289	            ("Brazil", "Germany", "2022-12-10", 3, 0),   # idx 0 — Brazil +3
290	            ("Brazil", "France",  "2022-12-18", 1, 0),   # idx 1 — current
291	        )
292	        assert goal_difference("Brazil", 1, df, window=5) == pytest.approx(3.0)
293	
294	    def test_when_window_limits_matches_then_only_recent_rows_counted(self) -> None:
295	        df = _frame(
296	            ("Brazil", "Germany", "2022-11-01", 5, 0),   # idx 0 — +5 (outside window=1)
297	            ("Brazil", "France",  "2022-12-01", 1, 2),   # idx 1 — -1 (inside window=1)
298	            ("Brazil", "Spain",   "2022-12-18", 0, 0),   # idx 2 — current
299	        )
300	        assert goal_difference("Brazil", 2, df, window=1) == pytest.approx(-1.0)
