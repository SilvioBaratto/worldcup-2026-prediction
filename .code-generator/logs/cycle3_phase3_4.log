331	class TestDeterminism:
332	    """FeatureBuilder output is byte-identical when FeatureBuildConfig.random_seed is fixed."""
333	
334	    def test_when_same_seed_then_build_produces_identical_frames(self) -> None:
335	        m = _matches([
336	            {"home": "Brazil", "away": "Germany", "home_goals": 2, "away_goals": 1},
337	            {"home": "France",  "away": "Spain",  "home_goals": 0, "away_goals": 0},
338	        ])
339	        elo = _elo([{"home_elo": 1600.0, "away_elo": 1400.0},
340	                    {"home_elo": 1550.0, "away_elo": 1580.0}])
341	
342	        cfg_a = FeatureBuildConfig(random_seed=42)
343	        cfg_b = FeatureBuildConfig(random_seed=42)
344	
345	        result_a = FeatureBuilder(cfg_a).build(m, elo, _BRA_GER_FRA_ESP)
346	        result_b = FeatureBuilder(cfg_b).build(m, elo, _BRA_GER_FRA_ESP)
347	
348	        pd.testing.assert_frame_equal(result_a, result_b)
