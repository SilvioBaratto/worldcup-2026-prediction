221	
222	
223	class TestAwayOnlySymmetry:
224	    """A team appearing only as away still accumulates form and goal-difference."""
225	
226	    def test_when_team_is_only_away_then_recent_form_is_positive_after_win(self) -> None:
227	        df = _frame(
228	            ("Brazil",  "Germany", "2022-12-10", 1, 3),   # idx 0 — Germany wins away
229	            ("France",  "Germany", "2022-12-18", 0, 0),   # idx 1 — current match
230	        )
231	        result = recent_form("Germany", 1, df, window=5, half_life_days=365.0)
232	        assert result == pytest.approx(3.0)
233	
234	    def test_when_team_is_only_away_then_goal_difference_reflects_away_goals(self) -> None:
235	        df = _frame(
236	            ("Brazil",  "Germany", "2022-12-10", 1, 3),   # idx 0 — Germany away: +2 GD
237	            ("France",  "Germany", "2022-12-18", 0, 0),   # idx 1 — current
238	        )
239	        result = goal_difference("Germany", 1, df, window=5)
240	        assert result == pytest.approx(2.0)   # 3 scored − 1 conceded
