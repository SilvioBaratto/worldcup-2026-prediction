315	    def test_when_same_input_run_twice_then_confederation_output_is_identical(self) -> None:
316	        """Determinism: same input always yields the same confederation encoding."""
317	        m = _matches([{"home": "Brazil", "away": "Argentina", "home_goals": 1, "away_goals": 0}])
318	        ab = _abilities({"Brazil":    {"attack": 1.5, "defence": 0.8},
319	                         "Argentina": {"attack": 1.6, "defence": 0.7}})
320	        r1 = FeatureBuilder(_DEFAULT_CFG).build(m, _elo([{}]), ab)
321	        r2 = FeatureBuilder(_DEFAULT_CFG).build(m, _elo([{}]), ab)
322	        assert r1.iloc[0]["home_confederation"] == r2.iloc[0]["home_confederation"]
323	        assert r1.iloc[0]["away_confederation"] == r2.iloc[0]["away_confederation"]
