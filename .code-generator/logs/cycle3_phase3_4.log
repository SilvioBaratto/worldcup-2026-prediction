105	        ])
106	        result = FeatureBuilder(_CFG).build(m, _elo([{}, {}]), _BRA_GER)
107	        # match-2 form for Brazil = 3.0 (single prior win; decay cancels in PPG formula)
108	        assert result.iloc[1]["home_form"] == pytest.approx(3.0)
