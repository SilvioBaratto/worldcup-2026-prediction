76	        result = sort_chronological(df)
77	        non_nat = result["DATE"].dropna().tolist()
78	        assert non_nat == sorted(non_nat), "Rows must be ordered by DATE ascending"
79	
80	    def test_nat_row_is_placed_last(self) -> None:
81	        df = _frame(
82	            ("Brazil", "Germany", None, 1, 1),
83	            ("France", "Croatia", "2018-07-10", 4, 2),
84	            ("England", "Belgium", "2018-07-14", 0, 2),
85	        )
86	        result = sort_chronological(df)
87	        assert pd.isna(result["DATE"].iloc[-1]), (
88	            "Row with NaT date must appear last (na_position='last')"
89	        )
90	
91	    def test_index_is_reset_to_zero_based_range(self) -> None:
92	        df = _frame(
93	            ("France", "Croatia", "2018-07-10", 4, 2),
94	            ("Brazil", "Germany", "2018-07-05", 1, 1),
95	        )
96	        result = sort_chronological(df)
97	        assert list(result.index) == list(range(len(result))), (
98	            "Index must be reset to a contiguous 0-based range after sorting"
99	        )
100	
101	    def test_equal_date_rows_preserve_original_relative_order(self) -> None:
102	        """Stability: identical-date rows must keep their original relative order."""
103	        df = _frame(
104	            ("A", "B", "2020-01-01", 1, 0),
105	            ("C", "D", "2020-01-01", 2, 1),
106	        )
107	        result = sort_chronological(df)
108	        homes = list(result["HOME_TEAM"])
109	        assert homes.index("A") < homes.index("C"), (
110	            "Stable sort: 'A vs B' appeared before 'C vs D' and must stay before it"
111	        )
