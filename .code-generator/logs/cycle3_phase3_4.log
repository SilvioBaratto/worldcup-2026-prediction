114	# ---------------------------------------------------------------------------
115	# Criterion 2 — recent_form
116	# ---------------------------------------------------------------------------
117	
118	
119	class TestRecentForm:
120	    """recent_form returns 0.0 with no prior data; max decayed PPG for a prior win."""
121	
122	    def test_no_prior_matches_returns_neutral_zero(self) -> None:
123	        """before_idx=0 means 'look at rows before index 0' — no rows exist → neutral 0.0."""
124	        df = _frame(
125	            ("Brazil", "Germany", "2022-12-18", 3, 0),
126	        )
127	        result = recent_form("Brazil", df, before_idx=0)
128	        assert result == 0.0, f"Expected neutral 0.0 with no prior rows, got {result!r}"
129	
130	    def test_single_prior_win_gives_positive_form(self) -> None:
131	        """A win in the only prior match must yield a strictly positive form value."""
132	        df = _frame(
133	            ("Brazil", "Germany", "2022-12-10", 3, 0),  # idx 0 — Brazil wins
134	            ("Brazil", "France",  "2022-12-18", 0, 1),  # idx 1 — current match, excluded
135	        )
136	        result = recent_form("Brazil", df, before_idx=1)
137	        assert result > 0.0, f"Expected positive form after a win, got {result!r}"
138	
139	    def test_single_three_nil_win_decayed_ppg_equals_three(self) -> None:
140	        """With exactly one prior match (a win), weighted_sum / sum_of_weights = 3·w / w = 3.0.
141	
142	        This equality holds for *any* positive decay weight w, so the implementation's specific
143	        decay function is irrelevant: the result must be exactly 3.0.
144	        """
145	        df = _frame(
146	            ("Argentina", "England", "2022-12-10", 3, 0),  # idx 0 — Argentina wins (home)
147	            ("Argentina", "France",  "2022-12-18", 1, 0),  # idx 1 — future match, excluded
148	        )
149	        result = recent_form("Argentina", df, before_idx=1)
150	        assert result == pytest.approx(3.0), (
151	            f"Single 3-0 win → decayed PPG must be 3.0, got {result!r}"
152	        )
153	
