155	# ---------------------------------------------------------------------------
156	# Criterion 3 — no-leakage (explicit unit test)
157	# ---------------------------------------------------------------------------
158	
159	
160	class TestNoLeakage:
161	    """Inserting a later match into the frame must not change recent_form(before_idx=i)."""
162	
163	    def test_appending_later_match_does_not_change_form_at_earlier_cutoff(self) -> None:
164	        base = [
165	            ("Germany", "Brazil", "2022-12-01", 1, 0),  # idx 0
166	            ("Germany", "France", "2022-12-10", 0, 1),  # idx 1
167	            ("Germany", "Spain",  "2022-12-18", 2, 0),  # idx 2  ← cut-off point
168	        ]
169	        df_original = _frame(*base)
170	        form_at_cutoff = recent_form("Germany", df_original, before_idx=2)
171	
172	        extended = base + [
173	            ("Germany", "Italy", "2022-12-25", 3, 2),   # idx 3 — must be invisible
174	        ]
175	        df_extended = _frame(*extended)
176	        form_with_extra = recent_form("Germany", df_extended, before_idx=2)
177	
178	        assert form_at_cutoff == pytest.approx(form_with_extra), (
179	            "recent_form(before_idx=2) must not change when a later match is appended at index 3"
180	        )
