2026-06-24 00:17:31,840 DEBUG msg #31: UserMessage tool_result(toolu_01GqMEnKm12TT5nTvGoxrt7P): 1	"""World Football Elo engine — chronological ratings from martj42 history.
2	
3	Consumes the DataFrame produced by ``Martj42Loader.load_results()``.  The module
4	is I/O-free and network-free so tests can build DataFrames in-memory.
5	
6	Design notes
7	------------
8	* ``elo_diff`` in ``MatchEloDiff`` is ``home_elo − away_elo`` without the
9	  ``home_advantage`` term so the emitted covariate is venue-agnostic.
10	* Rows are sorted by ``(date, HOME_TEAM, AWAY_TEAM, HOME_GOALS, AWAY_GOALS)``
11	  giving a total content-based order.  Rows that are equal on all five keys are
12	  truly identical matches; swapping them does not change any rating.  ``NaT``
13	  dates and ``NA`` goals sort last by pandas convention.
14	"""
15	
16	from __future__ import annotations
17	
18	import logging
19	from dataclasses import dataclass
20	from typing import Iterable
21	
22	import pandas as pd
23	
24	from worldcup_playoff.config import EloConfig
25	
26	logger = logging.getLogger(__name__)
27	
28	# ---------------------------------------------------------------------------
29	# Value objects
30	# ---------------------------------------------------------------------------
31	
32	_SORT_COLS = ["_d", "HOME_TEAM", "AWAY_TEAM", "HOME_GOALS", "AWAY_GOALS"]
33	
34	
35	@dataclass(frozen=True)
36	class EloRating:
37	    """Per-team, per-date Elo snapshot (post-match)."""
38	
39	    team: str
40	    date: str
41	    rating: float
42	
43	
44	@dataclass(frozen=True)
45	class MatchEloDiff:
46	    """Pre-match Elo state for a single fixture.
47	
48	    ``elo_diff = home_elo − away_elo`` is venue-agnostic (excludes home_advantage).
49	    """
50	
51	    date: str
52	    home_team: str
53	    away_team: str
54	    home_elo: float
55	    away_elo: float
56	    elo_diff: float
57	    neutral: bool
58	
59	
60	@dataclass(frozen=True)
61	class EloResult:
62	    """Outcome of ``EloEngine.run``.
63	
64	    Attributes
65	    ----------
66	    history:       Ordered per-team, per-date snapshots.
67	    match_diffs:   One entry per input row (incl. unplayed fixtures).
68	    final_ratings: Latest rating for every team that appeared.
69	    initial_rating: Default start rating — used by ``seed_wc2026`` for absent teams.
70	    """
71	
72	    history: list[EloRating]
73	    match_diffs: list[MatchEloDiff]
74	    final_ratings: dict[str, float]
75	    initial_rating: float
76	
77	    def history_frame(self) -> pd.DataFrame:
78	        """Return history as a tidy DataFrame (team / date / rating)."""
79	        if not self.history:
80	            return pd.DataFrame(columns=["team", "date", "rating"])
81	        return pd.DataFrame(
82	            [{"team": r.team, "date": r.date, "rating": r.rating} for r in self.history]
83	        )
84	
85	    def latest_ratings_frame(self) -> pd.DataFrame:
86	        """Return final_ratings as a tidy DataFrame (team / rating)."""
87	        if not self.final_ratings:
88	            return pd.DataFrame(columns=["team", "rating"])
89	        return pd.DataFrame([{"team": t, "rating": r} for t, r in self.final_ratings.items()])
90	
91	
92	# ---------------------------------------------------------------------------
93	# Module-level pure math helpers
94	# ---------------------------------------------------------------------------
95	
96	
97	def _we(dr: float) -> float:
98	    """Win expectation from Elo rating difference *dr*."""
99	    return float(1.0 / (1.0 + 10.0 ** (-dr / 400.0)))
100	
101	
102	def _g(margin: int) -> float:
103	    """Goal-margin multiplier (World-Football-Elo convention)."""
104	    if margin <= 1:
105	        return 1.0
106	    if margin == 2:
107	        return 1.5
108	    return (11 + margin) / 8.0
109	
110	
111	def _outcome(home_goals: int, away_goals: int) -> float:
112	    """W value: 1.0 home win / 0.5 draw / 0.0 home loss."""
113	    if home_goals > away_goals:
114	        return 1.0
115	    return 0.5 if home_goals == away_goals else 0.0
116	
117	
118	# ---------------------------------------------------------------------------
119	# Engine
120	# ---------------------------------------------------------------------------
121	
122	
123	class EloEngine:
124	    """Compute World Football Elo ratings chronologically from a martj42 DataFrame."""
125	
126	    def __init__(self, config: EloConfig) -> None:
127	        self._config = config
128	
129	    def run(self, df: pd.DataFrame) -> EloResult:
130	        """Process *df* and return per-team ratings + per-match diffs."""
131	        ratings: dict[str, float] = {}
132	        history: list[EloRating] = []
133	        diffs: list[MatchEloDiff] = []
134	        for _, row in self._sort(df).iterrows():
135	            self._process(row, ratings, history, diffs)
136	        return EloResult(
137	            history=history,
138	            match_diffs=diffs,
139	            final_ratings={t: float(r) for t, r in ratings.items()},
140	            initial_rating=self._config.initial_rating,
141	        )
142	
143	    def _sort(self, df: pd.DataFrame) -> pd.DataFrame:
144	        return (
145	            df.assign(_d=pd.to_datetime(df["DATE"], errors="coerce"))
146	            .sort_values(_SORT_COLS, kind="stable", na_position="last")
147	            .drop(columns=["_d"])
148	            .reset_index(drop=True)
149	        )
150	
151	    def _process(
152	        self,
153	        row: pd.Series,
154	        ratings: dict[str, float],
155	        history: list[EloRating],
156	        diffs: list[MatchEloDiff],
157	    ) -> None:
158	        home, away = str(row["HOME_TEAM"]), str(row["AWAY_TEAM"])
159	        date, neutral = str(row["DATE"]), bool(row["NEUTRAL"])
160	        h_elo = ratings.get(home, self._config.initial_rating)
161	        a_elo = ratings.get(away, self._config.initial_rating)
162	        diffs.append(MatchEloDiff(date, home, away, h_elo, a_elo, h_elo - a_elo, neutral))
163	        if pd.isna(row["HOME_GOALS"]) or pd.isna(row["AWAY_GOALS"]):
164	            ratings.setdefault(home, self._config.initial_rating)
165	            ratings.setdefault(away, self._config.initial_rating)
166	            history += [EloRating(home, date, ratings[home]), EloRating(away, date, ratings[away])]
167	            return
168	        new_h, new_a = self._update(
169	            h_elo,
170	            a_elo,
171	            int(row["HOME_GOALS"]),
172	            int(row["AWAY_GOALS"]),
173	            neutral,
174	            str(row["TOURNAMENT"]),
175	        )
176	        ratings[home], ratings[away] = new_h, new_a
177	        history += [EloRating(home, date, new_h), EloRating(away, date, new_a)]
178	
179	    def _update(
180	        self,
181	        h_elo: float,
182	        a_elo: float,
183	        hg: int,
184	        ag: int,
185	        neutral: bool,
186	        tournament: str,
187	    ) -> tuple[float, float]:
188	        home_adv = 0.0 if neutral else self._config.home_advantage
189	        we = _we(h_elo - a_elo + home_adv)
190	        delta = self._k(tournament) * _g(abs(hg - ag)) * (_outcome(hg, ag) - we)
191	        return h_elo + delta, a_elo - delta
192	
193	    def _k(self, tournament: str) -> int:
194	        """K factor: qualifier checked before world_cup for correct precedence."""
195	        t, c = tournament.lower(), self._config
196	        if any(kw.lower() in t for kw in c.qualifier_keywords):
197	            return c.k_qualifier
198	        if any(kw.lower() in t for kw in c.continental_keywords):
199	            return c.k_continental
200	        if any(kw.lower() in t for kw in c.world_cup_keywords):
201	            return c.k_world_cup
202	        return c.k_friendly
203	
204	
205	# ---------------------------------------------------------------------------
206	# Module-level API
207	# ---------------------------------------------------------------------------
208	
209	
210	def seed_wc2026(result: EloResult, teams: Iterable[str]) -> dict[str, float]:
211	    """Return each team's latest Elo, defaulting to *result.initial_rating* if absent.
212	
213	    Pass team names explicitly so this function stays decoupled from any HTTP
214	    client or live-data adapter.
215	    """
216	    return {team: result.final_ratings.get(team, result.initial_rating) for team in teams}
217	
218	
219	def compute_elo(df: pd.DataFrame, config: EloConfig | None = None) -> EloResult:
220	    """Factory: run the Elo engine with *config* (uses defaults when ``None``)."""
221	    return EloEngine(config or EloConfig()).run(df)
