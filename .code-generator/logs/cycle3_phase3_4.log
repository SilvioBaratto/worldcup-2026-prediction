107	def _make_martj42_history() -> pd.DataFrame:
108	    """
109	    Small martj42-shaped fixture built entirely in-process (no network calls).
110	
111	    Contains two played FIFA World Cup matches and two unplayed WC2026 matches
112	    (float-NaN scores, ``tournament == "FIFA World Cup"``).
113	    Column layout matches the martj42 ``results.csv`` contract verified in
114	    requirements.md: date, home_team, away_team, home_score, away_score,
115	    tournament, city, country, neutral.
116	    """
117	    _nan = float("nan")
118	    return pd.DataFrame(
119	        {
120	            "date": [
121	                "2022-11-20",
122	                "2022-11-24",
123	                "2026-06-11",
124	                "2026-06-15",
125	            ],
126	            "home_team": ["Brazil", "France", "Brazil", "Germany"],
127	            "away_team": ["Serbia", "Australia", "France", "Spain"],
128	            "home_score": [2.0, 4.0, _nan, _nan],
129	            "away_score": [0.0, 1.0, _nan, _nan],
130	            "tournament": [
131	                "FIFA World Cup",
132	                "FIFA World Cup",
133	                "FIFA World Cup",
134	                "FIFA World Cup",
135	            ],
136	            "city": ["Lusail", "Doha", "New York", "Los Angeles"],
137	            "country": ["Qatar", "Qatar", "USA", "USA"],
138	            "neutral": [True, True, True, True],
139	        }
140	    )
141	
142	
143	@pytest.fixture(name="smoke_frames")
144	def _smoke_frames_fixture() -> tuple[pd.DataFrame, pd.DataFrame]:
145	    """
146	    Builds (historical_df, wc2026_df) from the in-process martj42 fixture.
147	
148	    "The historical builder" (AC3) is assumed to be ``build_historical_features``.
149	    ``wc2026_features`` is cited verbatim in AC3.
150	    Both are imported from ``worldcup_playoff.features`` (the package under test).
151	    No network calls are made.
152	    """
153	    from worldcup_playoff.features import (
154	        build_historical_features,
155	        compute_elo,
156	        fit_dixon_coles,
157	        wc2026_features,
158	    )
159	
160	    history = _make_martj42_history()
161	    elo_ratings = compute_elo(history)
162	    dixon_coles = fit_dixon_coles(history)
163	    hist_df = build_historical_features(history, elo_ratings, dixon_coles)
164	    wc_df = wc2026_features(history, elo_ratings, dixon_coles)
165	    return hist_df, wc_df
166	
167	
168	def test_when_no_key_smoke_test_run_then_frames_share_same_column_set(
169	    smoke_frames: tuple[pd.DataFrame, pd.DataFrame],
170	) -> None:
171	    """
172	    Historical and WC2026 feature frames must expose an identical column set.
173	
174	    AC3: "assert the two output frames share the same column set".
175	    """
176	    hist, wc = smoke_frames
177	    hist_cols = set(hist.columns)
178	    wc_cols = set(wc.columns)
179	    assert hist_cols == wc_cols, (
180	        "Column mismatch between historical and WC2026 feature frames.\n"
181	        f"  Only in historical: {hist_cols - wc_cols}\n"
182	        f"  Only in wc2026:     {wc_cols - hist_cols}"
183	    )
184	
185	
186	def test_when_no_key_smoke_test_run_then_wc2026_rows_are_subset_of_historical_rows(
187	    smoke_frames: tuple[pd.DataFrame, pd.DataFrame],
188	) -> None:
189	    """
190	    WC2026 frame rows must be a strict subset of historical frame rows.
191	
192	    AC3: "the WC2026 frame's rows are a subset of the historical frame's rows".
193	
194	    Verified via two necessary conditions:
195	    (a) strict row-count: len(wc) < len(hist)
196	        The fixture has 2 played + 2 unplayed rows → historical processes all 4;
197	        wc2026_features returns only the 2 unplayed rows.
198	    (b) index containment: frozenset(wc.index) ⊆ frozenset(hist.index)
199	        WC2026 row-labels must appear in the historical frame's index, confirming
200	        the WC2026 frame is a filtered view of the same dataset.
201	    """
202	    hist, wc = smoke_frames
203	    assert len(wc) < len(hist), (
204	        f"WC2026 frame ({len(wc)} rows) must have strictly fewer rows than "
205	        f"historical frame ({len(hist)} rows)."
206	    )
207	    wc_idx = frozenset(wc.index)
208	    hist_idx = frozenset(hist.index)
209	    assert wc_idx.issubset(hist_idx), (
210	        "WC2026 frame index is not a subset of historical frame index.\n"
211	        f"  Missing from historical: {wc_idx - hist_idx}"
212	    )
