401	    "Japan", "Mexico", "United States", "Senegal", "New Zealand",
402	]))
403	@settings(max_examples=10)
404	def test_when_confederation_is_built_for_any_known_team_then_value_is_one_of_six_valid_codes(
405	    home_team: str,
406	) -> None:
407	    """Valid-output-domain invariant: home_confederation ∈ CONFEDERATIONS for all known teams.
408	
409	    Derived from criterion: 'Confederation columns are deterministically encoded over the
410	    six CONFEDERATIONS indicators.'
411	    """
412	    away_team = "Germany" if home_team != "Germany" else "Brazil"
413	    m = _matches([{"home": home_team, "away": away_team, "home_goals": 1, "away_goals": 0}])
414	    result = FeatureBuilder(_DEFAULT_CFG).build(
415	        m,
416	        _elo([{}]),
417	        _abilities({
