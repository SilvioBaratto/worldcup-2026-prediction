193	
194	
195	class TestRestDays:
196	    """rest_days returns None on first appearance; exact calendar delta otherwise."""
197	
198	    def test_when_first_appearance_then_rest_days_is_none(self) -> None:
199	        df = _frame(("France", "Croatia", "2018-07-15", 4, 2))
200	        assert rest_days("France", 0, df) is None
201	
202	    def test_when_two_matches_five_days_apart_then_rest_days_is_five(self) -> None:
203	        df = _frame(
204	            ("France", "Belgium", "2018-07-10", 1, 0),   # idx 0
205	            ("France", "Croatia", "2018-07-15", 4, 2),   # idx 1
206	        )
207	        assert rest_days("France", 1, df) == 5
208	
209	    def test_when_exact_nine_day_gap_then_rest_days_is_nine(self) -> None:
210	        date_a, date_b = date(2022, 11, 20), date(2022, 11, 29)
211	        df = _frame(
212	            ("Argentina", "Saudi Arabia", date_a.isoformat(), 1, 2),
213	            ("Argentina", "Mexico",        date_b.isoformat(), 2, 0),
214	        )
215	        assert rest_days("Argentina", 1, df) == (date_b - date_a).days
