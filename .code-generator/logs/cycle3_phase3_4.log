270	# ---------------------------------------------------------------------------
271	# Criterion 5 — confederation deterministic over 6 codes; None ranking OK
272	# ---------------------------------------------------------------------------
273	
274	
275	class TestConfederationEncoding:
276	    """Confederation columns are deterministically encoded over the six CONFEDERATIONS.
277	
278	    When the FIFA ranking DataFrame is None, the builder must fall back to the static
279	    confederation map and still populate confederation columns — no crash, no NA.
280	    """
281	
282	    def test_when_home_team_is_brazil_then_home_confederation_is_conmebol(self) -> None:
283	        m = _matches([{"home": "Brazil", "away": "Germany", "home_goals": 2, "away_goals": 1}])
284	        result = FeatureBuilder(_DEFAULT_CFG).build(m, _elo([{}]), _BRA_GER)
285	        assert result.iloc[0]["home_confederation"] == "CONMEBOL"
286	
287	    def test_when_home_team_is_germany_then_home_confederation_is_uefa(self) -> None:
288	        m = _matches([{"home": "Germany", "away": "France", "home_goals": 1, "away_goals": 1}])
289	        result = FeatureBuilder(_DEFAULT_CFG).build(
290	            m, _elo([{}]),
291	            _abilities({"Germany": {"attack": 1.3, "defence": 0.9},
292	                        "France":  {"attack": 1.2, "defence": 0.85}}),
293	        )
294	        assert result.iloc[0]["home_confederation"] == "UEFA"
295	
296	    def test_when_away_team_is_brazil_then_away_confederation_is_conmebol(self) -> None:
297	        m = _matches([{"home": "Germany", "away": "Brazil", "home_goals": 0, "away_goals": 1}])
298	        result = FeatureBuilder(_DEFAULT_CFG).build(
299	            m, _elo([{}]),
300	            _abilities({"Germany": {"attack": 1.3, "defence": 0.9},
301	                        "Brazil":  {"attack": 1.5, "defence": 0.8}}),
302	        )
303	        assert result.iloc[0]["away_confederation"] == "CONMEBOL"
304	
305	    def test_when_ranking_df_is_none_then_home_confederation_column_is_populated(self) -> None:
306	        """None FIFA ranking degrades gracefully — static map provides confederation."""
307	        m = _matches([{"home": "Brazil", "away": "Germany", "home_goals": 2, "away_goals": 1}])
308	        result = FeatureBuilder(_DEFAULT_CFG).build(
309	            m, _elo([{}]), _BRA_GER, ranking_df=None
310	        )
311	        assert "home_confederation" in result.columns
312	        assert not pd.isna(result.iloc[0]["home_confederation"])
313	
314	    def test_when_ranking_df_is_none_then_away_confederation_column_is_populated(self) -> None:
315	        m = _matches([{"home": "Brazil", "away": "Germany", "home_goals": 2, "away_goals": 1}])
316	        result = FeatureBuilder(_DEFAULT_CFG).build(
317	            m, _elo([{}]), _BRA_GER, ranking_df=None
318	        )
319	        assert "away_confederation" in result.columns
320	        assert not pd.isna(result.iloc[0]["away_confederation"])
321	
322	    def test_when_same_input_run_twice_then_confederation_output_is_identical(self) -> None:
323	        """Determinism: same input always yields the same confederation encoding."""
324	        m = _matches([{"home": "Brazil", "away": "Argentina", "home_goals": 1, "away_goals": 0}])
325	        ab = _abilities({"Brazil":    {"attack": 1.5, "defence": 0.8},
326	                         "Argentina": {"attack": 1.6, "defence": 0.7}})
327	        r1 = FeatureBuilder(_DEFAULT_CFG).build(m, _elo([{}]), ab)
328	        r2 = FeatureBuilder(_DEFAULT_CFG).build(m, _elo([{}]), ab)
329	        assert r1.iloc[0]["home_confederation"] == r2.iloc[0]["home_confederation"]
330	        assert r1.iloc[0]["away_confederation"] == r2.iloc[0]["away_confederation"]
331	
