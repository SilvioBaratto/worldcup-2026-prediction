262	_DATE_STRAT = st.dates(min_value=date(2000, 1, 1), max_value=date(2030, 12, 31))
263	_HOME_TEAMS = st.sampled_from(["Germany", "Brazil", "France", "Germany"])
264	_AWAY_TEAMS = st.sampled_from(["Spain", "England", "Argentina", "Italy"])
265	
266	
267	@given(
268	    rows=st.lists(
