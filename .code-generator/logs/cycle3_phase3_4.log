2026-06-24 01:13:11,663 DEBUG msg #31: assistant (tool_use) tool_use(Read): {'file_path': '/Volumes/External SSD/worldcup-2026-prediction/worldcup_playoff/features/timeaware.py'}
2026-06-24 01:13:12,014 DEBUG msg #32: UserMessage tool_result(toolu_01QRfv9UqBN6HzDAKjtcBKo9): 1	"""Time-aware per-match covariate helpers — no forward leakage.
2	
3	Every public function accepts a ``before_idx`` parameter and reads only rows
4	with ``index < before_idx``, making forward leakage structurally impossible.
5	
6	The sort produced by ``sort_chronological`` is byte-identical to the Elo
7	engine's ordering — both import ``SORT_COLS`` from ``worldcup_playoff.data.elo``
8	so they can never drift independently.  This alignment guarantee means the
9	sorted frame is positionally 1:1 with ``EloResult.match_diffs``.
10	
11	Input frame schema (from ``Martj42Loader.load_results``):
12	    DATE (object ISO), HOME_TEAM / AWAY_TEAM (object),
13	    HOME_GOALS / AWAY_GOALS (nullable Int64, <NA> for unplayed),
14	    TOURNAMENT (object), NEUTRAL (bool).
15	"""
16	from __future__ import annotations
17	
18	import logging
19	
20	import numpy as np
21	import pandas as pd
22	
23	from worldcup_playoff.data.elo import SORT_COLS
24	from worldcup_playoff.simulation.poisson import decay_weight
25	
26	logger = logging.getLogger(__name__)
27	
28	_WIN_PTS: float = 3.0
29	_DRAW_PTS: float = 1.0
30	_LOSS_PTS: float = 0.0
31	
32	
33	# ---------------------------------------------------------------------------
34	# Sort — shared key with Elo engine
35	# ---------------------------------------------------------------------------
36	
37	
38	def sort_chronological(df: pd.DataFrame) -> pd.DataFrame:
39	    """Sort *df* identically to the Elo engine: stable, NaT last, reset index.
40	
41	    Imports ``SORT_COLS`` from ``worldcup_playoff.data.elo`` so both code
42	    paths always use the same literal and any change to the key fails both.
43	    """
44	    return (
45	        df.assign(_d=pd.to_datetime(df["DATE"], errors="coerce"))
46	        .sort_values(SORT_COLS, kind="stable", na_position="last")
47	        .drop(columns=["_d"])
48	        .reset_index(drop=True)
49	    )
50	
51	
52	# ---------------------------------------------------------------------------
53	# Private helpers
54	# ---------------------------------------------------------------------------
55	
56	
57	def _team_prior(team: str, before_idx: int, df: pd.DataFrame) -> pd.DataFrame:
58	    """Rows before *before_idx* where *team* appeared (home or away)."""
59	    prior = df[df.index < before_idx]
60	    return prior[(prior["HOME_TEAM"] == team) | (prior["AWAY_TEAM"] == team)]
61	
62	
63	def _played_only(rows: pd.DataFrame) -> pd.DataFrame:
64	    """Keep only rows that have non-NA goals (played matches)."""
65	    return rows[~rows["HOME_GOALS"].isna() & ~rows["AWAY_GOALS"].isna()]
66	
67	
68	def _points_for(team: str, row: pd.Series) -> float:
69	    """Return 3 / 1 / 0 points from *team*'s perspective for one played match."""
70	    hg, ag = int(row["HOME_GOALS"]), int(row["AWAY_GOALS"])
71	    scored, conceded = (hg, ag) if row["HOME_TEAM"] == team else (ag, hg)
72	    if scored > conceded:
73	        return _WIN_PTS
74	    return _DRAW_PTS if scored == conceded else _LOSS_PTS
75	
76	
77	def _net_gd_for(team: str, row: pd.Series) -> int:
78	    """Net goal difference from *team*'s perspective for one played match."""
79	    hg, ag = int(row["HOME_GOALS"]), int(row["AWAY_GOALS"])
80	    return hg - ag if row["HOME_TEAM"] == team else ag - hg
81	
82	
83	def _ref_date(df: pd.DataFrame, before_idx: int) -> pd.Timestamp:
84	    """Parse DATE of the row at *before_idx* as a Timestamp."""
85	    return pd.to_datetime(df.loc[before_idx, "DATE"], errors="coerce")
86	
87	
88	def _age_days_array(ref: pd.Timestamp, played: pd.DataFrame) -> np.ndarray:
89	    """Days between each prior match and *ref*; NaT prior dates default to 0."""
90	    dates = pd.to_datetime(played["DATE"], errors="coerce")
91	    return (ref - dates).dt.days.fillna(0).values.astype(float)
92	
93	
94	def _weighted_ppg(pts: np.ndarray, weights: np.ndarray) -> float:
95	    """Decay-weighted points-per-game; 0.0 when all weights are zero."""
96	    total = float(weights.sum())
97	    return 0.0 if total == 0.0 else float((weights * pts).sum() / total)
98	
99	
100	# ---------------------------------------------------------------------------
101	# Public API
102	# ---------------------------------------------------------------------------
103	
104	
105	def recent_form(
106	    team: str,
107	    before_idx: int,
108	    sorted_df: pd.DataFrame,
109	    *,
110	    window: int = 5,
111	    half_life_days: float = 365.0,
112	) -> float:
113	    """Decay-weighted points-per-game over the last *window* played matches.
114	
115	    Age for each prior match is anchored to ``sorted_df.loc[before_idx, 'DATE']``
116	    so 'time-weighted' is unambiguous and testable.  Unplayed fixtures (<NA>
117	    goals) are excluded.  Returns ``0.0`` (neutral) with no prior played data.
118	    """
119	    played = _played_only(_team_prior(team, before_idx, sorted_df)).tail(window)
120	    if played.empty:
121	        return 0.0
122	    ref = _ref_date(sorted_df, before_idx)
123	    ages = _age_days_array(ref, played)
124	    weights = np.asarray(decay_weight(ages, half_life_days))
125	    pts = np.array([_points_for(team, row) for _, row in played.iterrows()])
126	    return _weighted_ppg(pts, weights)
127	
128	
129	def rest_days(
130	    team: str,
131	    before_idx: int,
132	    sorted_df: pd.DataFrame,
133	) -> int | None:
134	    """Calendar days since *team*'s most recent prior dated match.
135	
136	    Includes unplayed fixtures when they carry a known date (so WC2026
137	    scheduled matches contribute to rest-day logistics).  Returns ``None``
138	    on first appearance or when no prior dated match exists.
139	    """
140	    prior = _team_prior(team, before_idx, sorted_df)
141	    parsed = pd.to_datetime(prior["DATE"], errors="coerce")
142	    dated = prior[~parsed.isna()]
143	    if dated.empty:
144	        return None
145	    ref = _ref_date(sorted_df, before_idx)
146	    last = pd.to_datetime(dated["DATE"], errors="coerce").max()
147	    return int((ref - last).days)
148	
149	
150	def goal_difference(
151	    team: str,
152	    before_idx: int,
153	    sorted_df: pd.DataFrame,
154	    *,
155	    window: int = 5,
156	) -> float:
157	    """Total net goal difference from *team*'s perspective over last *window* played matches.
158	
159	    Returns ``0.0`` when no prior played matches exist.
160	    """
161	    played = _played_only(_team_prior(team, before_idx, sorted_df)).tail(window)
162	    if played.empty:
163	        return 0.0
164	    total = sum(_net_gd_for(team, row) for _, row in played.iterrows())
165	    return float(total)
166	
2026-06-24 01:13:12,038 DEBUG msg #33: assistant (tool_use) tool_use(Read): {'file_path': '/Volumes/External SSD/worldcup-2026-prediction/worldcup_playoff/features/build.py'}
2026-06-24 01:13:12,068 DEBUG msg #34: UserMessage tool_result(toolu_01B3JVNgGR93VaFyfWiN1pyR): 1	"""Core per-match feature assembler for the World Cup 2026 prediction model.
2	
3	Consumes a martj42 results DataFrame plus a pre-computed ``elo_df``
4	(columns ``home_elo``, ``away_elo``, aligned to ``sort_chronological(df)``)
5	and a ``TeamAbilities`` fitted by the Dixon-Coles estimator, then emits one
6	feature row per match including unplayed WC2026 fixtures.
7	
8	**Football-only** — no socioeconomic, market-value, or odds columns ever appear.
9	
10	**No forward leakage** — time-aware covariates (form, rest days, goal diff) are
11	computed via an incremental per-team rolling state updated AFTER each row is
12	assembled, so match i never sees its own or any later result.
13	
14	**O(N) performance** — a single chronological pass maintains per-team state
15	(deque of last *window* played results + last known match date), avoiding
16	the O(N²) prefix scans of the raw timeaware helpers.
17	"""
18	from __future__ import annotations
19	
20	import logging
21	from collections import deque
22	from dataclasses import asdict, dataclass
23	from typing import Any
24	
25	import pandas as pd
26	
27	from worldcup_playoff.config import FeatureBuildConfig
28	from worldcup_playoff.features.confederation import (
29	    CONFEDERATION_MAP,
30	    RankingResolution,
31	    resolve_ranking,
32	)
33	from worldcup_playoff.features.timeaware import sort_chronological
34	from worldcup_playoff.simulation.poisson import TeamAbilities
35	
36	__all__ = ["FEATURE_COLUMNS", "FeatureBuilder", "MatchFeatures", "TeamAbilities", "to_frame"]
37	
38	logger = logging.getLogger(__name__)
39	
40	# Stable, documented column order — asserted by the allow-list test.
41	FEATURE_COLUMNS: tuple[str, ...] = (
42	    "date", "home_team", "away_team", "neutral",
43	    "home_elo", "away_elo", "elo_diff",
44	    "home_attack", "home_defence", "away_attack", "away_defence",
45	    "home_form", "away_form",
46	    "home_rest_days", "away_rest_days",
47	    "home_goal_diff", "away_goal_diff",
48	    "home_confederation", "away_confederation",
49	    "home_ranking", "away_ranking",
50	    "home_goals", "away_goals",
51	)
52	
53	
54	# ---------------------------------------------------------------------------
55	# Value object — one frozen record per match
56	# ---------------------------------------------------------------------------
57	
58	
59	@dataclass(frozen=True)
60	class MatchFeatures:  # noqa: D101 — field names self-document
61	    date: str
62	    home_team: str
63	    away_team: str
64	    neutral: bool
65	    home_elo: float
66	    away_elo: float
67	    elo_diff: float
68	    home_attack: float
69	    home_defence: float
70	    away_attack: float
71	    away_defence: float
72	    home_form: float
73	    away_form: float
74	    home_rest_days: int | None
75	    away_rest_days: int | None
76	    home_goal_diff: float
77	    away_goal_diff: float
78	    home_confederation: str | None
79	    away_confederation: str | None
80	    home_ranking: float | None
81	    away_ranking: float | None
82	    home_goals: int | None
83	    away_goals: int | None
84	
85	
86	# ---------------------------------------------------------------------------
87	# O(N) incremental per-team rolling state
88	# ---------------------------------------------------------------------------
89	
90	
91	class _TeamState:
92	    """Rolling covariate state for one team, maintained chronologically."""
93	
94	    def __init__(self, window: int, half_life: float) -> None:
95	        self._half = half_life
96	        self._played: deque[tuple[float, int, pd.Timestamp]] = deque(maxlen=window)
97	        self._last: pd.Timestamp | None = None
98	
99	    def rest_days(self, ref: pd.Timestamp) -> int | None:
100	        if self._last is None or pd.isna(ref):
101	            return None
102	        return int((ref - self._last).days)
103	
104	    def form(self, ref: pd.Timestamp) -> float:
105	        if not self._played or pd.isna(ref):
106	            return 0.0
107	        weights = [float(0.5 ** ((ref - d).days / self._half)) for _, _, d in self._played]
108	        total = sum(weights)
109	        return 0.0 if total == 0.0 else sum(p * w for p, w in zip(
110	            [p for p, _, _ in self._played], weights
111	        )) / total
112	
113	    def goal_diff(self) -> float:
114	        return float(sum(gd for _, gd, _ in self._played))
115	
116	    def after_match(self, pts: float, gd: int, date: pd.Timestamp, played: bool) -> None:
117	        if played:
118	            self._played.append((pts, gd, date))
119	        if pd.notna(date):
120	            self._last = date
121	
122	
123	# ---------------------------------------------------------------------------
124	# Module-level pure helpers
125	# ---------------------------------------------------------------------------
126	
127	
128	def _pts_gd(scored: int, conceded: int) -> tuple[float, int]:
129	    """Return (points, net_goal_diff) from one team's perspective."""
130	    gd = scored - conceded
131	    if scored > conceded:
132	        return 3.0, gd
133	    return (1.0, gd) if scored == conceded else (0.0, gd)
134	
135	
136	def _date_str(raw: Any) -> str:
137	    """Coerce any DATE cell to a YYYY-MM-DD string; '' on NaT."""
138	    ts = pd.to_datetime(raw, errors="coerce")
139	    return "" if pd.isna(ts) else ts.strftime("%Y-%m-%d")
140	
141	
142	def _na_to_none(val: Any) -> int | None:
143	    return None if pd.isna(val) else int(val)
144	
145	
146	def _new_state(cfg: FeatureBuildConfig) -> _TeamState:
147	    return _TeamState(cfg.form_window, cfg.form_half_life_days)
148	
149	
150	def _check_alignment(df: pd.DataFrame, elo_df: pd.DataFrame) -> None:
151	    if len(df) != len(elo_df):
152	        raise ValueError(
153	            f"elo_df length {len(elo_df)} != matches length {len(df)}: "
154	            "elo_df must be pre-aligned to sort_chronological(matches_df)."
155	        )
156	
157	
158	def _record_match(
159	    row: pd.Series,
160	    home: str,
161	    away: str,
162	    date: pd.Timestamp,
163	    states: dict[str, _TeamState],
164	) -> None:
165	    if pd.isna(row["HOME_GOALS"]) or pd.isna(row["AWAY_GOALS"]):
166	        states[home].after_match(0.0, 0, date, False)
167	        states[away].after_match(0.0, 0, date, False)
168	        return
169	    hg, ag = int(row["HOME_GOALS"]), int(row["AWAY_GOALS"])
170	    h_pts, h_gd = _pts_gd(hg, ag)
171	    a_pts, a_gd = _pts_gd(ag, hg)
172	    states[home].after_match(h_pts, h_gd, date, True)
173	    states[away].after_match(a_pts, a_gd, date, True)
174	
175	
176	def _update_states(
177	    row: pd.Series,
178	    states: dict[str, _TeamState],
179	    cfg: FeatureBuildConfig,
180	) -> None:
181	    home, away = str(row["HOME_TEAM"]), str(row["AWAY_TEAM"])
182	    date = pd.to_datetime(_date_str(row["DATE"]), errors="coerce")
183	    for team in (home, away):
184	        states.setdefault(team, _new_state(cfg))
185	    _record_match(row, home, away, date, states)
186	
187	
188	def _make_features(
189	    row: pd.Series,
190	    elo: pd.Series,
191	    ab: TeamAbilities,
192	    h_st: _TeamState,
193	    a_st: _TeamState,
194	    h_rk: RankingResolution,
195	    a_rk: RankingResolution,
196	    date: str,
197	) -> MatchFeatures:
198	    home, away = str(row["HOME_TEAM"]), str(row["AWAY_TEAM"])
199	    ref = pd.to_datetime(date, errors="coerce")
200	    h_elo, a_elo = float(elo["home_elo"]), float(elo["away_elo"])
201	    return MatchFeatures(
202	        date=date, home_team=home, away_team=away, neutral=bool(row["NEUTRAL"]),
203	        home_elo=h_elo, away_elo=a_elo, elo_diff=h_elo - a_elo,
204	        home_attack=ab.attack.get(home, 0.0), home_defence=ab.defence.get(home, 0.0),
205	        away_attack=ab.attack.get(away, 0.0), away_defence=ab.defence.get(away, 0.0),
206	        home_form=h_st.form(ref), away_form=a_st.form(ref),
207	        home_rest_days=h_st.rest_days(ref), away_rest_days=a_st.rest_days(ref),
208	        home_goal_diff=h_st.goal_diff(), away_goal_diff=a_st.goal_diff(),
209	        home_confederation=h_rk.confederation, away_confederation=a_rk.confederation,
210	        home_ranking=h_rk.value, away_ranking=a_rk.value,
211	        home_goals=_na_to_none(row["HOME_GOALS"]), away_goals=_na_to_none(row["AWAY_GOALS"]),
212	    )
213	
214	
215	def to_frame(rows: list[MatchFeatures]) -> pd.DataFrame:
216	    """Convert a list of MatchFeatures into a tidy DataFrame (stable column order)."""
217	    if not rows:
218	        return pd.DataFrame(columns=list(FEATURE_COLUMNS))
219	    df = pd.DataFrame([asdict(r) for r in rows])[list(FEATURE_COLUMNS)]
220	    for col in ("home_goals", "away_goals"):
221	        df[col] = df[col].astype("Int64")
222	    return df
223	
224	
225	# ---------------------------------------------------------------------------
226	# Public assembler
227	# ---------------------------------------------------------------------------
228	
229	
230	class FeatureBuilder:
231	    """Assemble football-only per-match covariates from pre-computed inputs.
232	
233	    Parameters
234	    ----------
235	    config:     Feature-build settings (form window, half-life, staleness cutoff, seed).
236	    ranking:    Optional ``{team: ranking_points}`` dict; ``None`` falls back to
237	                the static confederation map for every team.
238	    confed_map: Confederation mapping (injectable for testing).
239	    """
240	
241	    def __init__(
242	        self,
243	        config: FeatureBuildConfig,
244	        *,
245	        ranking: dict[str, float] | None = None,
246	        confed_map: dict[str, str] = CONFEDERATION_MAP,
247	    ) -> None:
248	        self._cfg = config
249	        self._ranking = ranking
250	        self._confed_map = confed_map
251	
252	    def build(
253	        self,
254	        df: pd.DataFrame,
255	        elo_df: pd.DataFrame,
256	        abilities: TeamAbilities,
257	        *,
258	        ranking_df: dict[str, float] | None = None,
259	    ) -> pd.DataFrame:
260	        """Return one feature row per input match (includes unplayed WC2026 rows)."""
261	        sorted_df = sort_chronological(df)
262	        _check_alignment(sorted_df, elo_df)
263	        ranking = ranking_df if ranking_df is not None else self._ranking
264	        return to_frame(self._assemble(sorted_df, elo_df, abilities, ranking))
265	
266	    def _assemble(
267	        self,
268	        sorted_df: pd.DataFrame,
269	        elo_df: pd.DataFrame,
270	        abilities: TeamAbilities,
271	        ranking: dict[str, float] | None,
272	    ) -> list[MatchFeatures]:
273	        states: dict[str, _TeamState] = {}
274	        rows: list[MatchFeatures] = []
275	        for i, (_, row) in enumerate(sorted_df.iterrows()):
276	            rows.append(self._row(i, row, elo_df, abilities, ranking, states))
277	            _update_states(row, states, self._cfg)
278	        return rows
279	
280	    def _row(
281	        self,
282	        i: int,
283	        row: pd.Series,
284	        elo_df: pd.DataFrame,
285	        abilities: TeamAbilities,
286	        ranking: dict[str, float] | None,
287	        states: dict[str, _TeamState],
288	    ) -> MatchFeatures:
289	        home, away, date = str(row["HOME_TEAM"]), str(row["AWAY_TEAM"]), _date_str(row["DATE"])
290	        h_st = states.get(home, _new_state(self._cfg))
291	        a_st = states.get(away, _new_state(self._cfg))
292	        return _make_features(row, elo_df.iloc[i], abilities, h_st, a_st,
293	                               self._rank(home, date, ranking),
294	                               self._rank(away, date, ranking), date)
295	
296	    def _rank(self, team: str, date: str, ranking: dict[str, float] | None) -> RankingResolution:
297	        return resolve_ranking(
298	            team, ranking, date, self._cfg.ranking_staleness_cutoff, confed_map=self._confed_map
299	        )
300	
