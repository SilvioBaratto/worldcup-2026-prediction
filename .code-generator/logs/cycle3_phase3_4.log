419	            away_team: {"attack": 1.1, "defence": 0.95},
420	        }),
421	    )
422	    assert result.iloc[0]["home_confederation"] in CONFEDERATIONS
423	    assert result.iloc[0]["away_confederation"] in CONFEDERATIONS
