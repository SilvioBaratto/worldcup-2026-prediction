146	def test_when_confederation_map_keys_are_normalized_then_round_trip_holds():
147	    """Every key in CONFEDERATION_MAP must already be canonical.
148	
149	    A non-canonical key (e.g. 'Türkiye' instead of 'Turkey') would silently
150	    miss lookups when callers pre-normalize team names through the crosswalk.
151	    """
152	    non_canonical = [k for k in CONFEDERATION_MAP if normalize_team(k) != k]
153	    assert non_canonical == [], (
154	        f"Non-canonical keys found in CONFEDERATION_MAP: {non_canonical}"
155	    )
