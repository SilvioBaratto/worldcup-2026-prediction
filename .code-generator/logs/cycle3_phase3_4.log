380	@given(st.integers(min_value=1, max_value=8))
381	@settings(max_examples=20)
382	def test_when_n_matches_are_provided_then_output_has_exactly_n_rows(n: int) -> None:
383	    """Count invariant: len(output) == len(input) for every valid n.
384	
385	    Derived from criterion: 'Output frame has exactly one row per input match.'
386	    """
387	    rows = [
388	        {
389	            "home": "Brazil", "away": "Germany",
390	            "date": f"2026-01-{i + 1:02d}",
391	            "home_goals": 1, "away_goals": 0,
392	        }
393	        for i in range(n)
394	    ]
395	    result = FeatureBuilder(_DEFAULT_CFG).build(_matches(rows), _elo([{}] * n), _BRA_GER)
396	    assert len(result) == n
