186	
187	
188	class TestRestDays:
189	    """rest_days returns None on first appearance and the exact calendar delta otherwise."""
190	
191	    def test_first_appearance_returns_none(self) -> None:
192	        df = _frame(
193	            ("France", "Croatia", "2018-07-15", 4, 2),
194	        )
195	        result = rest_days("France", df, match_idx=0)
196	        assert result is None, f"First appearance must return None, got {result!r}"
197	
198	    def test_two_matches_five_days_apart_returns_five(self) -> None:
199	        df = _frame(
200	            ("France", "Belgium", "2018-07-10", 1, 0),  # idx 0
201	            ("France", "Croatia", "2018-07-15", 4, 2),  # idx 1  → 5 calendar days later
202	        )
203	        result = rest_days("France", df, match_idx=1)
204	        assert result == 5, f"Expected 5 rest days, got {result!r}"
205	
206	    def test_exact_calendar_day_delta_is_preserved(self) -> None:
207	        """rest_days must reflect the precise calendar-day count, not a rounded or floored value."""
208	        date_a = date(2022, 11, 20)
209	        date_b = date(2022, 11, 29)
210	        expected = (date_b - date_a).days  # 9
211	
212	        df = _frame(
213	            ("Argentina", "Saudi Arabia", date_a.isoformat(), 1, 2),  # idx 0
214	            ("Argentina", "Mexico",        date_b.isoformat(), 2, 0),  # idx 1
215	        )
216	        result = rest_days("Argentina", df, match_idx=1)
217	        assert result == expected, (
218	            f"Expected {expected} rest days between {date_a} and {date_b}, got {result!r}"
219	        )
