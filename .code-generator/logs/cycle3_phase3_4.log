2026-06-24 01:13:12,127 DEBUG msg #36: UserMessage tool_result(toolu_011d3y2BdWTiQKSfZtWTAANj): 1	"""WC2026 current-state feature frame.
2	
3	Produces feature rows for **unplayed** WC2026 fixtures by running the full
4	issue-#9 ``FeatureBuilder`` over the complete chronological history and then
5	filtering to the rows that correspond to unplayed ``FIFA World Cup`` matches.
6	
7	Running the builder over the full history (not over the WC2026 subset alone)
8	is essential: pre-match form, rest days, and Elo ratings must reflect ALL of a
9	team's prior football — not just their prior WC matches — to avoid leakage and
10	to produce the same covariate values the training pipeline would produce.
11	
12	The positional mask technique (``sort_chronological(df)['TOURNAMENT'] ==
13	'FIFA World Cup'``) is row-for-row aligned with the ``FeatureBuilder`` output
14	since both internally call ``sort_chronological`` with the same key.
15	
16	A ``tournament`` metadata column is appended to the output (always
17	``'FIFA World Cup'``) so callers can identify the WC2026 rows without
18	re-joining on ``(date, home_team, away_team)`` — a join that neutral-site
19	duplicates and same-day fixtures can corrupt.
20	"""
21	from __future__ import annotations
22	
23	import logging
24	
25	import pandas as pd
26	
27	from worldcup_playoff.config import FeatureBuildConfig
28	from worldcup_playoff.features.build import FeatureBuilder
29	from worldcup_playoff.features.timeaware import sort_chronological
30	from worldcup_playoff.simulation.poisson import TeamAbilities
31	
32	logger = logging.getLogger(__name__)
33	
34	_WC_TOURNAMENT = "FIFA World Cup"
35	
36	
37	# ---------------------------------------------------------------------------
38	# Private helpers
39	# ---------------------------------------------------------------------------
40	
41	
42	def _unplayed_wc_mask(sorted_df: pd.DataFrame) -> pd.Series:
43	    """Positional boolean mask: rows that are unplayed FIFA World Cup fixtures."""
44	    return (sorted_df["TOURNAMENT"] == _WC_TOURNAMENT) & sorted_df["HOME_GOALS"].isna()
45	
46	
47	def _filter_wc_rows(features_df: pd.DataFrame, mask: pd.Series) -> pd.DataFrame:
48	    """Filter feature rows by positional mask and tag with tournament metadata."""
49	    result = features_df[mask.values].copy()
50	    result["tournament"] = _WC_TOURNAMENT
51	    return result.reset_index(drop=True)
52	
53	
54	# ---------------------------------------------------------------------------
55	# Public API
56	# ---------------------------------------------------------------------------
57	
58	
59	def wc2026_features(
60	    results_df: pd.DataFrame,
61	    elo_df: pd.DataFrame,
62	    abilities: TeamAbilities,
63	    *,
64	    config: FeatureBuildConfig | None = None,
65	    ranking: dict[str, float] | None = None,
66	) -> pd.DataFrame:
67	    """Return feature rows for every unplayed WC2026 fixture in *results_df*.
68	
69	    Parameters
70	    ----------
71	    results_df: Full martj42 results frame (historical + WC2026 fixtures).
72	                Must be passable to ``FeatureBuilder.build``; includes both
73	                played and unplayed rows.
74	    elo_df:     Pre-computed Elo frame aligned to ``sort_chronological(results_df)``.
75	    abilities:  Dixon-Coles attack/defence abilities.
76	    config:     Feature-build settings; uses ``FeatureBuildConfig()`` defaults
77	                when ``None``.
78	    ranking:    Optional ``{team: ranking_points}`` dict; falls back to the
79	                static confederation map when ``None``.
80	
81	    Returns
82	    -------
83	    DataFrame with one row per unplayed WC2026 fixture, the full feature schema
84	    from ``FeatureBuilder`` plus a ``tournament`` metadata column, and
85	    ``home_goals``/``away_goals`` as ``<NA>``.
86	    """
87	    cfg = config or FeatureBuildConfig()
88	    sorted_df = sort_chronological(results_df)
89	    all_features = FeatureBuilder(cfg, ranking=ranking).build(sorted_df, elo_df, abilities)
90	    mask = _unplayed_wc_mask(sorted_df)
91	    return _filter_wc_rows(all_features, mask)
