2026-06-24 00:35:03,910 DEBUG msg #32: UserMessage tool_result(toolu_01WZafNJSqwSFbRA47GGawD3): 1	"""Time-aware per-match covariate helpers — no forward leakage.
2	
3	Every public function accepts a ``before_idx`` parameter and reads only rows
4	with ``index < before_idx``, making forward leakage structurally impossible.
5	
6	The sort produced by ``sort_chronological`` is byte-identical to the Elo
7	engine's ordering — both import ``SORT_COLS`` from ``worldcup_playoff.data.elo``
8	so they can never drift independently.  This alignment guarantee means the
9	sorted frame is positionally 1:1 with ``EloResult.match_diffs``.
10	
11	Input frame schema (from ``Martj42Loader.load_results``):
12	    DATE (object ISO), HOME_TEAM / AWAY_TEAM (object),
13	    HOME_GOALS / AWAY_GOALS (nullable Int64, <NA> for unplayed),
14	    TOURNAMENT (object), NEUTRAL (bool).
15	"""
16	from __future__ import annotations
17	
18	import logging
19	
20	import numpy as np
21	import pandas as pd
22	
23	from worldcup_playoff.data.elo import SORT_COLS
24	from worldcup_playoff.simulation.poisson import decay_weight
25	
26	logger = logging.getLogger(__name__)
27	
28	_WIN_PTS: float = 3.0
29	_DRAW_PTS: float = 1.0
30	_LOSS_PTS: float = 0.0
31	
32	
33	# ---------------------------------------------------------------------------
34	# Sort — shared key with Elo engine
35	# ---------------------------------------------------------------------------
36	
37	
38	def sort_chronological(df: pd.DataFrame) -> pd.DataFrame:
39	    """Sort *df* identically to the Elo engine: stable, NaT last, reset index.
40	
41	    Imports ``SORT_COLS`` from ``worldcup_playoff.data.elo`` so both code
42	    paths always use the same literal and any change to the key fails both.
43	    """
44	    return (
45	        df.assign(_d=pd.to_datetime(df["DATE"], errors="coerce"))
46	        .sort_values(SORT_COLS, kind="stable", na_position="last")
47	        .drop(columns=["_d"])
48	        .reset_index(drop=True)
49	    )
50	
51	
52	# ---------------------------------------------------------------------------
53	# Private helpers
54	# ---------------------------------------------------------------------------
55	
56	
57	def _team_prior(team: str, before_idx: int, df: pd.DataFrame) -> pd.DataFrame:
58	    """Rows before *before_idx* where *team* appeared (home or away)."""
59	    prior = df[df.index < before_idx]
60	    return prior[(prior["HOME_TEAM"] == team) | (prior["AWAY_TEAM"] == team)]
61	
62	
63	def _played_only(rows: pd.DataFrame) -> pd.DataFrame:
64	    """Keep only rows that have non-NA goals (played matches)."""
65	    return rows[~rows["HOME_GOALS"].isna() & ~rows["AWAY_GOALS"].isna()]
66	
67	
68	def _points_for(team: str, row: pd.Series) -> float:
69	    """Return 3 / 1 / 0 points from *team*'s perspective for one played match."""
70	    hg, ag = int(row["HOME_GOALS"]), int(row["AWAY_GOALS"])
71	    scored, conceded = (hg, ag) if row["HOME_TEAM"] == team else (ag, hg)
72	    if scored > conceded:
73	        return _WIN_PTS
74	    return _DRAW_PTS if scored == conceded else _LOSS_PTS
75	
76	
77	def _net_gd_for(team: str, row: pd.Series) -> int:
78	    """Net goal difference from *team*'s perspective for one played match."""
79	    hg, ag = int(row["HOME_GOALS"]), int(row["AWAY_GOALS"])
80	    return hg - ag if row["HOME_TEAM"] == team else ag - hg
81	
82	
83	def _ref_date(df: pd.DataFrame, before_idx: int) -> pd.Timestamp:
84	    """Parse DATE of the row at *before_idx* as a Timestamp."""
85	    return pd.to_datetime(df.loc[before_idx, "DATE"], errors="coerce")
86	
87	
88	def _age_days_array(ref: pd.Timestamp, played: pd.DataFrame) -> np.ndarray:
89	    """Days between each prior match and *ref*; NaT prior dates default to 0."""
90	    dates = pd.to_datetime(played["DATE"], errors="coerce")
91	    return (ref - dates).dt.days.fillna(0).values.astype(float)
92	
93	
94	def _weighted_ppg(pts: np.ndarray, weights: np.ndarray) -> float:
95	    """Decay-weighted points-per-game; 0.0 when all weights are zero."""
96	    total = float(weights.sum())
97	    return 0.0 if total == 0.0 else float((weights * pts).sum() / total)
98	
99	
100	# ---------------------------------------------------------------------------
101	# Public API
102	# ---------------------------------------------------------------------------
103	
104	
105	def recent_form(
106	    team: str,
107	    before_idx: int,
108	    sorted_df: pd.DataFrame,
109	    *,
110	    window: int = 5,
111	    half_life_days: float = 365.0,
112	) -> float:
113	    """Decay-weighted points-per-game over the last *window* played matches.
114	
115	    Age for each prior match is anchored to ``sorted_df.loc[before_idx, 'DATE']``
116	    so 'time-weighted' is unambiguous and testable.  Unplayed fixtures (<NA>
117	    goals) are excluded.  Returns ``0.0`` (neutral) with no prior played data.
118	    """
119	    played = _played_only(_team_prior(team, before_idx, sorted_df)).tail(window)
120	    if played.empty:
121	        return 0.0
122	    ref = _ref_date(sorted_df, before_idx)
123	    ages = _age_days_array(ref, played)
124	    weights = np.asarray(decay_weight(ages, half_life_days))
125	    pts = np.array([_points_for(team, row) for _, row in played.iterrows()])
126	    return _weighted_ppg(pts, weights)
127	
128	
129	def rest_days(
130	    team: str,
131	    before_idx: int,
132	    sorted_df: pd.DataFrame,
133	) -> int | None:
134	    """Calendar days since *team*'s most recent prior dated match.
135	
136	    Includes unplayed fixtures when they carry a known date (so WC2026
137	    scheduled matches contribute to rest-day logistics).  Returns ``None``
138	    on first appearance or when no prior dated match exists.
139	    """
140	    prior = _team_prior(team, before_idx, sorted_df)
141	    parsed = pd.to_datetime(prior["DATE"], errors="coerce")
142	    dated = prior[~parsed.isna()]
143	    if dated.empty:
144	        return None
145	    ref = _ref_date(sorted_df, before_idx)
146	    last = pd.to_datetime(dated["DATE"], errors="coerce").max()
147	    return int((ref - last).days)
148	
149	
150	def goal_difference(
151	    team: str,
152	    before_idx: int,
153	    sorted_df: pd.DataFrame,
154	    *,
155	    window: int = 5,
156	) -> float:
157	    """Total net goal difference from *team*'s perspective over last *window* played matches.
158	
159	    Returns ``0.0`` when no prior played matches exist.
160	    """
161	    played = _played_only(_team_prior(team, before_idx, sorted_df)).tail(window)
162	    if played.empty:
163	        return 0.0
164	    total = sum(_net_gd_for(team, row) for _, row in played.iterrows())
165	    return float(total)
166	
