224	# ---------------------------------------------------------------------------
225	
226	
227	class TestNAGoalsSkipped:
228	    """NA goals in prior rows must be excluded from form calculations."""
229	
230	    def test_only_prior_match_is_unplayed_gives_neutral_form(self) -> None:
231	        """If the sole prior match has NA goals, it is skipped → neutral default 0.0."""
232	        df = _frame(
233	            ("Spain", "Germany", "2022-12-01", None, None),  # idx 0 — unplayed, must skip
234	            ("Spain", "Brazil",  "2022-12-18", 1, 0),         # idx 1 — current match
235	        )
236	        result = recent_form("Spain", df, before_idx=1)
237	        assert result == 0.0, (
238	            f"Unplayed prior match (NA goals) must be skipped → neutral 0.0, got {result!r}"
239	        )
240	
241	    def test_rest_days_with_na_goals_prior_does_not_raise(self) -> None:
242	        """rest_days must handle a prior NA-goals match without raising any exception.
243	
244	        The exact convention (use the unplayed date vs. skip to the last played match)
245	        is implementation-defined.  This test only pins the observable contract:
246	        no exception is raised and the return type is Optional[int].
247	        """
248	        df = _frame(
249	            ("Spain", "Germany", "2022-12-01", None, None),  # idx 0 — unplayed
250	            ("Spain", "Brazil",  "2022-12-18", 1, 0),         # idx 1
251	        )
252	        result = rest_days("Spain", df, match_idx=1)
253	        assert result is None or isinstance(result, int), (
254	            f"rest_days must return None or int even with a prior NA-goals row; got {type(result)!r}"
255	        )
