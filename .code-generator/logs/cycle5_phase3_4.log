2	Source-blind example tests for the backtest_hybrid orchestrator.
3	
4	The function under test (from worldcup_playoff.models.evaluation) slices played
5	WC matches by tournament year on time-aware (no-shuffle) splits, predicts W/D/L
6	with a hybrid model and a legacy classifier, and returns a per-year comparison
7	table that optionally includes a bookmaker baseline column.
8	
9	All fixtures are synthetic — no network, no real data, no wall-clock dependencies.
10	
11	Assumed interface (derived from spec, not implementation source):
12	    backtest_hybrid(
13	        matches  : pd.DataFrame,   # history rows with 'date', 'tournament', 'outcome',
14	                                   # plus feature columns the models consume
15	        hybrid   : Any,            # sklearn-style: fit(X, y) + predict_proba(X) → (N,3)
16	        legacy   : Any,            # same protocol
17	        odds     : pd.DataFrame | None = None,  # de-vigged bookmaker W/D/L probs
18	        years    : list[int] | None = None,     # tournament years to evaluate
19	    ) -> pd.DataFrame
20	
21	Expected result columns:
22	    rps_hybrid    – mean RPS for the hybrid model (always present)
23	    rps_legacy    – mean RPS for the legacy classifier (always present)
24	    rps_bookmaker – mean RPS for the bookmaker baseline
25	                    (present ONLY when odds is not None)
26	
27	Tournament year accessible either as a 'year' column or as the DataFrame index.
28	
29	Outcome encoding: 0 = home win (W), 1 = draw (D), 2 = away win / loss (L).
30	"""
31	
32	import numpy as np
33	import pandas as pd
34	import pytest
35	
36	from worldcup_playoff.models.evaluation import backtest_hybrid
37	
38	
39	# ---------------------------------------------------------------------------
40	# Helpers
41	# ---------------------------------------------------------------------------
42	
43	
44	class _ConstantModel:
45	    """
46	    Stub estimator: always returns a fixed probability vector, ignores input.
47	    fit() is a no-op so the orchestrator can call it without error.
48	    """
49	
50	    def __init__(self, probs=(0.5, 0.3, 0.2)):
51	        self._probs = np.asarray(probs, dtype=float)
52	
53	    def fit(self, X, y):
54	        return self
55	
56	    def predict_proba(self, X):
57	        n = len(X)
58	        return np.tile(self._probs, (n, 1))
59	
60	
61	def _make_matches() -> pd.DataFrame:
62	    """
63	    Synthetic WC match rows for two tournament years (3 matches each).
64	    Includes 'elo_diff' and 'home_attack' as representative feature columns.
65	    Outcome: 0=W, 1=D, 2=L from home team's perspective.
66	    """
67	    return pd.DataFrame(
68	        {
69	            "date": pd.to_datetime(
70	                [
71	                    "2014-06-12",
72	                    "2014-06-13",
73	                    "2014-06-14",
74	                    "2022-11-20",
75	                    "2022-11-21",
76	                    "2022-11-22",
77	                ]
78	            ),
79	            "home_team": ["Brazil", "Spain", "Germany", "Qatar", "Senegal", "USA"],
80	            "away_team": [
81	                "Croatia",
82	                "Netherlands",
83	                "Portugal",
84	                "Ecuador",
85	                "Netherlands",
86	                "Wales",
87	            ],
88	            "tournament": ["FIFA World Cup"] * 6,
89	            "outcome": [0, 2, 0, 2, 1, 0],
90	            "elo_diff": [150.0, -50.0, 100.0, -200.0, 30.0, -10.0],
91	            "home_attack": [1.5, 1.2, 1.8, 0.5, 0.9, 1.0],
92	        }
93	    )
94	
95	
96	def _make_odds() -> pd.DataFrame:
97	    """
98	    Stub bookmaker odds aligned to the synthetic matches.
99	    Probabilities are already de-vigged (p_win + p_draw + p_loss == 1.0 per row).
100	    """
101	    return pd.DataFrame(
102	        {
103	            "date": pd.to_datetime(
104	                [
105	                    "2014-06-12",
106	                    "2014-06-13",
107	                    "2014-06-14",
108	                    "2022-11-20",
109	                    "2022-11-21",
110	                    "2022-11-22",
111	                ]
112	            ),
113	            "home_team": ["Brazil", "Spain", "Germany", "Qatar", "Senegal", "USA"],
114	            "away_team": [
115	                "Croatia",
116	                "Netherlands",
117	                "Portugal",
118	                "Ecuador",
119	                "Netherlands",
120	                "Wales",
121	            ],
122	            "p_win": [0.60, 0.30, 0.70, 0.20, 0.40, 0.35],
123	            "p_draw": [0.20, 0.30, 0.15, 0.25, 0.30, 0.30],
124	            "p_loss": [0.20, 0.40, 0.15, 0.55, 0.30, 0.35],
125	        }
126	    )
127	
128	
129	# ---------------------------------------------------------------------------
130	# Pytest fixtures
131	# ---------------------------------------------------------------------------
132	
133	
134	@pytest.fixture()
135	def matches():
136	    return _make_matches()
137	
138	
139	@pytest.fixture()
140	def hybrid():
141	    return _ConstantModel(probs=(0.5, 0.3, 0.2))
142	
143	
144	@pytest.fixture()
145	def legacy():
146	    return _ConstantModel(probs=(0.4, 0.3, 0.3))
147	
148	
149	@pytest.fixture()
150	def odds():
151	    return _make_odds()
152	
153	
154	# ---------------------------------------------------------------------------
155	# Tests
156	# ---------------------------------------------------------------------------
157	
158	
159	def test_when_two_tournament_years_provided_then_result_has_one_row_per_year(
160	    matches, hybrid, legacy
161	):
162	    """backtest_hybrid returns exactly one result row for each requested year."""
163	    result = backtest_hybrid(matches, hybrid, legacy, years=[2014, 2022])
164	    assert len(result) == 2
165	
166	
167	def test_when_two_tournament_years_provided_then_result_identifies_those_years(
168	    matches, hybrid, legacy
169	):
170	    """
171	    The requested years (2014, 2022) must appear in the result — either as a
172	    'year' column or as the integer index of the returned DataFrame.
173	    """
174	    result = backtest_hybrid(matches, hybrid, legacy, years=[2014, 2022])
175	    if "year" in result.columns:
176	        years_in_result = set(result["year"].astype(int).tolist())
177	    else:
178	        years_in_result = set(int(v) for v in result.index.tolist())
179	    assert 2014 in years_in_result
180	    assert 2022 in years_in_result
181	
182	
183	def test_when_backtest_runs_then_result_contains_hybrid_and_legacy_rps_columns(
184	    matches, hybrid, legacy
185	):
186	    """The comparison table always exposes rps_hybrid and rps_legacy."""
187	    result = backtest_hybrid(matches, hybrid, legacy, years=[2014, 2022])
188	    assert "rps_hybrid" in result.columns
189	    assert "rps_legacy" in result.columns
190	
191	
192	def test_when_odds_are_none_then_bookmaker_column_is_absent_but_hybrid_and_legacy_remain(
193	    matches, hybrid, legacy
194	):
195	    """
196	    Graceful degradation: passing odds=None must not raise, must still return
197	    rps_hybrid and rps_legacy, and must NOT include rps_bookmaker.
198	    """
199	    result = backtest_hybrid(matches, hybrid, legacy, odds=None, years=[2014, 2022])
200	    assert "rps_hybrid" in result.columns
201	    assert "rps_legacy" in result.columns
202	    assert "rps_bookmaker" not in result.columns
203	
204	
205	def test_when_odds_are_provided_then_bookmaker_rps_column_is_present(
206	    matches, hybrid, legacy, odds
207	):
208	    """When odds are supplied the comparison table includes rps_bookmaker."""
209	    result = backtest_hybrid(matches, hybrid, legacy, odds=odds, years=[2014, 2022])
210	    assert "rps_bookmaker" in result.columns
211	
212	
213	def test_when_backtest_runs_with_odds_then_all_rps_values_are_in_unit_interval(
214	    matches, hybrid, legacy, odds
215	):
216	    """
217	    RPS ∈ [0, 1] is an analytic property of the metric.  All three reported
218	    RPS columns must satisfy this bound for every row in the result.
219	    """
220	    result = backtest_hybrid(matches, hybrid, legacy, odds=odds, years=[2014, 2022])
221	    for col in ("rps_hybrid", "rps_legacy", "rps_bookmaker"):
222	        assert col in result.columns, f"expected column '{col}' missing from result"
223	        values = result[col].dropna()
224	        assert (values >= 0).all(), f"{col}: found negative RPS value"
225	        assert (values <= 1).all(), f"{col}: found RPS value > 1"
