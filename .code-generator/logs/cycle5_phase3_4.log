2026-06-24 04:49:06,134 DEBUG msg #34: UserMessage tool_result(toolu_01HyecUo7q6fuBqnXvFmJw4a): 1	"""
2	Source-blind example + property tests for probabilistic evaluation metrics:
3	  rank_probability_score, multiclass_log_loss, brier_score.
4	
5	All expected values are hand-computed directly from the metric formulae —
6	no implementation source was read during authoring.
7	
8	Metric formulae (J = 3 ordered classes: 0=Win, 1=Draw, 2=Loss):
9	  RPS  = (1/(J-1)) * sum_{k=1}^{J-1} (CDF_pred_k - CDF_obs_k)^2   [J-1 = 2]
10	  LL   = -(1/N) * sum_i  y_i[outcome_i] * log(p_i[outcome_i])
11	  BS   = (1/N) * sum_i sum_j (p_ij - o_ij)^2
12	
13	Outcome encoding: 0 = home win (W), 1 = draw (D), 2 = away win / loss (L).
14	"""
15	
16	import math
17	
18	import numpy as np
19	import pytest
20	from hypothesis import given, settings, strategies as st
21	
22	from worldcup_playoff.models.evaluation import (
23	    brier_score,
24	    multiclass_log_loss,
25	    rank_probability_score,
26	)
27	
28	
29	# ---------------------------------------------------------------------------
30	# rank_probability_score — example tests
31	# ---------------------------------------------------------------------------
32	
33	
34	def test_when_win_is_predicted_with_certainty_and_outcome_is_win_then_rps_is_zero():
35	    """Perfect prediction of Win → RPS = 0."""
36	    probs = np.array([[1.0, 0.0, 0.0]])
37	    y_true = np.array([0])
38	    assert rank_probability_score(y_true, probs) == pytest.approx(0.0)
39	
40	
41	def test_when_draw_is_predicted_with_certainty_and_outcome_is_draw_then_rps_is_zero():
42	    """Perfect prediction of Draw → RPS = 0.
43	    CDF_pred=[0,1], CDF_obs=[0,1] → both squared diffs are 0.
44	    """
45	    probs = np.array([[0.0, 1.0, 0.0]])
46	    y_true = np.array([1])
47	    assert rank_probability_score(y_true, probs) == pytest.approx(0.0)
48	
49	
50	def test_when_win_is_predicted_with_certainty_but_outcome_is_loss_then_rps_is_one():
51	    """
52	    Worst-case ordered-RPS: predict Win with certainty, actual outcome is Loss.
53	    CDF_pred = [1, 1]   CDF_obs = [0, 0]
54	    RPS = 0.5 * (1^2 + 1^2) = 1.0
55	    """
56	    probs = np.array([[1.0, 0.0, 0.0]])
57	    y_true = np.array([2])
58	    assert rank_probability_score(y_true, probs) == pytest.approx(1.0)
59	
60	
61	def test_when_uniform_prediction_and_win_outcome_then_rps_equals_five_eighteenths():
62	    """
63	    p = [1/3, 1/3, 1/3], outcome = Win (0).
64	    CDF_pred = [1/3, 2/3]   CDF_obs = [1, 1]
65	    RPS = 0.5 * ((1/3 - 1)^2 + (2/3 - 1)^2)
66	        = 0.5 * (4/9 + 1/9)
67	        = 5/18  ≈  0.27778
68	    """
69	    probs = np.array([[1 / 3, 1 / 3, 1 / 3]])
70	    y_true = np.array([0])
71	    assert rank_probability_score(y_true, probs) == pytest.approx(5 / 18, rel=1e-5)
72	
73	
74	def test_when_two_matches_provided_then_rps_is_arithmetic_mean_of_per_match_values():
75	    """
76	    Match 1: p=[0.7, 0.2, 0.1], outcome=Win(0)
77	      CDF_pred=[0.7, 0.9]  CDF_obs=[1, 1]
78	      RPS_1 = 0.5*((0.3)^2 + (0.1)^2) = 0.5*(0.09+0.01) = 0.05
79	
80	    Match 2: p=[0.2, 0.5, 0.3], outcome=Draw(1)
81	      CDF_pred=[0.2, 0.7]  CDF_obs=[0, 1]
82	      RPS_2 = 0.5*((0.2)^2 + (0.3)^2) = 0.5*(0.04+0.09) = 0.065
83	
84	    Mean RPS = (0.05 + 0.065) / 2 = 0.0575
85	    """
86	    probs = np.array([[0.7, 0.2, 0.1], [0.2, 0.5, 0.3]])
87	    y_true = np.array([0, 1])
88	    assert rank_probability_score(y_true, probs) == pytest.approx(0.0575, rel=1e-5)
89	
90	
91	# ---------------------------------------------------------------------------
92	# multiclass_log_loss — example tests
93	# ---------------------------------------------------------------------------
94	
95	
96	def test_when_single_win_predicted_at_0_7_then_log_loss_equals_negative_log_0_7():
97	    """
98	    p=[0.7, 0.2, 0.1], outcome=Win(0).
99	    LL = -log(0.7)  ≈  0.35667
100	    """
101	    probs = np.array([[0.7, 0.2, 0.1]])
102	    y_true = np.array([0])
103	    expected = -math.log(0.7)
104	    assert multiclass_log_loss(y_true, probs) == pytest.approx(expected, rel=1e-5)
105	
106	
107	def test_when_two_matches_then_log_loss_is_mean_of_individual_losses():
108	    """
109	    Match 1: p=[0.7, 0.2, 0.1], outcome=Win   → LL = -log(0.7)  ≈ 0.35667
110	    Match 2: p=[0.2, 0.5, 0.3], outcome=Draw  → LL = -log(0.5)  ≈ 0.69315
111	    Mean LL = (-log(0.7) + -log(0.5)) / 2  ≈ 0.52491
112	    """
113	    probs = np.array([[0.7, 0.2, 0.1], [0.2, 0.5, 0.3]])
114	    y_true = np.array([0, 1])
115	    expected = (-math.log(0.7) + -math.log(0.5)) / 2
116	    assert multiclass_log_loss(y_true, probs) == pytest.approx(expected, rel=1e-5)
117	
118	
119	# ---------------------------------------------------------------------------
120	# brier_score — example tests
121	# ---------------------------------------------------------------------------
122	
123	
124	def test_when_perfect_one_hot_prediction_then_brier_score_is_zero():
125	    """p=[1,0,0], outcome=Win(0) → all squared errors are 0 → BS = 0."""
126	    probs = np.array([[1.0, 0.0, 0.0]])
127	    y_true = np.array([0])
128	    assert brier_score(y_true, probs) == pytest.approx(0.0)
129	
130	
131	def test_when_single_match_then_brier_score_equals_sum_of_squared_errors():
132	    """
133	    p=[0.7, 0.2, 0.1], outcome=Win → one-hot=[1, 0, 0].
134	    BS = (0.7-1)^2 + (0.2-0)^2 + (0.1-0)^2
135	       = 0.09 + 0.04 + 0.01
136	       = 0.14
137	    """
138	    probs = np.array([[0.7, 0.2, 0.1]])
139	    y_true = np.array([0])
140	    assert brier_score(y_true, probs) == pytest.approx(0.14, rel=1e-5)
141	
142	
143	def test_when_two_matches_then_brier_score_is_mean_of_per_match_values():
144	    """
145	    Match 1: p=[0.7, 0.2, 0.1], outcome=Win   → BS = 0.14  (see test above)
146	    Match 2: p=[0.2, 0.5, 0.3], outcome=Draw  → one-hot=[0, 1, 0]
147	      BS = (0.2-0)^2 + (0.5-1)^2 + (0.3-0)^2 = 0.04 + 0.25 + 0.09 = 0.38
148	    Mean BS = (0.14 + 0.38) / 2 = 0.26
149	    """
150	    probs = np.array([[0.7, 0.2, 0.1], [0.2, 0.5, 0.3]])
151	    y_true = np.array([0, 1])
152	    assert brier_score(y_true, probs) == pytest.approx(0.26, rel=1e-5)
153	
154	
155	# ---------------------------------------------------------------------------
156	# Property-based tests (Hypothesis)
157	# Derived from the invariants implied by the metric definitions:
158	#   - RPS ∈ [0, 1]  (bounded ordered divergence)
159	#   - RPS = 0 iff predicted distribution = observed distribution (perfect score)
160	#   - Brier ≥ 0     (sum of squares is non-negative)
161	#   - log-loss ≥ 0  (cross-entropy is non-negative for p ∈ (0,1])
162	# ---------------------------------------------------------------------------
163	
164	
165	@st.composite
166	def _simplex_and_outcome(draw):
167	    """
168	    Strategy: draw a valid 3-class probability vector (each entry ≥ 0.01,
169	    normalised to sum to 1) and a random outcome label in {0, 1, 2}.
170	    """
171	    raw = draw(
172	        st.lists(
173	            st.floats(
174	                min_value=0.01,
175	                max_value=1.0,
176	                allow_nan=False,
177	                allow_infinity=False,
178	            ),
179	            min_size=3,
180	            max_size=3,
181	        )
182	    )
183	    total = sum(raw)
184	    probs = [v / total for v in raw]
185	    outcome = draw(st.integers(min_value=0, max_value=2))
186	    return np.array([probs]), np.array([outcome])
187	
188	
189	@given(_simplex_and_outcome())
190	def test_when_valid_probability_vector_then_rps_lies_in_unit_interval(args):
191	    """RPS ∈ [0, 1] for any valid 3-class probability simplex and any outcome."""
192	    probs, y_true = args
193	    result = rank_probability_score(y_true, probs)
194	    assert 0.0 - 1e-9 <= result <= 1.0 + 1e-9
195	
196	
197	@given(st.integers(min_value=0, max_value=2))
198	def test_when_predicted_distribution_matches_outcome_then_rps_is_zero(outcome):
199	    """
200	    One-hot prediction that exactly matches the true outcome → RPS = 0,
201	    regardless of which class (Win / Draw / Loss) occurred.
202	    """
203	    one_hot = [0.0, 0.0, 0.0]
204	    one_hot[outcome] = 1.0
205	    probs = np.array([one_hot])
206	    y_true = np.array([outcome])
207	    assert rank_probability_score(y_true, probs) == pytest.approx(0.0, abs=1e-9)
208	
209	
210	@given(_simplex_and_outcome())
211	def test_when_valid_probability_vector_then_brier_score_is_nonnegative(args):
212	    """Brier score ≥ 0 for any valid probability vector and any outcome."""
213	    probs, y_true = args
214	    assert brier_score(y_true, probs) >= -1e-9
215	
216	
217	@given(_simplex_and_outcome())
218	def test_when_valid_probability_vector_then_log_loss_is_nonnegative(args):
219	    """log-loss ≥ 0 for any valid (strictly positive) probability vector and any outcome."""
220	    probs, y_true = args
221	    assert multiclass_log_loss(y_true, probs) >= -1e-9
222	
