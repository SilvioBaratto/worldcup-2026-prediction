196	    # --- Rung 3: Goals for ---
197	
198	    def test_when_teams_equal_on_points_and_gd_then_goals_for_breaks_tie(self):
199	        """
200	        3-team group: X and Y both have 4 pts and GD=+2, but X has GF=4 vs Y's GF=3.
201	        X should rank above Y.
202	
203	        Fixtures (group G3):
204	          X vs Y: draw 1-1       → X: 1pt,  GF=1, GA=1; Y: 1pt,  GF=1, GA=1
205	          X vs Z: X wins 3-1     → X: +3pt, GF=3, GA=1; Z: 0pts, GF=1, GA=3
206	          Y vs Z: Y wins 2-0     → Y: +3pt, GF=2, GA=0; Z: 0pts, GF=0, GA=2
207	
208	        X total: 4pts, GF=4, GA=2, GD=+2
209	        Y total: 4pts, GF=3, GA=1, GD=+2   ← same GD, different GF
210	        """
211	        played = [
212	            LiveMatch("G3", "X", "Y", 1, 1),
213	            LiveMatch("G3", "X", "Z", 3, 1),
214	            LiveMatch("G3", "Y", "Z", 2, 0),
215	        ]
216	        standings, _ = _run(played=played)
217	        pos = {e["team"]["name"]: e["position"] for e in standings["G3"]}
218	        assert pos["X"] < pos["Y"], (
