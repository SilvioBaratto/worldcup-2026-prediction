330	    def test_when_group_has_four_teams_then_standings_list_contains_four_entries(self):
331	        """A 4-team group must produce exactly 4 entries in the standings list."""
332	        played = [
333	            LiveMatch("H2", "Brazil",    "Germany",   1, 0),
334	            LiveMatch("H2", "France",    "Argentina", 2, 2),
335	            LiveMatch("H2", "Brazil",    "France",    0, 0),
336	            LiveMatch("H2", "Germany",   "Argentina", 1, 1),
337	            LiveMatch("H2", "Brazil",    "Argentina", 1, 0),
338	            LiveMatch("H2", "Germany",   "France",    0, 1),
339	        ]
340	        standings, _ = _run(played=played)
341	        group = standings["H2"]
342	        assert isinstance(group, list)
343	        assert len(group) == 4, f"Expected 4 entries for a 4-team group; got {len(group)}"
344	
345	    def test_when_simulation_runs_then_each_entry_has_required_v4_fields(self):
346	        """
347	        Each entry must contain at minimum: team.name, position, points,
348	        goalDifference, goalsFor — matching the football-data.org v4 standings shape
349	        (table[] row: position, team{id,name}, points, goalsFor, goalDifference, ...).
350	        """
351	        played = [
352	            LiveMatch("H3", "Netherlands", "Ecuador", 2, 1),
353	            LiveMatch("H3", "Senegal",     "Qatar",   1, 0),
354	            LiveMatch("H3", "Netherlands", "Senegal", 2, 0),
355	            LiveMatch("H3", "Ecuador",     "Qatar",   2, 0),
356	            LiveMatch("H3", "Netherlands", "Qatar",   2, 0),
357	            LiveMatch("H3", "Ecuador",     "Senegal", 1, 2),
358	        ]
359	        standings, _ = _run(played=played)
360	        for entry in standings["H3"]:
361	            assert "team"           in entry,        f"Missing 'team' key in {entry}"
362	            assert "name"           in entry["team"], f"Missing 'team.name' in {entry}"
363	            assert "position"       in entry,        f"Missing 'position' in {entry}"
364	            assert "points"         in entry,        f"Missing 'points' in {entry}"
365	            assert "goalDifference" in entry,        f"Missing 'goalDifference' in {entry}"
366	            assert "goalsFor"       in entry,        f"Missing 'goalsFor' in {entry}"
367	
368	    def test_when_simulation_runs_then_positions_are_one_indexed_unique_and_contiguous(self):
369	        """Positions within a group must be exactly {1, 2, 3, ..., N} — no gaps, no dupes."""
370	        played = [
