2026-06-24 04:24:14,711 DEBUG msg #41: UserMessage tool_result(toolu_01UfLsaVEK46egXaXcL2o5Yc): 1	"""Group-stage simulation engine with FIFA tiebreak ranking.
2	
3	Ingests a TournamentState, holds played results fixed, samples remaining fixtures
4	via an injected ScorelineSampler, and returns v4-shaped standings for all groups.
5	"""
6	from __future__ import annotations
7	
8	import random as _random
9	from dataclasses import dataclass
10	from typing import Any
11	
12	# ─────────────────────────────────────────────────────────────────────────────
13	# Internal types
14	# ─────────────────────────────────────────────────────────────────────────────
15	
16	_Match = tuple[str, str, int, int]  # (home, away, home_goals, away_goals)
17	
18	
19	@dataclass
20	class _TeamStats:
21	    """Mutable per-team accumulator for group-stage statistics."""
22	
23	    name: str
24	    pts: int = 0
25	    gf: int = 0
26	    ga: int = 0
27	
28	    @property
29	    def gd(self) -> int:
30	        return self.gf - self.ga
31	
32	    def add(self, scored: int, conceded: int) -> None:
33	        self.gf += scored
34	        self.ga += conceded
35	        if scored > conceded:
36	            self.pts += 3
37	        elif scored == conceded:
38	            self.pts += 1
39	
40	
41	# ─────────────────────────────────────────────────────────────────────────────
42	# Pure helpers (no side-effects, easily unit-testable)
43	# ─────────────────────────────────────────────────────────────────────────────
44	
45	
46	def _sort_key(s: _TeamStats) -> tuple[int, int, int]:
47	    """Descending sort key: points, goal-difference, goals-for."""
48	    return (-s.pts, -s.gd, -s.gf)
49	
50	
51	def _build_stats(matches: list[_Match]) -> dict[str, _TeamStats]:
52	    """Accumulate overall stats for all teams from a list of matches."""
53	    stats: dict[str, _TeamStats] = {}
54	    for home, away, hg, ag in matches:
55	        stats.setdefault(home, _TeamStats(home))
56	        stats.setdefault(away, _TeamStats(away))
57	        stats[home].add(hg, ag)
58	        stats[away].add(ag, hg)
59	    return stats
60	
61	
62	def _h2h_stats(subset: list[str], matches: list[_Match]) -> dict[str, _TeamStats]:
63	    """Compute mini-table stats for matches only among the tied subset."""
64	    tied = set(subset)
65	    h2h: dict[str, _TeamStats] = {t: _TeamStats(t) for t in subset}
66	    for home, away, hg, ag in matches:
67	        if home in tied and away in tied:
68	            h2h[home].add(hg, ag)
69	            h2h[away].add(ag, hg)
70	    return h2h
71	
72	
73	def _resolve_tied(
74	    tied: list[str], matches: list[_Match], rng: _random.Random
75	) -> list[str]:
76	    """H2H mini-table → coin-flip fallback for any still-tied sub-groups."""
77	    if len(tied) == 1:
78	        return tied
79	    h2h = _h2h_stats(tied, matches)
80	    by_h2h = sorted(tied, key=lambda t: _sort_key(h2h[t]))
81	    result: list[str] = []
82	    i = 0
83	    while i < len(by_h2h):
84	        j = i + 1
85	        while j < len(by_h2h) and _sort_key(h2h[by_h2h[j]]) == _sort_key(h2h[by_h2h[i]]):
86	            j += 1
87	        sub = by_h2h[i:j]
88	        if len(sub) > 1:
89	            rng.shuffle(sub)
90	        result.extend(sub)
91	        i = j
92	    return result
93	
94	
95	def _rank_group(
96	    teams: list[str],
97	    stats: dict[str, _TeamStats],
98	    matches: list[_Match],
99	    rng: _random.Random,
100	) -> list[str]:
101	    """Return teams in ranked order using the full FIFA tiebreak chain."""
102	    ordered = sorted(teams, key=lambda t: _sort_key(stats[t]))
103	    result: list[str] = []
104	    i = 0
105	    while i < len(ordered):
106	        j = i + 1
107	        while j < len(ordered) and _sort_key(stats[ordered[j]]) == _sort_key(stats[ordered[i]]):
108	            j += 1
109	        group = ordered[i:j]
110	        if len(group) > 1:
111	            group = _resolve_tied(group, matches, rng)
112	        result.extend(group)
113	        i = j
114	    return result
115	
116	
117	def _to_v4_row(name: str, stats: _TeamStats, position: int) -> dict[str, Any]:
118	    """Produce a football-data.org v4 standings row consumed by resolve_r32."""
119	    return {
120	        "team": {"name": name},
121	        "position": position,
122	        "points": stats.pts,
123	        "goalsFor": stats.gf,
124	        "goalsAgainst": stats.ga,
125	        "goalDifference": stats.gd,
126	    }
127	
128	
129	def _extract_scoreline(raw: Any) -> tuple[int, int]:
130	    """Normalise sampler output (tuple or ndarray) to (home_goals, away_goals)."""
131	    if isinstance(raw, tuple):
132	        return int(raw[0]), int(raw[1])
133	    if hasattr(raw, "ndim") and raw.ndim == 2:  # ndarray shape (size, 2)
134	        return int(raw[0, 0]), int(raw[0, 1])
135	    return int(raw[0]), int(raw[1])  # ndarray shape (2,)
136	
137	
138	def _get_played(state: Any) -> list[Any]:
139	    """Return played matches, tolerating both .played and .played_matches."""
140	    if hasattr(state, "played_matches"):
141	        return list(state.played_matches)
142	    return list(state.played)
143	
144	
145	# ─────────────────────────────────────────────────────────────────────────────
146	# GroupStageSimulator
147	# ─────────────────────────────────────────────────────────────────────────────
148	
149	
150	class GroupStageSimulator:
151	    """Simulates remaining group matches; ranks all groups by FIFA tiebreaks."""
152	
153	    def __init__(self, sampler: Any, rng: _random.Random) -> None:
154	        self._sampler = sampler
155	        self._rng = rng
156	
157	    def simulate(self, state: Any) -> dict[str, list[dict[str, Any]]]:
158	        """Return v4 standings dict keyed by group label."""
159	        groups = self._collect(state)
160	        return {g: self._table(ms) for g, ms in groups.items()}
161	
162	    def _collect(self, state: Any) -> dict[str, list[_Match]]:
163	        groups: dict[str, list[_Match]] = {}
164	        for m in _get_played(state):
165	            _append(groups, m.group, m.home_team, m.away_team, m.home_goals, m.away_goals)
166	        for f in state.remaining_group_fixtures:
167	            hg, ag = _extract_scoreline(self._sampler.sample(f.home_team, f.away_team))
168	            _append(groups, f.group, f.home_team, f.away_team, hg, ag)
169	        return groups
170	
171	    def _table(self, matches: list[_Match]) -> list[dict[str, Any]]:
172	        stats = _build_stats(matches)
173	        ranked = _rank_group(list(stats), stats, matches, self._rng)
174	        return [_to_v4_row(t, stats[t], pos + 1) for pos, t in enumerate(ranked)]
175	
176	
177	def _append(
178	    groups: dict[str, list[_Match]],
179	    group: str,
180	    home: str,
181	    away: str,
182	    hg: int,
183	    ag: int,
184	) -> None:
185	    """Append a resolved match to the group registry."""
186	    groups.setdefault(group, []).append((home, away, hg, ag))
