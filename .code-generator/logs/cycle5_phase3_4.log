328	def test_when_any_non_draw_scoreline_then_resolve_tie_returns_one_of_the_two_teams(
329	    home_goals: int,
330	    away_goals: int,
331	    seed: int,
332	) -> None:
333	    """
334	    Totality invariant (never-raises-for-valid-input):
335	    resolve_tie accepts any non-draw scoreline and always returns exactly one of {home, away}.
336	    Draw path requires ET stub and is excluded here to keep the example self-contained.
337	    """
338	    from worldcup_playoff.simulation.knockout import resolve_tie
339	
340	    if home_goals == away_goals:
341	        return  # draw path requires ET resampling; tested in dedicated example tests
342	
343	    winner = resolve_tie(
