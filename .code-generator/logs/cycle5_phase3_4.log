647	@app.command()
648	def run(
649	    config: Path = typer.Option("config/default.toml", "--config", "-c"),
650	    bracket: Path = typer.Option(
651	        "config/playoff_2026.toml", "--bracket", "-b"
652	    ),
653	    verbose: int = typer.Option(0, "--verbose", "-v", count=True),
654	) -> None:
655	    """Execute the full pipeline: clean -> train -> fit -> simulate -> save probabilities.png."""
656	    _setup_logging(verbose)
657	    cfg = load_config(config)
658	    bracket_cfg = load_bracket(bracket)
659	
660	    root = _project_root(config)
661	    pipeline = Pipeline(cfg, bracket_config=bracket_cfg, root=root)
662	
663	    console.print("[bold]Step 1/4:[/bold] Cleaning data...")
664	    pipeline.run_clean()
665	    console.print("[green]  Done.[/green]")
666	
667	    console.print("[bold]Step 2/4:[/bold] Training classifiers...")
668	    results = pipeline.run_train()
669	    for name, (_, metrics) in results.items():
670	        _print_metrics(name, metrics)
671	
672	    console.print("[bold]Step 3/4:[/bold] Fitting distributions...")
673	    with console.status("[bold]Fitting distributions for all teams..."):
674	        team_dists = pipeline.run_fit_distributions()
675	    console.print(f"[green]  Fitted {len(team_dists)} teams.[/green]")
676	
677	    console.print("[bold]Step 4/4:[/bold] Running simulation...")
678	    clf_name = cfg.simulation.classifier
679	    classifier, _ = results[clf_name]
680	
681	    with Progress(
682	        SpinnerColumn(),
683	        TextColumn("[progress.description]{task.description}"),
684	        BarColumn(),
685	        TextColumn("{task.completed}/{task.total}"),
686	        console=console,
687	    ) as progress:
688	        task: TaskID = progress.add_task(
689	            "Simulating knockout bracket...", total=cfg.simulation.n_simulations
690	        )
691	
692	        def _update(n: int) -> None:
693	            progress.update(task, completed=n)
694	
695	        rounds = pipeline.run_simulate(
696	            classifier=classifier,
697	            team_distributions=team_dists,
698	            progress_callback=_update,
699	        )
700	
701	    _print_simulation_results(rounds)
702	
703	    # Save probabilities visualization
704	    from worldcup_playoff.visualization.plots import ResultPlotter
705	
706	    plotter_dir = root / Path(cfg.visualization.output_dir)
707	    plotter_dir.mkdir(parents=True, exist_ok=True)
708	    plotter = ResultPlotter(cfg.visualization)
709	    plotter.plot_round_probabilities(rounds, output_path=plotter_dir / "probabilities.png")
