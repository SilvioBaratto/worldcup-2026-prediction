61	# ---------------------------------------------------------------------------
62	# Bipartite matching (private helpers)
63	# ---------------------------------------------------------------------------
64	
65	
66	def _augment(
67	    slot: int,
68	    adj: list[list[int]],
69	    match: list[int],
70	    seen: list[bool],
71	) -> bool:
72	    """Try to find an augmenting path for *slot*; update *match* in-place."""
73	    for g in adj[slot]:
74	        if not seen[g]:
75	            seen[g] = True
76	            if match[g] == -1 or _augment(match[g], adj, match, seen):
77	                match[g] = slot
78	                return True
79	    return False
80	
81	
82	def _bipartite_match(
83	    qualifying: frozenset[str],
84	    slots: tuple[tuple[str, frozenset[str]], ...],
85	) -> dict[str, str] | None:
86	    """Return slot→group assignment via augmenting paths, or None if impossible."""
87	    groups = sorted(qualifying)
88	    g_idx = {g: i for i, g in enumerate(groups)}
89	    adj = [[g_idx[g] for g in cands if g in qualifying] for _, cands in slots]
90	    match: list[int] = [-1] * len(groups)
91	    n = sum(_augment(s, adj, match, [False] * len(groups)) for s in range(len(slots)))
92	    if n < len(slots):
93	        return None
94	    slot_map = {match[i]: groups[i] for i in range(len(groups)) if match[i] != -1}
95	    return {slots[s][0]: slot_map[s] for s in range(len(slots))}
96	
97	
98	# ---------------------------------------------------------------------------
99	# THIRD_PLACE_COMBINATIONS — computed once at import (pure, deterministic)
100	# ---------------------------------------------------------------------------
101	
102	
103	def _compute_third_place_combinations() -> dict[frozenset[str], dict[str, str]]:
104	    """Enumerate all valid 8-of-12 qualifying-third combinations via bipartite matching."""
105	    return {
106	        frozenset(combo): m
107	        for combo in combinations(GROUPS, 8)
108	        if (m := _bipartite_match(frozenset(combo), _THIRD_SLOT_CANDIDATES)) is not None
109	    }
110	
111	
112	# Official lookup: qualifying-8-groups frozenset → {placeholder: group_letter}.
113	# Covers every 8-of-12 combination that admits a valid slot assignment.
114	THIRD_PLACE_COMBINATIONS: dict[frozenset[str], dict[str, str]] = _compute_third_place_combinations()
