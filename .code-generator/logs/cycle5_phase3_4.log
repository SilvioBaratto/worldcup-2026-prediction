16	logger = logging.getLogger(__name__)
17	
18	
19	class ModelEvaluator:
20	    """Evaluates classifier performance."""
21	
22	    @staticmethod
23	    def evaluate(
24	        classifier: Any,
25	        X_test: np.ndarray,
26	        y_test: np.ndarray,
27	    ) -> dict[str, Any]:
28	        """Return confusion matrix and classification report as a dict."""
29	        y_pred = classifier.predict(X_test)
30	        return {
31	            "confusion_matrix": confusion_matrix(y_test, y_pred),
32	            "classification_report": classification_report(
33	                y_test, y_pred, output_dict=True
34	            ),
35	        }
36	
37	    @staticmethod
38	    def plot_roc_curves(
39	        classifiers: dict[str, Any],
40	        X_test: np.ndarray,
41	        y_test: np.ndarray,
42	        output_path: Path | None = None,
43	    ) -> None:
44	        """Plot ROC curves for multiple classifiers."""
45	        import matplotlib.pyplot as plt
46	
47	        fig, ax = plt.subplots(figsize=(10, 8))
48	        linestyles = ["-", ":", "--", "-.", (0, (3, 1, 1, 1))]
49	
50	        for i, (name, clf) in enumerate(classifiers.items()):
51	            RocCurveDisplay.from_estimator(
52	                clf, X_test, y_test,
53	                ax=ax,
54	                linewidth=3,
55	                linestyle=linestyles[i % len(linestyles)],
56	                name=name,
57	            )
58	
59	        ax.tick_params(axis="both", labelsize=16)
60	        ax.set_xlabel("False Positive Rate", fontsize=18)
61	        ax.set_ylabel("True Positive Rate", fontsize=18)
62	        ax.legend(fontsize=14)
63	
64	        if output_path:
65	            output_path.parent.mkdir(parents=True, exist_ok=True)
66	            fig.savefig(output_path, bbox_inches="tight")
67	            logger.info("ROC curve saved to %s", output_path)
68	        plt.close(fig)
