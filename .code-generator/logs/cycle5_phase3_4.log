457	@app.command(name="generate-bracket")
458	def generate_bracket(
459	    season: str | None = typer.Option(
460	        None,
461	        "--season",
462	        "-s",
463	        help='World Cup year, e.g. "2026". Defaults to nearest World Cup year.',
464	    ),
465	    output: Path | None = typer.Option(
466	        None,
