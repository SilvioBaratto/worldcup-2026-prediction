366	        extra_time_factor=0.33,
367	        seed=seed,
368	    )
369	    w2 = resolve_tie(
370	        "Alpha", "Beta",
371	        sampler=_stub_sampler([(0, 0), (0, 0)]),
372	        extra_time_factor=0.33,
373	        seed=seed,
374	    )
375	
376	    assert w1 == w2
