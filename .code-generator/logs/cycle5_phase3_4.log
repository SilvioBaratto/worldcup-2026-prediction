354	def test_when_penalty_path_then_same_seed_produces_same_winner_idempotently(seed: int) -> None:
355	    """
356	    Idempotence / seed-stability invariant:
357	    resolve_tie(... seed=s) == resolve_tie(... seed=s) for any seed s
358	    when both regulation and extra-time end level.
359	    This encodes 'deterministic given a seed' from the criterion.
360	    """
361	    from worldcup_playoff.simulation.knockout import resolve_tie
362	
363	    w1 = resolve_tie(
364	        "Alpha", "Beta",
