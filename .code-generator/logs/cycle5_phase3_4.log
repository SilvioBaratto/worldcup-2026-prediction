2026-06-24 05:03:04,927 DEBUG msg #49: assistant (tool_use) tool_use(Read): {'file_path': '/Volumes/External SSD/worldcup-2026-prediction/worldcup_playoff/models/evaluation.py'}
2026-06-24 05:03:04,937 DEBUG msg #50: UserMessage tool_result(toolu_01Rdh6Gp2JgoYSEnE5MacD4y): 1	"""Model evaluation and comparison.
2	
3	Public API
4	----------
5	Pure metric functions (source-blind, no sklearn dependency):
6	  rank_probability_score  — ordered 3-class RPS (primary)
7	  multiclass_log_loss     — mean cross-entropy
8	  brier_score             — mean multi-class Brier score
9	
10	Orchestration:
11	  backtest_hybrid         — time-aware WC backtest vs bookmaker + legacy baselines
12	
13	Legacy (kept for pipeline compatibility):
14	  ModelEvaluator          — confusion matrix + classification report
15	  plot_roc_curves         — ROC curve visualisation
16	"""
17	
18	from __future__ import annotations
19	
20	import logging
21	from pathlib import Path
22	from typing import Any
23	
24	import numpy as np
25	import pandas as pd
26	from sklearn.metrics import (
27	    RocCurveDisplay,
28	    classification_report,
29	    confusion_matrix,
30	)
31	
32	logger = logging.getLogger(__name__)
33	
34	# ── Constants ────────────────────────────────────────────────────────────────
35	
36	_EPS: float = 1e-15
37	_DEFAULT_WC_YEARS: list[int] = [2014, 2018, 2022]
38	_META_COLS: frozenset[str] = frozenset(
39	    {"date", "home_team", "away_team", "tournament", "outcome"}
40	)
41	
42	# ── Pure metric functions ────────────────────────────────────────────────────
43	
44	
45	def rank_probability_score(y_true: np.ndarray, y_pred: np.ndarray) -> float:
46	    """Mean RPS for ordered 3-class (Win/Draw/Loss) predictions.
47	
48	    RPS_i = (1/(J-1)) * Σ_{k=0}^{J-2} (CDF_pred_{i,k} − CDF_obs_{i,k})²
49	    averaged over N matches (J=3 → divides by 2).
50	    """
51	    yt = np.asarray(y_true)
52	    yp = np.asarray(y_pred, dtype=float)
53	    cdf_pred = np.cumsum(yp, axis=1)[:, :-1]          # (N, J-1)
54	    cutpoints = np.arange(yp.shape[1] - 1)            # [0, 1]
55	    cdf_obs = (yt[:, np.newaxis] <= cutpoints).astype(float)
56	    return float(np.mean(np.mean((cdf_pred - cdf_obs) ** 2, axis=1)))
57	
58	
59	def multiclass_log_loss(y_true: np.ndarray, y_pred: np.ndarray) -> float:
60	    """Mean cross-entropy loss; clips probabilities to avoid log(0)."""
61	    yt = np.asarray(y_true)
62	    yp = np.clip(np.asarray(y_pred, dtype=float), _EPS, 1.0)
63	    return float(-np.mean(np.log(yp[np.arange(len(yt)), yt])))
64	
65	
66	def brier_score(y_true: np.ndarray, y_pred: np.ndarray) -> float:
67	    """Mean multi-class Brier score (mean squared error in probability space)."""
68	    yt = np.asarray(y_true)
69	    yp = np.asarray(y_pred, dtype=float)
70	    one_hot = np.eye(yp.shape[1])[yt]
71	    return float(np.mean(np.sum((yp - one_hot) ** 2, axis=1)))
72	
73	
74	# ── Backtest helpers ─────────────────────────────────────────────────────────
75	
76	
77	def _feature_cols(df: pd.DataFrame) -> list[str]:
78	    return [c for c in df.columns if c not in _META_COLS]
79	
80	
81	def _slice_year(df: pd.DataFrame, year: int) -> pd.DataFrame:
82	    return df[pd.to_datetime(df["date"]).dt.year == year].reset_index(drop=True)
83	
84	
85	def _pre_year(df: pd.DataFrame, year: int) -> pd.DataFrame:
86	    return df[pd.to_datetime(df["date"]).dt.year < year].reset_index(drop=True)
87	
88	
89	def _bookmaker_rps(year_matches: pd.DataFrame, odds: pd.DataFrame) -> float | None:
90	    """Merge bookmaker odds onto year matches and return mean RPS; None if no overlap."""
91	    key = ["date", "home_team", "away_team"]
92	    merged = year_matches[key + ["outcome"]].merge(
93	        odds[key + ["p_win", "p_draw", "p_loss"]], on=key, how="inner"
94	    )
95	    if merged.empty:
96	        return None
97	    return rank_probability_score(
98	        merged["outcome"].to_numpy(),
99	        merged[["p_win", "p_draw", "p_loss"]].to_numpy(),
100	    )
101	
102	
103	def _build_row(
104	    year_matches: pd.DataFrame,
105	    hybrid: Any,
106	    legacy: Any,
107	    feat_cols: list[str],
108	    odds: pd.DataFrame | None,
109	) -> dict[str, Any]:
110	    X = year_matches[feat_cols].to_numpy()
111	    y_true = year_matches["outcome"].to_numpy()
112	    row: dict[str, Any] = {
113	        "rps_hybrid": rank_probability_score(y_true, hybrid.predict_proba(X)),
114	        "rps_legacy": rank_probability_score(y_true, legacy.predict_proba(X)),
115	    }
116	    if odds is not None:
117	        bk = _bookmaker_rps(year_matches, odds)
118	        if bk is not None:
119	            row["rps_bookmaker"] = bk
120	    return row
121	
122	
123	def backtest_hybrid(
124	    matches: pd.DataFrame,
125	    hybrid: Any,
126	    legacy: Any,
127	    odds: pd.DataFrame | None = None,
128	    years: list[int] | None = None,
129	) -> pd.DataFrame:
130	    """Time-aware WC backtest: train on pre-year data, evaluate on WC year.
131	
132	    Parameters
133	    ----------
134	    matches:  DataFrame with 'date', 'outcome', and feature columns.
135	    hybrid:   Model with fit(X, y) and predict_proba(X) → (N, 3).
136	    legacy:   Same protocol as hybrid (used as second baseline).
137	    odds:     Optional bookmaker odds with 'date', 'home_team', 'away_team',
138	              'p_win', 'p_draw', 'p_loss'. Skipped when None.
139	    years:    WC years to backtest (default [2014, 2018, 2022]).
140	
141	    Returns
142	    -------
143	    DataFrame indexed by year with columns rps_hybrid, rps_legacy, and
144	    (when odds are not None) rps_bookmaker.
145	    """
146	    eval_years = years if years is not None else _DEFAULT_WC_YEARS
147	    feat_cols = _feature_cols(matches)
148	    rows: dict[int, dict[str, Any]] = {}
149	    for year in eval_years:
150	        year_matches = _slice_year(matches, year)
151	        if year_matches.empty:
152	            continue
153	        train = _pre_year(matches, year)
154	        if not train.empty:
155	            X_tr = train[feat_cols].to_numpy()
156	            y_tr = train["outcome"].to_numpy()
157	            hybrid.fit(X_tr, y_tr)
158	            legacy.fit(X_tr, y_tr)
159	        rows[year] = _build_row(year_matches, hybrid, legacy, feat_cols, odds)
160	    result = pd.DataFrame.from_dict(rows, orient="index")
161	    result.index.name = "year"
162	    return result
163	
164	
165	class ModelEvaluator:
166	    """Evaluates classifier performance."""
167	
168	    @staticmethod
169	    def evaluate(
170	        classifier: Any,
171	        X_test: np.ndarray,
172	        y_test: np.ndarray,
173	    ) -> dict[str, Any]:
174	        """Return confusion matrix and classification report as a dict."""
175	        y_pred = classifier.predict(X_test)
176	        return {
177	            "confusion_matrix": confusion_matrix(y_test, y_pred),
178	            "classification_report": classification_report(
179	                y_test, y_pred, output_dict=True
180	            ),
181	        }
182	
183	    @staticmethod
184	    def plot_roc_curves(
185	        classifiers: dict[str, Any],
186	        X_test: np.ndarray,
187	        y_test: np.ndarray,
188	        output_path: Path | None = None,
189	    ) -> None:
190	        """Plot ROC curves for multiple classifiers."""
191	        import matplotlib.pyplot as plt
192	
193	        fig, ax = plt.subplots(figsize=(10, 8))
194	        linestyles = ["-", ":", "--", "-.", (0, (3, 1, 1, 1))]
195	
196	        for i, (name, clf) in enumerate(classifiers.items()):
197	            RocCurveDisplay.from_estimator(
198	                clf, X_test, y_test,
199	                ax=ax,
200	                linewidth=3,
201	                linestyle=linestyles[i % len(linestyles)],
202	                name=name,
203	            )
204	
205	        ax.tick_params(axis="both", labelsize=16)
206	        ax.set_xlabel("False Positive Rate", fontsize=18)
207	        ax.set_ylabel("True Positive Rate", fontsize=18)
208	        ax.legend(fontsize=14)
209	
210	        if output_path:
211	            output_path.parent.mkdir(parents=True, exist_ok=True)
212	            fig.savefig(output_path, bbox_inches="tight")
213	            logger.info("ROC curve saved to %s", output_path)
214	        plt.close(fig)
215	
2026-06-24 05:03:05,165 DEBUG msg #51: assistant (tool_use) tool_use(Read): {'file_path': '/Volumes/External SSD/worldcup-2026-prediction/worldcup_playoff/simulation/live_forecast.py'}
2026-06-24 05:03:05,234 DEBUG msg #52: UserMessage tool_result(toolu_01HpRnPy6oY7KSMYXxUE1mZH): 1	"""Live-tournament Monte-Carlo forecast orchestrator for WC2026.
2	
3	Runs ~100k seeded simulations (group-stage → knockout) conditioned on played
4	WC2026 results and aggregates per-team title odds + per-round advancement
5	probabilities for all 48 teams.
6	
7	Key design choices
8	------------------
9	- **Callable injection**: ``LiveForecaster`` accepts ``group_simulator`` and
10	  ``knockout_simulator`` protocol callables so it can be tested with stubs and
11	  used with real ``GroupStageSimulator`` / ``KnockoutSimulator`` via factory
12	  adapters.  This decouples orchestration from the concrete implementations in
13	  ``group_stage.py`` and ``knockout.py``.
14	- **SeedSequence sub-seeding**: the master seed is expanded into N
15	  statistically-independent child seeds via ``numpy.random.SeedSequence.spawn``
16	  so that (a) the same master seed yields bit-identical odds on any re-run, and
17	  (b) each tournament iteration draws from an independent, decorrelated stream —
18	  avoiding the intra-tournament correlation that arises from re-seeding with the
19	  same integer.
20	- **Fit-once pattern**: ``TeamAbilities`` are computed outside the Monte-Carlo
21	  loop and accepted by ``LiveForecaster.run()``; the loop only draws samples.
22	"""
23	from __future__ import annotations
24	
25	from dataclasses import dataclass
26	from typing import Any, Callable
27	
28	import numpy as np
29	
30	from worldcup_playoff.data.live import TournamentState
31	from worldcup_playoff.simulation.poisson import TeamAbilities
32	
33	# Re-export so callers can import everything from one place.
34	__all__ = [
35	    "ForecastResult",
36	    "LiveForecaster",
37	    "TournamentState",
38	    "TeamAbilities",
39	]
40	
41	# ---------------------------------------------------------------------------
42	# Callable protocols (structural — no ABC overhead)
43	# ---------------------------------------------------------------------------
44	
45	#: Signature: (state, abilities, rng) → list of 32 qualified team names.
46	_GroupSimFn = Callable[
47	    [TournamentState, TeamAbilities, np.random.Generator],
48	    list[str],
49	]
50	
51	#: Signature: (qualified_teams, abilities, rng) → {"champion": str, "rounds": dict}.
52	_KnockoutSimFn = Callable[
53	    [list[str], TeamAbilities, np.random.Generator],
54	    dict[str, Any],
55	]
56	
57	# ---------------------------------------------------------------------------
58	# Value objects
59	# ---------------------------------------------------------------------------
60	
61	
62	@dataclass(frozen=True)
63	class ForecastResult:
64	    """Immutable result of a live Monte-Carlo forecast.
65	
66	    Attributes
67	    ----------
68	    champion_probabilities:
69	        Per-team title-odds: ``count / n_simulations``.  **All 48 group-stage
70	        teams are present**, including those with probability 0.0.
71	    round_probabilities:
72	        ``{round_name: {team: probability}}`` advancement fractions.
73	        Reuses the ``RoundResult.probabilities`` contract: each team's value
74	        is its individual advancement probability (``count / n_simulations``),
75	        so values across a round sum to the number of ties in that round, not
76	        to 1.0.  Only rounds that appear in at least one simulation are
77	        included.
78	    """
79	
80	    champion_probabilities: dict[str, float]
81	    round_probabilities: dict[str, dict[str, float]]
82	
83	
84	# ---------------------------------------------------------------------------
85	# Private helpers (module-level, ≤10 lines each)
86	# ---------------------------------------------------------------------------
87	
88	
89	def _teams_from_matches(matches: list[Any]) -> set[str]:
90	    """Collect non-null home/away team names from a flat list of match objects."""
91	    teams: set[str] = set()
92	    for m in matches:
93	        if m.home_team:
94	            teams.add(m.home_team)
95	        if m.away_team:
96	            teams.add(m.away_team)
97	    return teams
98	
99	
100	def _extract_all_teams(state: TournamentState) -> list[str]:
101	    """Return sorted list of all group-stage teams from standings or match history."""
102	    teams = {
103	        row.team_name
104	        for gs in state.standings
105	        for row in gs.table
106	        if row.team_name
107	    }
108	    if not teams:
109	        teams = _teams_from_matches(list(state.played) + list(state.remaining_group_fixtures))
110	    return sorted(teams)
111	
112	
113	def _accumulate_rounds(
114	    acc: dict[str, dict[str, int]],
115	    rounds: dict[str, Any],
116	) -> None:
117	    """Merge one simulation's per-round team-count dict into *acc* in place."""
118	    for round_name, team_counts in rounds.items():
119	        bucket = acc.setdefault(round_name, {})
120	        for team, count in team_counts.items():
121	            bucket[team] = bucket.get(team, 0) + count
122	
123	
124	def _to_probabilities(counts: dict[str, int], n: int) -> dict[str, float]:
125	    """Divide raw counts by *n*; return zeroes when n == 0."""
126	    if n == 0:
127	        return {t: 0.0 for t in counts}
128	    return {t: c / n for t, c in counts.items()}
129	
130	
131	# ---------------------------------------------------------------------------
132	# LiveForecaster
133	# ---------------------------------------------------------------------------
134	
135	
136	class LiveForecaster:
137	    """Orchestrates N seeded Monte-Carlo WC2026 tournament simulations.
138	
139	    One child ``numpy.random.Generator`` is derived per iteration from the
140	    master seed via ``numpy.random.SeedSequence.spawn`` so that:
141	    - two calls with the same master seed produce bit-identical title odds;
142	    - draws within each tournament advance a **single** RNG, eliminating the
143	      intra-tournament correlation caused by re-seeding per match.
144	    """
145	
146	    def __init__(
147	        self,
148	        group_simulator: _GroupSimFn,
149	        knockout_simulator: _KnockoutSimFn,
150	    ) -> None:
151	        self._group_sim = group_simulator
152	        self._knockout_sim = knockout_simulator
153	
154	    def run(
155	        self,
156	        state: TournamentState,
157	        abilities: TeamAbilities,
158	        n_simulations: int,
159	        seed: int,
160	    ) -> ForecastResult:
161	        """Run *n_simulations* tournaments and return aggregated probabilities."""
162	        all_teams = _extract_all_teams(state)
163	        champion_counts: dict[str, int] = {t: 0 for t in all_teams}
164	        round_counts: dict[str, dict[str, int]] = {}
165	        child_seeds = np.random.SeedSequence(seed).spawn(n_simulations)
166	        for child_seed in child_seeds:
167	            rng = np.random.default_rng(child_seed)
168	            self._run_one(state, abilities, rng, champion_counts, round_counts)
169	        return self._to_result(champion_counts, round_counts, n_simulations)
170	
171	    def _run_one(
172	        self,
173	        state: TournamentState,
174	        abilities: TeamAbilities,
175	        rng: np.random.Generator,
176	        champion_counts: dict[str, int],
177	        round_counts: dict[str, dict[str, int]],
178	    ) -> None:
179	        qualified = self._group_sim(state, abilities, rng)
180	        result = self._knockout_sim(qualified, abilities, rng)
181	        champion_counts[result["champion"]] += 1
182	        _accumulate_rounds(round_counts, result.get("rounds", {}))
183	
184	    def _to_result(
185	        self,
186	        champion_counts: dict[str, int],
187	        round_counts: dict[str, dict[str, int]],
188	        n: int,
189	    ) -> ForecastResult:
190	        champ_probs = _to_probabilities(champion_counts, n)
191	        round_probs = {
192	            rnd: _to_probabilities(counts, n) for rnd, counts in round_counts.items()
193	        }
194	        return ForecastResult(
195	            champion_probabilities=champ_probs,
196	            round_probabilities=round_probs,
197	        )
198	
