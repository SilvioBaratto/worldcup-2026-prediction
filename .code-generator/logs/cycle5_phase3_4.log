222	    # --- Rung 4: Head-to-head ---
223	
224	    def test_when_teams_equal_on_points_gd_gf_then_h2h_breaks_tie(self):
225	        """
226	        4-team group where P and Q are identical on points / GD / GF overall
227	        but P beat Q head-to-head — P must rank above Q.
228	
229	        Fixtures (group G4):
230	          P vs Q: P wins 1-0   → P: 3pts, GF=1, GA=0; Q: 0pts, GF=0, GA=1
231	          P vs R: draw 1-1     → P: 1pt,  GF=1, GA=1; R: 1pt,  GF=1, GA=1
232	          P vs S: P loses 0-1  → P: 0pts, GF=0, GA=1; S: 3pts, GF=1, GA=0
233	          Q vs R: Q wins 2-1   → Q: 3pts, GF=2, GA=1; R: 0pts, GF=1, GA=2
234	          Q vs S: draw 0-0     → Q: 1pt,  GF=0, GA=0; S: 1pt,  GF=0, GA=0
235	          R vs S: R wins 2-0   → R: 3pts, GF=2, GA=0; S: 0pts, GF=0, GA=2
236	
237	        P total: 4pts, GF=2, GA=2, GD=0
238	        Q total: 4pts, GF=2, GA=2, GD=0   ← identical to P overall
239	        R total: 4pts, GF=4, GA=3, GD=+1  → ranks 1st by GD
240	        S total: 4pts, GF=1, GA=2, GD=-1  → ranks last by GD
241	        H2H P vs Q: P won 1-0 → P ranks above Q.
242	        """
243	        played = [
244	            LiveMatch("G4", "P", "Q", 1, 0),
245	            LiveMatch("G4", "P", "R", 1, 1),
246	            LiveMatch("G4", "P", "S", 0, 1),
247	            LiveMatch("G4", "Q", "R", 2, 1),
248	            LiveMatch("G4", "Q", "S", 0, 0),
249	            LiveMatch("G4", "R", "S", 2, 0),
250	        ]
251	        standings, _ = _run(played=played)
252	        pos = {e["team"]["name"]: e["position"] for e in standings["G4"]}
253	        assert pos["P"] < pos["Q"], (
254	            f"P (beat Q h2h 1-0) must rank above Q when both 4pts GD=0 GF=2; got {pos}"
255	        )
