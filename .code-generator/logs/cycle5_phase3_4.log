470	    ),
471	    verbose: int = typer.Option(0, "--verbose", "-v", count=True),
472	) -> None:
473	    """Generate a World Cup knockout bracket TOML from football-data.org team data."""
474	    _setup_logging(verbose)
475	
476	    from worldcup_playoff.data.bracket_builder import default_season
477	
478	    resolved_season = season or default_season()
479	    year = resolved_season.split("-")[0] if "-" in resolved_season else resolved_season
480	    output_path = output or Path(f"config/playoff_{year}.toml")
481	
482	    try:
483	        with console.status("[bold]Fetching team data..."):
484	            bracket = generate_bracket_toml(output_path, season=resolved_season)
485	        console.print(
486	            f"[green]Bracket saved to {output_path} "
487	            f"({len(bracket.matchups)} matchups)[/green]"
488	        )
489	    except (RuntimeError, ValueError) as exc:
490	        console.print(f"[red]{exc}[/red]")
491	        raise typer.Exit(code=1)
