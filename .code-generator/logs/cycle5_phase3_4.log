25	def _stub_sampler(sequence: list[tuple[int, int]]):
26	    """
27	    Return a callable sampler that yields scorelines from *sequence* in order.
28	
29	    Raises StopIteration when exhausted — any test that over-calls has a bug.
30	    Signature mirrors the expected production interface: sampler(home, away) → (h_goals, a_goals).
31	    """
32	    it = iter(sequence)
33	
34	    def _call(home: str, away: str) -> tuple[int, int]:
35	        return next(it)
36	
37	    return _call
