2026-06-24 05:09:59,748 DEBUG msg #538: UserMessage tool_result(toolu_01FbxEMc5aSb2Tpk9zXoZeNb): 157	class KnockoutSimulator:
158	    """Monte Carlo single-elimination knockout simulator for WC2026.
159	
160	    Seeds the R32 from live group standings via *resolve_r32*, then folds the
161	    bracket upward (R32 → R16 → QF → SF → Final) for each simulation, using
162	    the Dixon-Coles model for regulation and scaled-λ extra time.
163	    """
164	
165	    def __init__(
166	        self,
167	        abilities: TeamAbilities,
168	        config: SimulationConfig,
169	        poisson_config: PoissonConfig | None = None,
170	    ) -> None:
171	        self._abilities = abilities
172	        self._config = config
173	        self._pcfg = poisson_config or PoissonConfig()
174	
175	    def simulate(
176	        self,
177	        standings: dict[str, list[dict[str, Any]]],
178	        n_simulations: int | None = None,
179	    ) -> dict[int, RoundResult]:
180	        """Run *n_simulations* full knockouts; return per-round advancement counts."""
181	        n = n_simulations or self._config.n_simulations
182	        ties = resolve_r32(standings)
183	        all_teams = [t for pair in ties for t in pair]
184	        rounds: dict[int, RoundResult] = {}
185	        for i in range(n):
186	            rng = np.random.default_rng(self._config.random_seed + i)
187	            _simulate_once(ties, all_teams, rounds, self._make_resolver(rng, i))
188	        logger.info("Completed %d knockout simulations", n)
189	        return rounds
190	
191	    def _make_resolver(
192	        self,
193	        rng: np.random.Generator,
194	        sim_idx: int,
195	    ) -> Callable[[str, str, int], str]:
196	        """Return a per-match resolver bound to this simulation's RNG."""
197	        sampler = _make_sampler(self._abilities, self._pcfg, rng)
198	        def _resolve(home: str, away: str, match_idx: int) -> str:
199	            seed = self._config.random_seed + sim_idx * 1000 + match_idx
200	            return resolve_tie(
201	                home, away, sampler=sampler,
202	                extra_time_factor=self._config.extra_time_factor,
203	                seed=seed, abilities=self._abilities,
204	                poisson_config=self._pcfg, rng=rng,
205	            )
206	        return _resolve
