171	    def test_when_teams_equal_on_points_then_goal_difference_breaks_tie(self):
172	        """
173	        3-team group: A1 and A2 both have 4 pts but A1 has better goal difference.
174	        A1 should rank above A2.
175	
176	        Fixtures (group G2):
177	          A1 vs A2: draw 1-1    → A1: 1pt,  GF=1, GA=1
178	          A1 vs A3: A1 wins 3-0 → A1: +3pt, GF=3, GA=0
179	          A2 vs A3: A2 wins 1-0 → A2: +3pt, GF=1, GA=0
180	
181	        A1 total: 4pts, GF=4, GA=1, GD=+3
182	        A2 total: 4pts, GF=2, GA=1, GD=+1
183	        A3 total: 0pts
184	        """
185	        played = [
186	            LiveMatch("G2", "A1", "A2", 1, 1),
187	            LiveMatch("G2", "A1", "A3", 3, 0),
188	            LiveMatch("G2", "A2", "A3", 1, 0),
189	        ]
190	        standings, _ = _run(played=played)
191	        pos = {e["team"]["name"]: e["position"] for e in standings["G2"]}
192	        assert pos["A1"] < pos["A2"], (
193	            f"A1 (GD=+3) must rank above A2 (GD=+1) when both have 4 pts; got {pos}"
194	        )
