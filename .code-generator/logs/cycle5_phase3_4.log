51	def _build_round_slots(matchups: list[Matchup]) -> dict[int, list[tuple[str, str]]]:
52	    """Return a mapping of round index -> list of (home, away) pairs.
53	
54	    Round 0 contains the seed matchups from *matchups*.  Subsequent rounds are
55	    placeholder pairs ("TBD", "TBD") whose count halves each time, mirroring
56	    the single-elimination structure.
57	
58	    Args:
59	        matchups: First-round matchup definitions from :class:`BracketConfig`.
60	
61	    Returns:
62	        Dict mapping round index to a list of (home, away) tuples.
63	    """
64	    slots: dict[int, list[tuple[str, str]]] = {}
65	    current_pairs: list[tuple[str, str]] = [(m.home, m.away) for m in matchups]
66	    rnd = 0
67	    while current_pairs:
68	        slots[rnd] = current_pairs
69	        next_count = len(current_pairs) // 2
70	        current_pairs = [("TBD", "TBD")] * next_count
71	        rnd += 1
72	    return slots
73	
