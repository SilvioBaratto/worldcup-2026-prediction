136	class LiveForecaster:
137	    """Orchestrates N seeded Monte-Carlo WC2026 tournament simulations.
138	
139	    One child ``numpy.random.Generator`` is derived per iteration from the
140	    master seed via ``numpy.random.SeedSequence.spawn`` so that:
141	    - two calls with the same master seed produce bit-identical title odds;
142	    - draws within each tournament advance a **single** RNG, eliminating the
143	      intra-tournament correlation caused by re-seeding per match.
144	    """
145	
146	    def __init__(
147	        self,
148	        group_simulator: _GroupSimFn,
149	        knockout_simulator: _KnockoutSimFn,
150	    ) -> None:
151	        self._group_sim = group_simulator
152	        self._knockout_sim = knockout_simulator
153	
154	    def run(
155	        self,
156	        state: TournamentState,
157	        abilities: TeamAbilities,
158	        n_simulations: int,
159	        seed: int,
160	    ) -> ForecastResult:
161	        """Run *n_simulations* tournaments and return aggregated probabilities."""
162	        all_teams = _extract_all_teams(state)
163	        champion_counts: dict[str, int] = {t: 0 for t in all_teams}
164	        round_counts: dict[str, dict[str, int]] = {}
165	        child_seeds = np.random.SeedSequence(seed).spawn(n_simulations)
166	        for child_seed in child_seeds:
167	            rng = np.random.default_rng(child_seed)
168	            self._run_one(state, abilities, rng, champion_counts, round_counts)
169	        return self._to_result(champion_counts, round_counts, n_simulations)
170	
171	    def _run_one(
172	        self,
173	        state: TournamentState,
174	        abilities: TeamAbilities,
175	        rng: np.random.Generator,
176	        champion_counts: dict[str, int],
177	        round_counts: dict[str, dict[str, int]],
178	    ) -> None:
179	        qualified = self._group_sim(state, abilities, rng)
180	        result = self._knockout_sim(qualified, abilities, rng)
181	        champion_counts[result["champion"]] += 1
182	        _accumulate_rounds(round_counts, result.get("rounds", {}))
183	
184	    def _to_result(
