109	# Helpers
110	# ---------------------------------------------------------------------------
111	
112	
113	def _make_state() -> TournamentState:
114	    """Minimal TournamentState with all fixtures unplayed."""
115	    return TournamentState(
116	        groups=_GROUPS,
117	        played_results=[],
118	        remaining_fixtures=[],
119	    )
120	
121	
122	def _make_abilities() -> TeamAbilities:
123	    """Uniform TeamAbilities — every team rated equally."""
124	    return TeamAbilities(abilities={t: 1.0 for t in _ALL_TEAMS})
125	
126	
127	def _make_forecaster(*, stochastic: bool = False) -> LiveForecaster:
128	    knockout_sim = _stochastic_knockout_sim if stochastic else _fixed_knockout_sim
129	    return LiveForecaster(
130	        group_simulator=_fixed_group_sim,
131	        knockout_simulator=knockout_sim,
132	    )
133	
134	
135	def _run_forecast(
136	    n: int = 20,
137	    seed: int = 42,
138	    *,
139	    stochastic: bool = False,
140	) -> ForecastResult:
141	    return _make_forecaster(stochastic=stochastic).run(
142	        state=_make_state(),
143	        abilities=_make_abilities(),
144	        n_simulations=n,
145	        seed=seed,
146	    )
