2	Source-blind example tests for simulation/live_forecast.py — Issue #19.
3	
4	Derived from acceptance criteria only; no implementation source was read.
5	All tests use stub group-stage and knockout simulators: self-contained, fast,
6	network-free, and completely deterministic.
7	
8	Assumptions recorded here (chosen per criterion text, not from source):
9	- The main orchestrator class is ``LiveForecaster``, importable from
10	  ``worldcup_playoff.simulation.live_forecast``.
11	- ``LiveForecaster.__init__`` accepts ``group_simulator`` and
12	  ``knockout_simulator`` callables for dependency injection (criterion 1:
13	  "group sim from #17 + knockout from #18").
14	- ``LiveForecaster.run(state, abilities, n_simulations, seed)`` returns a
15	  ``ForecastResult`` value object.
16	- ``TournamentState(groups, played_results, remaining_fixtures)`` represents
17	  the current tournament state (criterion 1: "ingest TournamentState").
18	- ``TeamAbilities(abilities)`` wraps per-team numeric abilities (criterion 1:
19	  "fit/accept TeamAbilities once").
20	- ``ForecastResult.champion_probabilities`` is ``dict[str, float]``.
21	- ``ForecastResult.round_probabilities`` is ``dict[str, dict[str, float]]``.
22	- Sub-simulators receive ``(state_or_qualified, abilities, rng)`` where ``rng``
23	  is a seeded random-number source (numpy Generator or stdlib random.Random).
24	"""
25	from __future__ import annotations
26	
27	import math
28	
29	import pytest
30	from hypothesis import given, settings, strategies as st
31	
32	from worldcup_playoff.simulation.live_forecast import (
33	    ForecastResult,
34	    LiveForecaster,
35	    TeamAbilities,
36	    TournamentState,
37	)
38	
39	# ---------------------------------------------------------------------------
40	# Test constants — 48 teams in 12 groups of 4 (WC2026 structure)
41	# ---------------------------------------------------------------------------
42	
43	_NUM_GROUPS = 12
44	_TEAMS_PER_GROUP = 4
45	_GROUPS: dict[str, list[str]] = {
46	    chr(ord("A") + g): [
47	        f"Team{chr(ord('A') + g)}{t + 1}" for t in range(_TEAMS_PER_GROUP)
48	    ]
49	    for g in range(_NUM_GROUPS)
50	}
51	_ALL_TEAMS: list[str] = [t for group_teams in _GROUPS.values() for t in group_teams]
52	
53	assert len(_ALL_TEAMS) == 48, "Test setup requires exactly 48 teams"
54	
55	# ---------------------------------------------------------------------------
56	# Stub simulators
57	# The deterministic variant never calls rng so structural/coverage tests pass
58	# regardless of the rng object type the implementation provides.
59	# The stochastic variant uses rng.choice() (supported by both
60	# numpy.random.Generator and stdlib random.Random) to exercise the seeded
61	# sub-seed derivation path.
62	# ---------------------------------------------------------------------------
63	
64	_QUALIFIED_32: list[str] = _ALL_TEAMS[:32]
65	
66	
67	def _fixed_group_sim(
68	    state: TournamentState, abilities: TeamAbilities, rng
69	) -> list[str]:
70	    """Deterministic: always qualifies the first 32 teams."""
71	    return _QUALIFIED_32
72	
73	
74	def _fixed_knockout_sim(
75	    qualified: list[str], abilities: TeamAbilities, rng
76	) -> dict:
77	    """Deterministic: always crowns qualified[0] as champion."""
78	    return {
79	        "champion": qualified[0],
80	        "rounds": {
81	            "round_of_32": {t: 1 for t in qualified},
82	            "round_of_16": {t: 1 for t in qualified[:16]},
83	            "quarter_finals": {t: 1 for t in qualified[:8]},
84	            "semi_finals": {t: 1 for t in qualified[:4]},
85	            "final": {t: 1 for t in qualified[:2]},
86	        },
87	    }
88	
89	
90	def _stochastic_knockout_sim(
91	    qualified: list[str], abilities: TeamAbilities, rng
92	) -> dict:
93	    """
94	    Stochastic: picks a random champion via rng.choice().
95	    Handles numpy.random.Generator, stdlib random.Random, and int sub-seeds.
96	    """
97	    if isinstance(rng, int):
98	        import random as _random
99	
100	        _local = _random.Random(rng)
101	        champion: str = _local.choice(qualified)
102	    else:
103	        # Both numpy Generator and stdlib random.Random expose .choice(sequence).
104	        champion = str(rng.choice(qualified))
105	    return {"champion": champion, "rounds": {}}
106	
107	
