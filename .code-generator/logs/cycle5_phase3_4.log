232	
233	class TestSeedReproducibility:
234	    def test_when_same_seed_used_twice_then_champion_probabilities_are_identical(
235	        self,
236	    ) -> None:
237	        """Same master seed → same per-iteration sub-seeds → same champion counts."""
238	        result_a = _run_forecast(n=50, seed=42, stochastic=True)
239	        result_b = _run_forecast(n=50, seed=42, stochastic=True)
240	        assert result_a.champion_probabilities == result_b.champion_probabilities
241	
242	    def test_when_same_seed_used_twice_then_round_probabilities_are_identical(
243	        self,
244	    ) -> None:
245	        result_a = _run_forecast(n=50, seed=99, stochastic=True)
246	        result_b = _run_forecast(n=50, seed=99, stochastic=True)
247	        assert result_a.round_probabilities == result_b.round_probabilities
248	
249	
250	# ===========================================================================
251	# Criterion 1 — orchestration: TeamAbilities accepted directly + N iterations
252	# ===========================================================================
253	
254	
255	class TestOrchestration:
256	    def test_when_precomputed_abilities_are_passed_then_forecast_result_is_returned(
257	        self,
258	    ) -> None:
259	        """Criterion 1 'accept' path: pre-fitted TeamAbilities can be passed to run()."""
260	        forecaster = _make_forecaster()
261	        result = forecaster.run(
262	            state=_make_state(),
263	            abilities=_make_abilities(),
264	            n_simulations=5,
265	            seed=0,
266	        )
267	        assert isinstance(result, ForecastResult)
268	
269	    def test_when_n_simulations_is_10_then_champion_probability_sums_imply_10_iterations(
270	        self,
271	    ) -> None:
272	        """One champion per simulation → total_prob * n_simulations == n_simulations."""
273	        n = 10
274	        result = _run_forecast(n=n, stochastic=True, seed=0)
275	        total = sum(result.champion_probabilities.values())
276	        # total == 1.0 only if exactly n champions were accumulated and divided by n
277	        assert math.isclose(total, 1.0, abs_tol=1e-9)
278	
279	    def test_when_n_is_varied_then_champion_probabilities_always_cover_all_teams(
280	        self,
281	    ) -> None:
282	        """All 48 teams are initialised to 0.0 before accumulation regardless of n."""
283	        for n in (1, 5, 100):
284	            result = _run_forecast(n=n, stochastic=True, seed=7)
285	            assert len(result.champion_probabilities) == 48, (
286	                f"Expected 48 teams with n={n}, got {len(result.champion_probabilities)}"
287	            )
288	
289	
290	# ===========================================================================
291	# Property-based tests (Hypothesis)
292	# Invariants derived from criteria — no implementation source read.
293	# ===========================================================================
294	
295	
296	class TestProperties:
297	    @given(st.integers(min_value=0, max_value=2**31 - 1))
298	    @settings(max_examples=8)
299	    def test_when_same_seed_used_twice_then_identical_champion_probabilities_are_returned(
300	        self, seed: int
301	    ) -> None:
302	        """
303	        Idempotence / determinism invariant (criterion 7: 'seed reproducibility'):
304	        same master seed always yields bit-identical champion probabilities,
305	        for any valid non-negative integer seed.
306	        """
307	        a = _run_forecast(n=15, seed=seed, stochastic=True)
308	        b = _run_forecast(n=15, seed=seed, stochastic=True)
309	        assert a.champion_probabilities == b.champion_probabilities
310	
311	    @given(st.integers(min_value=1, max_value=30))
312	    @settings(max_examples=8)
313	    def test_when_any_positive_n_is_used_then_champion_probabilities_sum_to_one(
314	        self, n: int
315	    ) -> None:
316	        """
317	        Sum invariant (criterion 7: 'probability sanity'):
318	        champion probabilities always sum to exactly 1.0 for any n_simulations >= 1.
319	        """
320	        result = _run_forecast(n=n, seed=7, stochastic=True)
321	        total = sum(result.champion_probabilities.values())
322	        assert math.isclose(total, 1.0, abs_tol=1e-9)
323	
324	    @given(st.integers(min_value=1, max_value=20))
325	    @settings(max_examples=8)
326	    def test_when_any_positive_n_is_used_then_all_48_teams_are_present(
327	        self, n: int
328	    ) -> None:
329	        """
330	        Coverage invariant (criterion 7: '48-team coverage'):
331	        all 48 teams appear in champion_probabilities for any n_simulations >= 1,
332	        even if some teams have probability 0.0.
333	        """
334	        result = _run_forecast(n=n, seed=3)
335	        assert len(result.champion_probabilities) == 48
