2026-06-24 04:54:02,885 DEBUG msg #329: UserMessage tool_result(toolu_01TrCt7mcPYQMb9mcexssq9s): 1	"""Model evaluation and comparison.
2	
3	Public API
4	----------
5	Pure metric functions (source-blind, no sklearn dependency):
6	  rank_probability_score  — ordered 3-class RPS (primary)
7	  multiclass_log_loss     — mean cross-entropy
8	  brier_score             — mean multi-class Brier score
9	
10	Orchestration:
11	  backtest_hybrid         — time-aware WC backtest vs bookmaker + legacy baselines
12	
13	Legacy (kept for pipeline compatibility):
14	  ModelEvaluator          — confusion matrix + classification report
15	  plot_roc_curves         — ROC curve visualisation
16	"""
17	
18	from __future__ import annotations
19	
20	import logging
21	from pathlib import Path
22	from typing import Any
23	
24	import numpy as np
25	import pandas as pd
26	from sklearn.metrics import (
27	    RocCurveDisplay,
28	    classification_report,
29	    confusion_matrix,
30	)
31	
32	logger = logging.getLogger(__name__)
33	
34	# ── Constants ────────────────────────────────────────────────────────────────
35	
36	_EPS: float = 1e-15
37	_DEFAULT_WC_YEARS: list[int] = [2014, 2018, 2022]
38	_META_COLS: frozenset[str] = frozenset(
39	    {"date", "home_team", "away_team", "tournament", "outcome"}
40	)
41	
42	# ── Pure metric functions ────────────────────────────────────────────────────
43	
44	
45	def rank_probability_score(y_true: np.ndarray, y_pred: np.ndarray) -> float:
46	    """Mean RPS for ordered 3-class (Win/Draw/Loss) predictions.
47	
48	    RPS_i = (1/(J-1)) * Σ_{k=0}^{J-2} (CDF_pred_{i,k} − CDF_obs_{i,k})²
49	    averaged over N matches (J=3 → divides by 2).
50	    """
51	    yt = np.asarray(y_true)
52	    yp = np.asarray(y_pred, dtype=float)
53	    cdf_pred = np.cumsum(yp, axis=1)[:, :-1]          # (N, J-1)
54	    cutpoints = np.arange(yp.shape[1] - 1)            # [0, 1]
55	    cdf_obs = (yt[:, np.newaxis] <= cutpoints).astype(float)
56	    return float(np.mean(np.mean((cdf_pred - cdf_obs) ** 2, axis=1)))
57	
58	
59	def multiclass_log_loss(y_true: np.ndarray, y_pred: np.ndarray) -> float:
60	    """Mean cross-entropy loss; clips probabilities to avoid log(0)."""
61	    yt = np.asarray(y_true)
62	    yp = np.clip(np.asarray(y_pred, dtype=float), _EPS, 1.0)
63	    return float(-np.mean(np.log(yp[np.arange(len(yt)), yt])))
64	
65	
66	def brier_score(y_true: np.ndarray, y_pred: np.ndarray) -> float:
67	    """Mean multi-class Brier score (mean squared error in probability space)."""
68	    yt = np.asarray(y_true)
69	    yp = np.asarray(y_pred, dtype=float)
70	    one_hot = np.eye(yp.shape[1])[yt]
71	    return float(np.mean(np.sum((yp - one_hot) ** 2, axis=1)))
72	
73	
74	# ── Backtest helpers ─────────────────────────────────────────────────────────
75	
76	
77	def _feature_cols(df: pd.DataFrame) -> list[str]:
78	    return [c for c in df.columns if c not in _META_COLS]
79	
80	
81	def _slice_year(df: pd.DataFrame, year: int) -> pd.DataFrame:
82	    return df[pd.to_datetime(df["date"]).dt.year == year].reset_index(drop=True)
83	
84	
85	def _pre_year(df: pd.DataFrame, year: int) -> pd.DataFrame:
86	    return df[pd.to_datetime(df["date"]).dt.year < year].reset_index(drop=True)
87	
88	
89	def _bookmaker_rps(year_matches: pd.DataFrame, odds: pd.DataFrame) -> float | None:
90	    """Merge bookmaker odds onto year matches and return mean RPS; None if no overlap."""
91	    key = ["date", "home_team", "away_team"]
92	    merged = year_matches[key + ["outcome"]].merge(
93	        odds[key + ["p_win", "p_draw", "p_loss"]], on=key, how="inner"
94	    )
95	    if merged.empty:
96	        return None
97	    return rank_probability_score(
98	        merged["outcome"].to_numpy(),
99	        merged[["p_win", "p_draw", "p_loss"]].to_numpy(),
100	    )
101	
102	
103	def _build_row(
104	    year_matches: pd.DataFrame,
105	    hybrid: Any,
106	    legacy: Any,
107	    feat_cols: list[str],
108	    odds: pd.DataFrame | None,
109	) -> dict[str, Any]:
110	    X = year_matches[feat_cols].to_numpy()
111	    y_true = year_matches["outcome"].to_numpy()
112	    row: dict[str, Any] = {
113	        "rps_hybrid": rank_probability_score(y_true, hybrid.predict_proba(X)),
114	        "rps_legacy": rank_probability_score(y_true, legacy.predict_proba(X)),
115	    }
116	    if odds is not None:
117	        bk = _bookmaker_rps(year_matches, odds)
118	        if bk is not None:
119	            row["rps_bookmaker"] = bk
120	    return row
121	
122	
123	def backtest_hybrid(
124	    matches: pd.DataFrame,
125	    hybrid: Any,
126	    legacy: Any,
127	    odds: pd.DataFrame | None = None,
128	    years: list[int] | None = None,
129	) -> pd.DataFrame:
130	    """Time-aware WC backtest: train on pre-year data, evaluate on WC year.
131	
132	    Parameters
133	    ----------
134	    matches:  DataFrame with 'date', 'outcome', and feature columns.
135	    hybrid:   Model with fit(X, y) and predict_proba(X) → (N, 3).
136	    legacy:   Same protocol as hybrid (used as second baseline).
137	    odds:     Optional bookmaker odds with 'date', 'home_team', 'away_team',
138	              'p_win', 'p_draw', 'p_loss'. Skipped when None.
139	    years:    WC years to backtest (default [2014, 2018, 2022]).
140	
141	    Returns
142	    -------
143	    DataFrame indexed by year with columns rps_hybrid, rps_legacy, and
144	    (when odds are not None) rps_bookmaker.
145	    """
146	    eval_years = years if years is not None else _DEFAULT_WC_YEARS
147	    feat_cols = _feature_cols(matches)
148	    rows: dict[int, dict[str, Any]] = {}
149	    for year in eval_years:
150	        year_matches = _slice_year(matches, year)
151	        if year_matches.empty:
152	            continue
153	        train = _pre_year(matches, year)
154	        if not train.empty:
155	            X_tr = train[feat_cols].to_numpy()
156	            y_tr = train["outcome"].to_numpy()
157	            hybrid.fit(X_tr, y_tr)
158	            legacy.fit(X_tr, y_tr)
159	        rows[year] = _build_row(year_matches, hybrid, legacy, feat_cols, odds)
160	    result = pd.DataFrame.from_dict(rows, orient="index")
161	    result.index.name = "year"
162	    return result
163	
164	
165	class ModelEvaluator:
166	    """Evaluates classifier performance."""
167	
168	    @staticmethod
169	    def evaluate(
170	        classifier: Any,
171	        X_test: np.ndarray,
172	        y_test: np.ndarray,
173	    ) -> dict[str, Any]:
174	        """Return confusion matrix and classification report as a dict."""
175	        y_pred = classifier.predict(X_test)
176	        return {
177	            "confusion_matrix": confusion_matrix(y_test, y_pred),
178	            "classification_report": classification_report(
179	                y_test, y_pred, output_dict=True
180	            ),
181	        }
182	
183	    @staticmethod
184	    def plot_roc_curves(
185	        classifiers: dict[str, Any],
186	        X_test: np.ndarray,
187	        y_test: np.ndarray,
188	        output_path: Path | None = None,
189	    ) -> None:
190	        """Plot ROC curves for multiple classifiers."""
191	        import matplotlib.pyplot as plt
192	
193	        fig, ax = plt.subplots(figsize=(10, 8))
194	        linestyles = ["-", ":", "--", "-.", (0, (3, 1, 1, 1))]
195	
196	        for i, (name, clf) in enumerate(classifiers.items()):
197	            RocCurveDisplay.from_estimator(
198	                clf, X_test, y_test,
199	                ax=ax,
200	                linewidth=3,
201	                linestyle=linestyles[i % len(linestyles)],
202	                name=name,
203	            )
204	
205	        ax.tick_params(axis="both", labelsize=16)
206	        ax.set_xlabel("False Positive Rate", fontsize=18)
207	        ax.set_ylabel("True Positive Rate", fontsize=18)
208	        ax.legend(fontsize=14)
209	
210	        if output_path:
211	            output_path.parent.mkdir(parents=True, exist_ok=True)
212	            fig.savefig(output_path, bbox_inches="tight")
213	            logger.info("ROC curve saved to %s", output_path)
214	        plt.close(fig)
215	
