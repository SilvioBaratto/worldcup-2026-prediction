2	
3	Resolves the R32 bracket from group standings, then folds the tree
4	(R32 → R16 → QF → SF → Final) via Monte Carlo sampling:
5	  regulation → extra time (λ × extra_time_factor) → penalty coin-flip.
6	
7	All knockout matches are treated as neutral-venue fixtures.
8	"""
9	from __future__ import annotations
10	
11	import logging
12	from typing import Any, Callable
13	
14	import numpy as np
15	
16	from worldcup_playoff.config import PoissonConfig, SimulationConfig
17	from worldcup_playoff.data.wc2026_bracket import R32_SLOTS, resolve_r32
18	from worldcup_playoff.simulation.poisson import (
19	    TeamAbilities,
20	    lambdas,
21	    score_matrix,
22	)
23	from worldcup_playoff.simulation.tournament import RoundResult
24	
25	logger = logging.getLogger(__name__)
26	
27	# Re-export for consumers who import from this module.
28	__all__ = [
29	    "KnockoutSimulator",
30	    "R32_SLOTS",
31	    "resolve_r32",
32	    "resolve_tie",
33	]
34	
35	# Type alias for a scoreline sampler callable.
36	_Sampler = Callable[[str, str], tuple[int, int]]
37	
38	
39	# ---------------------------------------------------------------------------
40	# Pure helpers (module-level, ≤10 lines each)
41	# ---------------------------------------------------------------------------
42	
43	
44	def _draw_from_matrix(mat: np.ndarray, rng: np.random.Generator) -> tuple[int, int]:
45	    """Draw one (home_goals, away_goals) pair from a normalised score-matrix pmf."""
46	    g = mat.shape[0]
47	    idx = int(rng.choice(g * g, p=mat.ravel()))
48	    return idx // g, idx % g
49	
50	
51	def _penalty_flip(home: str, away: str, seed: int) -> str:
52	    """Return the penalty winner via a seeded coin-flip (0 → home, 1 → away)."""
53	    rng = np.random.default_rng(seed)
54	    return home if rng.integers(2) == 0 else away
55	
56	
57	def _et_goals(
58	    home: str,
59	    away: str,
60	    sampler: _Sampler,
61	    extra_time_factor: float,
62	    abilities: TeamAbilities | None,
63	    poisson_config: PoissonConfig | None,
64	    rng: np.random.Generator | None,
65	) -> tuple[int, int]:
66	    """Extra-time goals: scaled Poisson when abilities+rng available, else stub sampler."""
67	    if abilities is None or rng is None:
68	        return sampler(home, away)
69	    cfg = poisson_config or PoissonConfig()
70	    lh, la = lambdas(abilities, home, away, neutral=True)
71	    mat = score_matrix(lh * extra_time_factor, la * extra_time_factor,
72	                       rho=abilities.rho, max_goals=cfg.max_goals)
73	    return _draw_from_matrix(mat, rng)
74	
75	
76	def _record_round(
77	    rounds: dict[int, RoundResult],
78	    round_num: int,
79	    all_teams: list[str],
80	    winners: list[str],
81	) -> None:
82	    """Initialise (first call) and increment advancement counts for *round_num*."""
83	    if round_num not in rounds:
84	        rounds[round_num] = RoundResult(counts={t: 0 for t in all_teams})
85	    rounds[round_num].n_simulations += 1
86	    for w in winners:
87	        rounds[round_num].counts[w] += 1
88	
89	
90	def _make_sampler(
91	    abilities: TeamAbilities,
92	    config: PoissonConfig,
93	    rng: np.random.Generator,
94	) -> _Sampler:
95	    """Return a regulation-time scoreline sampler bound to *abilities* and *rng*."""
96	    def _sample(home: str, away: str) -> tuple[int, int]:
97	        lh, la = lambdas(abilities, home, away, neutral=True)
98	        mat = score_matrix(lh, la, rho=abilities.rho, max_goals=config.max_goals)
99	        return _draw_from_matrix(mat, rng)
100	    return _sample
101	
102	
103	def _simulate_once(
104	    ties: list[tuple[str, str]],
105	    all_teams: list[str],
106	    rounds: dict[int, RoundResult],
107	    resolver: Callable[[str, str, int], str],
108	) -> str:
109	    """Play one full single-elimination bracket; mutate *rounds*; return champion."""
110	    current, round_num, mc = ties, 0, 0
111	    while True:
112	        winners = [resolver(h, a, mc + i) for i, (h, a) in enumerate(current)]
113	        _record_round(rounds, round_num, all_teams, winners)
114	        mc += len(current)
115	        if len(winners) == 1:
116	            return winners[0]
117	        current, round_num = list(zip(winners[::2], winners[1::2])), round_num + 1
118	
119	
120	# ---------------------------------------------------------------------------
121	# Public: single-tie resolver
122	# ---------------------------------------------------------------------------
123	
124	
125	def resolve_tie(
126	    home: str,
127	    away: str,
128	    sampler: _Sampler,
129	    extra_time_factor: float,
130	    seed: int,
131	    abilities: TeamAbilities | None = None,
132	    poisson_config: PoissonConfig | None = None,
133	    rng: np.random.Generator | None = None,
134	) -> str:
135	    """Resolve one knockout tie: regulation → extra time → penalty coin-flip.
136	
137	    *sampler* is called for regulation.  Extra-time goals use the scaled Poisson
138	    model when *abilities* and *rng* are supplied; otherwise *sampler* is called
139	    a second time (convenient for stub-based tests).  ET goals are **added** to
140	    the full-time score.  The penalty coin-flip is seeded by *seed*.
141	    """
142	    h, a = sampler(home, away)
143	    if h != a:
144	        return home if h > a else away
145	    eth, eta = _et_goals(home, away, sampler, extra_time_factor, abilities, poisson_config, rng)
146	    h, a = h + eth, a + eta
147	    if h != a:
148	        return home if h > a else away
149	    return _penalty_flip(home, away, seed)
150	
151	
152	# ---------------------------------------------------------------------------
153	# KnockoutSimulator
154	# ---------------------------------------------------------------------------
155	
156	
157	class KnockoutSimulator:
158	    """Monte Carlo single-elimination knockout simulator for WC2026.
159	
160	    Seeds the R32 from live group standings via *resolve_r32*, then folds the
161	    bracket upward (R32 → R16 → QF → SF → Final) for each simulation, using
162	    the Dixon-Coles model for regulation and scaled-λ extra time.
163	    """
164	
165	    def __init__(
166	        self,
167	        abilities: TeamAbilities,
168	        config: SimulationConfig,
169	        poisson_config: PoissonConfig | None = None,
170	    ) -> None:
171	        self._abilities = abilities
172	        self._config = config
173	        self._pcfg = poisson_config or PoissonConfig()
174	
175	    def simulate(
176	        self,
177	        standings: dict[str, list[dict[str, Any]]],
178	        n_simulations: int | None = None,
179	    ) -> dict[int, RoundResult]:
180	        """Run *n_simulations* full knockouts; return per-round advancement counts."""
181	        n = n_simulations or self._config.n_simulations
182	        ties = resolve_r32(standings)
183	        all_teams = [t for pair in ties for t in pair]
184	        rounds: dict[int, RoundResult] = {}
185	        for i in range(n):
186	            rng = np.random.default_rng(self._config.random_seed + i)
187	            _simulate_once(ties, all_teams, rounds, self._make_resolver(rng, i))
188	        logger.info("Completed %d knockout simulations", n)
189	        return rounds
190	
191	    def _make_resolver(
192	        self,
193	        rng: np.random.Generator,
194	        sim_idx: int,
195	    ) -> Callable[[str, str, int], str]:
196	        """Return a per-match resolver bound to this simulation's RNG."""
197	        sampler = _make_sampler(self._abilities, self._pcfg, rng)
198	        def _resolve(home: str, away: str, match_idx: int) -> str:
199	            seed = self._config.random_seed + sim_idx * 1000 + match_idx
200	            return resolve_tie(
201	                home, away, sampler=sampler,
202	                extra_time_factor=self._config.extra_time_factor,
203	                seed=seed, abilities=self._abilities,
204	                poisson_config=self._pcfg, rng=rng,
205	            )
206	        return _resolve
