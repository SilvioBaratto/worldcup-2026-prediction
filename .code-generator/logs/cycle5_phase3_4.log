40	def _make_standings(groups_teams: dict[str, list[str]]) -> dict:
41	    """
42	    Build a minimal standings dict from {group_letter: [team1, team2, team3, team4]}
43	    where teams are already ordered 1st→4th with synthetic, consistent stats.
44	    """
45	    standings: dict = {}
46	    for group, teams in groups_teams.items():
47	        standings[group] = [
48	            {
49	                "position": rank,
50	                "team": {"name": team},
51	                "points": max(9 - (rank - 1) * 3, 0),
52	                "goalsFor": max(5 - rank, 0),
53	                "goalsAgainst": rank - 1,
54	                "goalDifference": max(6 - 2 * rank, -2),
55	            }
56	            for rank, team in enumerate(teams, start=1)
57	        ]
58	    return standings
59	
60	
61	# Synthetic WC2026 setup: 12 groups (A–L), 4 teams each.
62	# Teams named "{Group}{Position}" so assertions are self-documenting.
63	_GROUPS: dict[str, list[str]] = {
64	    g: [f"{g}1", f"{g}2", f"{g}3", f"{g}4"] for g in "ABCDEFGHIJKL"
65	}
66	_STANDINGS = _make_standings(_GROUPS)
67	
68	_FOURTH_PLACED = {f"{g}4" for g in "ABCDEFGHIJKL"}
69	_TOP_TWO = {f"{g}{p}" for g in "ABCDEFGHIJKL" for p in (1, 2)}
70	_THIRDS = {f"{g}3" for g in "ABCDEFGHIJKL"}  # 12 thirds; 8 qualify
71	
