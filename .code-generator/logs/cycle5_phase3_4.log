49	def _setup_logging(verbose: int) -> None:
50	    """Configure root logging level from the verbosity count flag."""
51	    level = {0: logging.WARNING, 1: logging.INFO}.get(verbose, logging.DEBUG)
52	    logging.basicConfig(
53	        level=level,
54	        format="%(levelname)-8s %(name)s: %(message)s",
55	    )
56	
57	
58	def _print_metrics(name: str, metrics: dict) -> None:  # type: ignore[type-arg]
59	    """Pretty-print classifier evaluation metrics as a Rich table.
60	
61	    Args:
62	        name: Classifier display name used as the table title.
63	        metrics: Dict returned by ``ModelEvaluator.evaluate`` — must contain
64	            ``"classification_report"`` with per-class dicts and ``"accuracy"``.
65	    """
66	    report = metrics["classification_report"]
67	    table = Table(title=f"[bold]{name}[/bold]", show_lines=True)
68	    table.add_column("Class", style="cyan")
69	    table.add_column("Precision", justify="right")
70	    table.add_column("Recall", justify="right")
71	    table.add_column("F1-Score", justify="right")
72	    table.add_column("Support", justify="right")
73	
74	    for label in ("0", "1"):
75	        if label in report:
76	            r = report[label]
77	            table.add_row(
78	                label,
79	                f"{r['precision']:.3f}",
80	                f"{r['recall']:.3f}",
81	                f"{r['f1-score']:.3f}",
82	                str(int(r["support"])),
83	            )
84	    table.add_row("accuracy", "", "", f"{report['accuracy']:.3f}", "", style="bold")
85	    console.print(table)
86	
87	
88	def _print_simulation_results(rounds: dict) -> None:  # type: ignore[type-arg]
89	    """Print simulation results as Rich tables, one per round.
90	
91	    Args:
92	        rounds: Mapping of round index to ``RoundResult`` from
93	            ``TournamentSimulator.simulate``.
94	    """
95	    round_names = {
96	        0: "Round of 32",
97	        1: "Round of 16",
98	        2: "Quarter-finals",
99	        3: "Semi-finals",
100	        4: "Final",
101	    }
102	
103	    for round_num, result in sorted(rounds.items()):
104	        probs = result.probabilities
105	        sorted_probs = sorted(
106	            ((team, p) for team, p in probs.items() if p > 0),
107	            key=lambda x: x[1],
108	            reverse=True,
109	        )
110	
111	        table = Table(
112	            title=f"[bold]{round_names.get(round_num, f'Round {round_num}')}[/bold]"
113	        )
114	        table.add_column("Team", style="cyan")
115	        table.add_column("Win Probability", justify="right")
116	
117	        for team, prob in sorted_probs:
118	            bar = "█" * int(prob * 40)
119	            table.add_row(team, f"{prob:6.1%} {bar}")
120	
121	        console.print(table)
122	        console.print()
123	
124	
125	def _project_root(config: Path) -> Path:
126	    """Derive project root from the config file path.
127	
128	    The default config lives at ``<root>/config/default.toml``, so the project
129	    root is two levels above the config file.  Using the *resolved* (absolute)
130	    path ensures the result is independent of the caller's working directory.
131	
132	    Args:
133	        config: Path to the pipeline config TOML (e.g. ``config/default.toml``).
134	
135	    Returns:
136	        Absolute path to the project root directory.
137	    """
138	    return config.resolve().parent.parent
139	
140	
141	_VALID_DATASETS = frozenset({"teams", "matches", "ranking", "players", "match_details"})
142	
143	
144	def _parse_season_range(seasons: str) -> tuple[int, int]:
145	    """Parse a ``'START-END'`` season range into ``(start_year, end_year)``.
146	
147	    Args:
148	        seasons: String of the form ``"2006-2026"``.
149	
150	    Returns:
151	        Tuple of ``(start_year, end_year)`` as integers.
152	
153	    Raises:
154	        ``typer.Exit(code=1)`` on malformed input.
155	    """
156	    parts = seasons.split("-")
157	    if len(parts) != 2:  # noqa: PLR2004
158	        console.print(
159	            f"[red]Invalid --seasons format '{seasons}'. "
160	            "Use 'START-END', e.g. '2006-2026'.[/red]"
161	        )
162	        raise typer.Exit(code=1)
163	    try:
164	        start, end = int(parts[0]), int(parts[1])
165	    except ValueError:
166	        console.print(f"[red]--seasons values must be integers, got '{seasons}'.[/red]")
167	        raise typer.Exit(code=1)
168	    if start > end:
169	        console.print(f"[red]Start year {start} must be <= end year {end}.[/red]")
170	        raise typer.Exit(code=1)
171	    return start, end
172	
173	
174	def _parse_only_filter(only: str | None) -> set[str] | None:
175	    """Parse a comma-separated ``--only`` filter into a set of dataset names.
176	
177	    Args:
178	        only: Comma-separated string such as ``"teams,matches"`` or ``None``.
179	
180	    Returns:
181	        Set of validated dataset names, or ``None`` if *only* was not supplied.
182	
183	    Raises:
184	        ``typer.Exit(code=1)`` if any name is not in ``_VALID_DATASETS``.
185	    """
186	    if only is None:
187	        return None
188	    names = {n.strip() for n in only.split(",") if n.strip()}
189	    unknown = names - _VALID_DATASETS
190	    if unknown:
191	        console.print(
192	            f"[red]Unknown dataset(s): {unknown}. "
193	            f"Valid: {sorted(_VALID_DATASETS)}[/red]"
194	        )
195	        raise typer.Exit(code=1)
196	    return names
197	
198	
199	def _should_run(name: str, only_set: set[str] | None, skip_details: bool) -> bool:
200	    """Return whether a dataset build stage should execute.
201	
202	    Args:
203	        name: Dataset name (e.g. ``"matches"`` or ``"match_details"``).
204	        only_set: Restrict to this set when not ``None``.
205	        skip_details: When ``True``, always skip ``match_details``.
206	
207	    Returns:
208	        ``True`` when the stage should run.
209	    """
210	    if name == "match_details" and skip_details:
211	        return False
212	    if only_set is not None and name not in only_set:
213	        return False
214	    return True
215	
216	
217	def _print_download_summary(results: dict[str, tuple[Path, int]]) -> None:
218	    """Print a Rich table summarising downloaded datasets.
219	
220	    Args:
221	        results: Mapping of ``{dataset_name: (output_path, row_count)}``.
222	    """
223	    table = Table(title="[bold]Download Summary[/bold]", show_lines=True)
224	    table.add_column("Dataset", style="cyan")
225	    table.add_column("Output Path")
226	    table.add_column("Rows", justify="right", style="green")
227	    for name, (path, rows) in results.items():
228	        table.add_row(name, str(path), f"{rows:,}")
229	    console.print(table)
