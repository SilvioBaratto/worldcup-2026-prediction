397	class TestDeterminism:
398	
399	    def test_when_same_seed_used_twice_then_identical_standings_are_produced(self):
400	        """Identical TournamentState + same seed must yield byte-for-byte identical output."""
401	        remaining = [
402	            GroupFixture("D1", "Alpha", "Beta"),
403	            GroupFixture("D1", "Gamma", "Delta"),
404	            GroupFixture("D1", "Alpha", "Gamma"),
405	            GroupFixture("D1", "Beta",  "Delta"),
406	            GroupFixture("D1", "Alpha", "Delta"),
407	            GroupFixture("D1", "Beta",  "Gamma"),
408	        ]
409	        result1, _ = _run(remaining=remaining, scorelines=((1, 0),), seed=42)
410	        result2, _ = _run(remaining=remaining, scorelines=((1, 0),), seed=42)
411	        assert result1 == result2, "Same seed + same state must produce identical standings"
412	
413	    def test_when_different_seeds_used_on_unbreakable_tie_then_outcomes_can_differ(self):
414	        """
415	        Different seeds applied to a coin-flip scenario must be able to produce
416	        different orderings — proving the seed actually drives the outcome.
417	        """
418	        played = [
419	            LiveMatch("D2", "Red",   "Blue",  1, 0),
420	            LiveMatch("D2", "Blue",  "Green", 1, 0),
421	            LiveMatch("D2", "Green", "Red",   1, 0),
422	        ]
423	        state = TournamentState(played_matches=played, remaining_group_fixtures=[])
424	        first_place_teams = set()
425	        for seed in range(20):
426	            spy = ScorelineSamplerSpy()
427	            rng = random.Random(seed)
428	            result = GroupStageSimulator(sampler=spy, rng=rng).simulate(state)
429	            first = next(e["team"]["name"] for e in result["D2"] if e["position"] == 1)
430	            first_place_teams.add(first)
431	
432	        assert len(first_place_teams) > 1, (
433	            "With 20 different seeds on an unbreakable 3-way tie, at least 2 distinct "
434	            "first-place teams must appear — otherwise the seed is not influencing the result"
435	        )
