257	    # --- Rung 5: Coin-flip with injected RNG ---
258	
259	    def test_when_all_tiebreakers_exhausted_then_injected_rng_produces_varying_outcomes(self):
260	        """
261	        A circular 3-team group (P→Q→Z→P, all 1-0) produces an unbreakable
262	        3-way tie on all statistical rungs. Coin-flip must use the injected RNG:
263	        across 30 different seeds at least two distinct top-team orderings must appear.
264	        """
265	        played = [
266	            LiveMatch("G5", "P", "Q", 1, 0),
267	            LiveMatch("G5", "Q", "Z", 1, 0),
268	            LiveMatch("G5", "Z", "P", 1, 0),
269	        ]
270	        state = TournamentState(played_matches=played, remaining_group_fixtures=[])
271	        orderings = set()
272	        for seed in range(30):
273	            spy = ScorelineSamplerSpy()
274	            rng = random.Random(seed)
275	            result = GroupStageSimulator(sampler=spy, rng=rng).simulate(state)
276	            top = tuple(
277	                e["team"]["name"]
278	                for e in sorted(result["G5"], key=lambda e: e["position"])[:2]
279	            )
280	            orderings.add(top)
281	
282	        assert len(orderings) > 1, (
283	            "With 30 seeds on an unbreakable 3-way tie, at least 2 distinct orderings "
284	            "must occur — if all seeds agree, the injected RNG is not being used"
285	        )
286	
287	    def test_when_same_injected_seed_but_different_global_random_state_then_result_is_identical(self):
288	        """
289	        The simulator must use ONLY the injected RNG, not the global random module.
290	        With the same injected seed but different global random seeds, results must agree.
291	        """
292	        played = [
293	            LiveMatch("G6", "T1", "T2", 1, 0),
294	            LiveMatch("G6", "T2", "T3", 1, 0),
295	            LiveMatch("G6", "T3", "T1", 1, 0),
296	        ]
297	        state = TournamentState(played_matches=played, remaining_group_fixtures=[])
298	
299	        def run_with_global_seed(global_seed: int, injected_seed: int):
300	            random.seed(global_seed)
301	            spy = ScorelineSamplerSpy()
302	            rng = random.Random(injected_seed)
303	            return GroupStageSimulator(sampler=spy, rng=rng).simulate(state)
304	
305	        result_a = run_with_global_seed(global_seed=1,   injected_seed=42)
306	        result_b = run_with_global_seed(global_seed=9999, injected_seed=42)
307	
308	        pos_a = {e["team"]["name"]: e["position"] for e in result_a["G6"]}
309	        pos_b = {e["team"]["name"]: e["position"] for e in result_b["G6"]}
310	        assert pos_a == pos_b, (
311	            "Changing the global random seed must not affect results when the injected "
312	            "RNG seed is held constant — the simulator must use only the injected RNG"
313	        )
