321	class TestOutputShape:
322	
323	    def test_when_simulation_runs_then_result_is_a_dict_keyed_by_group_label(self):
324	        """simulate() must return a dict; played group labels must be present as keys."""
325	        played = [LiveMatch("H1", "Spain", "Morocco", 2, 0)]
326	        standings, _ = _run(played=played)
327	        assert isinstance(standings, dict), "simulate() must return a dict"
328	        assert "H1" in standings
