2026-06-23 23:57:11,009 DEBUG msg #20: UserMessage tool_result(toolu_01R5AeDv9eG1kQegn8o5AK9D): 1	"""Dixon-Coles bivariate-Poisson estimator with exponential time-decay.
2	
3	Fits per-team attack/defence abilities (plus home advantage, rho, intercept) via
4	weighted MLE on martj42 match history, then provides a deterministic scoreline
5	sampler that draws from the τ-corrected joint Poisson pmf grid.
6	"""
7	from __future__ import annotations
8	
9	import logging
10	from dataclasses import dataclass
11	
12	import numpy as np
13	import pandas as pd
14	from scipy.optimize import minimize
15	from scipy.stats import poisson as sp_poisson
16	
17	from worldcup_playoff.config import PoissonConfig
18	
19	logger = logging.getLogger(__name__)
20	
21	
22	# ─────────────────────────────────────────────────────────────────────────────
23	# Value objects
24	# ─────────────────────────────────────────────────────────────────────────────
25	
26	
27	@dataclass(frozen=True)
28	class TeamAbilities:
29	    """Fitted per-team attack/defence abilities from the Dixon-Coles model."""
30	
31	    attack: dict[str, float]
32	    defence: dict[str, float]
33	    home_adv: float
34	    rho: float
35	    intercept: float
36	
37	
38	@dataclass(frozen=True)
39	class _PreparedData:
40	    teams: list[str]
41	    home_idx: np.ndarray
42	    away_idx: np.ndarray
43	    h_goals: np.ndarray
44	    a_goals: np.ndarray
45	    neutral_mask: np.ndarray
46	    weights: np.ndarray
47	
48	
49	# ─────────────────────────────────────────────────────────────────────────────
50	# Pure functions
51	# ─────────────────────────────────────────────────────────────────────────────
52	
53	
54	def dixon_coles_tau(h: int, a: int, lh: float, la: float, rho: float) -> float:
55	    """Dixon-Coles τ correction factor for low-score cells (h+a ≤ 1 or h==a==1)."""
56	    if h == 0 and a == 0:
57	        return 1.0 - lh * la * rho
58	    if h == 1 and a == 0:
59	        return 1.0 + la * rho
60	    if h == 0 and a == 1:
61	        return 1.0 + lh * rho
62	    if h == 1 and a == 1:
63	        return 1.0 - rho
64	    return 1.0
65	
66	
67	def decay_weight(age_days: float | np.ndarray, half_life_days: float) -> float | np.ndarray:
68	    """Exponential decay: weight = 0.5^(age_days / half_life_days)."""
69	    return 0.5 ** (age_days / half_life_days)
70	
71	
72	def lambdas(
73	    abilities: TeamAbilities,
74	    home: str,
75	    away: str,
76	    neutral: bool = False,
77	) -> tuple[float, float]:
78	    """Compute (λ_home, λ_away) expected goal rates for one match."""
79	    ha = 0.0 if neutral else abilities.home_adv
80	    lh = float(np.exp(abilities.intercept + abilities.attack[home] - abilities.defence[away] + ha))
81	    la = float(np.exp(abilities.intercept + abilities.attack[away] - abilities.defence[home]))
82	    return lh, la
83	
84	
85	def score_matrix(
86	    lh: float,
87	    la: float,
88	    rho: float = 0.0,
89	    max_goals: int = 10,
90	) -> np.ndarray:
91	    """Normalized (max_goals+1)×(max_goals+1) joint pmf grid with τ correction."""
92	    goals = np.arange(max_goals + 1)
93	    mat = np.outer(sp_poisson.pmf(goals, lh), sp_poisson.pmf(goals, la))
94	    _apply_tau_correction(mat, lh, la, rho, max_goals)
95	    return mat / mat.sum()  # type: ignore[no-any-return]
96	
97	
98	def _apply_tau_correction(
99	    mat: np.ndarray, lh: float, la: float, rho: float, max_goals: int
100	) -> None:
101	    """Apply τ correction in-place for the four low-score cells."""
102	    for h in range(min(2, max_goals + 1)):
103	        for a in range(min(2, max_goals + 1)):
104	            mat[h, a] *= dixon_coles_tau(h, a, lh, la, rho)
105	
106	
107	# ─────────────────────────────────────────────────────────────────────────────
108	# Preparation helpers (module-level to keep DixonColesEstimator small)
109	# ─────────────────────────────────────────────────────────────────────────────
110	
111	
112	def _filter_played(df: pd.DataFrame) -> pd.DataFrame:
113	    mask = ~df["HOME_GOALS"].isna() & ~df["AWAY_GOALS"].isna()
114	    played = df[mask].copy()
115	    played["_date"] = pd.to_datetime(played["DATE"])
116	    return played
117	
118	
119	def _compute_weights(played: pd.DataFrame, half_life_days: float) -> np.ndarray:
120	    ref = played["_date"].max()
121	    age = (ref - played["_date"]).dt.days.astype(float)
122	    return np.asarray(decay_weight(age.values, half_life_days))
123	
124	
125	def _build_team_index(played: pd.DataFrame) -> tuple[list[str], np.ndarray, np.ndarray]:
126	    teams = sorted(set(played["HOME_TEAM"]) | set(played["AWAY_TEAM"]))
127	    idx = {t: i for i, t in enumerate(teams)}
128	    return teams, played["HOME_TEAM"].map(idx).values, played["AWAY_TEAM"].map(idx).values
129	
130	
131	def _extract_neutral(played: pd.DataFrame) -> np.ndarray:
132	    if "NEUTRAL" in played.columns:
133	        return played["NEUTRAL"].values.astype(bool)  # type: ignore[no-any-return]
134	    return np.zeros(len(played), dtype=bool)
135	
136	
137	def _prepare(df: pd.DataFrame, half_life_days: float) -> _PreparedData:
138	    """Drop unplayed rows, compute decay weights, build team index."""
139	    played = _filter_played(df)
140	    weights = _compute_weights(played, half_life_days)
141	    teams, h_idx, a_idx = _build_team_index(played)
142	    hg = played["HOME_GOALS"].astype(int).values
143	    ag = played["AWAY_GOALS"].astype(int).values
144	    return _PreparedData(teams, h_idx, a_idx, hg, ag, _extract_neutral(played), weights)
145	
146	
147	# ─────────────────────────────────────────────────────────────────────────────
148	# Negative log-likelihood (module-level; passed to scipy.optimize.minimize)
149	# ─────────────────────────────────────────────────────────────────────────────
150	
151	
152	def _tau_vec(
153	    h: np.ndarray,
154	    a: np.ndarray,
155	    lh: np.ndarray,
156	    la: np.ndarray,
157	    rho: float,
158	) -> np.ndarray:
159	    """Vectorized τ corrections for arrays of match scores."""
160	    tau = np.ones(len(h))
161	    m00, m10, m01, m11 = (h == 0) & (a == 0), (h == 1) & (a == 0), (h == 0) & (a == 1), (h == 1) & (a == 1)
162	    tau[m00] = 1.0 - lh[m00] * la[m00] * rho
163	    tau[m10] = 1.0 + la[m10] * rho
164	    tau[m01] = 1.0 + lh[m01] * rho
165	    tau[m11] = 1.0 - rho
166	    return tau
167	
168	
169	def _nll(params: np.ndarray, data: _PreparedData) -> float:
170	    """Negative weighted DC log-likelihood; τ clipped to ε for numerical stability."""
171	    n = len(data.teams)
172	    atk, dfn = params[:n], params[n : 2 * n]
173	    home_adv, rho, intercept = params[2 * n], params[2 * n + 1], params[2 * n + 2]
174	    ha = np.where(data.neutral_mask, 0.0, home_adv)
175	    lh = np.exp(intercept + atk[data.home_idx] - dfn[data.away_idx] + ha)
176	    la = np.exp(intercept + atk[data.away_idx] - dfn[data.home_idx])
177	    tau = _tau_vec(data.h_goals, data.a_goals, lh, la, rho)
178	    ll = sp_poisson.logpmf(data.h_goals, lh) + sp_poisson.logpmf(data.a_goals, la)
179	    ll += np.log(np.maximum(tau, 1e-10))
180	    return float(-(data.weights * ll).sum())
181	
182	
183	def _normalize_attack(params: np.ndarray, n: int) -> np.ndarray:
184	    """Enforce mean-zero attack identifiability constraint."""
185	    mean_atk = float(np.mean(params[:n]))
186	    result = params.copy()
187	    result[:n] -= mean_atk
188	    result[2 * n + 2] += mean_atk  # compensate in intercept so rates are unchanged
189	    return result
190	
191	
192	# ─────────────────────────────────────────────────────────────────────────────
193	# Estimator
194	# ─────────────────────────────────────────────────────────────────────────────
195	
196	
197	class DixonColesEstimator:
198	    """Fits attack/defence abilities via weighted MLE (L-BFGS-B)."""
199	
200	    def __init__(self, config: PoissonConfig | None = None) -> None:
201	        self._cfg = config or PoissonConfig()
202	
203	    def fit(self, df: pd.DataFrame) -> TeamAbilities:
204	        """Return TeamAbilities fitted on played rows of *df*."""
205	        data = _prepare(df, self._cfg.half_life_days)
206	        n = len(data.teams)
207	        x0, bounds = self._initial_params(n)
208	        res = minimize(_nll, x0, args=(data,), method="L-BFGS-B", bounds=bounds,
209	                       options={"maxiter": self._cfg.optimizer_maxiter})
210	        return self._unpack(res.x, data.teams)
211	
212	    def _initial_params(self, n: int) -> tuple[np.ndarray, list[tuple[float | None, float | None]]]:
213	        x0 = np.zeros(2 * n + 3)
214	        x0[2 * n] = self._cfg.home_adv_init
215	        x0[2 * n + 1] = self._cfg.rho_init
216	        bounds = [(None, None)] * (2 * n) + [(None, None), (-0.99, 0.0), (None, None)]
217	        return x0, bounds
218	
219	    def _unpack(self, x: np.ndarray, teams: list[str]) -> TeamAbilities:
220	        n = len(teams)
221	        normed = _normalize_attack(x, n)
222	        atk = {t: float(normed[i]) for i, t in enumerate(teams)}
223	        dfn = {t: float(normed[n + i]) for i, t in enumerate(teams)}
224	        return TeamAbilities(atk, dfn, float(normed[2 * n]), float(normed[2 * n + 1]), float(normed[2 * n + 2]))
225	
226	
227	# ─────────────────────────────────────────────────────────────────────────────
228	# Scoreline sampler
229	# ─────────────────────────────────────────────────────────────────────────────
230	
231	
232	class ScorelineSampler:
233	    """Draws scorelines from the τ-corrected joint Poisson pmf."""
234	
235	    def __init__(self, abilities: TeamAbilities, config: PoissonConfig | None = None) -> None:
236	        self._abilities = abilities
237	        self._cfg = config or PoissonConfig()
238	
239	    def sample(
240	        self,
241	        home: str,
242	        away: str,
243	        neutral: bool = False,
244	        size: int = 1,
245	        random_state: int | None = None,
246	    ) -> np.ndarray:
247	        """Return int array of shape (size, 2): [home_goals, away_goals] per row."""
248	        seed = random_state if random_state is not None else self._cfg.random_seed
249	        rng = np.random.default_rng(seed)
250	        lh, la = lambdas(self._abilities, home, away, neutral=neutral)
251	        mat = score_matrix(lh, la, rho=self._abilities.rho, max_goals=self._cfg.max_goals)
252	        g = self._cfg.max_goals + 1
253	        choices = rng.choice(g * g, size=size, p=mat.ravel())
254	        return np.stack([choices // g, choices % g], axis=1).astype(int)
255	
256	
257	# ─────────────────────────────────────────────────────────────────────────────
258	# Factories
259	# ─────────────────────────────────────────────────────────────────────────────
260	
261	
262	def fit_dixon_coles(df: pd.DataFrame, config: PoissonConfig | None = None) -> TeamAbilities:
263	    """Fit and return Dixon-Coles abilities from a results DataFrame."""
264	    return DixonColesEstimator(config).fit(df)
265	
266	
267	def make_sampler(abilities: TeamAbilities, config: PoissonConfig | None = None) -> ScorelineSampler:
268	    """Create a ScorelineSampler from fitted abilities."""
269	    return ScorelineSampler(abilities, config)
270	
