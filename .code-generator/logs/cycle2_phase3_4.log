49	        ("Germany", "Argentina"),
50	        ("France", "Germany"),
51	        ("Argentina", "Brazil"),
52	        ("Brazil", "Germany"),
53	        ("France", "Argentina"),
54	        ("Germany", "Brazil"),
55	        ("Argentina", "France"),
56	        ("Brazil", "Argentina"),
57	        ("France", "Germany"),
58	        ("Germany", "France"),
59	        ("Argentina", "Brazil"),
60	    ]
61	
62	    for home, away in matchups:
63	        home_goals = int(rng.integers(0, 4))
64	        away_goals = int(rng.integers(0, 4))
65	        # Ensure no draws so HOME_WIN is meaningful
66	        if home_goals == away_goals:
67	            home_goals += 1
68	
69	        home_shots = home_goals * 5 + 7
70	        away_shots = away_goals * 5 + 7
71	        home_sot = max(home_goals + 2, home_shots // 3)
72	        away_sot = max(away_goals + 2, away_shots // 3)
73	
74	        rows.append(
75	            {
76	                "HOME_TEAM": home,
77	                "AWAY_TEAM": away,
78	                "GOALS_home": home_goals,
79	                "SHOTS_home": home_shots,
80	                "SHOTS_ON_TARGET_home": home_sot,
81	                "POSSESSION_home": 50.0 + rng.uniform(-5, 5),
82	                "PASS_PCT_home": 75.0 + rng.uniform(-5, 5),
83	                "GOALS_away": away_goals,
84	                "SHOTS_away": away_shots,
85	                "SHOTS_ON_TARGET_away": away_sot,
86	                "POSSESSION_away": 50.0 + rng.uniform(-5, 5),
87	                "PASS_PCT_away": 75.0 + rng.uniform(-5, 5),
88	                "HOME_WIN": int(home_goals > away_goals),
89	            }
90	        )
91	
92	    return pd.DataFrame(rows)
