2026-06-23 23:14:12,721 DEBUG msg #192: assistant (tool_use) tool_use(Write): {'file_path': '/Volumes/External SSD/worldcup-2026-prediction/worldcup_playoff/data/elo.py', 'content': '"""World Football Elo engine — chronological ratings from martj42 history.\n\nConsumes the DataFrame produced by ``Martj42Loader.load_results()``.  The module\nis I/O-free and network-free so tests can build DataFrames in-memory.\n\nDesign notes\n------------\n* ``elo_diff`` in ``MatchEloDiff`` is the raw ``home_elo − away_elo`` without the\n  ``home_advantage`` term.  The home-advantage shift is internal to the expectation\n  calculation so the emitted covariate is venue-agnostic and directly comparable\n  across neutral and non-neutral matches.\n* Same-day matches are sorted by ``(HOME_TEAM, AWAY_TEAM)`` for a deterministic\n  tiebreak that is invariant to input row order.  ``NaT`` dates (unparseable strings)\n  sort last by pandas convention.\n"""\n\nfrom __future__ import annotations\n\nimport logging\nfrom dataclasses import dataclass\nfrom typing import Iterable\n\nimport pandas as pd\n\nfrom worldcup_playoff.config import EloConfig\n\nlogger = logging.getLogger(__name__)\n\n\n# ---------------------------------------------------------------------------\n# Value objects\n# ---------------------------------------------------------------------------\n\n\n@dataclass(frozen=True)\nclass EloRating:\n    """Per-team, per-date Elo snapshot (post-match)."""\n\n    team: str\n    date: str\n    rating: float\n\n\n@dataclass(frozen=True)\nclass MatchEloDiff:\n    """Pre-match Elo state for a single fixture.\n\n    ``elo_diff = home_elo − away_elo`` is venue-agnostic (no home_advantage).\n    """\n\n    date: str\n    home_team: str\n    away_team: str\n    home_elo: float\n    away_elo: float\n    elo_diff: float\n    neutral: bool\n\n\n@dataclass(frozen=True)\nclass EloResult:\n    """Outcome of ``EloEngine.run``.\n\n    Attributes\n    ----------\n    history:\n        Ordered list of per-team, per-date rating snapshots.\n    match_diffs:\n        One entry per row in the input (including unplayed fixtures).\n    final_ratings:\n        Latest rating for every team that appeared in the input.\n    initial_rating:\n        The engine\'s default start rating — used by ``seed_wc2026`` for\n        teams absent from history.\n    """\n\n    history: list[EloRating]\n    match_diffs: list[MatchEloDiff]\n    final_ratings: dict[str, float]\n    initial_rating: float\n\n    def history_frame(self) -> pd.DataFrame:\n        """Return history as a tidy DataFrame with columns team/date/rating."""\n        if not self.history:\n            return pd.DataFrame(columns=["team", "date", "rating"])\n        return pd.DataFrame(\n            [{"team": r.team, "date": r.date, "rating": r.rating} for r in self.history]\n        )\n\n    def latest_ratings_frame(self) -> pd.DataFrame:\n        """Return final_ratings as a tidy DataFrame with columns team/rating."""\n        if not self.final_ratings:\n            return pd.DataFrame(columns=["team", "rating"])\n        return pd.DataFrame(\n            [{"team": t, "rating": r} for t, r in self.final_ratings.items()]\n        )\n\n\n# ---------------------------------------------------------------------------\n# Module-level pure math helpers (no instance state needed)\n# ---------------------------------------------------------------------------\n\n\ndef _we(dr: float) -> float:\n    """Win expectation from Elo difference *dr*."""\n    return 1.0 / (1.0 + 10.0 ** (-dr / 400.0))\n\n\ndef _g(margin: int) -> float:\n    """Goal-margin multiplier (World-Football-Elo convention)."""\n    if margin <= 1:\n        return 1.0\n    if margin == 2:\n        return 1.5\n    return (11 + margin) / 8.0\n\n\ndef _outcome(home_goals: int, away_goals: int) -> float:\n    """W value: 1.0 home win / 0.5 draw / 0.0 home loss."""\n    if home_goals > away_goals:\n        return 1.0\n    return 0.5 if home_goals == away_goals else 0.0\n\n\n# ---------------------------------------------------------------------------\n# Engine\n# ---------------------------------------------------------------------------\n\n\nclass EloEngine:\n    """Compute World Football Elo ratings chronologically from martj42 history."""\n\n    def __init__(self, config: EloConfig) -> None:\n        self._config = config\n\n    # --- public API ---\n\n    def run(self, df: pd.DataFrame) -> EloResult:\n        """Process *df* chronologically and return ratings + diffs.\n\n        Rows with ``<NA>`` goals emit a ``MatchEloDiff`` but do not change ratings.\n        """\n        sorted_df = self._sort(df)\n        ratings: dict[str, float] = {}\n        history: list[EloRating] = []\n        diffs: list[MatchEloDiff] = []\n        for _, row in sorted_df.iterrows():\n            self._process(row, ratings, history, diffs)\n        return EloResult(\n            history=history,\n            match_diffs=diffs,\n            final_ratings={t: float(r) for t, r in ratings.items()},\n            initial_rating=self._config.initial_rating,\n        )\n\n    # --- private helpers ---\n\n    def _sort(self, df: pd.DataFrame) -> pd.DataFrame:\n        """Sort by (date, HOME_TEAM, AWAY_TEAM) for deterministic processing."""\n        return (\n            df.assign(_d=pd.to_datetime(df["DATE"], errors="coerce"))\n            .sort_values(["_d", "HOME_TEAM", "AWAY_TEAM"], kind="stable")\n            .drop(columns=["_d"])\n            .reset_index(drop=True)\n        )\n\n    def _process(\n        self,\n        row: pd.Series,\n        ratings: dict[str, float],\n        history: list[EloRating],\n        diffs: list[MatchEloDiff],\n    ) -> None:\n        home, away = str(row["HOME_TEAM"]), str(row["AWAY_TEAM"])\n        date, neutral = str(row["DATE"]), bool(row["NEUTRAL"])\n        home_elo = ratings.get(home, self._config.initial_rating)\n        away_elo = ratings.get(away, self._config.initial_rating)\n        diffs.append(MatchEloDiff(date, home, away, home_elo, away_elo,\n                                  home_elo - away_elo, neutral))\n        if pd.isna(row["HOME_GOALS"]) or pd.isna(row["AWAY_GOALS"]):\n            ratings.setdefault(home, self._config.initial_rating)\n            ratings.setdefault(away, self._config.initial_rating)\n            history += [EloRating(home, date, ratings[home]),\n                        EloRating(away, date, ratings[away])]\n            return\n        new_h, new_a = self._update(\n            home_elo, away_elo, int(row["HOME_GOALS"]), int(row["AWAY_GOALS"]),\n            neutral, str(row["TOURNAMENT"]),\n        )\n        ratings[home], ratings[away] = new_h, new_a\n        history += [EloRating(home, date, new_h), EloRating(away, date, new_a)]\n\n    def _update(\n        self,\n        home_elo: float,\n        away_elo: float,\n        home_goals: int,\n        away_goals: int,\n        neutral: bool,\n        tournament: str,\n    ) -> tuple[float, float]:\n        """Return (new_home_elo, new_away_elo) after one match."""\n        home_adv = 0.0 if neutral else self._config.home_advantage\n        dr = home_elo - away_elo + home_adv\n        we = _we(dr)\n        w = _outcome(home_goals, away_goals)\n        k = self._k(tournament)\n        g = _g(abs(home_goals - away_goals))\n        delta = k * g * (w - we)\n        return home_elo + delta, away_elo - delta\n\n    def _k(self, tournament: str) -> int:\n        """Map tournament string to K factor using case-insensitive substring matching."""\n        t = tournament.lower()\n        c = self._config\n        # qualifier checked before world_cup to correctly classify\n        # "FIFA World Cup qualification" as qualifier, not world-cup tier.\n        if any(kw.lower() in t for kw in c.qualifier_keywords):\n            return c.k_qualifier\n        if any(kw.lower() in t for kw in c.continental_keywords):\n            return c.k_continental\n        if any(kw.lower() in t for kw in c.world_cup_keywords):\n            return c.k_world_cup\n        return c.k_friendly\n\n\n# ---------------------------------------------------------------------------\n# Module-level API\n# ---------------------------------------------------------------------------\n\n\ndef seed_wc2026(result: EloResult, teams: Iterable[str]) -> dict[str, float]:\n    """Return the latest Elo rating for each team in *teams*.\n\n    Teams absent from *result.final_ratings* receive *result.initial_rating*.\n    Pass team names explicitly so this function stays decoupled from any HTTP\n    client or live-data adapter.\n    """\n    return {\n        team: result.final_ratings.get(team, result.initial_rating)\n        for team in teams\n    }\n\n\ndef compute_elo(df: pd.DataFrame, config: EloConfig | None = None) -> EloResult:\n    """Factory: run the Elo engine with *config* (defaults if ``None``)."""\n    return EloEngine(config or EloConfig()).run(df)\n'}
