25	def _make_df(rows: list[dict]) -> pd.DataFrame:
26	    """Return a DataFrame matching the martj42 results schema."""
27	    if not rows:
28	        return pd.DataFrame(
29	            columns=["DATE", "HOME_TEAM", "AWAY_TEAM", "HOME_GOALS", "AWAY_GOALS", "TOURNAMENT",
30	                     "NEUTRAL"]
31	        )
32	    df = pd.DataFrame(rows)
33	    for col in ("HOME_GOALS", "AWAY_GOALS"):
34	        if col in df.columns:
35	            df[col] = df[col].astype("Int64")
36	    if "NEUTRAL" not in df.columns:
37	        df["NEUTRAL"] = False
38	    return df
39	
40	
41	def _one_match(
42	    *,
43	    home: str = "TeamA",
44	    away: str = "TeamB",
45	    home_goals: int | None = 1,
46	    away_goals: int | None = 0,
47	    date: str = "2020-06-01",
48	    tournament: str = "Friendly",
49	    neutral: bool = True,
50	) -> pd.DataFrame:
51	    return _make_df([{
52	        "DATE": date,
53	        "HOME_TEAM": home,
54	        "AWAY_TEAM": away,
55	        "HOME_GOALS": home_goals,
56	        "AWAY_GOALS": away_goals,
57	        "TOURNAMENT": tournament,
58	        "NEUTRAL": neutral,
59	    }])
60	
61	
62	def _gain_for_tournament(tournament: str, neutral: bool = True) -> float:
63	    """Return TeamA's rating gain from a 1-0 home win with the given tournament string."""
64	    config = EloConfig()
65	    result = EloEngine(config).run(
66	        _one_match(home_goals=1, away_goals=0, neutral=neutral, tournament=tournament)
67	    )
68	    return result.final_ratings["TeamA"] - config.initial_rating
