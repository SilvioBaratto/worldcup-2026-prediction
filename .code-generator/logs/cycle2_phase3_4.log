37	def _played_df(teams=_TEAMS, n_per_pair: int = 6, seed: int = 42) -> pd.DataFrame:
38	    """Minimal played-match DataFrame: DATE, HOME_TEAM, AWAY_TEAM, HOME_GOALS, AWAY_GOALS."""
39	    rng = np.random.default_rng(seed)
40	    base = pd.Timestamp("2021-01-01")
41	    rows = []
42	    for i, home in enumerate(teams):
43	        for j, away in enumerate(teams):
44	            if home == away:
45	                continue
46	            for k in range(n_per_pair):
47	                rows.append(
48	                    {
49	                        "DATE": base + pd.Timedelta(days=k * 10 + i * 2 + j),
50	                        "HOME_TEAM": home,
51	                        "AWAY_TEAM": away,
52	                        "HOME_GOALS": int(rng.poisson(1.5)),
53	                        "AWAY_GOALS": int(rng.poisson(1.0)),
54	                    }
55	                )
56	    return pd.DataFrame(rows)
57	
