118	
119	class TestDixonColesTau:
120	    LH, LA, RHO = 1.5, 1.0, 0.1
121	
122	    def test_when_score_is_0_0_then_correct_tau_is_returned(self):
123	        expected = 1.0 - self.LH * self.LA * self.RHO
124	        assert dixon_coles_tau(0, 0, self.LH, self.LA, self.RHO) == pytest.approx(expected)
125	
126	    def test_when_score_is_1_0_then_correct_tau_is_returned(self):
127	        # τ(1,0) = 1 + λ_away * ρ  (Dixon-Coles 1997, eq. 2)
128	        expected = 1.0 + self.LA * self.RHO
129	        assert dixon_coles_tau(1, 0, self.LH, self.LA, self.RHO) == pytest.approx(expected)
130	
131	    def test_when_score_is_0_1_then_correct_tau_is_returned(self):
132	        # τ(0,1) = 1 + λ_home * ρ
133	        expected = 1.0 + self.LH * self.RHO
134	        assert dixon_coles_tau(0, 1, self.LH, self.LA, self.RHO) == pytest.approx(expected)
135	
136	    def test_when_score_is_1_1_then_correct_tau_is_returned(self):
137	        # τ(1,1) = 1 - ρ
138	        expected = 1.0 - self.RHO
139	        assert dixon_coles_tau(1, 1, self.LH, self.LA, self.RHO) == pytest.approx(expected)
140	
141	    @pytest.mark.parametrize("h, a", [(2, 0), (0, 2), (2, 2), (3, 1), (1, 3), (10, 10)])
142	    def test_when_score_is_at_least_two_then_tau_is_one(self, h, a):
143	        assert dixon_coles_tau(h, a, self.LH, self.LA, self.RHO) == pytest.approx(1.0)
144	
145	    @pytest.mark.parametrize("h, a", [(0, 0), (1, 0), (0, 1), (1, 1)])
146	    def test_when_rho_is_zero_then_tau_is_one_for_each_low_score_cell(self, h, a):
147	        assert dixon_coles_tau(h, a, self.LH, self.LA, rho=0.0) == pytest.approx(1.0)
148	
149	    @pytest.mark.parametrize("h, a", [(0, 0), (1, 0), (0, 1), (1, 1)])
150	    def test_when_rho_is_small_positive_and_lambdas_typical_then_tau_is_positive(self, h, a):
151	        assert dixon_coles_tau(h, a, self.LH, self.LA, rho=0.1) > 0.0
152	
153	    @given(
154	        st.integers(min_value=0, max_value=1),
155	        st.integers(min_value=0, max_value=1),
156	    )
157	    def test_when_rho_zero_then_tau_is_one_for_any_low_score_cell(self, h, a):
158	        """Property: ρ=0 ⇒ τ==1.0 for all (h, a) in {0, 1}²."""
159	        assert dixon_coles_tau(h, a, 1.5, 1.0, 0.0) == pytest.approx(1.0)
160	
161	    @given(
162	        st.integers(min_value=0, max_value=20),
163	        st.integers(min_value=0, max_value=20),
164	        st.floats(min_value=-0.99, max_value=0.99, allow_nan=False, allow_infinity=False),
165	    )
166	    def test_when_high_score_then_tau_is_one_regardless_of_rho(self, h, a, rho):
167	        """Property: h≥2 or a≥2 ⇒ τ==1.0 for any ρ."""
168	        assume(h >= 2 or a >= 2)
169	        assert dixon_coles_tau(h, a, 1.5, 1.0, rho) == pytest.approx(1.0)
170	
171	
172	# ─────────────────────────────────────────────────────────────────────────────
173	# 2. DixonColesEstimator.fit — return type and NA handling
174	#    Criterion: returns TeamAbilities(attack, defence, home_adv, rho, intercept);
175	#    NA-goal rows dropped by _prepare; fit never raises on their presence.
176	# ─────────────────────────────────────────────────────────────────────────────
177	
178	class TestDixonColesEstimatorFit:
179	    def test_when_fit_on_played_data_then_returns_team_abilities(self):
180	        result = DixonColesEstimator().fit(_played_df())
181	        assert isinstance(result, TeamAbilities)
182	
183	    def test_when_fit_then_team_abilities_has_all_required_fields(self):
184	        abilities = DixonColesEstimator().fit(_played_df())
185	        for field in ("attack", "defence", "home_adv", "rho", "intercept"):
186	            assert hasattr(abilities, field), f"TeamAbilities missing field: {field}"
187	
188	    def test_when_na_rows_present_then_fit_does_not_raise(self):
189	        DixonColesEstimator().fit(_played_df_with_na())
190	
191	    def test_when_na_rows_present_then_fitted_teams_equal_played_only_teams(self):
192	        """NA rows are silently dropped; only played-match teams appear in abilities."""
193	        ab_played = DixonColesEstimator().fit(_played_df())
194	        ab_mixed = DixonColesEstimator().fit(_played_df_with_na())
195	        assert set(ab_played.attack.keys()) == set(ab_mixed.attack.keys())
196	
197	
198	# ─────────────────────────────────────────────────────────────────────────────
199	# 3. Time-decay weights
200	#    Criterion: reference date → 1.0; half_life_days old → 0.5;
201	#    2×half_life old → 0.25 (all pytest.approx).
202	#    Assumption: module exposes decay_weight(age_days, half_life_days) -> float.
203	# ─────────────────────────────────────────────────────────────────────────────
204	
205	class TestTimeDecayWeight:
206	    HALF_LIFE = 180.0
207	
208	    def test_when_age_is_zero_days_then_weight_is_one(self):
209	        assert decay_weight(0.0, self.HALF_LIFE) == pytest.approx(1.0)
210	
211	    def test_when_age_is_one_half_life_then_weight_is_half(self):
212	        assert decay_weight(self.HALF_LIFE, self.HALF_LIFE) == pytest.approx(0.5)
213	
214	    def test_when_age_is_two_half_lives_then_weight_is_quarter(self):
215	        assert decay_weight(2.0 * self.HALF_LIFE, self.HALF_LIFE) == pytest.approx(0.25)
216	
217	    @given(
218	        st.floats(min_value=0.0, max_value=3650.0, allow_nan=False, allow_infinity=False),
219	        st.floats(min_value=1.0, max_value=730.0, allow_nan=False, allow_infinity=False),
220	    )
221	    def test_when_age_grows_by_one_day_then_weight_is_non_increasing(self, age, half_life):
222	        """Property: exponential decay is monotonically non-increasing in age."""
223	        w_now = decay_weight(age, half_life)
224	        w_older = decay_weight(age + 1.0, half_life)
225	        assert w_older <= w_now + 1e-12
226	
227	
228	# ─────────────────────────────────────────────────────────────────────────────
229	# 4. Determinism
230	#    Criterion: fitting twice on identical data yields identical abilities (tight approx).
231	# ─────────────────────────────────────────────────────────────────────────────
232	
233	class TestFitDeterminism:
234	    def test_when_fit_twice_on_same_data_then_abilities_are_identical(self):
235	        df = _played_df()
236	        ab1 = DixonColesEstimator().fit(df)
237	        ab2 = DixonColesEstimator().fit(df)
238	        for team in ab1.attack:
239	            assert ab1.attack[team] == pytest.approx(ab2.attack[team], abs=1e-9)
240	        for team in ab1.defence:
241	            assert ab1.defence[team] == pytest.approx(ab2.defence[team], abs=1e-9)
242	        assert ab1.home_adv == pytest.approx(ab2.home_adv, abs=1e-9)
243	        assert ab1.rho == pytest.approx(ab2.rho, abs=1e-9)
244	        assert ab1.intercept == pytest.approx(ab2.intercept, abs=1e-9)
245	
246	
247	# ─────────────────────────────────────────────────────────────────────────────
248	# 5. Mean-zero attack normalization
249	#    Criterion: fitted attack values satisfy mean ≈ 0 (identifiability constraint).
250	# ─────────────────────────────────────────────────────────────────────────────
251	
252	class TestMeanZeroNormalization:
253	    def test_when_fitted_then_mean_of_attack_values_is_approximately_zero(self):
254	        abilities = DixonColesEstimator().fit(_played_df())
255	        assert np.mean(list(abilities.attack.values())) == pytest.approx(0.0, abs=1e-6)
256	
257	
258	# ─────────────────────────────────────────────────────────────────────────────
259	# 6. Recovery sanity
260	#    Criterion: seeded synthetic data where a clearly stronger team gets a higher
261	#    fitted attack than a weak team.
262	# ─────────────────────────────────────────────────────────────────────────────
263	
264	class TestRecoverySanity:
265	    def test_when_strong_team_consistently_outscores_weak_team_then_higher_attack_is_fitted(self):
266	        abilities = DixonColesEstimator().fit(_strong_vs_weak_df())
267	        assert abilities.attack["Strong"] > abilities.attack["Weak"]
268	
269	
270	# ─────────────────────────────────────────────────────────────────────────────
271	# 7. ScorelineSampler.sample
272	#    Criterion: returns int array (size, 2) with goals in [0, max_goals];
273	#    reproducible with same seed; divergent across seeds;
274	#    default seed comes from PoissonConfig.
275	# ─────────────────────────────────────────────────────────────────────────────
276	
277	class TestScorelineSampler:
278	    @pytest.fixture
279	    def abilities(self):
280	        return DixonColesEstimator().fit(_played_df())
281	
282	    @pytest.fixture
283	    def sampler(self, abilities):
284	        return ScorelineSampler(abilities=abilities, config=PoissonConfig())
285	
286	    def test_when_sample_called_then_result_shape_is_size_by_two(self, sampler):
287	        result = sampler.sample("Alpha", "Beta", size=100, random_state=0)
288	        assert result.shape == (100, 2)
289	
290	    def test_when_sample_called_then_dtype_is_integer(self, sampler):
291	        result = sampler.sample("Alpha", "Beta", size=50, random_state=1)
292	        assert np.issubdtype(result.dtype, np.integer)
293	
294	    def test_when_sample_called_then_goals_are_within_zero_and_max_goals(self, sampler):
295	        max_g = PoissonConfig().max_goals
296	        result = sampler.sample("Alpha", "Beta", size=500, random_state=2)
297	        assert int(result.min()) >= 0
298	        assert int(result.max()) <= max_g
299	
300	    def test_when_same_random_state_used_then_output_is_reproducible(self, sampler):
301	        r1 = sampler.sample("Alpha", "Beta", size=50, random_state=42)
302	        r2 = sampler.sample("Alpha", "Beta", size=50, random_state=42)
303	        np.testing.assert_array_equal(r1, r2)
304	
305	    def test_when_different_random_states_used_then_outputs_diverge(self, sampler):
306	        r1 = sampler.sample("Alpha", "Beta", size=300, random_state=0)
307	        r2 = sampler.sample("Alpha", "Beta", size=300, random_state=9999)
308	        assert not np.array_equal(r1, r2)
309	
310	    def test_when_no_random_state_given_then_default_seed_comes_from_poisson_config(self, sampler):
311	        """Assumption: PoissonConfig exposes a `random_seed` field used as the default."""
312	        cfg = PoissonConfig()
313	        r_default = sampler.sample("Alpha", "Beta", size=50)
314	        r_explicit = sampler.sample("Alpha", "Beta", size=50, random_state=cfg.random_seed)
315	        np.testing.assert_array_equal(r_default, r_explicit)
316	
317	
318	# ─────────────────────────────────────────────────────────────────────────────
319	# 8. lambdas — neutral venue drops home advantage
320	#    Criterion: lambdas(abilities, home, away, neutral=True) drops home_adv ⇒
321	#    strictly lower λ_home than the non-neutral case.
322	# ─────────────────────────────────────────────────────────────────────────────
323	
324	class TestLambdas:
325	    @pytest.fixture
326	    def abilities(self):
327	        return DixonColesEstimator().fit(_played_df())
328	
329	    def test_when_neutral_true_then_lambda_home_is_strictly_lower_than_non_neutral(self, abilities):
330	        lh_non_neutral, _ = lambdas(abilities, "Alpha", "Beta", neutral=False)
331	        lh_neutral, _ = lambdas(abilities, "Alpha", "Beta", neutral=True)
332	        assert lh_neutral < lh_non_neutral
333	
334	    def test_when_neutral_flag_toggled_then_lambda_away_is_unchanged(self, abilities):
335	        _, la_non_neutral = lambdas(abilities, "Alpha", "Beta", neutral=False)
336	        _, la_neutral = lambdas(abilities, "Alpha", "Beta", neutral=True)
337	        assert la_neutral == pytest.approx(la_non_neutral)
338	
339	
340	# ─────────────────────────────────────────────────────────────────────────────
341	# 9. score_matrix — joint pmf grid
342	#    Criterion: sums to 1.0 (approx); equals product of marginals when ρ=0.
343	#    Assumption: score_matrix(lambda_home, lambda_away, rho, max_goals) -> ndarray.
344	# ─────────────────────────────────────────────────────────────────────────────
345	
346	class TestScoreMatrix:
347	    def test_when_score_matrix_computed_then_probabilities_sum_to_one(self):
348	        m = score_matrix(1.5, 1.0, rho=0.1, max_goals=15)
349	        assert m.sum() == pytest.approx(1.0, abs=1e-5)
350	
351	    def test_when_rho_is_zero_then_matrix_equals_product_of_row_and_col_marginals(self):
352	        m = score_matrix(1.5, 1.0, rho=0.0, max_goals=15)
353	        row_marginals = m.sum(axis=1)
354	        col_marginals = m.sum(axis=0)
355	        expected = np.outer(row_marginals, col_marginals)
356	        np.testing.assert_allclose(m, expected, atol=1e-9)
357	
358	    @given(
359	        st.floats(min_value=0.1, max_value=4.0, allow_nan=False, allow_infinity=False),
360	        st.floats(min_value=0.1, max_value=4.0, allow_nan=False, allow_infinity=False),
361	    )
362	    @settings(max_examples=50)
363	    def test_when_valid_lambdas_any_value_then_score_matrix_sums_to_one(self, lh, la):
364	        """Property: score_matrix with ρ=0 sums to ≈1.0 for any λ in (0.1, 4.0]."""
365	        m = score_matrix(lh, la, rho=0.0, max_goals=20)
366	        assert m.sum() == pytest.approx(1.0, abs=1e-3)
367	
368	
369	# ─────────────────────────────────────────────────────────────────────────────
370	# 10. PoissonConfig validation
371	#     Criterion: defaults load; half_life_days≤0, max_goals<1, optimizer_maxiter<1
372	#     raise ValidationError; AppConfig().poisson is a PoissonConfig.
373	# ─────────────────────────────────────────────────────────────────────────────
374	
375	class TestPoissonConfig:
376	    def test_when_no_arguments_given_then_poisson_config_loads(self):
377	        assert PoissonConfig() is not None
378	
379	    def test_when_half_life_days_is_zero_then_validation_error_is_raised(self):
380	        with pytest.raises(ValidationError):
381	            PoissonConfig(half_life_days=0)
382	
383	    def test_when_half_life_days_is_negative_then_validation_error_is_raised(self):
384	        with pytest.raises(ValidationError):
385	            PoissonConfig(half_life_days=-1)
386	
387	    def test_when_max_goals_is_zero_then_validation_error_is_raised(self):
388	        with pytest.raises(ValidationError):
389	            PoissonConfig(max_goals=0)
390	
391	    def test_when_max_goals_is_negative_then_validation_error_is_raised(self):
392	        with pytest.raises(ValidationError):
393	            PoissonConfig(max_goals=-1)
394	
395	    def test_when_optimizer_maxiter_is_zero_then_validation_error_is_raised(self):
396	        with pytest.raises(ValidationError):
397	            PoissonConfig(optimizer_maxiter=0)
398	
399	    def test_when_optimizer_maxiter_is_negative_then_validation_error_is_raised(self):
400	        with pytest.raises(ValidationError):
401	            PoissonConfig(optimizer_maxiter=-1)
402	
403	    def test_when_app_config_created_then_poisson_attribute_is_poisson_config_instance(self):
404	        assert isinstance(AppConfig().poisson, PoissonConfig)
