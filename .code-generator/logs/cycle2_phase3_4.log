382	    @given(
383	        st.lists(
384	            st.fixed_dictionaries({
385	                "home_goals": st.integers(min_value=0, max_value=5),
386	                "away_goals": st.integers(min_value=0, max_value=5),
387	                "month": st.integers(min_value=1, max_value=12),
388	                "day": st.integers(min_value=1, max_value=28),
389	            }),
390	            min_size=2,
391	            max_size=8,
392	        )
393	    )
394	    @settings(max_examples=50)
395	    def test_property_when_rows_shuffled_then_final_ratings_are_deterministic(
396	        self, params: list[dict]
397	    ) -> None:
398	        """Chronological sort must produce the same final ratings regardless of input row order."""
399	        teams = ["Alpha", "Beta", "Gamma", "Delta"]
400	        rows = [
401	            {
402	                "DATE": f"2020-{p['month']:02d}-{p['day']:02d}",
403	                "HOME_TEAM": teams[i % len(teams)],
404	                "AWAY_TEAM": teams[(i + 1) % len(teams)],
405	                "HOME_GOALS": p["home_goals"],
406	                "AWAY_GOALS": p["away_goals"],
407	                "TOURNAMENT": "Friendly",
408	                "NEUTRAL": True,
409	            }
410	            for i, p in enumerate(params)
411	        ]
412	        shuffled = rows[:]
413	        random.shuffle(shuffled)
414	
415	        config = EloConfig()
416	        result_a = EloEngine(config).run(_make_df(rows))
417	        result_b = EloEngine(config).run(_make_df(shuffled))
418	
419	        for team in teams:
420	            if team in result_a.final_ratings and team in result_b.final_ratings:
421	                assert result_a.final_ratings[team] == pytest.approx(
422	                    result_b.final_ratings[team], rel=1e-6
423	                )
