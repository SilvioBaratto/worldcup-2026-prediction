357	
358	class TestWhenInputShuffledThenFinalRatingsAreIdentical:
359	    def test_when_rows_shuffled_then_final_ratings_match(self):
360	        rows = [
361	            {"DATE": "2020-01-01", "HOME_TEAM": "A", "AWAY_TEAM": "B",
362	             "HOME_GOALS": 2, "AWAY_GOALS": 1, "TOURNAMENT": "Friendly", "NEUTRAL": True},
363	            {"DATE": "2020-01-01", "HOME_TEAM": "C", "AWAY_TEAM": "D",
364	             "HOME_GOALS": 0, "AWAY_GOALS": 3, "TOURNAMENT": "Friendly", "NEUTRAL": True},
365	            {"DATE": "2020-03-15", "HOME_TEAM": "A", "AWAY_TEAM": "C",
366	             "HOME_GOALS": 1, "AWAY_GOALS": 1, "TOURNAMENT": "Friendly", "NEUTRAL": True},
367	            {"DATE": "2020-06-01", "HOME_TEAM": "B", "AWAY_TEAM": "D",
368	             "HOME_GOALS": 0, "AWAY_GOALS": 0, "TOURNAMENT": "Friendly", "NEUTRAL": True},
369	        ]
370	        shuffled = rows[:]
371	        random.shuffle(shuffled)
372	
373	        config = EloConfig()
374	        result_a = EloEngine(config).run(_make_df(rows))
375	        result_b = EloEngine(config).run(_make_df(shuffled))
376	
377	        for team in ("A", "B", "C", "D"):
378	            assert result_a.final_ratings[team] == pytest.approx(
379	                result_b.final_ratings[team], rel=1e-6
380	            )
