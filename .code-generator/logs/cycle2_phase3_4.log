130	    def test_when_dr_400_via_home_advantage_then_delta_implies_we_approx_0_909(self):
131	        """home_advantage=400, equal initial ratings, non-neutral → dr=400 → We=10/11.
132	
133	        ΔR = k_friendly × G=1.0 × (1 − 10/11) = k_friendly / 11.
134	        """
