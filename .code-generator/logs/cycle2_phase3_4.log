59	def _played_df_with_na() -> pd.DataFrame:
60	    """Played matches mixed with unplayed (NA goals) rows."""
61	    played = _played_df()
62	    na_rows = pd.DataFrame(
63	        {
64	            "DATE": [pd.Timestamp("2025-06-01"), pd.Timestamp("2025-06-15")],
65	            "HOME_TEAM": ["Alpha", "Beta"],
66	            "AWAY_TEAM": ["Beta", "Gamma"],
