2026-06-24 03:41:26,668 DEBUG msg #23: UserMessage tool_result(toolu_01GfbXzDeaVYGaa9DTU94hiD): 1	"""Monte Carlo single-elimination tournament simulation.
2	
3	Mirrors ``nba_playoff.simulation.tournament`` but replaces the best-of-N series
4	with a **single-match** knockout tie throughout.  Key differences from the NBA
5	original:
6	
7	- ``TournamentSimulator._play_series`` is replaced by ``_play_tie``, which
8	  delegates to ``GamePredictor.predict_tie`` for one prediction instead of
9	  accumulating wins across multiple games.
10	- ``SimulationConfig`` carries no ``games_per_series`` / ``wins_to_advance``
11	  fields; the constructor only stores ``_n_simulations`` for logging purposes.
12	- ``build_bracket_tree`` accepts ``list[Matchup]`` where ``Matchup.group``
13	  replaces ``Matchup.conference`` (field name in the football config).
14	- Round indices remain 0-based: 0 = Round of 32, …, 4 = Final.
15	"""
16	
17	from __future__ import annotations
18	
19	import logging
20	from collections import deque
21	from dataclasses import dataclass, field
22	from typing import Callable
23	
24	from worldcup_playoff.config import Matchup, SimulationConfig
25	from worldcup_playoff.simulation.game import GamePredictor
26	
27	logger = logging.getLogger(__name__)
28	
29	
30	@dataclass
31	class RoundResult:
32	    """Tracks per-team advancement counts at a given round.
33	
34	    Each team's probability is its individual advancement probability:
35	    ``count / n_simulations``.  For rounds with multiple concurrent ties this
36	    means the probabilities across all teams sum to the number of ties in the
37	    round, not to 1.0.
38	
39	    Attributes:
40	        counts: Raw advancement counts keyed by team name.
41	        n_simulations: Total number of bracket simulations completed so far for
42	            this round (incremented once per ``_simulate_once`` call).
43	    """
44	
45	    counts: dict[str, int] = field(default_factory=dict)
46	    n_simulations: int = 0
47	
48	    @property
49	    def probabilities(self) -> dict[str, float]:
50	        """Convert raw counts to per-team advancement probabilities.
51	
52	        Uses ``n_simulations`` as the denominator so each value correctly
53	        reflects the fraction of simulations in which that team advanced,
54	        regardless of how many ties were played concurrently in the round.
55	
56	        Returns:
57	            Empty dict when ``n_simulations`` is 0 to avoid division by zero.
58	        """
59	        if self.n_simulations == 0:
60	            return {}
61	        return {k: v / self.n_simulations for k, v in self.counts.items()}
62	
63	
64	@dataclass
65	class BracketSlot:
66	    """A node in the bracket tree.
67	
68	    Leaves hold the two teams from a first-round tie.
69	    Internal nodes aggregate all teams reachable through their sub-bracket.
70	
71	    Attributes:
72	        teams: All team names that could appear in this slot.
73	        children: The two child ``BracketSlot`` nodes whose winners meet here,
74	            or ``None`` for leaf nodes.
75	        group: The group/conference label inherited from the originating
76	            ``Matchup.group`` value (propagated upward only when both children
77	            share the same label).
78	    """
79	
80	    teams: list[str]
81	    children: tuple[BracketSlot, BracketSlot] | None = None
82	    group: str = ""
83	
84	
85	def build_bracket_tree(matchups: list[Matchup]) -> BracketSlot:
86	    """Build a bracket tree from the sequential matchup list.
87	
88	    Mirrors the pairing logic in ``TournamentSimulator._simulate_once``:
89	    adjacent matchup winners pair into the next round until only the root
90	    (the Final) remains.
91	
92	    Args:
93	        matchups: A non-empty list whose length is a power of 2.  World Cup
94	            knockout brackets satisfy this constraint (2, 4, 8, 16, 32 teams).
95	
96	    Returns:
97	        The root ``BracketSlot`` whose ``teams`` contains every participant.
98	
99	    Raises:
100	        ValueError: If ``matchups`` is empty or its length is not a power of 2.
101	    """
102	    n = len(matchups)
103	    if n == 0 or (n & (n - 1)) != 0:
104	        raise ValueError(
105	            f"matchups must be a non-empty power-of-2 length, got {n}"
106	        )
107	
108	    # Build leaf nodes — one per first-round tie.
109	    slots: list[BracketSlot] = [
110	        BracketSlot(
111	            teams=[m.home, m.away],
112	            group=m.group,
113	        )
114	        for m in matchups
115	    ]
116	
117	    # Fold adjacent pairs upward until only the root remains.
118	    while len(slots) > 1:
119	        next_level: list[BracketSlot] = []
120	        for i in range(0, len(slots), 2):
121	            left, right = slots[i], slots[i + 1]
122	            shared_group = left.group if left.group == right.group else ""
123	            next_level.append(
124	                BracketSlot(
125	                    teams=left.teams + right.teams,
126	                    children=(left, right),
127	                    group=shared_group,
128	                )
129	            )
130	        slots = next_level
131	
132	    return slots[0]
133	
134	
135	def extract_bracket_slots(root: BracketSlot) -> dict[int, list[BracketSlot]]:
136	    """Return ``{round_number: [slots]}`` by BFS from root.
137	
138	    Round 0 = leaves (first round), increasing toward the root (Final).
139	
140	    Args:
141	        root: The root ``BracketSlot`` returned by ``build_bracket_tree``.
142	
143	    Returns:
144	        Dict mapping round index to the list of ``BracketSlot`` nodes at that
145	        depth level.
146	    """
147	    depth = 0
148	    node = root
149	    while node.children:
150	        depth += 1
151	        node = node.children[0]
152	
153	    levels: dict[int, list[BracketSlot]] = {}
154	    queue: deque[tuple[BracketSlot, int]] = deque([(root, 0)])
155	    while queue:
156	        slot, d = queue.popleft()
157	        round_num = depth - d
158	        levels.setdefault(round_num, []).append(slot)
159	        if slot.children:
160	            queue.append((slot.children[0], d + 1))
161	            queue.append((slot.children[1], d + 1))
162	
163	    return levels
164	
165	
166	class TournamentSimulator:
167	    """Runs Monte Carlo simulations of a single-elimination knockout bracket.
168	
169	    Uses composition: holds a ``GamePredictor`` rather than inheriting from it.
170	
171	    Unlike the NBA ``TournamentSimulator``, there are no series-length fields.
172	    Each tie is decided by a single ``GamePredictor.predict_tie`` call.
173	    """
174	
175	    def __init__(
176	        self,
177	        game_predictor: GamePredictor,
178	        config: SimulationConfig,
179	    ) -> None:
180	        self._predictor = game_predictor
181	        # Store n_simulations only for logging; the caller controls it via
182	        # the simulate() argument so the same instance can be reused.
183	        self._default_n_simulations = config.n_simulations
184	
185	    def simulate(
186	        self,
187	        bracket: list[Matchup],
188	        n_simulations: int,
189	        progress_callback: Callable[[int], None] | None = None,
190	    ) -> dict[int, RoundResult]:
191	        """Run *n_simulations* full single-elimination brackets.
192	
193	        Args:
194	            bracket: The first-round matchup list.  Length must be a power of 2
195	                (validated inside ``_simulate_once`` via the pairing logic).
196	            n_simulations: Number of independent bracket simulations to run.
197	            progress_callback: Optional callable invoked after each simulation
198	                with the 1-based iteration index, e.g. for a progress bar.
199	
200	        Returns:
201	            ``{round_number: RoundResult}`` with accumulated advancement counts.
202	            Round numbers are 0-based (0 = first knockout round, N = Final).
203	
204	        Raises:
205	            ValueError: If *bracket* is empty or its length is not a power of 2.
206	        """
207	        n = len(bracket)
208	        if n == 0 or (n & (n - 1)) != 0:
209	            raise ValueError(
210	                f"bracket length must be a non-empty power of 2, got {n}"
211	            )
212	
213	        all_teams = [m.home for m in bracket] + [m.away for m in bracket]
214	        rounds: dict[int, RoundResult] = {}
215	
216	        for i in range(n_simulations):
217	            self._simulate_once(bracket, all_teams, rounds)
218	            if progress_callback is not None:
219	                progress_callback(i + 1)
220	
221	        logger.info("Completed %d simulations", n_simulations)
222	        return rounds
223	
224	    # ------------------------------------------------------------------
225	    # Private helpers
226	    # ------------------------------------------------------------------
227	
228	    def _simulate_once(
229	        self,
230	        bracket: list[Matchup],
231	        all_teams: list[str],
232	        rounds: dict[int, RoundResult],
233	    ) -> str:
234	        """Play one full bracket and mutate *rounds* to accumulate counts.
235	
236	        Args:
237	            bracket: First-round matchup list (length is a power of 2).
238	            all_teams: Flat list of every participating team; used to initialize
239	                the ``RoundResult.counts`` dict on the first simulation.
240	            rounds: Mutable accumulator updated in-place.
241	
242	        Returns:
243	            The name of the tournament champion.
244	        """
245	        current_matchups = bracket
246	        round_num = 0
247	
248	        while True:
249	            winners = [self._play_tie(m) for m in current_matchups]
250	
251	            if round_num not in rounds:
252	                rounds[round_num] = RoundResult(
253	                    counts={team: 0 for team in all_teams}
254	                )
255	            rounds[round_num].n_simulations += 1
256	
257	            for winner in winners:
258	                rounds[round_num].counts[winner] += 1
259	
260	            # Single champion — tournament complete.
261	            if len(winners) == 1:
262	                return winners[0]
263	
264	            # Pair adjacent winners for the next round.
265	            current_matchups = [
266	                Matchup(home=winners[i], away=winners[i + 1])
267	                for i in range(0, len(winners), 2)
268	            ]
269	            round_num += 1
270	
271	    def _play_tie(self, matchup: Matchup) -> str:
272	        """Decide a single knockout tie via the ``GamePredictor``.
273	
274	        This replaces the NBA ``_play_series`` loop entirely — one prediction,
275	        one winner.
276	
277	        Args:
278	            matchup: The tie to resolve.
279	
280	        Returns:
281	            The advancing team's name.
282	        """
283	        return self._predictor.predict_tie(matchup.home, matchup.away)
