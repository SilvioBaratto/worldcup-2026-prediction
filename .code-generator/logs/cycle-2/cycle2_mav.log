408	# AC9 — Chronological determinism: shuffled input → identical final ratings
409	# ---------------------------------------------------------------------------
410	
411	
412	class TestWhenInputShuffledThenFinalRatingsAreIdentical:
413	    def test_when_rows_shuffled_then_final_ratings_match(self):
414	        rows = [
415	            {
416	                "DATE": "2020-01-01",
417	                "HOME_TEAM": "A",
418	                "AWAY_TEAM": "B",
419	                "HOME_GOALS": 2,
420	                "AWAY_GOALS": 1,
421	                "TOURNAMENT": "Friendly",
422	                "NEUTRAL": True,
423	            },
424	            {
425	                "DATE": "2020-01-01",
426	                "HOME_TEAM": "C",
427	                "AWAY_TEAM": "D",
428	                "HOME_GOALS": 0,
429	                "AWAY_GOALS": 3,
430	                "TOURNAMENT": "Friendly",
431	                "NEUTRAL": True,
432	            },
433	            {
434	                "DATE": "2020-03-15",
435	                "HOME_TEAM": "A",
436	                "AWAY_TEAM": "C",
437	                "HOME_GOALS": 1,
438	                "AWAY_GOALS": 1,
439	                "TOURNAMENT": "Friendly",
440	                "NEUTRAL": True,
441	            },
442	            {
443	                "DATE": "2020-06-01",
444	                "HOME_TEAM": "B",
445	                "AWAY_TEAM": "D",
446	                "HOME_GOALS": 0,
447	                "AWAY_GOALS": 0,
448	                "TOURNAMENT": "Friendly",
449	                "NEUTRAL": True,
450	            },
451	        ]
452	        shuffled = rows[:]
453	        random.shuffle(shuffled)
454	
455	        config = EloConfig()
456	        result_a = EloEngine(config).run(_make_df(rows))
457	        result_b = EloEngine(config).run(_make_df(shuffled))
458	
459	        for team in ("A", "B", "C", "D"):
460	            assert result_a.final_ratings[team] == pytest.approx(
461	                result_b.final_ratings[team], rel=1e-6
462	            )
463	
464	    @given(
465	        st.lists(
466	            st.fixed_dictionaries(
467	                {
468	                    "home_goals": st.integers(min_value=0, max_value=5),
469	                    "away_goals": st.integers(min_value=0, max_value=5),
470	                    "month": st.integers(min_value=1, max_value=12),
471	                    "day": st.integers(min_value=1, max_value=28),
472	                }
473	            ),
474	            min_size=2,
475	            max_size=8,
476	        )
477	    )
478	    @settings(max_examples=50)
479	    def test_property_when_rows_shuffled_then_final_ratings_are_deterministic(
480	        self, params: list[dict]
481	    ) -> None:
482	        """Chronological sort must produce the same final ratings regardless of input row order."""
483	        teams = ["Alpha", "Beta", "Gamma", "Delta"]
484	        rows = [
485	            {
486	                "DATE": f"2020-{p['month']:02d}-{p['day']:02d}",
487	                "HOME_TEAM": teams[i % len(teams)],
488	                "AWAY_TEAM": teams[(i + 1) % len(teams)],
489	                "HOME_GOALS": p["home_goals"],
490	                "AWAY_GOALS": p["away_goals"],
491	                "TOURNAMENT": "Friendly",
492	                "NEUTRAL": True,
493	            }
494	            for i, p in enumerate(params)
495	        ]
496	        shuffled = rows[:]
497	        random.shuffle(shuffled)
498	
499	        config = EloConfig()
500	        result_a = EloEngine(config).run(_make_df(rows))
501	        result_b = EloEngine(config).run(_make_df(shuffled))
502	
503	        for team in teams:
504	            if team in result_a.final_ratings and team in result_b.final_ratings:
505	                assert result_a.final_ratings[team] == pytest.approx(
506	                    result_b.final_ratings[team], rel=1e-6
507	                )
