147	class TestWhenExpectationMathThenValuesAreExact:
148	    def test_when_equal_ratings_on_neutral_then_delta_implies_we_is_0_5(self):
149	        """Equal ratings + neutral → We=0.5 → ΔR = k_friendly × 1.0 × 0.5."""
150	        config = EloConfig()
151	        result = EloEngine(config).run(_one_match(home_goals=1, away_goals=0, neutral=True))
152	        expected_delta = config.k_friendly * 0.5
