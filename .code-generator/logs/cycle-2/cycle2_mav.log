2026-06-23 23:46:52,229 DEBUG msg #33: UserMessage tool_result(toolu_01Dh4UzyGSX3rSNLpNheCkF2): 1	"""World Football Elo engine — chronological ratings from martj42 history.
2	
3	Consumes the DataFrame produced by ``Martj42Loader.load_results()``.  The module
4	is I/O-free and network-free so tests can build DataFrames in-memory.
5	
6	Design notes
7	------------
8	* ``elo_diff`` in ``MatchEloDiff`` is ``home_elo − away_elo`` without the
9	  ``home_advantage`` term so the emitted covariate is venue-agnostic.
10	* Rows are sorted by ``(date, HOME_TEAM, AWAY_TEAM, HOME_GOALS, AWAY_GOALS)``
11	  giving a total content-based order.  Rows that are equal on all five keys are
12	  truly identical matches; swapping them does not change any rating.  ``NaT``
13	  dates and ``NA`` goals sort last by pandas convention.
14	"""
15	
16	from __future__ import annotations
17	
18	import logging
19	from dataclasses import dataclass
20	from typing import Iterable
21	
22	import pandas as pd
23	
24	from worldcup_playoff.config import EloConfig
25	
26	logger = logging.getLogger(__name__)
27	
28	# ---------------------------------------------------------------------------
29	# Value objects
30	# ---------------------------------------------------------------------------
31	
32	_SORT_COLS = ["_d", "HOME_TEAM", "AWAY_TEAM", "HOME_GOALS", "AWAY_GOALS"]
33	
34	
35	@dataclass(frozen=True)
36	class EloRating:
37	    """Per-team, per-date Elo snapshot (post-match)."""
38	
39	    team: str
40	    date: str
41	    rating: float
42	
43	
44	@dataclass(frozen=True)
45	class MatchEloDiff:
46	    """Pre-match Elo state for a single fixture.
47	
48	    ``elo_diff = home_elo − away_elo`` is venue-agnostic (excludes home_advantage).
49	    """
50	
51	    date: str
52	    home_team: str
53	    away_team: str
54	    home_elo: float
55	    away_elo: float
56	    elo_diff: float
57	    neutral: bool
58	
59	
60	@dataclass(frozen=True)
61	class EloResult:
62	    """Outcome of ``EloEngine.run``.
63	
64	    Attributes
65	    ----------
66	    history:       Ordered per-team, per-date snapshots.
67	    match_diffs:   One entry per input row (incl. unplayed fixtures).
68	    final_ratings: Latest rating for every team that appeared.
69	    initial_rating: Default start rating — used by ``seed_wc2026`` for absent teams.
70	    """
71	
72	    history: list[EloRating]
73	    match_diffs: list[MatchEloDiff]
74	    final_ratings: dict[str, float]
75	    initial_rating: float
76	
77	    def history_frame(self) -> pd.DataFrame:
78	        """Return history as a tidy DataFrame (team / date / rating)."""
79	        if not self.history:
80	            return pd.DataFrame(columns=["team", "date", "rating"])
81	        return pd.DataFrame(
82	            [{"team": r.team, "date": r.date, "rating": r.rating} for r in self.history]
83	        )
84	
85	    def latest_ratings_frame(self) -> pd.DataFrame:
86	        """Return final_ratings as a tidy DataFrame (team / rating)."""
87	        if not self.final_ratings:
88	            return pd.DataFrame(columns=["team", "rating"])
89	        return pd.DataFrame([{"team": t, "rating": r} for t, r in self.final_ratings.items()])
90	
91	
92	# ---------------------------------------------------------------------------
93	# Module-level pure math helpers
94	# ---------------------------------------------------------------------------
95	
96	
97	def _we(dr: float) -> float:
98	    """Win expectation from Elo rating difference *dr*."""
99	    return float(1.0 / (1.0 + 10.0 ** (-dr / 400.0)))
100	
101	
102	def _g(margin: int) -> float:
103	    """Goal-margin multiplier (World-Football-Elo convention)."""
104	    if margin <= 1:
105	        return 1.0
106	    if margin == 2:
107	        return 1.5
108	    return (11 + margin) / 8.0
109	
110	
111	def _outcome(home_goals: int, away_goals: int) -> float:
112	    """W value: 1.0 home win / 0.5 draw / 0.0 home loss."""
113	    if home_goals > away_goals:
114	        return 1.0
115	    return 0.5 if home_goals == away_goals else 0.0
116	
117	
118	# ---------------------------------------------------------------------------
