123	class EloEngine:
124	    """Compute World Football Elo ratings chronologically from a martj42 DataFrame."""
125	
126	    def __init__(self, config: EloConfig) -> None:
127	        self._config = config
128	
129	    def run(self, df: pd.DataFrame) -> EloResult:
130	        """Process *df* and return per-team ratings + per-match diffs."""
131	        ratings: dict[str, float] = {}
132	        history: list[EloRating] = []
133	        diffs: list[MatchEloDiff] = []
134	        for _, row in self._sort(df).iterrows():
