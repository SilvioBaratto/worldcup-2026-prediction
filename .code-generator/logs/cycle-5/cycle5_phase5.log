165	# ── High-level CLI entry ─────────────────────────────────────────────────────
166	
167	
168	def _read_features(root: Any) -> "pd.DataFrame | None":
169	    from pathlib import Path
170	    try:
171	        df = pd.read_csv(Path(root) / "dataset" / "features.csv")
172	        return df if "outcome" in df.columns else None
173	    except (FileNotFoundError, OSError):
174	        return None
175	
176	
177	def _sklearn_pair(seed: int = 42) -> tuple:
178	    from sklearn.ensemble import GradientBoostingClassifier, RandomForestClassifier
179	    return (
180	        GradientBoostingClassifier(random_state=seed),
181	        RandomForestClassifier(n_estimators=10, random_state=seed),
182	    )
183	
184	
185	def run_backtest(cfg: Any = None, root: Any = None) -> "pd.DataFrame | None":
186	    """High-level CLI entry: load features+targets and run time-aware WC backtest.
187	
188	    Returns ``None`` when ``dataset/features.csv`` is unavailable or lacks
189	    an ``outcome`` column.  Delegates to ``backtest_hybrid`` with sklearn
190	    classifiers compatible with its ``fit(X, y)`` / ``predict_proba(X)`` protocol.
191	    """
192	    from worldcup_playoff.config import AppConfig
193	    resolved = cfg if cfg is not None else AppConfig()
194	    matches = _read_features(root or ".")
195	    if matches is None:
196	        return None
197	    seed = getattr(getattr(resolved, "hybrid", None), "random_seed", 42)
198	    try:
199	        return backtest_hybrid(matches, *_sklearn_pair(seed))
200	    except Exception:
201	        return None
202	
