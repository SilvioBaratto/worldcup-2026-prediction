2026-06-24 05:37:59,117 DEBUG msg #326: UserMessage tool_result(toolu_01NcBYaXg3iF35sUdp3RDNHJ): 1	"""Title-odds and per-round advancement visualizations for the live forecast.
2	
3	Implements two public plotting functions:
4	- ``plot_title_odds``: ranked horizontal bar chart of champion probabilities.
5	- ``plot_round_advancement``: heatmap of per-round advancement fractions.
6	
7	Both duck-type against ``ForecastResult`` (``champion_probabilities``,
8	``round_probabilities``) and the ``{round: {team: prob}}`` contract.
9	Figures are always closed after saving — never displayed (Agg backend).
10	"""
11	
12	from __future__ import annotations
13	
14	import logging
15	from pathlib import Path
16	from typing import Any
17	
18	import matplotlib.axes
19	import matplotlib.pyplot as plt
20	import numpy as np
21	
22	from worldcup_playoff.config import VisualizationConfig
23	
24	logger = logging.getLogger(__name__)
25	
26	# ---------------------------------------------------------------------------
27	# Shared helpers
28	# ---------------------------------------------------------------------------
29	
30	
31	def _resolve_config(config: VisualizationConfig | None) -> VisualizationConfig:
32	    return config or VisualizationConfig()
33	
34	
35	def _apply_style(config: VisualizationConfig) -> None:
36	    plt.style.use(config.style)
37	    plt.rcParams["figure.dpi"] = config.dpi
38	
39	
40	def _save_and_close(fig: plt.Figure, output_path: Path | str) -> None:
41	    path = Path(output_path)
42	    path.parent.mkdir(parents=True, exist_ok=True)
43	    fig.savefig(path, bbox_inches="tight")
44	    logger.info("Plot saved to %s", path)
45	    plt.close(fig)
46	
47	
48	# ---------------------------------------------------------------------------
49	# Title-odds: ranked horizontal bar chart
50	# ---------------------------------------------------------------------------
51	
52	
53	def _sorted_champion_probs(forecast_result: Any) -> list[tuple[str, float]]:
54	    return sorted(
55	        forecast_result.champion_probabilities.items(),
56	        key=lambda kv: kv[1],
57	        reverse=True,
58	    )
59	
60	
61	def _build_title_odds_axes(
62	    ax: matplotlib.axes.Axes,
63	    items: list[tuple[str, float]],
64	) -> None:
65	    """Render a ranked horizontal bar chart onto *ax*."""
66	    teams = [t for t, _ in items]
67	    values = [p for _, p in items]
68	    n = len(teams)
69	    ax.barh(range(n), values, align="center", color="steelblue", edgecolor="white")
70	    ax.set_yticks(range(n))
71	    ax.set_yticklabels(teams, fontsize=max(5, 9 - n // 10))
72	    ax.invert_yaxis()
73	    ax.set_xlabel("Champion Probability")
74	    ax.set_title("FIFA World Cup 2026 — Title Odds")
75	
76	
77	def _build_title_odds_figure(items: list[tuple[str, float]]) -> plt.Figure:
78	    n = len(items)
79	    fig, ax = plt.subplots(figsize=(10, max(6, n * 0.28)))
80	    _build_title_odds_axes(ax, items)
81	    plt.tight_layout()
82	    return fig
83	
84	
85	def plot_title_odds(
86	    forecast_result: Any,
87	    output_path: Path | str,
88	    config: VisualizationConfig | None = None,
89	) -> None:
90	    """Render a ranked horizontal bar chart of champion probabilities and save a PNG.
91	
92	    Reads ``forecast_result.champion_probabilities`` duck-typed.
93	
94	    Args:
95	        forecast_result: Object exposing ``.champion_probabilities: dict[str, float]``.
96	        output_path: Destination PNG path (``str`` or ``Path``).
97	        config: Visualization settings; uses :class:`VisualizationConfig` defaults if None.
98	    """
99	    cfg = _resolve_config(config)
100	    _apply_style(cfg)
101	    fig = _build_title_odds_figure(_sorted_champion_probs(forecast_result))
102	    _save_and_close(fig, output_path)
103	
104	
105	# ---------------------------------------------------------------------------
106	# Per-round advancement: heatmap
107	# ---------------------------------------------------------------------------
108	
109	
110	def _round_team_matrix(
111	    rounds: list[str],
112	    teams: list[str],
113	    round_probs: dict[str, dict[str, float]],
114	) -> np.ndarray:
115	    return np.array([[round_probs[r].get(t, 0.0) for r in rounds] for t in teams])
116	
117	
118	def _configure_heatmap(
119	    ax: matplotlib.axes.Axes,
120	    data: np.ndarray,
121	    rounds: list[str],
122	    teams: list[str],
123	) -> Any:
124	    """Paint the heatmap image and configure axis labels; returns the image."""
125	    im = ax.imshow(data, aspect="auto", cmap="Blues")
126	    ax.set_xticks(range(len(rounds)))
127	    ax.set_xticklabels(rounds, rotation=30, ha="right", fontsize=9)
128	    ax.set_yticks(range(len(teams)))
129	    ax.set_yticklabels(teams, fontsize=max(4, 8 - len(teams) // 10))
130	    return im
131	
132	
133	def _build_round_advancement_figure(
134	    round_probs: dict[str, dict[str, float]],
135	) -> plt.Figure:
136	    rounds = list(round_probs.keys())
137	    teams = sorted({t for probs in round_probs.values() for t in probs})
138	    fig, ax = plt.subplots(figsize=(max(6, len(rounds) * 1.5), max(6, len(teams) * 0.28)))
139	    if not rounds or not teams:
140	        return fig
141	    data = _round_team_matrix(rounds, teams, round_probs)
142	    im = _configure_heatmap(ax, data, rounds, teams)
143	    fig.colorbar(im, ax=ax, label="Advancement Probability")
144	    ax.set_title("FIFA World Cup 2026 — Per-Round Advancement Probabilities")
145	    plt.tight_layout()
146	    return fig
147	
148	
149	def plot_round_advancement(
150	    round_probs: dict[str, dict[str, float]],
151	    output_path: Path | str,
152	    config: VisualizationConfig | None = None,
153	) -> None:
154	    """Render a per-round advancement heatmap and save a PNG.
155	
156	    Accepts the ``{round_name: {team: probability}}`` contract directly.
157	
158	    Args:
159	        round_probs: Mapping of round name to ``{team: advancement_probability}``.
160	        output_path: Destination PNG path (``str`` or ``Path``).
161	        config: Visualization settings; uses :class:`VisualizationConfig` defaults if None.
162	    """
163	    cfg = _resolve_config(config)
164	    _apply_style(cfg)
165	    fig = _build_round_advancement_figure(round_probs)
166	    _save_and_close(fig, output_path)
