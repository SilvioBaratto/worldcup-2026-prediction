30	class OddsScraper:
31	    """Cache-first scraper for WC2014/18/22 bookmaker odds (backtest baseline only)."""
32	
33	    def __init__(
34	        self,
35	        config: OddsConfig | None = None,
36	        cache_dir: Path | None = None,
37	    ) -> None:
38	        cfg = config or OddsConfig()
39	        self._config = cfg
40	        self._cache_dir = cache_dir if cache_dir is not None else cfg.cache_dir
41	
42	    def load(self, tournament: str) -> pd.DataFrame:
43	        """Return the odds DataFrame for *tournament*, reading from cache when available."""
44	        path = self._cache_path(tournament)
45	        if path.exists():
46	            return pd.read_csv(path)
47	        return self._fetch_and_cache(tournament, path)
48	
49	    def parse_html(self, html: str) -> pd.DataFrame:
50	        """Parse a bookmaker odds page with BeautifulSoup; return 'team'/'odds' DataFrame."""
51	        soup = BeautifulSoup(html, "html.parser")
52	        rows = [r for row in soup.select("tr") for r in [self._parse_row(row)] if r]
53	        if not rows:
54	            return pd.DataFrame(columns=["team", "odds"])
55	        return pd.DataFrame(rows, columns=["team", "odds"])
56	
57	    # ── private ──────────────────────────────────────────────────────────────
58	
59	    def _cache_path(self, tournament: str) -> Path:
60	        return self._cache_dir / f"{tournament}_odds.csv"
61	
62	    def _fetch_and_cache(self, tournament: str, path: Path) -> pd.DataFrame:
63	        try:
64	            url = _SEASON_URLS.get(tournament, self._config.source_url)
65	            html = self._fetch_html(url)
66	            df = self.parse_html(html)
67	            df["team"] = df["team"].map(_cw.normalize_team)
68	            path.parent.mkdir(parents=True, exist_ok=True)
69	            df.to_csv(path, index=False)
70	            return df
71	        except Exception:
72	            logger.warning("Odds fetch failed for %s; returning empty frame.", tournament)
73	            return pd.DataFrame(columns=["team", "odds"])
