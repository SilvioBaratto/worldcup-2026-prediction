204	class ModelEvaluator:
205	    """Evaluates classifier performance."""
206	
207	    @staticmethod
208	    def evaluate(
209	        classifier: Any,
210	        X_test: np.ndarray,
211	        y_test: np.ndarray,
212	    ) -> dict[str, Any]:
213	        """Return confusion matrix and classification report as a dict."""
214	        y_pred = classifier.predict(X_test)
215	        return {
216	            "confusion_matrix": confusion_matrix(y_test, y_pred),
217	            "classification_report": classification_report(
218	                y_test, y_pred, output_dict=True
219	            ),
220	        }
221	
222	    @staticmethod
223	    def plot_roc_curves(
224	        classifiers: dict[str, Any],
225	        X_test: np.ndarray,
226	        y_test: np.ndarray,
227	        output_path: Path | None = None,
228	    ) -> None:
229	        """Plot ROC curves for multiple classifiers."""
230	        import matplotlib.pyplot as plt
231	
232	        fig, ax = plt.subplots(figsize=(10, 8))
233	        linestyles = ["-", ":", "--", "-.", (0, (3, 1, 1, 1))]
234	
235	        for i, (name, clf) in enumerate(classifiers.items()):
236	            RocCurveDisplay.from_estimator(
237	                clf, X_test, y_test,
238	                ax=ax,
239	                linewidth=3,
240	                linestyle=linestyles[i % len(linestyles)],
241	                name=name,
242	            )
243	
244	        ax.tick_params(axis="both", labelsize=16)
245	        ax.set_xlabel("False Positive Rate", fontsize=18)
246	        ax.set_ylabel("True Positive Rate", fontsize=18)
247	        ax.legend(fontsize=14)
248	
249	        if output_path:
250	            output_path.parent.mkdir(parents=True, exist_ok=True)
251	            fig.savefig(output_path, bbox_inches="tight")
252	            logger.info("ROC curve saved to %s", output_path)
253	        plt.close(fig)
