3	Predicts per-match expected goals via a blended Random-Forest + Gradient-Boosting
4	regressor pair, then converts the goal pair to a W/D/L distribution via the
5	reused Dixon-Coles τ-corrected score matrix from ``simulation.poisson``.
6	
7	Design matrix conventions:
8	- Explicit allow-list: only numeric + encoded columns enter; targets/identity/metadata
9	  (home_goals, away_goals, date, home_team, away_team, tournament) are silently excluded.
10	- Confederation strings (home_confederation, away_confederation) are one-hot encoded
11	  against the fixed ``CONFEDERATIONS`` tuple — never data-dependent discovery.
12	- None/unknown confederation → all-zero one-hot row (no NaN leakage).
13	- Nullable numeric columns (rest_days, ranking) are imputed at fit time with the
14	  training-set median; sentinels are stored and reused at inference (no leakage).
15	"""
16	
17	from __future__ import annotations
18	
19	from dataclasses import dataclass
20	from typing import Any
21	
22	import numpy as np
23	import pandas as pd
24	from sklearn.ensemble import GradientBoostingRegressor, RandomForestRegressor
25	
26	from worldcup_playoff.config import HybridConfig
27	from worldcup_playoff.features.confederation import CONFEDERATIONS
28	from worldcup_playoff.models.dataset import MatchDataset
29	from worldcup_playoff.simulation.poisson import score_matrix
30	
31	__all__ = ["GoalPrediction", "HybridModel", "fit_hybrid"]
32	
33	# ─── Constants ───────────────────────────────────────────────────────────────
34	
35	_FORBIDDEN: frozenset[str] = frozenset(
36	    {"home_goals", "away_goals", "date", "home_team", "away_team", "tournament"}
37	)
38	_CONFED_COLS: frozenset[str] = frozenset({"home_confederation", "away_confederation"})
39	
40	
41	# ─── Value object ────────────────────────────────────────────────────────────
42	
43	
44	@dataclass(frozen=True)
45	class GoalPrediction:
46	    """Outcome distribution and expected goal pair for one match."""
47	
48	    prob_home: float
49	    prob_draw: float
50	    prob_away: float
51	    home_goals: float
52	    away_goals: float
53	    margin: float  # home_goals − away_goals
54	
55	
56	# ─── Pure module-level helpers ────────────────────────────────────────────────
57	
58	
59	def _one_hot_confed(series: pd.Series) -> np.ndarray:
60	    """Encode confederation strings → (n, 6) float array; None/unknown → all-zero row."""
61	    cats = list(CONFEDERATIONS)
62	    out = np.zeros((len(series), len(cats)), dtype=float)
63	    for i, val in enumerate(series):
64	        if val in cats:
65	            out[i, cats.index(val)] = 1.0
66	    return out
67	
68	
69	def _numeric_col(series: pd.Series, sentinel: float) -> np.ndarray:
70	    """Cast a numeric-or-bool Series to a (n,1) float array, filling NaN with sentinel."""
71	    if pd.api.types.is_bool_dtype(series):
72	        return np.asarray(series.fillna(False).astype(float), dtype=float).reshape(-1, 1)
73	    coerced = pd.to_numeric(series, errors="coerce").fillna(sentinel)
74	    return np.asarray(coerced, dtype=float).reshape(-1, 1)
75	
76	
77	def _col_array(df: pd.DataFrame, col: str, sentinels: dict[str, float]) -> np.ndarray:
78	    """Convert one feature column to a (n, k) float array; impute NaN via sentinel."""
79	    if col not in df.columns:
80	        return np.full((len(df), 1), sentinels.get(col, 0.0))
81	    series = df[col]
82	    if col in _CONFED_COLS:
83	        return _one_hot_confed(series)
84	    return _numeric_col(series, sentinels.get(col, 0.0))
85	
86	
87	def build_design_matrix(
88	    df: pd.DataFrame, feature_cols: list[str], sentinels: dict[str, float] | None = None
89	) -> np.ndarray:
90	    """Return float design matrix; excludes forbidden cols, encodes categoricals, imputes NaN."""
91	    safe = [c for c in feature_cols if c not in _FORBIDDEN]
92	    if not safe:
93	        return np.zeros((len(df), 0))
94	    return np.hstack([_col_array(df, c, sentinels or {}) for c in safe])
95	
96	
97	def _fit_sentinels(df: pd.DataFrame, cols: list[str]) -> dict[str, float]:
98	    """Compute fit-time median imputation values for nullable numeric columns."""
99	    out: dict[str, float] = {}
100	    for col in cols:
101	        if col in _FORBIDDEN or col in _CONFED_COLS or col not in df.columns:
102	            continue
103	        median = float(pd.to_numeric(df[col], errors="coerce").median())
104	        out[col] = 0.0 if np.isnan(median) else median
105	    return out
106	
107	
108	def derive_outcome_probs(
109	    lh: float, la: float, *, max_goals: int, rho: float
110	) -> tuple[float, float, float]:
111	    """Return (prob_home, prob_draw, prob_away) via the τ-corrected score matrix."""
112	    mat = score_matrix(lh, la, rho=rho, max_goals=max_goals)
113	    ph = float(np.tril(mat, -1).sum())  # home score > away score
114	    pd_ = float(np.diag(mat).sum())  # equal scores (draw)
115	    pa = float(np.triu(mat, 1).sum())  # away score > home score
116	    return ph, pd_, pa
117	
118	
119	def _make_prediction(lh: float, la: float, cfg: HybridConfig) -> GoalPrediction:
120	    ph, pd_, pa = derive_outcome_probs(lh, la, max_goals=cfg.max_goals, rho=cfg.rho)
121	    return GoalPrediction(ph, pd_, pa, lh, la, lh - la)
122	
123	
124	def _new_rf(cfg: HybridConfig) -> RandomForestRegressor:
125	    return RandomForestRegressor(
126	        n_estimators=cfg.rf_n_estimators,
127	        max_depth=cfg.rf_max_depth,
128	        random_state=cfg.random_seed,
129	        n_jobs=1,
130	    )
131	
132	
133	def _new_gb(cfg: HybridConfig) -> GradientBoostingRegressor:
134	    return GradientBoostingRegressor(
135	        n_estimators=cfg.gb_n_estimators,
136	        learning_rate=cfg.gb_learning_rate,
137	        random_state=cfg.random_seed,
138	    )
139	
140	
141	def _fit_pair(
142	    cfg: HybridConfig, X: np.ndarray, y: np.ndarray
143	) -> tuple[RandomForestRegressor, GradientBoostingRegressor]:
144	    """Fit and return one (RF, GB) regressor pair for a single goal target."""
145	    return _new_rf(cfg).fit(X, y), _new_gb(cfg).fit(X, y)
146	
