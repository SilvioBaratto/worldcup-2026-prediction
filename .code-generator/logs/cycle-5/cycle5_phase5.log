23	def de_vig(odds: list[float]) -> list[float]:
24	    """De-vig decimal odds to probabilities: p_i = (1/o_i) / Σ(1/o_j)."""
25	    inv = [1.0 / o for o in odds]
26	    total = sum(inv)
27	    return [v / total for v in inv]
