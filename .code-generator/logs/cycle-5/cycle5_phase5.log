140	
141	def _fetch_state_and_abilities(cfg: Any) -> tuple[TournamentState, TeamAbilities]:
142	    """Load live tournament state and fit Dixon-Coles abilities (may raise)."""
143	    from worldcup_playoff.data.live import fetch_tournament_state
144	    from worldcup_playoff.data.martj42_loader import load_martj42_results
145	    from worldcup_playoff.simulation.poisson import fit_dixon_coles
146	    state = fetch_tournament_state()
147	    df = load_martj42_results(cfg.martj42)
148	    return state, fit_dixon_coles(df, cfg.poisson)
149	
150	
151	def _play_round(
152	    pairs: list[tuple[str, str]],
153	    abilities: TeamAbilities,
154	    sampler: Any,
155	    rng: np.random.Generator,
156	    extra_time_factor: float,
157	    pcfg: Any,
158	) -> list[str]:
159	    from worldcup_playoff.simulation.knockout import resolve_tie
160	    return [
161	        resolve_tie(h, a, sampler=sampler, extra_time_factor=extra_time_factor,
162	                    seed=int(rng.integers(2**32)), abilities=abilities, poisson_config=pcfg, rng=rng)
163	        for h, a in pairs
164	    ]
165	
166	
167	def _knockout_sim_fn(abilities: TeamAbilities, cfg: Any) -> _KnockoutSimFn:
168	    """Return a one-shot knockout callable wired to the real Dixon-Coles model."""
169	    from worldcup_playoff.config import SimulationConfig, PoissonConfig
170	    from worldcup_playoff.simulation.poisson import make_sampler
171	    sim_cfg = getattr(cfg, "simulation", SimulationConfig())
172	    pcfg = getattr(cfg, "poisson", PoissonConfig())
173	
174	    def _sim(qualified: list[str], ab: TeamAbilities, rng: np.random.Generator) -> dict:
175	        sampler = make_sampler(ab, pcfg)
176	        pairs = [(qualified[i], qualified[i + 1]) for i in range(0, len(qualified), 2)]
177	        rounds: dict[str, dict[str, int]] = {}
178	        current = _play_round(pairs, ab, sampler, rng, sim_cfg.extra_time_factor, pcfg)
179	        rounds["R32"] = {w: 1 for w in current}
180	        for rnd in ("R16", "QF", "SF", "Final"):
181	            if len(current) <= 1:
182	                break
183	            current = _play_round(
184	                [(current[i], current[i + 1]) for i in range(0, len(current), 2)],
185	                ab, sampler, rng, sim_cfg.extra_time_factor, pcfg,
186	            )
187	            rounds[rnd] = {w: 1 for w in current}
188	        return {"champion": current[0] if current else "", "rounds": rounds}
189	
190	    return _sim
191	
192	
193	def _group_sim_fn(abilities: TeamAbilities) -> _GroupSimFn:
194	    """Return a group-stage callable wired to GroupStageSimulator + resolve_r32."""
195	    from worldcup_playoff.simulation.poisson import make_sampler
196	    from worldcup_playoff.simulation.group_stage import GroupStageSimulator
197	    from worldcup_playoff.data.wc2026_bracket import resolve_r32
198	    import random
199	
200	    def _sim(state: TournamentState, ab: TeamAbilities, rng: np.random.Generator) -> list[str]:
201	        py_rng = random.Random(int(rng.integers(2**32)))
202	        gs = GroupStageSimulator(make_sampler(ab), py_rng)
203	        return [t for pair in resolve_r32(gs.simulate(state)) for t in pair]
204	
205	    return _sim
206	
207	
208	def run_forecast(
209	    cfg: Any = None,
210	    *,
211	    seed: int = 42,
212	    n_simulations: int = 10_000,
213	) -> ForecastResult | None:
214	    """High-level CLI entry: fetch live WC2026 state, fit abilities, run N simulations.
215	
216	    Falls back to ``None`` when martj42 data or the live API is unavailable so
217	    the ``forecast`` CLI command can degrade gracefully without crashing.
218	    Re-runnable: each call derives fresh child seeds from *seed* via SeedSequence.
219	    """
220	    from worldcup_playoff.config import AppConfig
221	    resolved = cfg if cfg is not None else AppConfig()
222	    try:
223	        state, abilities = _fetch_state_and_abilities(resolved)
224	    except Exception:
225	        return None
226	    return LiveForecaster(
227	        _group_sim_fn(abilities), _knockout_sim_fn(abilities, resolved)
228	    ).run(state, abilities, n_simulations, seed)
