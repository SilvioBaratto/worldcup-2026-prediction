2026-06-24 05:32:19,655 DEBUG msg #58: UserMessage tool_result(toolu_01N7cSXgJWm21TBxVmoxFgyV): 1	"""Live-tournament Monte-Carlo forecast orchestrator for WC2026.
2	
3	Runs ~100k seeded simulations (group-stage → knockout) conditioned on played
4	WC2026 results and aggregates per-team title odds + per-round advancement
5	probabilities for all 48 teams.
6	
7	Key design choices
8	------------------
9	- **Callable injection**: ``LiveForecaster`` accepts ``group_simulator`` and
10	  ``knockout_simulator`` protocol callables so it can be tested with stubs and
11	  used with real ``GroupStageSimulator`` / ``KnockoutSimulator`` via factory
12	  adapters.  This decouples orchestration from the concrete implementations in
13	  ``group_stage.py`` and ``knockout.py``.
14	- **SeedSequence sub-seeding**: the master seed is expanded into N
15	  statistically-independent child seeds via ``numpy.random.SeedSequence.spawn``
16	  so that (a) the same master seed yields bit-identical odds on any re-run, and
17	  (b) each tournament iteration draws from an independent, decorrelated stream —
18	  avoiding the intra-tournament correlation that arises from re-seeding with the
19	  same integer.
20	- **Fit-once pattern**: ``TeamAbilities`` are computed outside the Monte-Carlo
21	  loop and accepted by ``LiveForecaster.run()``; the loop only draws samples.
22	"""
23	from __future__ import annotations
24	
25	from dataclasses import dataclass
26	from typing import Any, Callable
27	
28	import numpy as np
29	
30	from worldcup_playoff.data.live import TournamentState
31	from worldcup_playoff.simulation.poisson import TeamAbilities
32	
33	# Re-export so callers can import everything from one place.
34	__all__ = [
35	    "ForecastResult",
36	    "LiveForecaster",
37	    "TournamentState",
38	    "TeamAbilities",
39	]
40	
41	# ---------------------------------------------------------------------------
42	# Callable protocols (structural — no ABC overhead)
43	# ---------------------------------------------------------------------------
44	
45	#: Signature: (state, abilities, rng) → list of 32 qualified team names.
46	_GroupSimFn = Callable[
47	    [TournamentState, TeamAbilities, np.random.Generator],
48	    list[str],
49	]
50	
51	#: Signature: (qualified_teams, abilities, rng) → {"champion": str, "rounds": dict}.
52	_KnockoutSimFn = Callable[
53	    [list[str], TeamAbilities, np.random.Generator],
54	    dict[str, Any],
55	]
56	
57	# ---------------------------------------------------------------------------
58	# Value objects
59	# ---------------------------------------------------------------------------
60	
61	
62	@dataclass(frozen=True)
63	class ForecastResult:
64	    """Immutable result of a live Monte-Carlo forecast.
65	
66	    Attributes
67	    ----------
68	    champion_probabilities:
69	        Per-team title-odds: ``count / n_simulations``.  **All 48 group-stage
70	        teams are present**, including those with probability 0.0.
71	    round_probabilities:
72	        ``{round_name: {team: probability}}`` advancement fractions.
73	        Reuses the ``RoundResult.probabilities`` contract: each team's value
74	        is its individual advancement probability (``count / n_simulations``),
75	        so values across a round sum to the number of ties in that round, not
76	        to 1.0.  Only rounds that appear in at least one simulation are
77	        included.
78	    """
79	
80	    champion_probabilities: dict[str, float]
81	    round_probabilities: dict[str, dict[str, float]]
82	
83	
84	# ---------------------------------------------------------------------------
85	# Private helpers (module-level, ≤10 lines each)
86	# ---------------------------------------------------------------------------
87	
88	
89	def _teams_from_matches(matches: list[Any]) -> set[str]:
90	    """Collect non-null home/away team names from a flat list of match objects."""
91	    teams: set[str] = set()
92	    for m in matches:
93	        if m.home_team:
94	            teams.add(m.home_team)
95	        if m.away_team:
96	            teams.add(m.away_team)
97	    return teams
98	
99	
100	def _extract_all_teams(state: TournamentState) -> list[str]:
101	    """Return sorted list of all group-stage teams from standings or match history."""
102	    teams = {
103	        row.team_name
104	        for gs in state.standings
105	        for row in gs.table
106	        if row.team_name
107	    }
108	    if not teams:
109	        teams = _teams_from_matches(list(state.played) + list(state.remaining_group_fixtures))
110	    return sorted(teams)
111	
112	
113	def _accumulate_rounds(
114	    acc: dict[str, dict[str, int]],
115	    rounds: dict[str, Any],
116	) -> None:
117	    """Merge one simulation's per-round team-count dict into *acc* in place."""
118	    for round_name, team_counts in rounds.items():
119	        bucket = acc.setdefault(round_name, {})
120	        for team, count in team_counts.items():
121	            bucket[team] = bucket.get(team, 0) + count
122	
123	
124	def _to_probabilities(counts: dict[str, int], n: int) -> dict[str, float]:
125	    """Divide raw counts by *n*; return zeroes when n == 0."""
126	    if n == 0:
127	        return {t: 0.0 for t in counts}
128	    return {t: c / n for t, c in counts.items()}
129	
