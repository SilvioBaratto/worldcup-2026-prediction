86	            j += 1
87	        sub = by_h2h[i:j]
88	        if len(sub) > 1:
89	            rng.shuffle(sub)
90	        result.extend(sub)
91	        i = j
92	    return result
93	
94	
95	def _rank_group(
96	    teams: list[str],
97	    stats: dict[str, _TeamStats],
98	    matches: list[_Match],
99	    rng: _random.Random,
100	) -> list[str]:
101	    """Return teams in ranked order using the full FIFA tiebreak chain."""
102	    ordered = sorted(teams, key=lambda t: _sort_key(stats[t]))
103	    result: list[str] = []
104	    i = 0
105	    while i < len(ordered):
106	        j = i + 1
107	        while j < len(ordered) and _sort_key(stats[ordered[j]]) == _sort_key(stats[ordered[i]]):
108	            j += 1
109	        group = ordered[i:j]
110	        if len(group) > 1:
111	            group = _resolve_tied(group, matches, rng)
112	        result.extend(group)
113	        i = j
114	    return result
115	
116	
117	def _to_v4_row(name: str, stats: _TeamStats, position: int) -> dict[str, Any]:
118	    """Produce a football-data.org v4 standings row consumed by resolve_r32."""
119	    return {
120	        "team": {"name": name},
121	        "position": position,
122	        "points": stats.pts,
123	        "goalsFor": stats.gf,
124	        "goalsAgainst": stats.ga,
125	        "goalDifference": stats.gd,
126	    }
127	
128	
129	def _extract_scoreline(raw: Any) -> tuple[int, int]:
130	    """Normalise sampler output (tuple or ndarray) to (home_goals, away_goals)."""
131	    if isinstance(raw, tuple):
132	        return int(raw[0]), int(raw[1])
133	    if hasattr(raw, "ndim") and raw.ndim == 2:  # ndarray shape (size, 2)
134	        return int(raw[0, 0]), int(raw[0, 1])
135	    return int(raw[0]), int(raw[1])  # ndarray shape (2,)
136	
137	
138	def _get_played(state: Any) -> list[Any]:
139	    """Return played matches, tolerating both .played and .played_matches."""
140	    if hasattr(state, "played_matches"):
141	        return list(state.played_matches)
142	    return list(state.played)
143	
144	
145	# ─────────────────────────────────────────────────────────────────────────────
146	# GroupStageSimulator
147	# ─────────────────────────────────────────────────────────────────────────────
148	
149	
150	class GroupStageSimulator:
151	    """Simulates remaining group matches; ranks all groups by FIFA tiebreaks."""
152	
153	    def __init__(self, sampler: Any, rng: _random.Random) -> None:
154	        self._sampler = sampler
155	        self._rng = rng
156	
157	    def simulate(self, state: Any) -> dict[str, list[dict[str, Any]]]:
158	        """Return v4 standings dict keyed by group label."""
159	        groups = self._collect(state)
160	        return {g: self._table(ms) for g, ms in groups.items()}
161	
162	    def _collect(self, state: Any) -> dict[str, list[_Match]]:
163	        groups: dict[str, list[_Match]] = {}
164	        for m in _get_played(state):
165	            _append(groups, m.group, m.home_team, m.away_team, m.home_goals, m.away_goals)
166	        for f in state.remaining_group_fixtures:
167	            hg, ag = _extract_scoreline(self._sampler.sample(f.home_team, f.away_team))
168	            _append(groups, f.group, f.home_team, f.away_team, hg, ag)
169	        return groups
170	
171	    def _table(self, matches: list[_Match]) -> list[dict[str, Any]]:
172	        stats = _build_stats(matches)
173	        ranked = _rank_group(list(stats), stats, matches, self._rng)
174	        return [_to_v4_row(t, stats[t], pos + 1) for pos, t in enumerate(ranked)]
175	
176	
177	def _append(
178	    groups: dict[str, list[_Match]],
179	    group: str,
180	    home: str,
181	    away: str,
182	    hg: int,
183	    ag: int,
184	) -> None:
185	    """Append a resolved match to the group registry."""
186	    groups.setdefault(group, []).append((home, away, hg, ag))
