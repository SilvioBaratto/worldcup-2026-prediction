12	from worldcup_playoff.config import OddsConfig
13	
14	logger = logging.getLogger(__name__)
15	
16	_SEASON_URLS: dict[str, str] = {
17	    "wc2014": "https://www.oddsportal.com/soccer/world/world-cup-2014/results/",
18	    "wc2018": "https://www.oddsportal.com/soccer/world/world-cup-2018/results/",
19	    "wc2022": "https://www.oddsportal.com/soccer/world/world-cup-2022/results/",
20	}
21	
22	
23	def de_vig(odds: list[float]) -> list[float]:
24	    """De-vig decimal odds to probabilities: p_i = (1/o_i) / Σ(1/o_j)."""
25	    inv = [1.0 / o for o in odds]
26	    total = sum(inv)
27	    return [v / total for v in inv]
28	
29	
30	class OddsScraper:
31	    """Cache-first scraper for WC2014/18/22 bookmaker odds (backtest baseline only)."""
32	
33	    def __init__(
34	        self,
35	        config: OddsConfig | None = None,
36	        cache_dir: Path | None = None,
37	    ) -> None:
38	        cfg = config or OddsConfig()
39	        self._config = cfg
40	        self._cache_dir = cache_dir if cache_dir is not None else cfg.cache_dir
41	
42	    def load(self, tournament: str) -> pd.DataFrame:
43	        """Return the odds DataFrame for *tournament*, reading from cache when available."""
44	        path = self._cache_path(tournament)
45	        if path.exists():
46	            return pd.read_csv(path)
47	        return self._fetch_and_cache(tournament, path)
48	
49	    def parse_html(self, html: str) -> pd.DataFrame:
50	        """Parse a bookmaker odds page with BeautifulSoup; return 'team'/'odds' DataFrame."""
51	        soup = BeautifulSoup(html, "html.parser")
52	        rows = [r for row in soup.select("tr") for r in [self._parse_row(row)] if r]
53	        if not rows:
54	            return pd.DataFrame(columns=["team", "odds"])
55	        return pd.DataFrame(rows, columns=["team", "odds"])
56	
57	    # ── private ──────────────────────────────────────────────────────────────
58	
59	    def _cache_path(self, tournament: str) -> Path:
60	        return self._cache_dir / f"{tournament}_odds.csv"
61	
62	    def _fetch_and_cache(self, tournament: str, path: Path) -> pd.DataFrame:
63	        try:
64	            url = _SEASON_URLS.get(tournament, self._config.source_url)
65	            html = self._fetch_html(url)
66	            df = self.parse_html(html)
67	            df["team"] = df["team"].map(_cw.normalize_team)
68	            path.parent.mkdir(parents=True, exist_ok=True)
69	            df.to_csv(path, index=False)
70	            return df
71	        except Exception:
72	            logger.warning("Odds fetch failed for %s; returning empty frame.", tournament)
73	            return pd.DataFrame(columns=["team", "odds"])
74	
75	    def _fetch_html(self, url: str) -> str:
76	        """Fetch raw HTML from *url*. Assign to the instance to override in tests."""
77	        headers = {"User-Agent": self._config.user_agent}
78	        resp = requests.get(url, headers=headers, timeout=self._config.request_timeout)
79	        resp.raise_for_status()
80	        return resp.text
81	
82	    def _parse_row(self, row: BeautifulSoup) -> tuple[str, float] | None:
83	        team_tag = row.select_one(".team-name") or row.select_one("td.table-participant")
84	        odds_tag = row.select_one(".table-odds")
85	        if not (team_tag and odds_tag):
86	            return None
87	        try:
88	            return (team_tag.get_text(strip=True), float(odds_tag.get_text(strip=True)))
89	        except (ValueError, AttributeError):
90	            return None
91	
92	
93	def load_odds(tournament: str, config: OddsConfig | None = None) -> pd.DataFrame:
94	    """Module-level convenience: load archived odds for *tournament*."""
95	    return OddsScraper(config=config).load(tournament)
