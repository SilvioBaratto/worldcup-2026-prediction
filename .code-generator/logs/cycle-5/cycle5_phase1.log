88	def _print_simulation_results(rounds: dict) -> None:  # type: ignore[type-arg]
89	    """Print simulation results as Rich tables, one per round.
90	
91	    Args:
92	        rounds: Mapping of round index to ``RoundResult`` from
93	            ``TournamentSimulator.simulate``.
94	    """
95	    round_names = {
96	        0: "Round of 32",
97	        1: "Round of 16",
98	        2: "Quarter-finals",
99	        3: "Semi-finals",
100	        4: "Final",
101	    }
102	
103	    for round_num, result in sorted(rounds.items()):
104	        probs = result.probabilities
105	        sorted_probs = sorted(
106	            ((team, p) for team, p in probs.items() if p > 0),
107	            key=lambda x: x[1],
108	            reverse=True,
109	        )
110	
111	        table = Table(
112	            title=f"[bold]{round_names.get(round_num, f'Round {round_num}')}[/bold]"
113	        )
114	        table.add_column("Team", style="cyan")
115	        table.add_column("Win Probability", justify="right")
116	
117	        for team, prob in sorted_probs:
118	            bar = "█" * int(prob * 40)
119	            table.add_row(team, f"{prob:6.1%} {bar}")
120	
121	        console.print(table)
122	        console.print()
