61	# ---------------------------------------------------------------------------
62	# Bipartite matching (private helpers)
63	# ---------------------------------------------------------------------------
64	
65	
66	def _augment(
67	    slot: int,
68	    adj: list[list[int]],
69	    match: list[int],
70	    seen: list[bool],
71	) -> bool:
72	    """Try to find an augmenting path for *slot*; update *match* in-place."""
73	    for g in adj[slot]:
74	        if not seen[g]:
75	            seen[g] = True
76	            if match[g] == -1 or _augment(match[g], adj, match, seen):
77	                match[g] = slot
78	                return True
79	    return False
80	
81	
82	def _bipartite_match(
83	    qualifying: frozenset[str],
84	    slots: tuple[tuple[str, frozenset[str]], ...],
85	) -> dict[str, str] | None:
86	    """Return slot→group assignment via augmenting paths, or None if impossible."""
87	    groups = sorted(qualifying)
88	    g_idx = {g: i for i, g in enumerate(groups)}
89	    adj = [[g_idx[g] for g in cands if g in qualifying] for _, cands in slots]
90	    match: list[int] = [-1] * len(groups)
91	    n = sum(_augment(s, adj, match, [False] * len(groups)) for s in range(len(slots)))
92	    if n < len(slots):
93	        return None
94	    slot_map = {match[i]: groups[i] for i in range(len(groups)) if match[i] != -1}
95	    return {slots[s][0]: slot_map[s] for s in range(len(slots))}
96	
97	
98	# ---------------------------------------------------------------------------
99	# THIRD_PLACE_COMBINATIONS — computed once at import (pure, deterministic)
100	# ---------------------------------------------------------------------------
101	
102	
103	def _compute_third_place_combinations() -> dict[frozenset[str], dict[str, str]]:
104	    """Enumerate all valid 8-of-12 qualifying-third combinations via bipartite matching."""
105	    return {
106	        frozenset(combo): m
107	        for combo in combinations(GROUPS, 8)
108	        if (m := _bipartite_match(frozenset(combo), _THIRD_SLOT_CANDIDATES)) is not None
109	    }
110	
111	
112	# Official lookup: qualifying-8-groups frozenset → {placeholder: group_letter}.
113	# Covers every 8-of-12 combination that admits a valid slot assignment.
114	THIRD_PLACE_COMBINATIONS: dict[frozenset[str], dict[str, str]] = _compute_third_place_combinations()
115	
116	
117	# ---------------------------------------------------------------------------
118	# Private slot-resolution helpers
119	# ---------------------------------------------------------------------------
120	
121	
122	def _get_row_at(table: list[dict[str, Any]], position: int) -> dict[str, Any]:
123	    """Return the row whose `position` field equals *position*, or fall back by index."""
124	    return next(
125	        (r for r in table if r.get("position") == position),
126	        table[position - 1],
127	    )
128	
129	
130	def _third_sort_key(group: str, row: dict[str, Any]) -> tuple[int, int, int, str]:
131	    """FIFA tiebreak key for third-placed teams (lower = better rank)."""
132	    return (
133	        -row.get("points", 0),
134	        -row.get("goalDifference", 0),
135	        -row.get("goalsFor", 0),
136	        group,  # alphabetical as the final, deterministic tiebreaker
137	    )
138	
139	
140	def _resolve_slot(
141	    slot: str,
142	    standings: dict[str, list[dict[str, Any]]],
143	    third_map: dict[str, str],
144	) -> str:
145	    """Translate a bracket slot label into a concrete team name."""
146	    group = third_map[slot] if slot.startswith("3") else slot[1]
147	    pos = 3 if slot.startswith("3") else int(slot[0])
148	    team_info: dict[str, Any] = _get_row_at(standings[group], pos)["team"]
149	    return cast(str, team_info["name"])
150	
151	
152	# ---------------------------------------------------------------------------
153	# Public API
154	# ---------------------------------------------------------------------------
155	
156	
157	def rank_third_places(standings: dict[str, list[dict[str, Any]]]) -> list[str]:
158	    """Return the 8 qualifying third-place group letters ranked by FIFA tiebreak.
159	
160	    *standings* maps group letter → list-of-table-row dicts (football-data.org v4 schema).
161	    """
162	    ranked = sorted(
163	        standings.items(),
164	        key=lambda kv: _third_sort_key(kv[0], _get_row_at(kv[1], 3)),
165	    )
166	    return [group for group, _ in ranked[:8]]
167	
168	
169	def assign_thirds(qualified_third_groups: frozenset[str]) -> dict[str, str]:
170	    """Map each 3X placeholder to a concrete group letter via THIRD_PLACE_COMBINATIONS."""
171	    return THIRD_PLACE_COMBINATIONS[qualified_third_groups]
172	
173	
174	def resolve_r32(standings: dict[str, list[dict[str, Any]]]) -> list[tuple[str, str]]:
175	    """Resolve 16 R32 ties from final group standings to concrete (home, away) pairs."""
176	    third_map = assign_thirds(frozenset(rank_third_places(standings)))
177	    return [
178	        (_resolve_slot(h, standings, third_map), _resolve_slot(a, standings, third_map))
179	        for h, a in R32_SLOTS
180	    ]
