406	@app.command(name="build-match-details")
407	def build_match_details(
408	    config: Path = typer.Option(
409	        "config/default.toml", "--config", "-c", help="Pipeline config"
410	    ),
411	    matches_csv: Path = typer.Option(
412	        "dataset/csv/matches.csv",
413	        "--matches-csv",
414	        help="Source matches.csv for MATCH_ID column.",
415	    ),
416	    skip_details: bool = typer.Option(
417	        False, "--skip-details", help="Skip this command entirely."
418	    ),
419	    checkpoint_every: int = typer.Option(
420	        100, "--checkpoint-every", help="Checkpoint interval (matches)."
421	    ),
422	    verbose: int = typer.Option(0, "--verbose", "-v", count=True),
423	) -> None:
424	    """Fetch per-match detail stats and write dataset/csv/match_details.csv."""
425	    _setup_logging(verbose)
426	
427	    if skip_details:
428	        console.print("[yellow]Skipping match_details.csv build (--skip-details)[/yellow]")
429	        return
430	
431	    cfg = load_config(config)
432	    root = _project_root(config)
433	    matches_path = root / matches_csv
434	
435	    if not matches_path.exists():
436	        console.print(
