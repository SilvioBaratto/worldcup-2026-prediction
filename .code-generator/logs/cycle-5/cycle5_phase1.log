2026-06-24 03:33:14,205 DEBUG msg #95: UserMessage tool_result(toolu_01MvPLvvbdvD3cvjWm2yBwxt): 1	"""WC2026 current-state feature frame.
2	
3	Produces feature rows for **unplayed** WC2026 fixtures by running the full
4	issue-#9 ``FeatureBuilder`` over the complete chronological history and then
5	filtering to the rows that correspond to unplayed ``FIFA World Cup`` matches.
6	
7	Running the builder over the full history (not over the WC2026 subset alone)
8	is essential: pre-match form, rest days, and Elo ratings must reflect ALL of a
9	team's prior football — not just their prior WC matches — to avoid leakage and
10	to produce the same covariate values the training pipeline would produce.
11	
12	The positional mask technique (``sort_chronological(df)['TOURNAMENT'] ==
13	'FIFA World Cup'``) is row-for-row aligned with the ``FeatureBuilder`` output
14	since both internally call ``sort_chronological`` with the same key.
15	
16	A ``tournament`` metadata column is appended to the output (always
17	``'FIFA World Cup'``) so callers can identify the WC2026 rows without
18	re-joining on ``(date, home_team, away_team)`` — a join that neutral-site
19	duplicates and same-day fixtures can corrupt.
20	"""
21	from __future__ import annotations
22	
23	import logging
24	from typing import TYPE_CHECKING
25	
26	import pandas as pd
27	
28	from worldcup_playoff.config import FeatureBuildConfig
29	from worldcup_playoff.data.live import live_fixtures_to_df  # re-exported as part of wc2026 surface
30	from worldcup_playoff.features.build import FeatureBuilder
31	from worldcup_playoff.features.timeaware import sort_chronological
32	from worldcup_playoff.simulation.poisson import TeamAbilities
33	
34	if TYPE_CHECKING:
35	    from worldcup_playoff.data.elo import EloResult
36	
37	logger = logging.getLogger(__name__)
38	
39	_WC_TOURNAMENT = "FIFA World Cup"
40	
41	__all__ = ["live_fixtures_to_df", "wc2026_features"]
42	
43	
44	# ---------------------------------------------------------------------------
45	# Private helpers
46	# ---------------------------------------------------------------------------
47	
48	
49	def _unplayed_wc_mask(sorted_df: pd.DataFrame) -> pd.Series:
50	    """Positional boolean mask: rows that are unplayed FIFA World Cup fixtures."""
51	    return (sorted_df["TOURNAMENT"] == _WC_TOURNAMENT) & sorted_df["HOME_GOALS"].isna()
52	
53	
54	def _filter_wc_rows(features_df: pd.DataFrame, mask: pd.Series) -> pd.DataFrame:
55	    """Filter feature rows by positional mask and tag with tournament metadata."""
56	    result = features_df[mask.values].copy()
57	    result["tournament"] = _WC_TOURNAMENT
58	    return result.reset_index(drop=True)
59	
60	
61	# ---------------------------------------------------------------------------
62	# Public API
63	# ---------------------------------------------------------------------------
64	
65	
66	def _to_elo_df(elo_result: EloResult) -> pd.DataFrame:
67	    """Extract home_elo/away_elo per match from an EloResult (aligned to sorted df)."""
68	    return pd.DataFrame(
69	        [{"home_elo": d.home_elo, "away_elo": d.away_elo} for d in elo_result.match_diffs]
70	    )
71	
72	
73	def wc2026_features(
74	    results_df: pd.DataFrame,
75	    elo: EloResult | pd.DataFrame,
76	    abilities: TeamAbilities,
77	    *,
78	    config: FeatureBuildConfig | None = None,
79	    ranking: dict[str, float] | None = None,
80	) -> pd.DataFrame:
81	    """Return feature rows for every unplayed WC2026 fixture in *results_df*.
82	
83	    Parameters
84	    ----------
85	    results_df: Full martj42 results frame (historical + WC2026 fixtures).
86	                Must be passable to ``FeatureBuilder.build``; includes both
87	                played and unplayed rows.
88	    elo:        Either an ``EloResult`` from ``compute_elo`` or a pre-built elo DataFrame
89	                with ``home_elo`` / ``away_elo`` columns aligned to
90	                ``sort_chronological(results_df)``.
91	    abilities:  Dixon-Coles attack/defence abilities.
92	    config:     Feature-build settings; uses ``FeatureBuildConfig()`` defaults
93	                when ``None``.
94	    ranking:    Optional ``{team: ranking_points}`` dict; falls back to the
95	                static confederation map when ``None``.
96	
97	    Returns
98	    -------
99	    DataFrame with one row per unplayed WC2026 fixture, the full feature schema
100	    from ``FeatureBuilder`` plus a ``tournament`` metadata column, and
101	    ``home_goals``/``away_goals`` as ``<NA>``.
102	    """
103	    from worldcup_playoff.data.elo import EloResult as _EloResult  # avoid circular at import time
104	
105	    cfg = config or FeatureBuildConfig()
106	    sorted_df = sort_chronological(results_df)
107	    elo_df = _to_elo_df(elo) if isinstance(elo, _EloResult) else elo
108	    all_features = FeatureBuilder(cfg, ranking=ranking).build(sorted_df, elo_df, abilities)
109	    mask = _unplayed_wc_mask(sorted_df)
110	    return _filter_wc_rows(all_features, mask)
