15	from __future__ import annotations
16	
17	import logging
18	from pathlib import Path
19	from typing import TYPE_CHECKING, Any
20	
21	import matplotlib.axes
22	import matplotlib.patches as mpatches
23	import matplotlib.pyplot as plt
24	import numpy as np
25	import seaborn as sns
26	
27	from worldcup_playoff.config import BracketConfig, Matchup, VisualizationConfig
28	
29	if TYPE_CHECKING:
30	    # Only used for type annotations; not imported at runtime to avoid cycles.
31	    pass
32	
33	logger = logging.getLogger(__name__)
