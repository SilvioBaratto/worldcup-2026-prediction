393	    # ------------------------------------------------------------------
394	    # Private drawing helpers
395	    # ------------------------------------------------------------------
396	
397	    def _draw_team_box(
398	        self,
399	        ax: matplotlib.axes.Axes,
400	        x: float,
401	        y: float,
402	        teams_with_probs: list[tuple[str, float]],
403	        palette: tuple[str, str, str],
404	        box_w: float,
405	        box_h: float,
406	    ) -> None:
407	        """Draw a single bracket slot box at *(x, y)*.
408	
409	        The box lists competing teams vertically; the leader row (highest
410	        probability) receives a tinted background.  A narrow accent stripe
411	        runs along the left edge.
412	
413	        Args:
414	            ax: Target matplotlib axes.
415	            x: Left edge of the box in axes coordinates.
416	            y: Bottom edge of the box in axes coordinates.
417	            teams_with_probs: List of (team_name, probability) pairs, sorted
418	                descending by probability.
419	            palette: Three-tuple of (background, accent, dark) hex colours.
420	            box_w: Box width in axes units.
421	            box_h: Box height in axes units.
422	        """
423	        bg, accent, dark = palette
424	
425	        # Outer rounded rectangle
426	        rect = mpatches.FancyBboxPatch(
427	            (x, y),
428	            box_w,
429	            box_h,
430	            boxstyle=mpatches.BoxStyle.Round(pad=0.08),
431	            facecolor="white",
432	            edgecolor="#cccccc",
433	            linewidth=0.8,
434	        )
435	        ax.add_patch(rect)
436	
437	        row_h = box_h / max(len(teams_with_probs), 1)
438	        for i, (name, prob) in enumerate(teams_with_probs):
439	            ry = y + box_h - (i + 1) * row_h
440	            is_leader = i == 0 and prob > 0.0
441	
442	            if is_leader:
443	                row_bg = mpatches.FancyBboxPatch(
444	                    (x + 0.05, ry + 0.05),
445	                    box_w - 0.1,
446	                    row_h - 0.1,
447	                    boxstyle=mpatches.BoxStyle.Round(pad=0.04),
448	                    facecolor=bg,
449	                    edgecolor="none",
450	                )
451	                ax.add_patch(row_bg)
452	
453	            if i > 0:
454	                ax.plot(
455	                    [x + 0.15, x + box_w - 0.15],
456	                    [ry + row_h, ry + row_h],
457	                    color="#e0e0e0",
458	                    lw=0.6,
459	                )
460	
461	            ty = ry + row_h / 2
462	            ax.text(
463	                x + 0.3,
464	                ty,
465	                name,
466	                ha="left",
467	                va="center",
468	                fontsize=8.5,
469	                fontweight="bold" if is_leader else "normal",
470	                color=dark if is_leader else "#555555",
471	                fontfamily="sans-serif",
472	            )
473	            if prob > 0.0:
474	                ax.text(
475	                    x + box_w - 0.25,
476	                    ty,
477	                    f"{prob:.1%}",
478	                    ha="right",
479	                    va="center",
480	                    fontsize=8,
481	                    color=accent if is_leader else "#888888",
482	                    fontweight="bold" if is_leader else "normal",
483	                    fontfamily="sans-serif",
484	                )
485	
486	        # Left accent stripe
487	        stripe = mpatches.FancyBboxPatch(
488	            (x, y),
489	            0.12,
490	            box_h,
491	            boxstyle=mpatches.BoxStyle.Round(pad=0.02),
492	            facecolor=accent,
493	            edgecolor="none",
494	        )
495	        ax.add_patch(stripe)
496	
497	    @staticmethod
498	    def _draw_connector(
499	        ax: matplotlib.axes.Axes,
500	        parent_xy: tuple[float, float],
501	        child1_xy: tuple[float, float],
502	        child2_xy: tuple[float, float],
503	    ) -> None:
504	        """Draw bracket connector lines from two child slots to a parent slot.
505	
506	        The connector uses three segments: two horizontal stubs from the child
507	        right-edges to a shared vertical mid-point, then one horizontal segment
508	        from that mid-point to the parent left-edge.
509	
510	        Args:
511	            ax: Target matplotlib axes.
512	            parent_xy: (x, y) of the parent slot's connection point (left edge
513	                centre).
514	            child1_xy: (x, y) of the first child slot's right edge centre.
515	            child2_xy: (x, y) of the second child slot's right edge centre.
516	        """
517	        mid_x = (parent_xy[0] + child1_xy[0]) / 2
518	        color = "#cccccc"
519	        lw = 1.0
520	
521	        ax.plot([child1_xy[0], mid_x], [child1_xy[1], child1_xy[1]], color=color, lw=lw)
522	        ax.plot([child2_xy[0], mid_x], [child2_xy[1], child2_xy[1]], color=color, lw=lw)
523	        ax.plot([mid_x, mid_x], [child1_xy[1], child2_xy[1]], color=color, lw=lw)
524	        ax.plot([mid_x, parent_xy[0]], [parent_xy[1], parent_xy[1]], color=color, lw=lw)
525	
