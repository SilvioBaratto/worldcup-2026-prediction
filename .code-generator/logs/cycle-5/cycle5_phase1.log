26	# Each entry: (placeholder_name, frozenset_of_eligible_source_groups)
27	# Source: official FIFA WC2026 R32 bracket (matches 73–88).
28	_THIRD_SLOT_CANDIDATES: tuple[tuple[str, frozenset[str]], ...] = (
