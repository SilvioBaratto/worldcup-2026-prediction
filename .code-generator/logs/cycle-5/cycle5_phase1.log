35	# ---------------------------------------------------------------------------
36	# Domain constant
37	# ---------------------------------------------------------------------------
38	ROUND_NAMES: list[str] = [
39	    "Round of 32",
40	    "Round of 16",
41	    "Quarter-finals",
42	    "Semi-finals",
43	    "Final",
44	]
45	
46	
47	# ---------------------------------------------------------------------------
48	# Internal bracket layout helpers
49	# ---------------------------------------------------------------------------
50	
51	def _build_round_slots(matchups: list[Matchup]) -> dict[int, list[tuple[str, str]]]:
52	    """Return a mapping of round index -> list of (home, away) pairs.
53	
54	    Round 0 contains the seed matchups from *matchups*.  Subsequent rounds are
55	    placeholder pairs ("TBD", "TBD") whose count halves each time, mirroring
56	    the single-elimination structure.
57	
58	    Args:
59	        matchups: First-round matchup definitions from :class:`BracketConfig`.
60	
61	    Returns:
62	        Dict mapping round index to a list of (home, away) tuples.
63	    """
64	    slots: dict[int, list[tuple[str, str]]] = {}
65	    current_pairs: list[tuple[str, str]] = [(m.home, m.away) for m in matchups]
66	    rnd = 0
67	    while current_pairs:
68	        slots[rnd] = current_pairs
69	        next_count = len(current_pairs) // 2
70	        current_pairs = [("TBD", "TBD")] * next_count
71	        rnd += 1
72	    return slots
73	
74	
75	def _round_label(rnd: int, total_rounds: int) -> str:
76	    """Return a human-readable name for *rnd* given *total_rounds*.
77	
78	    The mapping aligns ROUND_NAMES from the Final backwards so that the last
79	    round is always "Final", the penultimate is "Semi-finals", etc.
80	
81	    Args:
82	        rnd: Zero-based round index.
83	        total_rounds: Total number of rounds in the bracket.
84	
85	    Returns:
86	        A display string such as "Quarter-finals" or "Round 0".
87	    """
88	    offset = len(ROUND_NAMES) - total_rounds
89	    idx = offset + rnd
90	    if 0 <= idx < len(ROUND_NAMES):
91	        return ROUND_NAMES[idx]
92	    return f"Round {rnd}"
93	
94	
95	# ---------------------------------------------------------------------------
96	# Main plotter
97	# ---------------------------------------------------------------------------
98	
99	class ResultPlotter:
100	    """Generates knockout bracket and advancement probability visualizations.
101	
102	    Constructed from a :class:`~worldcup_playoff.config.VisualizationConfig`
103	    and exposes two public methods that mirror the NBA original:
104	    ``plot_bracket`` and ``plot_round_probabilities``.
105	
106	    Args:
107	        config: Visualization settings (dpi, matplotlib style, output dir).
108	    """
109	
110	    def __init__(self, config: VisualizationConfig) -> None:
111	        self._config = config
112	
113	    # ------------------------------------------------------------------
114	    # Public API
115	    # ------------------------------------------------------------------
116	
117	    def plot_round_probabilities(
118	        self,
119	        rounds: dict[int, Any],
120	        output_path: Path | None = None,
121	    ) -> None:
122	        """Stacked area chart of advancement probabilities by team and round.
123	
124	        Each column of the stacked area corresponds to one knockout round;
125	        the height of each coloured band is the team's probability of having
126	        advanced to (or through) that round, mirroring the NBA probabilities
127	        plot.
128	
129	        Args:
130	            rounds: Mapping of round index to a RoundResult-like object that
131	                exposes ``.probabilities`` (``dict[str, float]``).
132	            output_path: Destination PNG path.  If *None* the figure is shown
133	                interactively via ``plt.show()``.
134	        """
135	        plt.style.use(self._config.style)
136	        plt.rcParams["figure.dpi"] = self._config.dpi
137	
138	        rounds_stats = list(rounds.values())
139	        team_names: list[str] = list(rounds_stats[0].probabilities.keys())
140	        x: list[int] = list(rounds.keys())
141	        y: np.ndarray = np.array(
142	            [list(r.probabilities.values()) for r in rounds_stats]
143	        ).T
144	
145	        c1 = sns.color_palette("tab10", n_colors=10)
146	        c2 = sns.color_palette("pastel", n_colors=10)
147	        color_map: list[Any] = list(c1) + list(c2)
148	
149	        total_rounds = len(rounds)
150	        x_labels = [_round_label(i, total_rounds) for i in x]
151	
152	        fig = plt.figure(figsize=(14, 8))
153	        plt.stackplot(x, y, labels=team_names, colors=color_map)
154	        plt.legend(bbox_to_anchor=(1.01, 1.0), loc="upper left", fontsize=10)
155	        plt.xticks(x, x_labels, fontsize=12, rotation=15, ha="right")
156	        plt.yticks(fontsize=13)
157	        plt.xlabel("Round", fontsize=14)
158	        plt.ylabel("Cumulative Advancement Probability", fontsize=14)
159	        plt.title(
160	            "World Cup 2026 — Advancement Probabilities by Team & Round",
161	            pad=20,
162	            fontsize=18,
163	        )
164	        plt.tight_layout()
165	
166	        if output_path:
167	            output_path.parent.mkdir(parents=True, exist_ok=True)
168	            fig.savefig(output_path, bbox_inches="tight")
169	            logger.info("Probabilities plot saved to %s", output_path)
170	        else:
171	            plt.show()
172	        plt.close(fig)
173	
174	    def plot_bracket(
175	        self,
176	        rounds: dict[int, Any],
177	        bracket: BracketConfig,
178	        output_path: Path | None = None,
179	    ) -> None:
180	        """Render the knockout bracket as a PNG with per-team probabilities.
181	
182	        Each slot box shows the two competing countries and their round
183	        advancement probabilities drawn from *rounds*.  Connector lines
184	        flow left-to-right (no conference split — World Cup has no
185	        conferences).
186	
187	        Args:
188	            rounds: Mapping of round index to a RoundResult-like object with
189	                ``.probabilities`` (``dict[str, float]``).
190	            bracket: Bracket definition including first-round matchups.
191	            output_path: Destination PNG path.  If *None* the figure is shown
192	                interactively.
193	        """
194	        slots_by_round = _build_round_slots(bracket.matchups)
195	        if not slots_by_round:
196	            logger.warning("plot_bracket called with empty matchup list — nothing to draw.")
197	            return
198	
199	        max_round = max(slots_by_round)
200	        total_rounds = max_round + 1
201	
202	        # --- Layout constants (tweaked for left-to-right single side) ---
203	        BOX_W: float = 3.8
204	        BOX_H: float = 1.6
205	        ROW_GAP: float = 0.7
206	        COL_SPACING: float = 5.2
207	        MARGIN_X: float = 1.0
208	        MARGIN_TOP: float = 3.0
209	        MARGIN_BOT: float = 2.5
210	
211	        n_first = len(slots_by_round[0])
212	
213	        bracket_h: float = n_first * BOX_H + (n_first - 1) * ROW_GAP
214	        fig_w: float = COL_SPACING * total_rounds + BOX_W + 2 * MARGIN_X
215	        fig_h: float = bracket_h + MARGIN_TOP + MARGIN_BOT
216	
217	        fig, ax = plt.subplots(figsize=(fig_w * 0.55, fig_h * 0.55))
218	        fig.patch.set_facecolor("#F8F9FA")
219	        ax.set_xlim(0, fig_w)
220	        ax.set_ylim(0, fig_h)
221	        ax.set_aspect("equal")
222	        ax.axis("off")
223	
224	        y_top: float = fig_h - MARGIN_TOP
225	
226	        # --- Title ---
227	        title = bracket.name or "FIFA World Cup 2026 Knockout Bracket"
228	        ax.text(
229	            fig_w / 2,
230	            fig_h - 0.5,
231	            title,
232	            ha="center",
233	            va="top",
234	            fontsize=15,
235	            fontweight="bold",
236	            color="#0d1b2a",
237	            fontfamily="sans-serif",
238	        )
239	
240	        # --- Compute box positions for each round ---
241	        # Round 0 positions: evenly spaced down the left column.
242	        positions: dict[int, list[tuple[float, float]]] = {}
243	        positions[0] = [
244	            (MARGIN_X, y_top - i * (BOX_H + ROW_GAP))
245	            for i in range(n_first)
246	        ]
247	
248	        for rnd in range(1, total_rounds):
249	            prev = positions[rnd - 1]
250	            x_col = MARGIN_X + COL_SPACING * rnd
251	            new_pos: list[tuple[float, float]] = []
252	            for i in range(0, len(prev), 2):
253	                if i + 1 < len(prev):
254	                    y_mid = (prev[i][1] + prev[i + 1][1]) / 2
255	                else:
256	                    y_mid = prev[i][1]
257	                new_pos.append((x_col, y_mid))
258	            positions[rnd] = new_pos
259	
260	        # --- Draw connector lines (behind boxes) ---
261	        for rnd in range(max_round):
262	            prev_pos = positions[rnd]
263	            next_pos = positions[rnd + 1]
264	            ni = 0
265	            for i in range(0, len(prev_pos), 2):
266	                c1_xy = (prev_pos[i][0] + BOX_W, prev_pos[i][1] + BOX_H / 2)
267	                if i + 1 < len(prev_pos):
268	                    c2_xy = (
269	                        prev_pos[i + 1][0] + BOX_W,
270	                        prev_pos[i + 1][1] + BOX_H / 2,
271	                    )
272	                else:
273	                    c2_xy = c1_xy
274	                if ni < len(next_pos):
275	                    p_xy = (next_pos[ni][0], next_pos[ni][1] + BOX_H / 2)
276	                    self._draw_connector(ax, p_xy, c1_xy, c2_xy)
277	                ni += 1
278	
279	        # --- Palette cycling (no conference colours; use round tints) ---
280	        PALETTES: list[tuple[str, str, str]] = [
281	            ("#d6eaf8", "#2e86c1", "#1a5276"),  # round 0 — cool blue
282	            ("#d5f5e3", "#1e8449", "#145a32"),  # round 1 — green
283	            ("#fdebd0", "#ca6f1e", "#784212"),  # round 2 — amber
284	            ("#e8daef", "#7d3c98", "#4a235a"),  # round 3 — purple
285	            ("#fef9e7", "#d4ac0d", "#7d6608"),  # Final — gold
286	        ]
287	
288	        def _palette_for_round(rnd: int) -> tuple[str, str, str]:
289	            return PALETTES[min(rnd, len(PALETTES) - 1)]
290	
291	        # --- Round column labels ---
292	        label_y = fig_h - 1.8
293	        for rnd in range(total_rounds):
294	            if positions[rnd]:
295	                col_cx = positions[rnd][0][0] + BOX_W / 2
296	                ax.text(
297	                    col_cx,
298	                    label_y,
299	                    _round_label(rnd, total_rounds),
300	                    ha="center",
301	                    va="top",
302	                    fontsize=8,
303	                    color="#555555",
304	                    fontfamily="sans-serif",
305	                )
306	
307	        # --- Draw slot boxes ---
308	        for rnd in range(total_rounds):
309	            slot_list = slots_by_round.get(rnd, [])
310	            pos_list = positions.get(rnd, [])
311	            probs: dict[str, float] = (
312	                rounds[rnd].probabilities if rnd in rounds else {}
313	            )
314	            palette = _palette_for_round(rnd)
315	
316	            for (home, away), (bx, by) in zip(slot_list, pos_list):
317	                teams = [home, away]
318	                team_probs = sorted(
319	                    ((t, probs.get(t, 0.0)) for t in teams),
320	                    key=lambda tp: tp[1],
321	                    reverse=True,
322	                )
323	                self._draw_team_box(ax, bx, by, team_probs, palette, BOX_W, BOX_H)
324	
325	        # --- Champion banner below the Final slot ---
326	        if max_round in rounds:
327	            finals_probs: dict[str, float] = rounds[max_round].probabilities
328	            if finals_probs:
329	                champion = max(finals_probs, key=lambda t: finals_probs[t])
330	                champ_prob = finals_probs[champion]
331	
332	                fx, fy = positions[max_round][0]
333	                banner_cx = fx + BOX_W / 2
334	                banner_y = fy - 1.8
335	
336	                ax.plot(
337	                    [banner_cx, banner_cx],
338	                    [fy, banner_y + 0.7],
339	                    color="#d4af37",
340	                    lw=2.5,
341	                    solid_capstyle="round",
342	                )
343	
344	                bw, bh = BOX_W + 1.0, 1.2
345	                champ_rect = mpatches.FancyBboxPatch(
346	                    (banner_cx - bw / 2, banner_y - bh / 2),
347	                    bw,
348	                    bh,
349	                    boxstyle=mpatches.BoxStyle.Round(pad=0.15),
350	                    facecolor="#fef9e7",
351	                    edgecolor="#d4af37",
352	                    linewidth=2.5,
353	                )
354	                ax.add_patch(champ_rect)
355	
356	                ax.text(
357	                    banner_cx,
358	                    banner_y + 0.22,
359	                    "W O R L D   C U P   C H A M P I O N",
360	                    ha="center",
361	                    va="center",
362	                    fontsize=6.5,
363	                    color="#b7950b",
364	                    fontweight="bold",
365	                    fontfamily="sans-serif",
366	                )
367	                ax.text(
368	                    banner_cx,
369	                    banner_y - 0.22,
370	                    f"{champion}  ({champ_prob:.1%})",
371	                    ha="center",
372	                    va="center",
373	                    fontsize=10,
374	                    color="#0d1b2a",
375	                    fontweight="bold",
376	                    fontfamily="sans-serif",
377	                )
378	
379	        if output_path:
380	            output_path.parent.mkdir(parents=True, exist_ok=True)
381	            fig.savefig(
382	                output_path,
383	                bbox_inches="tight",
384	                dpi=max(self._config.dpi, 150),
385	                facecolor=fig.get_facecolor(),
386	                edgecolor="none",
