207	        MARGIN_TOP: float = 3.0
208	        MARGIN_BOT: float = 2.5
209	
210	        n_first = len(slots_by_round[0])
211	
212	        bracket_h: float = n_first * BOX_H + (n_first - 1) * ROW_GAP
213	        fig_w: float = COL_SPACING * total_rounds + BOX_W + 2 * MARGIN_X
214	        fig_h: float = bracket_h + MARGIN_TOP + MARGIN_BOT
215	
216	        fig, ax = plt.subplots(figsize=(fig_w * 0.55, fig_h * 0.55))
217	        fig.patch.set_facecolor("#F8F9FA")
218	        ax.set_xlim(0, fig_w)
219	        ax.set_ylim(0, fig_h)
220	        ax.set_aspect("equal")
221	        ax.axis("off")
222	
223	        y_top: float = fig_h - MARGIN_TOP
224	
225	        # --- Title ---
226	        title = bracket.name or "FIFA World Cup 2026 Knockout Bracket"
227	        ax.text(
228	            fig_w / 2,
229	            fig_h - 0.5,
230	            title,
231	            ha="center",
232	            va="top",
233	            fontsize=15,
234	            fontweight="bold",
235	            color="#0d1b2a",
236	            fontfamily="sans-serif",
237	        )
