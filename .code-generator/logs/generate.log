318	
319	_RANKING_COLUMNS = [
320	    "TEAM",
321	    "COMPETITION",
322	    "SEASON",
323	    "POSITION",
324	    "PLAYED",
325	    "WON",
326	    "DRAW",
327	    "LOST",
328	    "POINTS",
329	    "GOALS_FOR",
330	    "GOALS_AGAINST",
331	]
332	
333	# Competitions with structured standings tables (group-stage tournaments)
334	_RANKING_COMPETITION_CODES = ["WC", "EC", "CA"]
335	
336	
337	class RankingBuilder:
338	    """Fetches group/league standings per season and assembles ranking.csv.
339	
340	    Mirrors ``RankingBuilder`` in the NBA original.
341	    """
342	
343	    def __init__(
344	        self,
345	        client: FootballClient,
346	        start_year: int = 2006,
347	        end_year: int | None = None,
348	        competition_codes: list[str] | None = None,
349	    ) -> None:
350	        self._client = client
351	        self._start_year = start_year
352	        self._end_year = end_year if end_year is not None else datetime.date.today().year
353	        self._competition_codes = competition_codes or _RANKING_COMPETITION_CODES
354	
355	    def build(self) -> pd.DataFrame:
356	        """Fetch standings for all competitions × years and return the DataFrame."""
357	        frames: list[pd.DataFrame] = []
358	
359	        for code in self._competition_codes:
360	            for year in range(self._start_year, self._end_year + 1):
361	                df = self._fetch_season(code, year)
362	                if df is not None:
363	                    frames.append(df)
364	
365	        if not frames:
366	            msg = "All standings fetches failed — no data to build ranking.csv"
367	            raise RuntimeError(msg)
368	
369	        result = pd.concat(frames, ignore_index=True)
370	
371	        missing = set(_RANKING_COLUMNS) - set(result.columns)
372	        if missing:
373	            msg = f"Missing columns after transformation: {missing}"
374	            raise RuntimeError(msg)
375	
376	        logger.info("Built ranking DataFrame: %d rows", len(result))
377	        return result
378	
379	    def _fetch_season(self, code: str, year: int) -> pd.DataFrame | None:
380	        """Fetch standings for one competition-season. Returns None on failure."""
381	        try:
382	            data = self._client.get(
383	                f"/competitions/{code}/standings",
384	                params={"season": str(year)},
385	            )
386	            standings: list[dict[str, object]] = data.get("standings", [])
387	            if not standings:
388	                return None
389	            rows: list[dict[str, object]] = []
390	            for table in standings:
391	                table_rows: list[dict[str, object]] = table.get("table", [])  # type: ignore[assignment]
392	                for entry in table_rows:
393	                    row = self._extract_ranking_row(entry, code, year)
394	                    if row is not None:
395	                        rows.append(row)
396	            if not rows:
397	                return None
398	            df = pd.DataFrame(rows, columns=_RANKING_COLUMNS)
399	            logger.info(
400	                "Fetched %d ranking rows for %s/%d", len(df), code, year
401	            )
402	            return df
403	        except Exception:
404	            logger.warning(
405	                "Failed to fetch standings for %s/%d", code, year, exc_info=True
406	            )
407	            return None
408	
409	    @staticmethod
410	    def _extract_ranking_row(
411	        entry: dict[str, object],
412	        code: str,
413	        year: int,
414	    ) -> dict[str, object] | None:
415	        """Map a single standings table row to the ranking.csv schema.
416	
417	        Pure transformation — no I/O.
418	        """
419	        try:
420	            team = entry.get("team", {})  # type: ignore[union-attr]
421	            team_name = team.get("name", "") or team.get("shortName", "")  # type: ignore[union-attr]
422	            if not team_name:
423	                return None
424	            return {
425	                "TEAM": str(team_name),
426	                "COMPETITION": code,
427	                "SEASON": year,
428	                "POSITION": int(entry.get("position", 0)),  # type: ignore[call-overload]
429	                "PLAYED": int(entry.get("playedGames", 0)),  # type: ignore[call-overload]
430	                "WON": int(entry.get("won", 0)),  # type: ignore[call-overload]
431	                "DRAW": int(entry.get("draw", 0)),  # type: ignore[call-overload]
432	                "LOST": int(entry.get("lost", 0)),  # type: ignore[call-overload]
433	                "POINTS": int(entry.get("points", 0)),  # type: ignore[call-overload]
434	                "GOALS_FOR": int(entry.get("goalsFor", 0)),  # type: ignore[call-overload]
435	                "GOALS_AGAINST": int(entry.get("goalsAgainst", 0)),  # type: ignore[call-overload]
436	            }
437	        except Exception:
438	            logger.debug("Skipping malformed standings entry: %s", entry, exc_info=True)
439	            return None
440	
441	
442	def build_ranking_csv(
443	    output_path: Path,
444	    client: FootballClient | None = None,
445	    start_year: int = 2006,
446	    end_year: int | None = None,
447	) -> pd.DataFrame:
448	    """Build ranking.csv and write to disk.
449	
450	    Args:
451	        output_path: Where to write the CSV.
452	        client: Rate-limited API client. Created with defaults if ``None``.
453	        start_year: First season year to query.
454	        end_year: Last season year. Defaults to current year.
455	
456	    Returns:
457	        The assembled DataFrame (11 columns matching the ranking.csv schema).
458	    """
459	    if client is None:
460	        client = FootballClient(ClientConfig())
461	
462	    builder = RankingBuilder(client, start_year=start_year, end_year=end_year)
463	    df = builder.build()
464	
465	    output_path.parent.mkdir(parents=True, exist_ok=True)
466	    df.to_csv(output_path, index=False)
467	    logger.info("Wrote %d ranking rows to %s", len(df), output_path)
468	    return df
