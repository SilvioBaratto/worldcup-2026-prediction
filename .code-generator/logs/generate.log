239	        # --- Compute box positions for each round ---
240	        # Round 0 positions: evenly spaced down the left column.
241	        positions: dict[int, list[tuple[float, float]]] = {}
242	        positions[0] = [
243	            (MARGIN_X, y_top - i * (BOX_H + ROW_GAP))
244	            for i in range(n_first)
245	        ]
246	
247	        for rnd in range(1, total_rounds):
248	            prev = positions[rnd - 1]
249	            x_col = MARGIN_X + COL_SPACING * rnd
250	            new_pos: list[tuple[float, float]] = []
251	            for i in range(0, len(prev), 2):
252	                if i + 1 < len(prev):
253	                    y_mid = (prev[i][1] + prev[i + 1][1]) / 2
254	                else:
255	                    y_mid = prev[i][1]
256	                new_pos.append((x_col, y_mid))
257	            positions[rnd] = new_pos
258	
259	        # --- Draw connector lines (behind boxes) ---
260	        for rnd in range(max_round):
261	            prev_pos = positions[rnd]
262	            next_pos = positions[rnd + 1]
263	            ni = 0
264	            for i in range(0, len(prev_pos), 2):
265	                c1_xy = (prev_pos[i][0] + BOX_W, prev_pos[i][1] + BOX_H / 2)
266	                if i + 1 < len(prev_pos):
267	                    c2_xy = (
268	                        prev_pos[i + 1][0] + BOX_W,
269	                        prev_pos[i + 1][1] + BOX_H / 2,
270	                    )
271	                else:
272	                    c2_xy = c1_xy
273	                if ni < len(next_pos):
274	                    p_xy = (next_pos[ni][0], next_pos[ni][1] + BOX_H / 2)
275	                    self._draw_connector(ax, p_xy, c1_xy, c2_xy)
276	                ni += 1
277	
