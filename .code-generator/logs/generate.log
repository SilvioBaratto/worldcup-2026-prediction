2026-06-23 20:49:38,047 DEBUG msg #27: UserMessage tool_result(toolu_01WifZmFWAEXA8Pj7JpkY2Ry): 1	"""Dataset builders: constructs teams.csv, matches.csv, ranking.csv, players.csv,
2	and match_details.csv from the football-data.org v4 REST API.
3	
4	Competition codes queried for historical match data:
5	- WC  : FIFA World Cup (every 4 years)
6	- EC  : UEFA European Championship (every 4 years)
7	- CA  : CONMEBOL Copa América (every 4 years)
8	- CLI : UEFA Champions League (annual club competition, excluded by default)
9	- WCQ : World Cup Qualifiers (not a v4 competition code — handled per-confederation below)
10	
11	For ranking/standings the builder uses competition codes that expose group-stage
12	standings via /competitions/{code}/standings.  Qualifiers are not structured as
13	league tables in v4 so the builder collects World Cup and major confederate
14	championship points where available.
15	
16	Fallback statistics for match_details.csv
17	------------------------------------------
18	football-data.org free-tier endpoints do not expose shots, possession, or pass
19	accuracy per match.  When those fields are absent the builder fills them with
20	deterministic heuristics:
21	
22	  SHOTS_home / SHOTS_away   = GOALS * 5 + 7
23	      (average ~12 shots/game for teams that score 1+ goals; 7 baseline for 0-goal teams)
24	
25	  SHOTS_ON_TARGET_home / _away  = max(GOALS + 2, SHOTS // 3)
26	      (roughly a third of all shots are on target; floors at goals+2)
27	
28	  POSSESSION_home / _away   = 50.0 (neutral split — no data)
29	
30	  PASS_PCT_home / _away     = 75.0 (global average pass completion ~75%)
31	
32	These are fixed constants, never random, so output is reproducible.
33	"""
34	
35	from __future__ import annotations
36	
37	import datetime
38	import logging
39	from pathlib import Path
40	
41	import pandas as pd
42	
43	from worldcup_playoff.config import ClientConfig
44	from worldcup_playoff.data.client import FootballClient
45	
46	logger = logging.getLogger(__name__)
47	
48	# ---------------------------------------------------------------------------
49	# teams.csv
50	# ---------------------------------------------------------------------------
51	
52	_TEAMS_COLUMNS = [
53	    "TEAM_ID",
54	    "NAME",
55	    "SHORT_NAME",
56	    "TLA",
57	    "COUNTRY",
58	    "COMPETITION",
59	]
60	
61	# Competition codes whose /teams endpoint we query to harvest national-team records
62	_TEAM_COMPETITION_CODES = ["WC", "EC", "CA"]
63	
64	
65	class TeamsBuilder:
66	    """Fetches team metadata for major international competitions."""
67	
68	    def __init__(
69	        self,
70	        client: FootballClient,
71	        competition_codes: list[str] | None = None,
72	    ) -> None:
73	        self._client = client
74	        self._competition_codes = competition_codes or _TEAM_COMPETITION_CODES
75	
76	    def build(self) -> pd.DataFrame:
77	        """Fetch teams for each competition and return the deduplicated DataFrame."""
78	        rows: list[dict[str, object]] = []
79	        seen_ids: set[int] = set()
80	
81	        for code in self._competition_codes:
82	            fetched = self._fetch_teams(code)
83	            for team in fetched:
84	                tid = int(team.get("id", 0))
85	                if tid in seen_ids:
86	                    continue
87	                seen_ids.add(tid)
88	                rows.append(
89	                    {
90	                        "TEAM_ID": tid,
91	                        "NAME": team.get("name", ""),
92	                        "SHORT_NAME": team.get("shortName", ""),
93	                        "TLA": team.get("tla", ""),
94	                        "COUNTRY": team.get("area", {}).get("name", ""),
95	                        "COMPETITION": code,
96	                    }
97	                )
98	
99	        if not rows:
100	            msg = "No teams fetched — all competition requests failed"
101	            raise RuntimeError(msg)
102	
103	        df = pd.DataFrame(rows, columns=_TEAMS_COLUMNS)
104	        logger.info("Built teams DataFrame: %d unique teams", len(df))
105	        return df
106	
107	    def _fetch_teams(self, code: str) -> list[dict[str, object]]:
108	        """Fetch teams for a single competition. Returns empty list on failure."""
109	        try:
110	            data = self._client.get(f"/competitions/{code}/teams")
111	            teams: list[dict[str, object]] = data.get("teams", [])
112	            logger.info("Fetched %d teams for competition %s", len(teams), code)
113	            return teams
114	        except Exception:
115	            logger.warning("Failed to fetch teams for competition %s", code, exc_info=True)
116	            return []
117	
118	
119	def build_teams_csv(
120	    output_path: Path,
121	    client: FootballClient | None = None,
122	) -> pd.DataFrame:
123	    """Build teams.csv and write to disk.
124	
125	    Args:
126	        output_path: Where to write the CSV.
127	        client: Rate-limited API client. Created with defaults if ``None``.
128	
129	    Returns:
130	        The assembled DataFrame.
131	    """
132	    if client is None:
133	        client = FootballClient(ClientConfig())
134	
135	    builder = TeamsBuilder(client)
136	    df = builder.build()
137	
138	    output_path.parent.mkdir(parents=True, exist_ok=True)
139	    df.to_csv(output_path, index=False)
140	    logger.info("Wrote %d teams to %s", len(df), output_path)
141	    return df
142	
143	
144	# ---------------------------------------------------------------------------
145	# matches.csv
146	# ---------------------------------------------------------------------------
147	
148	_MATCHES_COLUMNS = [
149	    "MATCH_ID",
150	    "DATE",
151	    "HOME_TEAM",
152	    "AWAY_TEAM",
153	    "HOME_GOALS",
154	    "AWAY_GOALS",
155	    "COMPETITION",
156	    "SEASON",
157	]
158	
159	# Competition codes iterated when building the historical matches dataset.
160	# These are the main international tournaments available on football-data.org v4.
161	_MATCH_COMPETITION_CODES = ["WC", "EC", "CA", "CL", "PL", "BL1", "SA", "PD", "FL1"]
162	
163	
164	class MatchesBuilder:
165	    """Fetches match results per competition per season and assembles matches.csv.
166	
167	    Mirrors ``GamesBuilder`` in the NBA original.
168	    """
169	
170	    def __init__(
171	        self,
172	        client: FootballClient,
173	        start_year: int = 2006,
174	        end_year: int | None = None,
175	        competition_codes: list[str] | None = None,
176	    ) -> None:
177	        self._client = client
178	        self._start_year = start_year
179	        self._end_year = end_year if end_year is not None else datetime.date.today().year
180	        self._competition_codes = competition_codes or _MATCH_COMPETITION_CODES
181	
182	    def build(self) -> pd.DataFrame:
183	        """Fetch all competitions × seasons, returning the matches DataFrame."""
184	        frames: list[pd.DataFrame] = []
185	
186	        for code in self._competition_codes:
187	            for year in range(self._start_year, self._end_year + 1):
188	                df = self._fetch_season(code, year)
189	                if df is not None:
190	                    frames.append(df)
191	
192	        if not frames:
193	            msg = "All match fetches failed — no data to build matches.csv"
194	            raise RuntimeError(msg)
195	
196	        result = pd.concat(frames, ignore_index=True)
197	
198	        # Remove duplicate match IDs (same match may appear under multiple codes)
199	        result = result.drop_duplicates(subset=["MATCH_ID"]).reset_index(drop=True)
200	
201	        missing = set(_MATCHES_COLUMNS) - set(result.columns)
202	        if missing:
203	            msg = f"Missing columns after assembly: {missing}"
204	            raise RuntimeError(msg)
205	
206	        logger.info(
207	            "Built matches DataFrame: %d rows across %d competition-season combos",
208	            len(result),
209	            len(frames),
210	        )
211	        return result
212	
213	    def _fetch_season(self, code: str, year: int) -> pd.DataFrame | None:
214	        """Fetch all finished matches for one competition-season. Returns None on failure."""
215	        try:
216	            data = self._client.get(
217	                f"/competitions/{code}/matches",
218	                params={"season": str(year), "status": "FINISHED"},
219	            )
220	            matches: list[dict[str, object]] = data.get("matches", [])
221	            if not matches:
222	                return None
223	            rows = [self._extract_match_row(m, code, year) for m in matches]
224	            # Drop rows where team names could not be resolved
225	            valid = [r for r in rows if r is not None]
226	            if not valid:
227	                return None
228	            df = pd.DataFrame(valid, columns=_MATCHES_COLUMNS)
229	            logger.info(
230	                "Fetched %d matches for %s/%d", len(df), code, year
231	            )
232	            return df
233	        except Exception:
234	            logger.warning(
235	                "Failed to fetch matches for %s/%d", code, year, exc_info=True
236	            )
237	            return None
238	
239	    @staticmethod
240	    def _extract_match_row(
241	        match: dict[str, object],
242	        code: str,
243	        year: int,
244	    ) -> dict[str, object] | None:
245	        """Map a single API match object to the matches.csv row schema.
246	
247	        Pure transformation — no I/O.
248	        """
249	        try:
250	            home_team = (
251	                match.get("homeTeam", {}).get("name", "")  # type: ignore[union-attr]
252	                or match.get("homeTeam", {}).get("shortName", "")  # type: ignore[union-attr]
253	            )
254	            away_team = (
255	                match.get("awayTeam", {}).get("name", "")  # type: ignore[union-attr]
256	                or match.get("awayTeam", {}).get("shortName", "")  # type: ignore[union-attr]
257	            )
258	            if not home_team or not away_team:
259	                return None
260	
261	            score = match.get("score", {})  # type: ignore[union-attr]
262	            full_time = score.get("fullTime", {})  # type: ignore[union-attr]
263	            home_goals = full_time.get("home")
264	            away_goals = full_time.get("away")
265	            if home_goals is None or away_goals is None:
266	                return None
267	
268	            utc_date = str(match.get("utcDate", ""))
269	            date_str = utc_date[:10] if utc_date else ""  # "YYYY-MM-DD"
270	
271	            return {
272	                "MATCH_ID": int(match.get("id", 0)),  # type: ignore[call-overload]
273	                "DATE": date_str,
274	                "HOME_TEAM": str(home_team),
275	                "AWAY_TEAM": str(away_team),
276	                "HOME_GOALS": int(home_goals),
277	                "AWAY_GOALS": int(away_goals),
278	                "COMPETITION": code,
279	                "SEASON": year,
280	            }
281	        except Exception:
282	            logger.debug("Skipping malformed match record: %s", match, exc_info=True)
283	            return None
284	
285	
286	def build_matches_csv(
287	    output_path: Path,
288	    client: FootballClient | None = None,
289	    start_year: int = 2006,
290	    end_year: int | None = None,
291	) -> pd.DataFrame:
292	    """Build matches.csv and write to disk.
293	
294	    Args:
295	        output_path: Where to write the CSV.
296	        client: Rate-limited API client. Created with defaults if ``None``.
297	        start_year: First season year to query (e.g. 2006).
298	        end_year: Last season year to query. Defaults to the current year.
299	
300	    Returns:
301	        The assembled DataFrame (8 columns matching the matches.csv schema).
302	    """
303	    if client is None:
304	        client = FootballClient(ClientConfig())
305	
306	    builder = MatchesBuilder(client, start_year=start_year, end_year=end_year)
307	    df = builder.build()
308	
309	    output_path.parent.mkdir(parents=True, exist_ok=True)
310	    df.to_csv(output_path, index=False)
311	    logger.info("Wrote %d matches to %s", len(df), output_path)
312	    return df
