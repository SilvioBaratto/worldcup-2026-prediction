825	def build_match_details_csv(
826	    output_path: Path,
827	    match_ids: list[int],
828	    client: FootballClient | None = None,
829	    checkpoint_every: int = 100,
830	) -> pd.DataFrame:
831	    """Build match_details.csv and write to disk.
832	
833	    Args:
834	        output_path: Where to write the CSV.
835	        match_ids: List of integer match IDs to fetch.
836	        client: Rate-limited API client. Created with defaults if ``None``.
837	        checkpoint_every: Save partial results every N matches.
838	
839	    Returns:
840	        The assembled DataFrame (11 columns matching the match_details.csv schema).
841	    """
842	    if client is None:
843	        client = FootballClient(ClientConfig())
844	
845	    partial_path = output_path.parent / (output_path.name + ".partial")
846	    builder = MatchDetailsBuilder(client, match_ids, checkpoint_every=checkpoint_every)
847	    df = builder.build(partial_path=partial_path)
848	
849	    output_path.parent.mkdir(parents=True, exist_ok=True)
850	    df.to_csv(output_path, index=False)
851	    logger.info("Wrote %d match detail rows to %s", len(df), output_path)
852	
853	    if partial_path.exists():
854	        partial_path.unlink()
855	
856	    return df
