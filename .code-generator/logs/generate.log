64	@dataclass
65	class BracketSlot:
66	    """A node in the bracket tree.
67	
68	    Leaves hold the two teams from a first-round tie.
69	    Internal nodes aggregate all teams reachable through their sub-bracket.
70	
71	    Attributes:
72	        teams: All team names that could appear in this slot.
73	        children: The two child ``BracketSlot`` nodes whose winners meet here,
74	            or ``None`` for leaf nodes.
75	        group: The group/conference label inherited from the originating
76	            ``Matchup.group`` value (propagated upward only when both children
77	            share the same label).
78	    """
79	
80	    teams: list[str]
81	    children: tuple[BracketSlot, BracketSlot] | None = None
82	    group: str = ""
83	
84	
85	def build_bracket_tree(matchups: list[Matchup]) -> BracketSlot:
86	    """Build a bracket tree from the sequential matchup list.
87	
88	    Mirrors the pairing logic in ``TournamentSimulator._simulate_once``:
89	    adjacent matchup winners pair into the next round until only the root
90	    (the Final) remains.
91	
92	    Args:
93	        matchups: A non-empty list whose length is a power of 2.  World Cup
94	            knockout brackets satisfy this constraint (2, 4, 8, 16, 32 teams).
95	
96	    Returns:
97	        The root ``BracketSlot`` whose ``teams`` contains every participant.
98	
99	    Raises:
100	        ValueError: If ``matchups`` is empty or its length is not a power of 2.
101	    """
102	    n = len(matchups)
103	    if n == 0 or (n & (n - 1)) != 0:
104	        raise ValueError(
105	            f"matchups must be a non-empty power-of-2 length, got {n}"
106	        )
107	
108	    # Build leaf nodes — one per first-round tie.
109	    slots: list[BracketSlot] = [
110	        BracketSlot(
111	            teams=[m.home, m.away],
112	            group=m.group,
113	        )
114	        for m in matchups
115	    ]
116	
117	    # Fold adjacent pairs upward until only the root remains.
118	    while len(slots) > 1:
119	        next_level: list[BracketSlot] = []
120	        for i in range(0, len(slots), 2):
121	            left, right = slots[i], slots[i + 1]
122	            shared_group = left.group if left.group == right.group else ""
123	            next_level.append(
124	                BracketSlot(
125	                    teams=left.teams + right.teams,
126	                    children=(left, right),
127	                    group=shared_group,
128	                )
129	            )
130	        slots = next_level
131	
132	    return slots[0]
133	
134	
135	def extract_bracket_slots(root: BracketSlot) -> dict[int, list[BracketSlot]]:
136	    """Return ``{round_number: [slots]}`` by BFS from root.
137	
138	    Round 0 = leaves (first round), increasing toward the root (Final).
139	
140	    Args:
141	        root: The root ``BracketSlot`` returned by ``build_bracket_tree``.
142	
143	    Returns:
144	        Dict mapping round index to the list of ``BracketSlot`` nodes at that
145	        depth level.
146	    """
147	    depth = 0
148	    node = root
149	    while node.children:
150	        depth += 1
