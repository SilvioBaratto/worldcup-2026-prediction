74	def _round_label(rnd: int, total_rounds: int) -> str:
75	    """Return a human-readable name for *rnd* given *total_rounds*.
76	
77	    The mapping aligns ROUND_NAMES from the Final backwards so that the last
78	    round is always "Final", the penultimate is "Semi-finals", etc.
79	
80	    Args:
81	        rnd: Zero-based round index.
82	        total_rounds: Total number of rounds in the bracket.
83	
84	    Returns:
85	        A display string such as "Quarter-finals" or "Round 0".
86	    """
87	    offset = len(ROUND_NAMES) - total_rounds
88	    idx = offset + rnd
89	    if 0 <= idx < len(ROUND_NAMES):
90	        return ROUND_NAMES[idx]
91	    return f"Round {rnd}"
