39	
40	class FootballClient:
41	    """Wraps football-data.org v4 REST calls with rate limiting and retries.
42	
43	    Implements a circuit-breaker pattern: after ``_circuit_breaker_threshold``
44	    consecutive failures the client pauses for ``_circuit_breaker_cooldown``
45	    seconds before allowing the next attempt, giving the remote server time
46	    to recover.
47	
48	    The API key is read from the ``FOOTBALL_DATA_API_KEY`` environment variable.
49	    If the variable is absent or empty the client still works but is subject to
50	    the unauthenticated rate limit (10 req/min → default delay of 6 s).
51	    """
52	
53	    _SESSION_RESET_INTERVAL: int = 50
54	
55	    def __init__(self, config: ClientConfig | None = None) -> None:
56	        self._config = config or ClientConfig()
57	        self._session: requests.Session = self._build_session()
58	        self._call_count: int = 0
59	        self._consecutive_failures: int = 0
60	        self._circuit_breaker_threshold: int = 3
61	        self._circuit_breaker_cooldown: float = 60.0
62	
63	    # ------------------------------------------------------------------
64	    # Public API
65	    # ------------------------------------------------------------------
66	
67	    def get(self, path: str, params: dict[str, Any] | None = None) -> dict[str, Any]:
68	        """Issue a GET request against the v4 base URL and return parsed JSON.
69	
70	        Args:
71	            path: Endpoint path, e.g. ``"/competitions/WC/matches"``.
72	            params: Optional query-string parameters.
73	
74	        Returns:
75	            Parsed JSON response as a Python dict.
76	
77	        Raises:
78	            requests.exceptions.HTTPError: On non-retryable 4xx responses.
79	            RuntimeError: When all retry attempts are exhausted.
80	        """
81	        # Circuit breaker: if many consecutive failures, pause before retrying
82	        if self._consecutive_failures >= self._circuit_breaker_threshold:
83	            logger.warning(
84	                "Circuit breaker open (%d consecutive failures) — "
85	                "cooling down %.0fs before next attempt",
86	                self._consecutive_failures,
87	                self._circuit_breaker_cooldown,
88	            )
89	            time.sleep(self._circuit_breaker_cooldown)
90	            self._reset_session()
91	
92	        # Periodic session recycling to avoid stale connections
93	        self._call_count += 1
94	        if self._call_count % self._SESSION_RESET_INTERVAL == 0:
95	            self._reset_session()
96	
97	        result = self._get_with_retry(path, params)
98	        self._consecutive_failures = 0
99	        time.sleep(self._config.delay)
100	        return result
101	
102	    # ------------------------------------------------------------------
103	    # Internal helpers
104	    # ------------------------------------------------------------------
105	
106	    def _get_with_retry(
107	        self,
108	        path: str,
109	        params: dict[str, Any] | None,
110	    ) -> dict[str, Any]:
111	        """Attempt the GET request up to ``max_retries + 1`` times.
112	
113	        Uses exponential backoff with jitter on retryable errors:
114	        ``wait = backoff_base ^ attempt + random(0, 1)``
115	        """
116	        last_exception: Exception | None = None
117	        url = f"{_BASE_URL}{path}"
118	
119	        for attempt in range(self._config.max_retries + 1):
120	            try:
121	                response = self._session.get(
122	                    url,
123	                    params=params,
124	                    timeout=self._config.timeout,
125	                )
126	                response.raise_for_status()
127	                return response.json()  # type: ignore[no-any-return]
128	            except requests.exceptions.HTTPError as exc:
129	                status = exc.response.status_code if exc.response is not None else None
130	                if status not in _RETRYABLE_STATUS_CODES:
131	                    raise
132	                last_exception = exc
133	            except (
134	                requests.exceptions.Timeout,
135	                requests.exceptions.ConnectionError,
136	                RemoteDisconnected,
137	                ConnectionResetError,
138	                OSError,
139	            ) as exc:
140	                last_exception = exc
141	            except Exception:
142	                raise
143	
144	            self._consecutive_failures += 1
145	
146	            if attempt < self._config.max_retries:
147	                jitter = random.uniform(0, 1)  # noqa: S311
148	                wait = self._config.backoff_base**attempt + jitter
149	                logger.warning(
150	                    "Retry %d/%d for %s (error: %s), sleeping %.1fs",
151	                    attempt + 1,
152	                    self._config.max_retries,
153	                    url,
154	                    last_exception,
155	                    wait,
156	                )
157	                time.sleep(wait)
158	
159	                # Fresh TCP connection on connection-level errors
160	                if isinstance(
161	                    last_exception,
162	                    (
163	                        requests.exceptions.ConnectionError,
164	                        RemoteDisconnected,
165	                        ConnectionResetError,
166	                    ),
167	                ):
168	                    self._reset_session()
169	
170	        msg = f"All {self._config.max_retries + 1} attempts failed for {url}"
171	        raise RuntimeError(msg) from last_exception
172	
173	    def _reset_session(self) -> None:
174	        """Replace the requests.Session with a fresh instance."""
175	        try:
176	            self._session.close()
177	        except Exception:  # noqa: BLE001
178	            pass
179	        self._session = self._build_session()
180	        logger.debug("Reset HTTP session")
181	
182	    def _build_session(self) -> requests.Session:
183	        """Create a new requests.Session with appropriate headers."""
184	        session = requests.Session()
185	
186	        if self._config.use_custom_headers:
187	            session.headers.update(CUSTOM_HEADERS)
188	
189	        # Attach API key if available — unauthenticated access still works at lower rate
190	        api_key = os.environ.get("FOOTBALL_DATA_API_KEY", "").strip()
191	        if api_key:
192	            session.headers["X-Auth-Token"] = api_key
193	            logger.debug("Authenticated session created (API key present)")
194	        else:
195	            logger.debug("Unauthenticated session created (no API key found)")
196	
197	        return session
