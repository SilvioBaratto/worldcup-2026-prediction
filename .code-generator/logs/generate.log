248	class FeatureSampler:
249	    """Assembles synthetic feature vectors from two teams' fitted distributions.
250	
251	    The sampling contract mirrors the NBA ``FeatureSampler`` but is adapted for
252	    the football feature layout.  A World Cup feature vector is ordered exactly
253	    as ``FeaturesConfig.selected``:
254	
255	    ``[GOALS_home, SHOTS_home, SHOTS_ON_TARGET_home, POSSESSION_home, PASS_PCT_home,``
256	    ``GOALS_away, SHOTS_away, SHOTS_ON_TARGET_away, POSSESSION_away, PASS_PCT_away]``
257	
258	    Usage::
259	
260	        sampler = FeatureSampler(features_config)
261	        vector = sampler.assemble(home_dists, away_dists)
262	    """
263	
264	    def __init__(self, features_config: FeaturesConfig) -> None:
265	        self._features = features_config
266	
267	    def assemble(
268	        self,
269	        home_distributions: list[FittedDistribution],
270	        away_distributions: list[FittedDistribution],
271	        random_state: int | None = None,
272	    ) -> np.ndarray:
273	        """Sample one feature vector for a single knockout tie.
274	
275	        Draws one value per base statistic for the home team (first 5 positions)
276	        and one value per base statistic for the away team (last 5 positions),
277	        producing a 1-D array of length ``2 * per_team_count`` (i.e. 10).
278	
279	        Args:
280	            home_distributions: Fitted distributions for the home team, ordered
281	                by base stat index matching ``FeaturesConfig.selected[:per_team_count]``.
282	            away_distributions: Fitted distributions for the away team, ordered
283	                by base stat index matching ``FeaturesConfig.selected[per_team_count:]``.
284	            random_state: Optional seed for reproducible sampling.
285	
286	        Returns:
287	            1-D ``np.ndarray`` of shape ``(10,)`` ready for ``classifier.predict``.
288	        """
289	        home_samples = self._sample_team(home_distributions, random_state=random_state)
290	        away_samples = self._sample_team(away_distributions, random_state=random_state)
291	        return np.concatenate([home_samples, away_samples])
292	
293	    @staticmethod
294	    def sample(
295	        distributions: list[FittedDistribution],
296	        size: int = 1,
297	        random_state: int | None = None,
298	    ) -> np.ndarray:
299	        """Sample ``size`` observations for each feature from *distributions*.
300	
301	        This low-level helper mirrors the NBA ``FeatureSampler.sample`` signature
302	        exactly so that ``GamePredictor`` can share the same call site pattern.
303	
304	        Args:
305	            distributions: List of fitted distributions, one per feature.
306	            size: Number of samples to draw per feature.
307	            random_state: Optional seed for reproducibility.
308	
309	        Returns:
310	            Array of shape ``(size, n_features)``.
311	        """
312	        rng = np.random.default_rng(random_state)
313	        samples: list[Any] = []
314	        for dist in distributions:
315	            generator = SCIPY_GENERATORS[dist.name]
316	            s = generator(*dist.params, size=size, random_state=rng)
317	            samples.append(s)
318	        return np.array(samples).T
319	
320	    # ------------------------------------------------------------------
321	    # Private helpers
322	    # ------------------------------------------------------------------
323	
324	    def _sample_team(
325	        self,
326	        distributions: list[FittedDistribution],
327	        random_state: int | None = None,
328	    ) -> np.ndarray:
329	        """Return a 1-D array of one sampled value per base stat for one team."""
330	        # sample() returns shape (1, n_features); squeeze to (n_features,)
331	        return self.sample(distributions, size=1, random_state=random_state).squeeze(axis=0)
