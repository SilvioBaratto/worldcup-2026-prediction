50	def _build_round_slots(matchups: list[Matchup]) -> dict[int, list[tuple[str, str]]]:
51	    """Return a mapping of round index -> list of (home, away) pairs.
52	
53	    Round 0 contains the seed matchups from *matchups*.  Subsequent rounds are
54	    placeholder pairs ("TBD", "TBD") whose count halves each time, mirroring
55	    the single-elimination structure.
56	
57	    Args:
58	        matchups: First-round matchup definitions from :class:`BracketConfig`.
59	
60	    Returns:
61	        Dict mapping round index to a list of (home, away) tuples.
62	    """
63	    slots: dict[int, list[tuple[str, str]]] = {}
64	    current_pairs: list[tuple[str, str]] = [(m.home, m.away) for m in matchups]
65	    rnd = 0
66	    while current_pairs:
67	        slots[rnd] = current_pairs
68	        next_count = len(current_pairs) // 2
69	        current_pairs = [("TBD", "TBD")] * next_count
70	        rnd += 1
71	    return slots
72	
