282	            ("#fdebd0", "#ca6f1e", "#784212"),  # round 2 — amber
283	            ("#e8daef", "#7d3c98", "#4a235a"),  # round 3 — purple
284	            ("#fef9e7", "#d4ac0d", "#7d6608"),  # Final — gold
285	        ]
