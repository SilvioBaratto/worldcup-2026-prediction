54	class ClassifierTrainer:
55	    """Handles data preparation and model fitting."""
56	
57	    def __init__(self, config: TrainingConfig, features_config: FeaturesConfig) -> None:
58	        self._config = config
59	        self._features = features_config
60	
61	    def prepare_data(
62	        self, df: pd.DataFrame
63	    ) -> tuple[Any, Any, Any, Any]:
64	        """Extract features/labels and split into train/test.
65	
66	        Returns (X_train, X_test, y_train, y_test) as numpy arrays.
67	        """
68	        X = df[self._features.selected].to_numpy()
69	        y = df["HOME_WIN"].to_numpy()
70	        X_train, X_test, y_train, y_test = train_test_split(
71	            X, y,
72	            test_size=self._config.test_size,
73	            random_state=self._config.random_state,
74	            shuffle=False,
75	        )
76	        logger.info(
77	            "Data split: train=%d, test=%d", len(X_train), len(X_test)
78	        )
79	        return X_train, X_test, y_train, y_test
80	
81	    @staticmethod
82	    def train(
83	        classifier: Any,
84	        X_train: np.ndarray,
85	        y_train: np.ndarray,
86	    ) -> Any:
