2026-06-23 20:49:49,120 DEBUG msg #51: UserMessage tool_result(toolu_015MYjGwsv6ZApkQNa52Dh8g): 1	"""Knockout tie prediction using sampled features and a trained classifier.
2	
3	Mirrors ``nba_playoff.simulation.game`` but replaces the best-of-N series loop
4	with a **single-match** tie: one feature vector is sampled, the classifier runs
5	once, and the result immediately determines the advancing team.
6	
7	In the World Cup knockout stage extra time and penalties collapse into a single
8	win/loss outcome, so there is no ``num_games`` parameter here — the method is
9	``predict_tie(home, away) -> str``.
10	"""
11	
12	from __future__ import annotations
13	
14	from typing import Any
15	
16	import numpy as np
17	
18	from worldcup_playoff.simulation.distributions import (
19	    FeatureSampler,
20	    FittedDistribution,
21	)
22	
23	
24	class GamePredictor:
25	    """Predicts the winner of a single knockout tie between two national teams.
26	
27	    Uses dependency injection instead of global state:
28	
29	    - ``classifier``: a trained ML model satisfying the ``Classifier`` Protocol.
30	    - ``sampler``: a ``FeatureSampler`` that draws synthetic match statistics.
31	    - ``team_distributions``: fitted distributions keyed by country name.
32	
33	    The NBA ``GamePredictor.predict`` accepted ``num_games`` for a best-of-N
34	    series.  Here ``predict_tie`` always simulates exactly one match — the World
35	    Cup knockout format leaves no room for series length configuration.
36	
37	    Teams too sparse to fit their own distributions (e.g. nations with only a
38	    handful of matches in the training window) fall back to the pooled
39	    league-average distribution stored under ``POOLED_KEY`` when present — an
40	    "unknown-strength prior" — instead of raising ``KeyError``.
41	    """
42	
43	    POOLED_KEY = "__POOLED__"
44	
45	    def __init__(
46	        self,
47	        classifier: Any,
48	        sampler: FeatureSampler,
49	        team_distributions: dict[str, list[FittedDistribution]],
50	    ) -> None:
51	        self._classifier = classifier
52	        self._sampler = sampler
53	        self._team_distributions = team_distributions
54	
55	    def predict_tie(self, home: str, away: str) -> str:
56	        """Simulate a single knockout tie and return the advancing team.
57	
58	        Samples one feature vector from the fitted distributions of *home* and
59	        *away*, concatenates them in the order prescribed by
60	        ``FeaturesConfig.selected`` (home stats first, away stats second), feeds
61	        the vector to the classifier, and maps the binary prediction back to a
62	        team name.
63	
64	        Args:
65	            home: Country name of the team playing at (or designated as) home.
66	            away: Country name of the team playing away.
67	
68	        Returns:
69	            The country name of the winning team (either *home* or *away*).
70	
71	        Raises:
72	            KeyError: If *home* or *away* are absent and no ``POOLED_KEY``
73	                fallback distribution is available.
74	        """
75	        home_features = self._sampler.sample(
76	            self._dists_for(home), size=1
77	        )
78	        away_features = self._sampler.sample(
79	            self._dists_for(away), size=1
80	        )
81	        combined: np.ndarray = np.hstack([home_features, away_features])
82	        # predict returns an array of shape (1,); 1 = home win, 0 = away win.
83	        prediction: int = int(self._classifier.predict(combined)[0])
84	        return home if prediction == 1 else away
85	
86	    def _dists_for(self, team: str) -> list[FittedDistribution]:
87	        """Resolve a team's fitted distributions, falling back to the pool.
88	
89	        Sparse teams without their own fitted distributions use the pooled
90	        league-average distribution under ``POOLED_KEY`` when it exists.
91	        """
92	        dists = self._team_distributions.get(team)
93	        if dists is not None:
94	            return dists
95	        pooled = self._team_distributions.get(self.POOLED_KEY)
96	        if pooled is not None:
97	            return pooled
98	        raise KeyError(
99	            f"No fitted distributions for {team!r} and no {self.POOLED_KEY!r} fallback"
100	        )
101	
