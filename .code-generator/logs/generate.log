49	def _setup_logging(verbose: int) -> None:
50	    """Configure root logging level from the verbosity count flag."""
51	    level = {0: logging.WARNING, 1: logging.INFO}.get(verbose, logging.DEBUG)
52	    logging.basicConfig(
53	        level=level,
54	        format="%(levelname)-8s %(name)s: %(message)s",
55	    )
