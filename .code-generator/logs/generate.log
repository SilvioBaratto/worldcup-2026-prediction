55	class DistributionFitter:
56	    """Fits statistical distributions to per-team football match data.
57	
58	    Unlike the NBA fitter (which pivots on ``HOME_TEAM_ID`` / ``VISITOR_TEAM_ID``
59	    and a ``SEASON`` column), this class reads from the football train_data.csv
60	    schema:
61	
62	    - Column names for home perspective: ``GOALS_home``, ``SHOTS_home``, …
63	    - Column names for away perspective: ``GOALS_away``, ``SHOTS_away``, …
64	    - Team identification columns: ``HOME_TEAM``, ``AWAY_TEAM``
65	    - No ``SEASON`` column — ``DistributionConfig.min_season`` is interpreted as
66	      the minimum calendar year extracted from an optional ``DATE`` column.  When
67	      no ``DATE`` column exists all rows are used.
68	
69	    For each team ``T`` and each of the five base statistics the fitter gathers:
70	
71	    - The ``*_home`` column values from rows where ``HOME_TEAM == T``
72	    - The ``*_away`` column values from rows where ``AWAY_TEAM == T``
73	
74	    Both slices are stacked vertically so that the fitted distribution captures
75	    the team's performance regardless of venue.
76	    """
77	
78	    def __init__(
79	        self,
80	        config: DistributionConfig,
81	        features_config: FeaturesConfig,
82	    ) -> None:
83	        self._config = config
84	        self._features = features_config
85	
86	    def fit_all_teams(
87	        self,
88	        df: pd.DataFrame,
89	    ) -> dict[str, list[FittedDistribution]]:
90	        """Fit distributions for each team found in *df*.
91	
92	        Args:
93	            df: DataFrame conforming to the train_data.csv schema.  Must contain
94	                ``HOME_TEAM``, ``AWAY_TEAM``, and the 10 feature columns listed in
95	                ``FeaturesConfig.selected``.  An optional ``DATE`` column (ISO
96	                format) is used to filter by ``DistributionConfig.min_season``.
97	
98	        Returns:
99	            Mapping of ``{team_name: [FittedDistribution per base stat]}``.
100	            The list length equals ``FeaturesConfig.per_team_count`` (5).
101	        """
102	        filtered_df = self._filter_by_season(df)
103	        team_data = self._aggregate_team_data(filtered_df)
104	
105	        result: dict[str, list[FittedDistribution]] = {}
106	        for team_name, data in team_data.items():
107	            logger.info("Fitting distributions for %s", team_name)
108	            result[team_name] = self._fit_team(data)
109	
110	        return result
111	
112	    # ------------------------------------------------------------------
113	    # Private helpers
114	    # ------------------------------------------------------------------
115	
116	    def _filter_by_season(self, df: pd.DataFrame) -> pd.DataFrame:
117	        """Return only rows at or after ``min_season``.
118	
119	        Falls back to the full DataFrame when no ``DATE`` column is present.
120	        """
121	        if "DATE" not in df.columns:
122	            logger.debug(
123	                "No DATE column found; using all %d rows for distribution fitting",
124	                len(df),
125	            )
126	            return df.reset_index(drop=True)
127	
128	        years = pd.to_datetime(df["DATE"], errors="coerce").dt.year
129	        mask = years >= self._config.min_season
130	        filtered = df.loc[mask].reset_index(drop=True)
131	        logger.debug(
132	            "Filtered to %d rows from year >= %d", len(filtered), self._config.min_season
133	        )
134	        return filtered
