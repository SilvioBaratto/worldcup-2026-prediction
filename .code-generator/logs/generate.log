173	    def plot_bracket(
174	        self,
175	        rounds: dict[int, Any],
176	        bracket: BracketConfig,
177	        output_path: Path | None = None,
178	    ) -> None:
179	        """Render the knockout bracket as a PNG with per-team probabilities.
180	
181	        Each slot box shows the two competing countries and their round
182	        advancement probabilities drawn from *rounds*.  Connector lines
183	        flow left-to-right (no conference split — World Cup has no
184	        conferences).
185	
186	        Args:
187	            rounds: Mapping of round index to a RoundResult-like object with
188	                ``.probabilities`` (``dict[str, float]``).
189	            bracket: Bracket definition including first-round matchups.
190	            output_path: Destination PNG path.  If *None* the figure is shown
191	                interactively.
192	        """
193	        slots_by_round = _build_round_slots(bracket.matchups)
194	        if not slots_by_round:
195	            logger.warning("plot_bracket called with empty matchup list — nothing to draw.")
196	            return
