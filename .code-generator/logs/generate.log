24	class ClassifierFactory:
25	    """Creates configured classifier instances from config."""
26	
27	    @staticmethod
28	    def create(name: str, config: TrainingConfig) -> Any:
29	        match name:
30	            case "svm":
31	                cfg = config.svm
32	                return make_pipeline(
33	                    StandardScaler(),
34	                    SVC(C=cfg.C, gamma=cfg.gamma, kernel=cfg.kernel, probability=True),  # type: ignore[arg-type]
35	                )
36	            case "random_forest":
37	                cfg = config.random_forest
38	                return RandomForestClassifier(
39	                    n_estimators=cfg.n_estimators,
40	                    max_features=cfg.max_features,
41	                    max_depth=cfg.max_depth,
42	                    bootstrap=cfg.bootstrap,
43	                )
44	            case "naive_bayes":
45	                cfg = config.naive_bayes
46	                return GaussianNB(var_smoothing=cfg.var_smoothing)
47	            case _:
48	                raise ValueError(
49	                    f"Unknown classifier '{name}'. "
50	                    f"Choose from: svm, random_forest, naive_bayes"
51	                )
