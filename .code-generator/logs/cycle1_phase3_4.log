454	def test_when_standings_given_to_resolve_r32_then_exactly_8_third_placed_teams_appear():
455	    """The 8 qualifying thirds (not the 4 eliminated) must fill the third-place slots."""
456	    from worldcup_playoff.data import rank_third_places, resolve_r32
457	
458	    standings = _standings_for_first_known_combo()
459	    result = resolve_r32(standings)
