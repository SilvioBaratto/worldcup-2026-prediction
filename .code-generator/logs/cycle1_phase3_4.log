15	# ---------------------------------------------------------------------------
16	# Required column schemas (column name -> expected pandas dtype string)
17	# ---------------------------------------------------------------------------
18	
19	REQUIRED_MATCHES_COLUMNS: dict[str, str] = {
20	    "MATCH_ID": "int64",
21	    "DATE": "object",
22	    "HOME_TEAM": "object",
23	    "AWAY_TEAM": "object",
24	    "HOME_GOALS": "int64",
25	    "AWAY_GOALS": "int64",
26	    "COMPETITION": "object",
27	    "SEASON": "int64",
28	}
