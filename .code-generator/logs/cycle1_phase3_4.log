162	# ---------------------------------------------------------------------------
163	
164	
165	def wc2026_schedule(df: pd.DataFrame) -> pd.DataFrame:
166	    """Return rows where TOURNAMENT == 'FIFA World Cup', including unplayed fixtures."""
167	    return df[df["TOURNAMENT"] == "FIFA World Cup"].reset_index(drop=True)
168	
169	
170	# ---------------------------------------------------------------------------
171	# Loader
172	# ---------------------------------------------------------------------------
173	
174	
175	class Martj42Loader:
176	    """Cache-first loader for the martj42/international_results CC0 datasets."""
177	
178	    def __init__(
179	        self,
180	        config: Martj42Config,
181	        cache_dir: Path | None = None,
182	        base_url: str | None = None,
183	    ) -> None:
184	        self._config = config
185	        self._cache_dir = cache_dir or config.cache_dir
186	        self._base_url = base_url or config.base_url
187	
188	    # --- public API ---
189	
190	    def load_results(self) -> pd.DataFrame:
191	        """Return the results DataFrame coerced to the internal schema."""
192	        return self._coerce_results(self._fetch_raw(self._config.results_file))
193	
194	    def load_shootouts(self) -> pd.DataFrame:
195	        """Return the shootouts DataFrame coerced to the internal schema."""
196	        return self._coerce_shootouts(self._fetch_raw(self._config.shootouts_file))
197	
198	    def load_goalscorers(self) -> pd.DataFrame:
199	        """Return the goalscorers DataFrame coerced to the internal schema."""
200	        return self._coerce_goalscorers(self._fetch_raw(self._config.goalscorers_file))
201	
202	    def wc2026_schedule(self) -> pd.DataFrame:
203	        """Return FIFA World Cup rows (played + unplayed) from results."""
204	        return wc2026_schedule(self.load_results())
205	
206	    # --- private helpers ---
207	
208	    def _fetch_raw(self, filename: str) -> pd.DataFrame:
209	        path = self._cache_dir / filename
210	        if path.exists():
211	            logger.info("Loading %s from cache: %s", filename, path)
212	            return pd.read_csv(path)
213	        url = self._base_url + filename
214	        logger.info("Downloading %s from %s", filename, url)
215	        df = pd.read_csv(url)
216	        path.parent.mkdir(parents=True, exist_ok=True)
217	        df.to_csv(path, index=False)
218	        return df
219	
220	    def _apply_crosswalk(self, df: pd.DataFrame, cols: list[str]) -> None:
221	        for col in cols:
222	            df[col] = normalize_series(df[col])
223	
224	    def _coerce_results(self, raw: pd.DataFrame) -> pd.DataFrame:
225	        df = raw.rename(columns=_RESULTS_RENAME)[list(_RESULTS_RENAME.values())].copy()
226	        df["HOME_GOALS"] = pd.to_numeric(df["HOME_GOALS"], errors="coerce").astype("Int64")
227	        df["AWAY_GOALS"] = pd.to_numeric(df["AWAY_GOALS"], errors="coerce").astype("Int64")
228	        df["NEUTRAL"] = _parse_bool_column(df["NEUTRAL"])
229	        self._apply_crosswalk(df, ["HOME_TEAM", "AWAY_TEAM"])
230	        validate_results_df(df)
231	        return df
232	
233	    def _coerce_shootouts(self, raw: pd.DataFrame) -> pd.DataFrame:
234	        df = raw.rename(columns=_SHOOTOUTS_RENAME)[list(_SHOOTOUTS_RENAME.values())].copy()
235	        self._apply_crosswalk(df, ["HOME_TEAM", "AWAY_TEAM"])
236	        validate_shootouts_df(df)
237	        return df
238	
239	    def _coerce_goalscorers(self, raw: pd.DataFrame) -> pd.DataFrame:
240	        df = raw.rename(columns=_GOALSCORERS_RENAME)[list(_GOALSCORERS_RENAME.values())].copy()
241	        df["MINUTE"] = pd.to_numeric(df["MINUTE"], errors="coerce").astype("Int64")
242	        df["OWN_GOAL"] = _parse_bool_column(df["OWN_GOAL"])
243	        df["PENALTY"] = _parse_bool_column(df["PENALTY"])
244	        self._apply_crosswalk(df, ["HOME_TEAM", "AWAY_TEAM", "TEAM"])
245	        validate_goalscorers_df(df)
246	        return df
247	
248	
249	# ---------------------------------------------------------------------------
250	# Module-level factory functions (mirrors build_*_csv / generate_bracket_toml)
251	# ---------------------------------------------------------------------------
252	
253	
254	def load_martj42_results(config: Martj42Config) -> pd.DataFrame:
255	    """Load and return the martj42 results DataFrame."""
256	    return Martj42Loader(config=config).load_results()
257	
258	
259	def load_martj42_shootouts(config: Martj42Config) -> pd.DataFrame:
260	    """Load and return the martj42 shootouts DataFrame."""
261	    return Martj42Loader(config=config).load_shootouts()
262	
263	
264	def load_martj42_goalscorers(config: Martj42Config) -> pd.DataFrame:
265	    """Load and return the martj42 goalscorers DataFrame."""
266	    return Martj42Loader(config=config).load_goalscorers()
