474	# --- Filter invariant: wc2026_schedule(df) only ever returns FIFA World Cup rows ---
475	
476	_TOURNAMENT_NAMES = st.sampled_from(
477	    ["FIFA World Cup", "UEFA Nations League", "Friendly", "CONMEBOL World Cup Qualifying", "AFC Cup"]
478	)
479	
480	
481	@given(
482	    st.lists(
483	        st.fixed_dictionaries(
484	            {
485	                "DATE": st.just("2026-06-11"),
486	                "HOME_TEAM": st.text(min_size=1, max_size=30),
487	                "AWAY_TEAM": st.text(min_size=1, max_size=30),
488	                "HOME_GOALS": st.none(),
489	                "AWAY_GOALS": st.none(),
490	                "TOURNAMENT": _TOURNAMENT_NAMES,
491	                "NEUTRAL": st.booleans(),
492	            }
493	        ),
494	        min_size=0,
495	        max_size=30,
496	    )
497	)
498	def test_when_wc2026_schedule_filters_any_results_df_then_all_rows_are_world_cup(
499	    rows: list,
500	):
501	    """Filter invariant: wc2026_schedule never admits non-FIFA-World-Cup rows."""
502	    df = (
503	        pd.DataFrame(rows)
504	        if rows
505	        else pd.DataFrame(
506	            columns=["DATE", "HOME_TEAM", "AWAY_TEAM", "HOME_GOALS", "AWAY_GOALS", "TOURNAMENT", "NEUTRAL"]
507	        )
508	    )
509	    result = wc2026_schedule(df)
510	    assert isinstance(result, pd.DataFrame)
511	    if len(result) > 0:
512	        assert (result["TOURNAMENT"] == "FIFA World Cup").all()
