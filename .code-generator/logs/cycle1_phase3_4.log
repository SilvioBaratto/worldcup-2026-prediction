513	def test_when_data_package_reloaded_then_football_client_is_not_constructed(monkeypatch):
514	    """FootballClient.__init__ must not be called as a side-effect of importing."""
515	    import importlib
516	
517	    constructed: list[bool] = []
518	    try:
519	        from worldcup_playoff.data import client as _client_mod
520	
521	        _original_init = _client_mod.FootballClient.__init__
522	
523	        def _spy_init(self, *args, **kwargs):
524	            constructed.append(True)
525	            return _original_init(self, *args, **kwargs)
526	
527	        monkeypatch.setattr(_client_mod.FootballClient, "__init__", _spy_init)
528	    except (ImportError, AttributeError):
529	        return  # client module absent — purity is guaranteed by absence
530	
531	    import worldcup_playoff.data
532	
533	    importlib.reload(worldcup_playoff.data)
534	    assert not constructed, "FootballClient was instantiated during package import"
535	
