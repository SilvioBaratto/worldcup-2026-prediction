84	# ---------------------------------------------------------------------------
85	# Boolean column parser (handles both string and auto-inferred bool input)
86	# ---------------------------------------------------------------------------
87	
88	
89	def _parse_bool_column(series: pd.Series) -> pd.Series:
90	    """Coerce TRUE/FALSE (string or auto-detected bool) to numpy bool.
91	
92	    pandas may auto-detect 'TRUE'/'FALSE' CSV strings as bool; converting to
93	    str first normalises both paths: str(True)='True' -> upper='TRUE' -> True.
94	    """
95	    return series.astype(str).str.upper().map({"TRUE": True, "FALSE": False}).astype(bool)
96	
97	
98	# dtype family sets used by the validator
99	_INT64_DTYPES = {"Int64"}
100	_BOOL_DTYPES = {"bool", "boolean"}
101	_NUMERIC_DTYPES = {"int64", "float64", "int32", "float32"}
102	_STRING_DTYPES = {"object", "str", "string"}
103	
104	# ---------------------------------------------------------------------------
105	# Validator
106	# ---------------------------------------------------------------------------
107	
108	
109	def _validate_martj42(df: pd.DataFrame, required: dict[str, str], label: str) -> None:
110	    """Raise ValueError for missing columns or incompatible dtypes.
111	
112	    Extends loader.py's family logic to accept nullable Int64 and bool.
113	    """
114	    missing = set(required) - set(df.columns)
115	    if missing:
116	        parts = []
117	        for col in sorted(missing):
118	            near = difflib.get_close_matches(col, df.columns.tolist(), n=1, cutoff=0.7)
119	            hint = f" — did you mean '{near[0]}'?" if near else ""
120	            parts.append(f"  '{col}'{hint}")
121	        raise ValueError(f"{label} DataFrame missing required column(s):\n" + "\n".join(parts))
122	
123	    type_errors: list[str] = []
124	    for col, expected in required.items():
125	        actual = str(df[col].dtype)
126	        if actual == expected:
127	            continue
128	        if expected in _INT64_DTYPES:
129	            type_errors.append(f"  '{col}' has dtype '{actual}', expected '{expected}'")
130	            continue
131	        if expected in _BOOL_DTYPES:
132	            if df[col].dtype.kind != "b":
133	                type_errors.append(f"  '{col}' has dtype '{actual}', expected bool-like")
134	            continue
135	        if actual in _NUMERIC_DTYPES and expected in _NUMERIC_DTYPES:
136	            continue
137	        if actual in _STRING_DTYPES and expected in _STRING_DTYPES:
138	            continue
139	        type_errors.append(f"  '{col}' has dtype '{actual}', expected '{expected}'")
140	
141	    if type_errors:
142	        raise ValueError(f"{label} DataFrame has wrong column dtype(s):\n" + "\n".join(type_errors))
143	
144	
145	def validate_results_df(df: pd.DataFrame) -> None:
146	    """Validate that a results DataFrame conforms to the martj42 results schema."""
147	    _validate_martj42(df, REQUIRED_MARTJ42_RESULTS_COLUMNS, "martj42_results")
148	
149	
150	def validate_shootouts_df(df: pd.DataFrame) -> None:
151	    """Validate that a shootouts DataFrame conforms to the martj42 shootouts schema."""
152	    _validate_martj42(df, REQUIRED_MARTJ42_SHOOTOUTS_COLUMNS, "martj42_shootouts")
153	
154	
155	def validate_goalscorers_df(df: pd.DataFrame) -> None:
156	    """Validate that a goalscorers DataFrame conforms to the martj42 goalscorers schema."""
157	    _validate_martj42(df, REQUIRED_MARTJ42_GOALSCORERS_COLUMNS, "martj42_goalscorers")
158	
