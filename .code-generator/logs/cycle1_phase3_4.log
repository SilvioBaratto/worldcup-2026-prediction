489	def _make_group_match(match_id: int, status: str) -> dict:
490	    return {
491	        "id": match_id,
492	        "utcDate": "2026-06-20T12:00:00Z",
493	        "status": status,
494	        "stage": "GROUP_STAGE",
495	        "group": "GROUP_A",
496	        "matchday": 1,
497	        "homeTeam": {"id": 1, "name": "TeamA"},
498	        "awayTeam": {"id": 2, "name": "TeamB"},
499	        "score": {
500	            "winner": "HOME_TEAM" if status == "FINISHED" else None,
501	            "duration": "REGULAR",
502	            "fullTime": (
503	                {"home": 1, "away": 0} if status == "FINISHED" else {"home": None, "away": None}
504	            ),
505	            "halfTime": (
506	                {"home": 0, "away": 0} if status == "FINISHED" else {"home": None, "away": None}
507	            ),
508	        },
509	    }
510	
511	
512	@given(
513	    statuses=st.lists(
514	        st.sampled_from(["FINISHED", "SCHEDULED", "TIMED"]),
515	        min_size=0,
516	        max_size=8,
517	    )
518	)
519	@settings(max_examples=40)
520	def test_when_group_stage_matches_have_mixed_statuses_then_partition_covers_all_of_them(
521	    statuses: list,
522	) -> None:
523	    """
524	    Invariant from AC2: played ∪ remaining_group_fixtures must cover every group-stage
525	    match exactly once — no match may be silently dropped from TournamentState.
526	    """
527	    from worldcup_playoff.data.live import LiveTournamentAdapter
528	
529	    group_matches = [_make_group_match(i, status) for i, status in enumerate(statuses)]
530	    matches_json = {**_MATCHES_JSON, "matches": group_matches}
531	
532	    client = MagicMock()
533	    client.get.side_effect = [matches_json, _STANDINGS_JSON]
534	
535	    state = LiveTournamentAdapter(client, competition="WC").tournament_state()
536	    total_partitioned = len(state.played) + len(state.remaining_group_fixtures)
537	    assert total_partitioned == len(group_matches)
