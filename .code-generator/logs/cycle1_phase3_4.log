14	# ---------------------------------------------------------------------------
15	# normalize_team: whitespace handling
16	# ---------------------------------------------------------------------------
17	
18	
19	def test_when_name_has_leading_trailing_whitespace_then_it_is_stripped():
20	    result = normalize_team("  Germany  ")
21	    assert result == result.strip()
22	
23	
24	def test_when_name_has_internal_multiple_spaces_then_they_are_collapsed():
25	    result = normalize_team("United  States")
26	    assert "  " not in result
27	
28	
29	def test_when_unknown_name_is_given_then_cleaned_input_is_returned():
30	    unknown = "Ruritania"
31	    result = normalize_team(unknown)
32	    assert result == unknown
33	
34	
35	def test_when_unknown_name_with_whitespace_is_given_then_stripped_form_is_returned():
36	    result = normalize_team("  Ruritania  ")
37	    assert result == "Ruritania"
38	
39	
40	# ---------------------------------------------------------------------------
41	# CANONICAL_NAMES alias coverage (data-contract aliases)
42	# ---------------------------------------------------------------------------
43	
44	
45	@pytest.mark.parametrize(
46	    "alias,expected_canonical",
47	    [
48	        ("Türkiye", "Turkey"),
49	        ("Turkey", "Turkey"),
50	        ("Czechia", "Czech Republic"),
51	        ("South Korea", "South Korea"),
52	        ("Korea Republic", "South Korea"),
53	        ("Republic of Korea", "South Korea"),
54	        ("United States", "United States"),
55	        ("USA", "United States"),
56	        ("United States of America", "United States"),
57	        ("IR Iran", "Iran"),
58	        ("Iran", "Iran"),
59	        ("China PR", "China"),
60	        ("China", "China"),
61	    ],
62	)
63	def test_when_known_alias_is_normalized_then_canonical_name_is_returned(
64	    alias: str, expected_canonical: str
65	):
66	    assert normalize_team(alias) == expected_canonical
67	
68	
69	def test_when_alias_is_uppercase_then_canonical_is_still_returned():
70	    assert normalize_team("TÜRKIYE") == "Turkey"
71	
72	
73	def test_when_alias_is_lowercase_then_canonical_is_still_returned():
74	    assert normalize_team("türkiye") == "Turkey"
75	
76	
77	def test_when_alias_has_surrounding_whitespace_then_canonical_is_still_returned():
78	    assert normalize_team("  IR Iran  ") == "Iran"
79	
80	
81	def test_when_canonical_names_dict_is_accessed_then_it_is_a_dict():
82	    assert isinstance(CANONICAL_NAMES, dict)
83	
84	
85	def test_when_canonical_names_dict_is_checked_then_all_data_contract_aliases_are_covered():
86	    required_aliases = {
87	        "türkiye",
88	        "korea republic",
89	        "republic of korea",
90	        "south korea",
91	        "usa",
92	        "united states of america",
93	        "ir iran",
94	        "china pr",
95	        "czechia",
96	    }
97	    lowered_keys = {k.lower().strip() for k in CANONICAL_NAMES}
98	    missing = required_aliases - lowered_keys
99	    assert not missing, f"Missing aliases in CANONICAL_NAMES: {missing}"
100	
101	
102	# ---------------------------------------------------------------------------
103	# normalize_series: length and index preservation
104	# ---------------------------------------------------------------------------
105	
106	
107	def test_when_series_is_normalized_then_length_is_preserved():
108	    s = pd.Series(["Germany", "Türkiye", "IR Iran"])
109	    result = normalize_series(s)
110	    assert len(result) == len(s)
111	
112	
113	def test_when_series_is_normalized_then_index_is_preserved():
114	    s = pd.Series(["Germany", "Türkiye"], index=[10, 20])
115	    result = normalize_series(s)
116	    assert list(result.index) == [10, 20]
117	
118	
119	def test_when_series_contains_known_alias_then_canonical_name_is_returned():
120	    s = pd.Series(["Türkiye"])
121	    result = normalize_series(s)
122	    assert result.iloc[0] == "Turkey"
123	
124	
125	def test_when_series_contains_unknown_name_then_it_is_returned_cleaned():
126	    s = pd.Series(["Ruritania"])
127	    result = normalize_series(s)
128	    assert result.iloc[0] == "Ruritania"
129	
130	
131	def test_when_series_is_empty_then_empty_series_is_returned():
132	    s = pd.Series([], dtype=str)
133	    result = normalize_series(s)
134	    assert len(result) == 0
135	
136	
137	def test_when_series_has_mixed_names_then_all_are_mapped_correctly():
138	    s = pd.Series(["Türkiye", "Germany", "IR Iran"])
139	    result = normalize_series(s)
140	    assert result.tolist() == ["Turkey", "Germany", "Iran"]
141	
142	
143	# ---------------------------------------------------------------------------
144	# Idempotence
145	# ---------------------------------------------------------------------------
146	
147	
148	def test_when_canonical_name_is_normalized_then_result_is_unchanged():
149	    for canonical in set(CANONICAL_NAMES.values()):
150	        assert normalize_team(canonical) == canonical, (
151	            f"normalize_team({canonical!r}) is not idempotent"
152	        )
153	
154	
155	@given(st.text())
156	def test_when_normalize_team_is_applied_twice_then_result_is_unchanged(name: str):
157	    """Idempotence invariant: applying normalize_team twice equals applying it once."""
158	    once = normalize_team(name)
159	    assert normalize_team(once) == once
