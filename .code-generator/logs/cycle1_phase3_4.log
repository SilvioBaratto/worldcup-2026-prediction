84	def _standings_for_first_known_combo() -> dict[str, list[dict]]:
85	    """
86	    Build standings whose top-8 thirds exactly match the first entry in
87	    THIRD_PLACE_COMBINATIONS, so resolve_r32 can always resolve the bracket.
88	    """
89	    from worldcup_playoff.data import THIRD_PLACE_COMBINATIONS
90	
91	    first_key = next(iter(THIRD_PLACE_COMBINATIONS))
92	    qualifying = frozenset(first_key)
93	    result = {}
94	    for g in _ALL_GROUPS:
95	        if g in qualifying:
96	            result[g] = _group_table(g, pts3=4, gd3=2, gf3=4)
97	        else:
98	            result[g] = _group_table(g, pts3=1, gd3=-3, gf3=1)
99	    return result
