463	    # In our fixture, third-placed teams are named "Team{G}3"
464	    third_teams_in_bracket = {t for t in all_teams if t.endswith("3")}
465	    assert len(third_teams_in_bracket) == 8
466	    for t in third_teams_in_bracket:
467	        group_letter = t[4]  # "TeamA3" → index 4 → "A"
468	        assert group_letter in qualifying_groups, (
469	            f"Team {t!r} from group {group_letter!r} should not be in the bracket"
470	        )
