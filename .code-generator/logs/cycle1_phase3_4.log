53	
54	def _group_table(letter: str, pts3: int, gd3: int, gf3: int) -> list[dict]:
55	    """4-row group table; third-placed team ('Team{letter}3') has the given stats."""
56	    gf3 = max(gf3, 0)
57	    return [
58	        _table_row(1, f"Team{letter}1", 9, 6, 8),
59	        _table_row(2, f"Team{letter}2", 6, 2, 5),
60	        _table_row(3, f"Team{letter}3", pts3, gd3, gf3),
61	        _table_row(4, f"Team{letter}4", 0, -8, 1),
62	    ]
63	
64	
65	def _uniform_standings(pts3: int = 3, gd3: int = 0, gf3: int = 2) -> dict[str, list[dict]]:
66	    """All 12 groups with identical third-place statistics (ties broken by group letter)."""
67	    return {g: _group_table(g, pts3, gd3, gf3) for g in _ALL_GROUPS}
68	
69	
70	def _standings_first_n_superior(n: int = 8) -> dict[str, list[dict]]:
71	    """
72	    First *n* groups (A … nth) have clearly superior third-placed teams;
73	    the remaining (12 - n) have clearly inferior ones.
74	    """
75	    result = {}
76	    for i, g in enumerate(_ALL_GROUPS):
77	        if i < n:
78	            result[g] = _group_table(g, pts3=4, gd3=2, gf3=4)
79	        else:
80	            result[g] = _group_table(g, pts3=1, gd3=-3, gf3=1)
81	    return result
82	
