32	def _table_row(
33	    position: int,
34	    team_name: str,
35	    points: int,
36	    gd: int,
37	    gf: int,
38	) -> dict:
39	    """Build one row of a group table matching the football-data.org v4 schema."""
40	    return {
41	        "position": position,
42	        "team": {"name": team_name},
43	        "playedGames": 3,
44	        "points": points,
45	        "goalsFor": gf,
46	        "goalsAgainst": max(gf - gd, 0),
47	        "goalDifference": gd,
48	        "won": 0,
49	        "draw": 0,
50	        "lost": 0,
51	    }
