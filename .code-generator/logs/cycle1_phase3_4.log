477	
478	def test_when_data_package_imported_then_no_exception_is_raised():
479	    """The data package must be importable with no side-effects."""
480	    import importlib
481	
482	    import worldcup_playoff.data  # noqa: F401
483	
484	    importlib.reload(worldcup_playoff.data)  # re-execute module top-level — must not raise
485	
486	
487	def test_when_data_package_reloaded_then_no_http_request_is_initiated(monkeypatch):
488	    """No HTTP request (via requests.Session or requests.get) must fire on import."""
489	    import importlib
490	
491	    import requests
492	
493	    blocked: list[tuple] = []
494	
495	    def _forbid_get(*args, **kwargs):
496	        blocked.append(args)
497	        raise AssertionError(f"HTTP GET called during import: {args}")
498	
499	    def _forbid_post(*args, **kwargs):
500	        blocked.append(args)
501	        raise AssertionError(f"HTTP POST called during import: {args}")
502	
503	    monkeypatch.setattr(requests, "get", _forbid_get)
504	    monkeypatch.setattr(requests, "post", _forbid_post)
505	
506	    import worldcup_playoff.data
507	
508	    importlib.reload(worldcup_playoff.data)  # must not trigger _forbid_get/_forbid_post
509	
510	    assert not blocked, f"HTTP call(s) made on import: {blocked}"
511	
