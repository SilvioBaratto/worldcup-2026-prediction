68	
69	def _abilities(*team_names: str) -> TeamAbilities:
70	    """Build a uniform TeamAbilities for the named teams."""
71	    return TeamAbilities(
72	        attack={t: 1.3 for t in team_names},
73	        defence={t: 0.9 for t in team_names},
74	        home_adv=0.0,
75	        rho=-0.1,
76	        intercept=0.0,
77	    )
