2	
3	from __future__ import annotations
4	
5	import logging
6	from typing import Any, Optional
7	
8	import pandas as pd
9	from pydantic import BaseModel, ConfigDict, model_validator
10	
11	from worldcup_playoff.data.client import FootballClient
12	from worldcup_playoff.data.crosswalk import normalize_team
13	
14	logger = logging.getLogger(__name__)
15	
16	_FINISHED_STATUS = "FINISHED"
17	_WC_TOURNAMENT = "FIFA World Cup"
18	_RESULTS_COLS = ("DATE", "HOME_TEAM", "AWAY_TEAM", "HOME_GOALS", "AWAY_GOALS", "TOURNAMENT", "NEUTRAL")
19	
20	
21	class LiveMatch(BaseModel):
22	    """A single match from the football-data.org matches endpoint.
23	
24	    Fields ``date``, ``home_goals``, ``away_goals``, and ``neutral`` carry
25	    martj42-compatible values for use with ``live_fixtures_to_df``.
26	    """
27	
28	    model_config = ConfigDict(extra="ignore")
29	
30	    id: int
31	    utc_date: str = ""
32	    status: str
33	    stage: str = ""
34	    group: Optional[str] = None
35	    home_team: Optional[str] = None
36	    away_team: Optional[str] = None
37	    date: str = ""
38	    home_goals: Optional[int] = None
39	    away_goals: Optional[int] = None
40	    neutral: bool = True
41	
42	    @model_validator(mode="before")
43	    @classmethod
44	    def _extract_fields(cls, data: Any) -> Any:
45	        if not isinstance(data, dict):
46	            return data
47	        out = dict(data)
48	        if "utcDate" in data:
49	            utc = data["utcDate"] or ""
50	            out["utc_date"] = utc
51	            out.setdefault("date", utc[:10])
52	        if "homeTeam" in data:
53	            n = (data.get("homeTeam") or {}).get("name")
54	            out["home_team"] = normalize_team(n) if n else None
55	        if "awayTeam" in data:
56	            n = (data.get("awayTeam") or {}).get("name")
57	            out["away_team"] = normalize_team(n) if n else None
58	        if "score" in data:
59	            ft = (data.get("score") or {}).get("fullTime") or {}
60	            out.setdefault("home_goals", ft.get("home"))
61	            out.setdefault("away_goals", ft.get("away"))
62	        return out
63	
64	
65	class TableRow(BaseModel):
66	    """One team's row in a group standings table."""
67	
68	    model_config = ConfigDict(extra="ignore")
69	
70	    position: int = 0
71	    team_name: Optional[str] = None
72	    played_games: int = 0
73	    won: int = 0
74	    draw: int = 0
75	    lost: int = 0
76	    points: int = 0
77	    goals_for: int = 0
78	    goals_against: int = 0
79	    goal_difference: int = 0
80	
81	    @model_validator(mode="before")
82	    @classmethod
83	    def _flatten(cls, data: Any) -> Any:
84	        if not isinstance(data, dict):
85	            return data
86	        return {
87	            **data,
88	            "team_name": (data.get("team") or {}).get("name"),
89	            "played_games": data.get("playedGames", 0),
90	            "goals_for": data.get("goalsFor", 0),
91	            "goals_against": data.get("goalsAgainst", 0),
92	            "goal_difference": data.get("goalDifference", 0),
93	        }
94	
95	
96	class GroupStanding(BaseModel):
97	    """Standings for a single WC group."""
98	
99	    model_config = ConfigDict(extra="ignore")
100	
101	    group: Optional[str] = None
102	    stage: str = ""
103	    table: list[TableRow] = []
104	
105	
106	class TournamentState(BaseModel):
107	    """Snapshot of the WC2026 tournament as of today."""
108	
109	    model_config = ConfigDict(extra="ignore")
110	
111	    played: list[LiveMatch]
112	    remaining_group_fixtures: list[LiveMatch]
113	    standings: list[GroupStanding]
114	
115	
116	class LiveTournamentAdapter:
117	    """Fetches live WC2026 data and assembles a TournamentState."""
118	
119	    def __init__(self, client: FootballClient, competition: str = "WC") -> None:
120	        self._client = client
121	        self._competition = competition
122	
123	    def fetch_matches(self) -> list[LiveMatch]:
124	        data = self._client.get(f"/competitions/{self._competition}/matches")
125	        return [self._parse_match(m) for m in data.get("matches", [])]
126	
127	    def fetch_standings(self) -> list[GroupStanding]:
128	        data = self._client.get(f"/competitions/{self._competition}/standings")
129	        return [GroupStanding.model_validate(s) for s in data.get("standings", [])]
130	
131	    def tournament_state(self) -> TournamentState:
132	        matches = self.fetch_matches()
133	        standings = self.fetch_standings()
134	        played, remaining = self._split_played_remaining(matches)
135	        return TournamentState(
136	            played=played, remaining_group_fixtures=remaining, standings=standings
137	        )
138	
139	    def _parse_match(self, raw: dict[str, Any]) -> LiveMatch:
140	        return LiveMatch.model_validate(raw)
141	
142	    def _split_played_remaining(
143	        self, matches: list[LiveMatch]
144	    ) -> tuple[list[LiveMatch], list[LiveMatch]]:
145	        group_stage = [m for m in matches if m.stage == "GROUP_STAGE"]
146	        played = [m for m in group_stage if m.status == _FINISHED_STATUS]
147	        remaining = [m for m in group_stage if m.status != _FINISHED_STATUS]
148	        return played, remaining
149	
150	
151	def fetch_tournament_state(
152	    client: FootballClient | None = None,
153	    competition: str = "WC",
154	) -> TournamentState:
155	    """Build a TournamentState, creating a default FootballClient when none is passed."""
156	    if client is None:
157	        client = FootballClient()
158	    return LiveTournamentAdapter(client, competition=competition).tournament_state()
159	
160	
161	# ---------------------------------------------------------------------------
162	# martj42-schema conversion
163	# ---------------------------------------------------------------------------
164	
165	
166	def _match_to_row(m: LiveMatch) -> dict:
167	    return {
168	        "DATE": m.date,
169	        "HOME_TEAM": m.home_team,
170	        "AWAY_TEAM": m.away_team,
171	        "HOME_GOALS": m.home_goals,
172	        "AWAY_GOALS": m.away_goals,
173	        "TOURNAMENT": _WC_TOURNAMENT,
174	        "NEUTRAL": m.neutral,
175	    }
176	
177	
178	def _to_results_df(matches: list[LiveMatch]) -> pd.DataFrame:
179	    """Build a martj42 results DataFrame from a list of valid LiveMatch objects."""
180	    if not matches:
181	        return pd.DataFrame(columns=list(_RESULTS_COLS))
182	    rows = [_match_to_row(m) for m in matches]
183	    df = pd.DataFrame(rows)[list(_RESULTS_COLS)]
184	    df["HOME_GOALS"] = df["HOME_GOALS"].astype("Int64")
185	    df["AWAY_GOALS"] = df["AWAY_GOALS"].astype("Int64")
186	    return df
187	
188	
189	def live_fixtures_to_df(
190	    state: TournamentState, *, include_played: bool = False
191	) -> pd.DataFrame:
192	    """Convert TournamentState fixtures to a martj42-schema DataFrame.
193	
194	    Processes ``remaining_group_fixtures`` (and optionally ``played``).
195	    None-team placeholder slots (unresolved knockout positions) are dropped.
196	    Goals are ``<NA>`` for remaining (unplayed) fixtures.
197	    """
198	    fixtures: list[LiveMatch] = list(state.remaining_group_fixtures)
199	    if include_played:
200	        fixtures += list(state.played)
201	    valid = [m for m in fixtures if m.home_team is not None and m.away_team is not None]
202	    return _to_results_df(valid)
203	
