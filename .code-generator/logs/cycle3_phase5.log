29	def _make_history() -> pd.DataFrame:
30	    """Minimal martj42-internal DataFrame: 3 played WC matches + 2 unplayed WC2026."""
31	    return pd.DataFrame({
32	        "DATE": pd.to_datetime([
33	            "2022-11-20", "2022-11-24", "2022-11-28",
34	            "2026-06-11", "2026-06-15",
35	        ]),
36	        "HOME_TEAM":  ["Brazil", "France", "Argentina", "Brazil", "Germany"],
