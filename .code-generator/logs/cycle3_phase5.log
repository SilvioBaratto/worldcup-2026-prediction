8	"""
9	from __future__ import annotations
10	
11	import pandas as pd
12	import pytest
13	
14	from worldcup_playoff.config import FeatureBuildConfig
15	from worldcup_playoff.features.build import FEATURE_COLUMNS, FeatureBuilder, TeamAbilities
16	
17	_CFG = FeatureBuildConfig(random_seed=42)
18	
19	_FORBIDDEN_SUBSTRINGS = ("gdp", "market_value", "transfer", "odds", "bookie", "wage")
20	
21	
22	def _matches(rows: list[dict]) -> pd.DataFrame:
23	    return pd.DataFrame({
24	        "DATE":       pd.to_datetime([r.get("date", "2026-01-01") for r in rows]),
25	        "HOME_TEAM":  [r["home"] for r in rows],
26	        "AWAY_TEAM":  [r["away"] for r in rows],
27	        "HOME_GOALS": pd.array([r.get("home_goals", pd.NA) for r in rows], dtype="Int64"),
28	        "AWAY_GOALS": pd.array([r.get("away_goals", pd.NA) for r in rows], dtype="Int64"),
29	        "TOURNAMENT": [r.get("tournament", "Friendly") for r in rows],
30	        "NEUTRAL":    [r.get("neutral", False) for r in rows],
31	    })
32	
33	
34	def _elo(rows: list[dict]) -> pd.DataFrame:
35	    return pd.DataFrame({
36	        "home_elo": [float(r.get("home_elo", 1500)) for r in rows],
37	        "away_elo": [float(r.get("away_elo", 1500)) for r in rows],
38	    })
39	
40	
41	_BRA_GER = TeamAbilities(
42	    attack={"Brazil": 1.5, "Germany": 1.3},
43	    defence={"Brazil": 0.8, "Germany": 0.9},
44	    home_adv=0.0, rho=-0.1, intercept=0.0,
45	)
