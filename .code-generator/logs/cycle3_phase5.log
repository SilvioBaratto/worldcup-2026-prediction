55	
56	# ---------------------------------------------------------------------------
57	# Acceptance criterion: same column set
58	# ---------------------------------------------------------------------------
59	
60	
61	def test_when_integration_frames_built_then_historical_and_wc2026_share_same_column_set(
62	    integration_frames: tuple[pd.DataFrame, pd.DataFrame],
63	) -> None:
64	    """
65	    The historical-features frame and the WC2026-features frame must expose
66	    the same column set.
67	
68	    AC: "assert the two frames share the same column set".
69	    """
