48	# ---------------------------------------------------------------------------
49	# Criterion 2 — Football-only allow-list
50	# ---------------------------------------------------------------------------
51	
52	
53	class TestFootballOnlyAllowList:
54	    """The exact output column set must be FEATURE_COLUMNS — no forbidden fields."""
55	
56	    def test_when_features_are_built_then_column_set_equals_feature_columns(self) -> None:
57	        m = _matches([{"home": "Brazil", "away": "Germany", "home_goals": 1, "away_goals": 0}])
58	        result = FeatureBuilder(_CFG).build(m, _elo([{}]), _BRA_GER)
59	        assert set(result.columns) == set(FEATURE_COLUMNS)
60	
61	    def test_when_features_are_built_then_column_order_matches_feature_columns(self) -> None:
62	        m = _matches([{"home": "Brazil", "away": "Germany", "home_goals": 1, "away_goals": 0}])
63	        result = FeatureBuilder(_CFG).build(m, _elo([{}]), _BRA_GER)
64	        assert list(result.columns) == list(FEATURE_COLUMNS)
