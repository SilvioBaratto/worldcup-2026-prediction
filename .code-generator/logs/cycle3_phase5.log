81	    """Return feature rows for every unplayed WC2026 fixture in *results_df*.
82	
83	    Parameters
84	    ----------
85	    results_df: Full martj42 results frame (historical + WC2026 fixtures).
86	                Must be passable to ``FeatureBuilder.build``; includes both
87	                played and unplayed rows.
88	    elo:        Either an ``EloResult`` from ``compute_elo`` or a pre-built elo DataFrame
89	                with ``home_elo`` / ``away_elo`` columns aligned to
90	                ``sort_chronological(results_df)``.
91	    abilities:  Dixon-Coles attack/defence abilities.
92	    config:     Feature-build settings; uses ``FeatureBuildConfig()`` defaults
93	                when ``None``.
94	    ranking:    Optional ``{team: ranking_points}`` dict; falls back to the
95	                static confederation map when ``None``.
96	
97	    Returns
98	    -------
99	    DataFrame with one row per unplayed WC2026 fixture, the full feature schema
100	    from ``FeatureBuilder`` plus a ``tournament`` metadata column, and
101	    ``home_goals``/``away_goals`` as ``<NA>``.
102	    """
103	    from worldcup_playoff.data.elo import EloResult as _EloResult  # avoid circular at import time
104	
105	    cfg = config or FeatureBuildConfig()
106	    sorted_df = sort_chronological(results_df)
107	    elo_df = _to_elo_df(elo) if isinstance(elo, _EloResult) else elo  # type: ignore[arg-type]
