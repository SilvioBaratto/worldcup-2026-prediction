71	                assert substr not in col.lower(), f"Forbidden column found: {col!r}"
72	
73	
74	# ---------------------------------------------------------------------------
75	# Criterion 5 — End-to-end no-leakage
76	# ---------------------------------------------------------------------------
77	
78	
79	class TestEndToEndNoLeakage:
80	    """Match-2 features must use only match-1 information (no forward leakage)."""
81	
82	    def test_when_first_match_has_no_prior_history_then_home_form_is_zero(self) -> None:
83	        m = _matches([
84	            {"home": "Brazil", "away": "Germany",
85	             "date": "2026-01-01", "home_goals": 3, "away_goals": 0},
86	        ])
87	        result = FeatureBuilder(_CFG).build(m, _elo([{}]), _BRA_GER)
88	        # No prior matches → neutral default form
89	        assert result.iloc[0]["home_form"] == pytest.approx(0.0)
90	
91	    def test_when_match2_is_computed_then_home_form_equals_match1_win_points(self) -> None:
92	        """
93	        Two-match history for Brazil:
94	          match-1: Brazil beats Germany 3-0 on 2026-01-01 (Brazil earns 3 pts)
95	          match-2: Brazil vs Germany on 2026-01-10
96	
97	        At match-2, Brazil's home_form must reflect match-1's 3-0 win.
98	        With a single prior played match, PPG = 3.0 regardless of decay weight.
99	        """
100	        m = _matches([
101	            {"home": "Brazil", "away": "Germany",
102	             "date": "2026-01-01", "home_goals": 3, "away_goals": 0},
103	            {"home": "Brazil", "away": "Germany",
104	             "date": "2026-01-10", "home_goals": 1, "away_goals": 2},
105	        ])
106	        result = FeatureBuilder(_CFG).build(m, _elo([{}, {}]), _BRA_GER)
107	        # match-2 form for Brazil = 3.0 (single prior win; decay cancels in PPG formula)
108	        assert result.iloc[1]["home_form"] == pytest.approx(3.0)
109	
110	    def test_when_match2_result_is_a_loss_then_match2_away_form_reflects_only_match1(
111	        self,
112	    ) -> None:
113	        """
114	        Germany won match-1 as away team (Brazil 3-0 → Germany 0 pts).
115	        At match-2, Germany's away_form must show 0.0 (a prior loss), NOT be
116	        influenced by match-2's result (Germany wins 2-1, which would give 3 pts).
117	        """
118	        m = _matches([
119	            {"home": "Brazil", "away": "Germany",
120	             "date": "2026-01-01", "home_goals": 3, "away_goals": 0},
121	            {"home": "Brazil", "away": "Germany",
122	             "date": "2026-01-10", "home_goals": 1, "away_goals": 2},
123	        ])
124	        result = FeatureBuilder(_CFG).build(m, _elo([{}, {}]), _BRA_GER)
125	        # Germany's form at match-2 is based on match-1 only (a 3-0 loss → 0 pts)
126	        assert result.iloc[1]["away_form"] == pytest.approx(0.0)
127	
128	    def test_when_match2_goal_diff_is_read_then_it_reflects_only_match1_result(self) -> None:
129	        m = _matches([
130	            {"home": "Brazil", "away": "Germany",
131	             "date": "2026-01-01", "home_goals": 3, "away_goals": 1},
132	            {"home": "Brazil", "away": "Germany",
133	             "date": "2026-01-10", "home_goals": 0, "away_goals": 0},
134	        ])
135	        result = FeatureBuilder(_CFG).build(m, _elo([{}, {}]), _BRA_GER)
136	        # Brazil GD at match-2: only match-1 (3-1 → +2)
137	        assert result.iloc[1]["home_goal_diff"] == pytest.approx(2.0)
138	        # Germany GD at match-2: only match-1 (1-3 → -2)
139	        assert result.iloc[1]["away_goal_diff"] == pytest.approx(-2.0)
