363	@settings(max_examples=30)
364	def test_when_any_mix_of_valid_and_null_slots_then_row_count_equals_valid_count(
365	    n_valid: int,
366	    n_null: int,
367	) -> None:
368	    """
369	    Invariant: for ANY combination of valid and null-team LiveMatch objects,
370	    live_fixtures_to_df drops exactly the null-team slots, leaving precisely
371	    n_valid rows in the output.
372	
373	    Derived from criterion: 'drops None-team placeholder slots.'
374	    """
375	    from worldcup_playoff.data.live import LiveMatch, TournamentState, live_fixtures_to_df
376	
377	    valid_matches = [
378	        LiveMatch(
379	            id=i,
380	            home_team=f"HomeTeam{i}",
381	            away_team=f"AwayTeam{i}",
382	            home_goals=None,
383	            away_goals=None,
384	            date="2026-07-01",
385	            status="SCHEDULED",
386	            neutral=True,
387	        )
388	        for i in range(n_valid)
389	    ]
390	    null_matches = [
391	        LiveMatch(
392	            id=n_valid + j,
393	            home_team=None,
394	            away_team=None,
395	            home_goals=None,
396	            away_goals=None,
397	            date="2026-07-01",
398	            status="SCHEDULED",
399	            neutral=True,
400	        )
401	        for j in range(n_null)
402	    ]
403	    state = TournamentState(
404	        played=[],
405	        remaining_group_fixtures=valid_matches + null_matches,
406	        standings=[],
407	    )
408	    result = live_fixtures_to_df(state)
409	
410	    assert len(result) == n_valid
