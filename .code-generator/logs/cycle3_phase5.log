100	def _make_history() -> pd.DataFrame:
101	    """
102	    Small in-process fixture in the uppercase internal schema used by all
103	    FeatureBuilder-facing code.  Two played WC rows + two unplayed WC2026 rows.
104	    No network calls are made.
105	    """
106	    return pd.DataFrame({
