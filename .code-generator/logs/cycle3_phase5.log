38	        "HOME_GOALS": pd.array([2, 4, 2, pd.NA, pd.NA], dtype="Int64"),
39	        "AWAY_GOALS": pd.array([0, 1, 0, pd.NA, pd.NA], dtype="Int64"),
40	        "TOURNAMENT": ["FIFA World Cup"] * 5,
41	        "NEUTRAL":    [True, True, True, True, True],
42	    })
43	
44	
45	@pytest.fixture(scope="module", name="integration_frames")
46	def _integration_frames_fixture() -> tuple[pd.DataFrame, pd.DataFrame]:
47	    """(historical_features_df, wc2026_features_df) built once per test module."""
48	    history = _make_history()
49	    elo_result = compute_elo(history)
50	    abilities = fit_dixon_coles(history)
51	    hist_df = build_features(history, elo_result, abilities)
52	    wc_df = wc2026_features(history, elo_result, abilities)
53	    return hist_df, wc_df
