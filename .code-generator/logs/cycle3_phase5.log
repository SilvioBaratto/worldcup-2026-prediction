109	        "AWAY_TEAM":  ["Serbia", "Australia", "France", "Spain"],
110	        "HOME_GOALS": pd.array([2, 4, pd.NA, pd.NA], dtype="Int64"),
111	        "AWAY_GOALS": pd.array([0, 1, pd.NA, pd.NA], dtype="Int64"),
