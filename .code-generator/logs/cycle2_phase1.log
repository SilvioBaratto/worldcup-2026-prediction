42	class TestFeatureSampler:
43	    def test_sample_shape_single(self) -> None:
44	        dists = [FittedDistribution(name="norm", params=(0.0, 1.0))]
45	        result = FeatureSampler.sample(dists, size=1, random_state=42)
46	        assert result.shape == (1, 1)
47	
48	    def test_sample_shape_multiple(self) -> None:
49	        dists = [
50	            FittedDistribution(name="norm", params=(0.0, 1.0)),
51	            FittedDistribution(name="norm", params=(5.0, 2.0)),
52	        ]
53	        result = FeatureSampler.sample(dists, size=10, random_state=42)
54	        assert result.shape == (10, 2)
55	
56	    def test_sample_reproducible_with_same_seed(self) -> None:
57	        dists = [FittedDistribution(name="norm", params=(0.0, 1.0))]
58	        r1 = FeatureSampler.sample(dists, size=5, random_state=42)
59	        r2 = FeatureSampler.sample(dists, size=5, random_state=42)
60	        np.testing.assert_array_equal(r1, r2)
61	
62	    def test_sample_differs_with_different_seeds(self) -> None:
63	        dists = [FittedDistribution(name="norm", params=(0.0, 1.0))]
64	        r1 = FeatureSampler.sample(dists, size=10, random_state=1)
65	        r2 = FeatureSampler.sample(dists, size=10, random_state=2)
66	        assert not np.allclose(r1, r2)
67	
68	    def test_sample_features_are_independent(self) -> None:
69	        """Features drawn with the same seed must not be perfectly correlated."""
70	        dists = [
71	            FittedDistribution(name="norm", params=(0.0, 1.0)),
72	            FittedDistribution(name="norm", params=(5.0, 2.0)),
73	        ]
74	        result = FeatureSampler.sample(dists, size=200, random_state=42)
75	        col0 = (result[:, 0] - result[:, 0].mean()) / result[:, 0].std()
76	        col1 = (result[:, 1] - result[:, 1].mean()) / result[:, 1].std()
77	        corr = float(np.abs(np.corrcoef(col0, col1)[0, 1]))
78	        assert corr < 0.3, (
79	            f"Feature columns are too correlated ({corr:.3f}); each feature must "
80	            "draw from its own independent random stream."
81	        )
