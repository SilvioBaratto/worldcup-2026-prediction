142	def _make_fitter(min_season: int = 2019, candidates: list[str] | None = None) -> DistributionFitter:
143	    dist_cfg = DistributionConfig(
144	        min_season=min_season,
145	        candidates=candidates or ["norm"],
146	    )
147	    feat_cfg = FeaturesConfig()
148	    return DistributionFitter(config=dist_cfg, features_config=feat_cfg)
