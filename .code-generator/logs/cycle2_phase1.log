115	def _make_train_df(n: int = 20) -> pd.DataFrame:
116	    """Minimal train_data.csv-format DataFrame for two teams."""
117	    rng = np.random.default_rng(0)
118	    rows = []
119	    for i in range(n):
120	        home, away = ("Brazil", "France") if i % 2 == 0 else ("France", "Brazil")
121	        rows.append(
122	            {
123	                "HOME_TEAM": home,
124	                "AWAY_TEAM": away,
125	                "DATE": f"2020-0{(i % 9) + 1}-01",
126	                "GOALS_home": int(rng.integers(0, 4)),
127	                "SHOTS_home": int(rng.integers(5, 20)),
128	                "SHOTS_ON_TARGET_home": int(rng.integers(2, 8)),
129	                "POSSESSION_home": float(rng.uniform(40, 65)),
130	                "PASS_PCT_home": float(rng.uniform(65, 85)),
131	                "GOALS_away": int(rng.integers(0, 4)),
132	                "SHOTS_away": int(rng.integers(5, 20)),
133	                "SHOTS_ON_TARGET_away": int(rng.integers(2, 8)),
134	                "POSSESSION_away": float(rng.uniform(40, 65)),
135	                "PASS_PCT_away": float(rng.uniform(65, 85)),
136	                "HOME_WIN": 1,
137	            }
138	        )
139	    return pd.DataFrame(rows)
