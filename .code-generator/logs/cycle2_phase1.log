82	# ---------------------------------------------------------------------------
83	# Boolean column parser (handles both string and auto-inferred bool input)
84	# ---------------------------------------------------------------------------
85	
86	
87	def _parse_bool_column(series: pd.Series) -> pd.Series:
88	    """Coerce TRUE/FALSE (string or auto-detected bool) to numpy bool.
89	
90	    pandas may auto-detect 'TRUE'/'FALSE' CSV strings as bool; converting to
91	    str first normalises both paths: str(True)='True' -> upper='TRUE' -> True.
92	    """
93	    return series.astype(str).str.upper().map({"TRUE": True, "FALSE": False}).astype(bool)
94	
95	
96	# dtype family sets used by the validator
97	_INT64_DTYPES = {"Int64"}
98	_BOOL_DTYPES = {"bool", "boolean"}
99	_NUMERIC_DTYPES = {"int64", "float64", "int32", "float32"}
100	_STRING_DTYPES = {"object", "str", "string"}
101	
102	# ---------------------------------------------------------------------------
103	# Validator
104	# ---------------------------------------------------------------------------
105	
106	
107	def _validate_martj42(df: pd.DataFrame, required: dict[str, str], label: str) -> None:
108	    """Raise ValueError for missing columns or incompatible dtypes.
109	
110	    Extends loader.py's family logic to accept nullable Int64 and bool.
111	    """
112	    missing = set(required) - set(df.columns)
113	    if missing:
114	        parts = []
115	        for col in sorted(missing):
116	            near = difflib.get_close_matches(col, df.columns.tolist(), n=1, cutoff=0.7)
117	            hint = f" — did you mean '{near[0]}'?" if near else ""
118	            parts.append(f"  '{col}'{hint}")
119	        raise ValueError(f"{label} DataFrame missing required column(s):\n" + "\n".join(parts))
120	
121	    type_errors: list[str] = []
122	    for col, expected in required.items():
123	        actual = str(df[col].dtype)
124	        if actual == expected:
125	            continue
126	        if expected in _INT64_DTYPES:
127	            type_errors.append(f"  '{col}' has dtype '{actual}', expected '{expected}'")
128	            continue
129	        if expected in _BOOL_DTYPES:
130	            if df[col].dtype.kind != "b":
131	                type_errors.append(f"  '{col}' has dtype '{actual}', expected bool-like")
132	            continue
133	        if actual in _NUMERIC_DTYPES and expected in _NUMERIC_DTYPES:
134	            continue
135	        if actual in _STRING_DTYPES and expected in _STRING_DTYPES:
136	            continue
137	        type_errors.append(f"  '{col}' has dtype '{actual}', expected '{expected}'")
138	
139	    if type_errors:
140	        raise ValueError(f"{label} DataFrame has wrong column dtype(s):\n" + "\n".join(type_errors))
141	
142	
143	def validate_results_df(df: pd.DataFrame) -> None:
144	    """Validate that a results DataFrame conforms to the martj42 results schema."""
145	    _validate_martj42(df, REQUIRED_MARTJ42_RESULTS_COLUMNS, "martj42_results")
