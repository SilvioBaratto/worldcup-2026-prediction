116	            near = difflib.get_close_matches(col, df.columns.tolist(), n=1, cutoff=0.7)
117	            hint = f" — did you mean '{near[0]}'?" if near else ""
118	            parts.append(f"  '{col}'{hint}")
119	        raise ValueError(f"{label} DataFrame missing required column(s):\n" + "\n".join(parts))
120	
121	    type_errors: list[str] = []
122	    for col, expected in required.items():
123	        actual = str(df[col].dtype)
124	        if actual == expected:
125	            continue
126	        if expected in _INT64_DTYPES:
127	            type_errors.append(f"  '{col}' has dtype '{actual}', expected '{expected}'")
128	            continue
129	        if expected in _BOOL_DTYPES:
130	            if df[col].dtype.kind != "b":
131	                type_errors.append(f"  '{col}' has dtype '{actual}', expected bool-like")
132	            continue
133	        if actual in _NUMERIC_DTYPES and expected in _NUMERIC_DTYPES:
134	            continue
135	        if actual in _STRING_DTYPES and expected in _STRING_DTYPES:
136	            continue
137	        type_errors.append(f"  '{col}' has dtype '{actual}', expected '{expected}'")
138	
139	    if type_errors:
140	        raise ValueError(f"{label} DataFrame has wrong column dtype(s):\n" + "\n".join(type_errors))
141	
142	
143	def validate_results_df(df: pd.DataFrame) -> None:
144	    """Validate that a results DataFrame conforms to the martj42 results schema."""
145	    _validate_martj42(df, REQUIRED_MARTJ42_RESULTS_COLUMNS, "martj42_results")
146	
147	
148	def validate_shootouts_df(df: pd.DataFrame) -> None:
149	    """Validate that a shootouts DataFrame conforms to the martj42 shootouts schema."""
150	    _validate_martj42(df, REQUIRED_MARTJ42_SHOOTOUTS_COLUMNS, "martj42_shootouts")
151	
152	
153	def validate_goalscorers_df(df: pd.DataFrame) -> None:
154	    """Validate that a goalscorers DataFrame conforms to the martj42 goalscorers schema."""
155	    _validate_martj42(df, REQUIRED_MARTJ42_GOALSCORERS_COLUMNS, "martj42_goalscorers")
156	
157	
158	# ---------------------------------------------------------------------------
159	# Convenience filter
160	# ---------------------------------------------------------------------------
161	
162	
163	def wc2026_schedule(df: pd.DataFrame) -> pd.DataFrame:
164	    """Return rows where TOURNAMENT == 'FIFA World Cup', including unplayed fixtures."""
165	    return df[df["TOURNAMENT"] == "FIFA World Cup"].reset_index(drop=True)
166	
167	
168	# ---------------------------------------------------------------------------
169	# Loader
170	# ---------------------------------------------------------------------------
171	
172	
173	class Martj42Loader:
174	    """Cache-first loader for the martj42/international_results CC0 datasets."""
175	
176	    def __init__(
177	        self,
178	        config: Martj42Config,
179	        cache_dir: Path | None = None,
180	        base_url: str | None = None,
181	    ) -> None:
182	        self._config = config
183	        self._cache_dir = cache_dir or config.cache_dir
184	        self._base_url = base_url or config.base_url
185	
186	    # --- public API ---
187	
188	    def load_results(self) -> pd.DataFrame:
189	        """Return the results DataFrame coerced to the internal schema."""
190	        return self._coerce_results(self._fetch_raw(self._config.results_file))
191	
192	    def load_shootouts(self) -> pd.DataFrame:
193	        """Return the shootouts DataFrame coerced to the internal schema."""
194	        return self._coerce_shootouts(self._fetch_raw(self._config.shootouts_file))
195	
196	    def load_goalscorers(self) -> pd.DataFrame:
197	        """Return the goalscorers DataFrame coerced to the internal schema."""
198	        return self._coerce_goalscorers(self._fetch_raw(self._config.goalscorers_file))
199	
200	    def wc2026_schedule(self) -> pd.DataFrame:
201	        """Return FIFA World Cup rows (played + unplayed) from results."""
202	        return wc2026_schedule(self.load_results())
203	
204	    # --- private helpers ---
205	
206	    def _fetch_raw(self, filename: str) -> pd.DataFrame:
207	        path = self._cache_dir / filename
208	        if path.exists():
209	            logger.info("Loading %s from cache: %s", filename, path)
210	            return pd.read_csv(path)
211	        url = self._base_url + filename
212	        logger.info("Downloading %s from %s", filename, url)
213	        df = pd.read_csv(url)
214	        path.parent.mkdir(parents=True, exist_ok=True)
215	        df.to_csv(path, index=False)
216	        return df
217	
218	    def _apply_crosswalk(self, df: pd.DataFrame, cols: list[str]) -> None:
219	        for col in cols:
220	            df[col] = normalize_series(df[col])
221	
222	    def _coerce_results(self, raw: pd.DataFrame) -> pd.DataFrame:
223	        df = raw.rename(columns=_RESULTS_RENAME)[list(_RESULTS_RENAME.values())].copy()
224	        df["HOME_GOALS"] = pd.to_numeric(df["HOME_GOALS"], errors="coerce").astype("Int64")
225	        df["AWAY_GOALS"] = pd.to_numeric(df["AWAY_GOALS"], errors="coerce").astype("Int64")
226	        df["NEUTRAL"] = _parse_bool_column(df["NEUTRAL"])
227	        self._apply_crosswalk(df, ["HOME_TEAM", "AWAY_TEAM"])
228	        validate_results_df(df)
229	        return df
230	
231	    def _coerce_shootouts(self, raw: pd.DataFrame) -> pd.DataFrame:
232	        df = raw.rename(columns=_SHOOTOUTS_RENAME)[list(_SHOOTOUTS_RENAME.values())].copy()
233	        self._apply_crosswalk(df, ["HOME_TEAM", "AWAY_TEAM"])
234	        validate_shootouts_df(df)
235	        return df
236	
237	    def _coerce_goalscorers(self, raw: pd.DataFrame) -> pd.DataFrame:
238	        df = raw.rename(columns=_GOALSCORERS_RENAME)[list(_GOALSCORERS_RENAME.values())].copy()
239	        df["MINUTE"] = pd.to_numeric(df["MINUTE"], errors="coerce").astype("Int64")
240	        df["OWN_GOAL"] = _parse_bool_column(df["OWN_GOAL"])
241	        df["PENALTY"] = _parse_bool_column(df["PENALTY"])
242	        self._apply_crosswalk(df, ["HOME_TEAM", "AWAY_TEAM", "TEAM"])
243	        validate_goalscorers_df(df)
244	        return df
245	
246	
247	# ---------------------------------------------------------------------------
248	# Module-level factory functions (mirrors build_*_csv / generate_bracket_toml)
249	# ---------------------------------------------------------------------------
250	
251	
252	def load_martj42_results(config: Martj42Config) -> pd.DataFrame:
253	    """Load and return the martj42 results DataFrame."""
254	    return Martj42Loader(config=config).load_results()
255	
256	
257	def load_martj42_shootouts(config: Martj42Config) -> pd.DataFrame:
258	    """Load and return the martj42 shootouts DataFrame."""
259	    return Martj42Loader(config=config).load_shootouts()
260	
261	
262	def load_martj42_goalscorers(config: Martj42Config) -> pd.DataFrame:
263	    """Load and return the martj42 goalscorers DataFrame."""
264	    return Martj42Loader(config=config).load_goalscorers()
265	
