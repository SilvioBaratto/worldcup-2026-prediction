73	def _make_martj42(n: int = 48) -> pd.DataFrame:
74	    """Return n rows in martj42 UPPERCASE schema; all matches have known scores.
75	
76	    Dates monotonically increase (30 per year) so chronological_split is
77	    well-defined.  home_team != away_team by construction (offset by 1 in
78	    the 8-team cycle).
79	    """
80	    rows = [
81	        {
82	            "DATE": pd.Timestamp(f"20{18 + i // 30:02d}-01-{i % 30 + 1:02d}"),
83	            "HOME_TEAM": _TEAMS[i % len(_TEAMS)],
84	            "AWAY_TEAM": _TEAMS[(i + 1) % len(_TEAMS)],
85	            "HOME_GOALS": i % 4,
86	            "AWAY_GOALS": i % 3,
87	            "TOURNAMENT": "FIFA World Cup" if i % 7 == 0 else "Friendly",
88	            "NEUTRAL": i % 5 == 0,
89	        }
90	        for i in range(n)
91	    ]
92	    df = pd.DataFrame(rows)
93	    df["HOME_GOALS"] = df["HOME_GOALS"].astype("Int64")
94	    df["AWAY_GOALS"] = df["AWAY_GOALS"].astype("Int64")
95	    return df
96	
97	
98	def _build_dataset(n: int = 48, test_size: float = 0.2) -> MatchDataset:
99	    """Run the full no-key pipeline and return a MatchDataset."""
100	    df = _make_martj42(n)
101	    elo = compute_elo(df)
102	    abilities = fit_dixon_coles(df)
103	    features = add_targets(build_features(df, elo, abilities))
104	    return build_dataset(features, test_size=test_size, feature_cols=_FEATURE_COLS)
