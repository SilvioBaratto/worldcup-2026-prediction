24	# ---------------------------------------------------------------------------
25	# Shared fixture — martj42 internal schema, in-process only
26	# ---------------------------------------------------------------------------
27	
28	
29	def _make_history() -> pd.DataFrame:
30	    """Minimal martj42-internal DataFrame: 3 played WC matches + 2 unplayed WC2026."""
31	    return pd.DataFrame(
32	        {
33	            "DATE": pd.to_datetime(
34	                [
35	                    "2022-11-20",
36	                    "2022-11-24",
37	                    "2022-11-28",
38	                    "2026-06-11",
39	                    "2026-06-15",
40	                ]
41	            ),
42	            "HOME_TEAM": ["Brazil", "France", "Argentina", "Brazil", "Germany"],
43	            "AWAY_TEAM": ["Serbia", "Australia", "Poland", "France", "Spain"],
44	            "HOME_GOALS": pd.array([2, 4, 2, pd.NA, pd.NA], dtype="Int64"),
45	            "AWAY_GOALS": pd.array([0, 1, 0, pd.NA, pd.NA], dtype="Int64"),
46	            "TOURNAMENT": ["FIFA World Cup"] * 5,
47	            "NEUTRAL": [True, True, True, True, True],
48	        }
49	    )
50	
51	
52	@pytest.fixture(scope="module", name="integration_frames")
53	def _integration_frames_fixture() -> tuple[pd.DataFrame, pd.DataFrame]:
54	    """(historical_features_df, wc2026_features_df) built once per test module."""
55	    history = _make_history()
56	    elo_result = compute_elo(history)
57	    abilities = fit_dixon_coles(history)
58	    hist_df = build_features(history, elo_result, abilities)
59	    wc_df = wc2026_features(history, elo_result, abilities)
60	    return hist_df, wc_df
61	
