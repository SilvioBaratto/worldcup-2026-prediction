420	def test_when_two_models_fit_with_different_seeds_then_at_least_one_prob_differs():
421	    """
422	    Different random_seeds must actually affect the model — verifies the seed
423	    controls the random state, not just a no-op parameter (AC5 contrapositive).
424	    """
425	    ds = _make_dataset()
426	    m1, m2 = HybridModel(random_seed=1), HybridModel(random_seed=2)
427	    m1.fit(ds)
428	    m2.fit(ds)
429	    p1 = m1.predict(_neutral_features())
430	    p2 = m2.predict(_neutral_features())
431	    differ = (
432	        not np.isclose(p1.prob_home, p2.prob_home)
433	        or not np.isclose(p1.prob_draw, p2.prob_draw)
434	        or not np.isclose(p1.prob_away, p2.prob_away)
435	    )
436	    assert differ, (
437	        "Models with different random_seeds produced identical predictions; "
438	        "random_seed may not control the model's random state."
439	    )
