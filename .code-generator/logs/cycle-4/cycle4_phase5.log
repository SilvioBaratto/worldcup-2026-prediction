151	def test_when_ordered_logit_model_is_refit_with_same_data_then_predictions_are_identical():
152	    """Criterion 4: BFGS on a convex objective is deterministic — same data → same output."""
153	    ds = _shared_dataset()
154	    X = pd.DataFrame({"elo_diff": [-50.0, 0.0, 50.0]})
155	    r1 = OrderedLogitModel().fit(ds).predict(X)
156	    r2 = OrderedLogitModel().fit(ds).predict(X)
157	    for a, b in zip(r1, r2):
158	        assert abs(a.prob_home - b.prob_home) < 1e-10
159	        assert abs(a.prob_draw - b.prob_draw) < 1e-10
160	        assert abs(a.prob_away - b.prob_away) < 1e-10
