443	# AC6 — Design matrix excludes forbidden cols; no NaN feature cols; runs no-key
444	# ---------------------------------------------------------------------------
445	
446	
447	def test_when_feature_cols_contain_no_forbidden_columns_then_fit_succeeds():
448	    """
449	    The design matrix must exclude home_goals, away_goals, date, home_team, away_team.
