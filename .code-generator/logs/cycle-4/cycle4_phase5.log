94	) -> None:
95	    """
96	    The WC2026 frame must have strictly fewer rows than the historical frame.
97	
98	    Fixture: 3 played + 2 unplayed → historical outputs 5 rows; wc2026_features
99	    returns only the 2 unplayed WC2026 rows (strict subset by count).
100	
101	    AC: "the WC2026 frame's rows are a subset of the historical frame's rows".
102	    """
103	    hist, wc = integration_frames
104	    assert len(wc) < len(hist), (
105	        f"WC2026 frame ({len(wc)} rows) must be smaller than historical frame ({len(hist)} rows)."
106	    )
107	
108	
109	def test_when_integration_frames_built_then_wc2026_index_is_subset_of_historical_index(
110	    integration_frames: tuple[pd.DataFrame, pd.DataFrame],
111	) -> None:
112	    """
113	    WC2026 frame row-index labels must be a subset of historical frame row-index labels.
114	
115	    Both frames use reset_index(drop=True), so WC2026's [0, 1] is a subset of
116	    historical's [0, 1, 2, 3, 4].
117	    """
118	    hist, wc = integration_frames
119	    assert frozenset(wc.index).issubset(frozenset(hist.index)), (
120	        "WC2026 frame index is not a subset of the historical frame index.\n"
121	        f"  WC2026 index:     {sorted(wc.index)}\n"
122	        f"  Historical index: {sorted(hist.index)}"
123	    )
124	
125	
126	# ---------------------------------------------------------------------------
127	# Smoke: WC2026 rows have NA goals; historical played rows have integer goals
128	# ---------------------------------------------------------------------------
129	
130	
131	def test_when_integration_frames_built_then_wc2026_goals_are_na(
132	    integration_frames: tuple[pd.DataFrame, pd.DataFrame],
133	) -> None:
134	    """home_goals and away_goals must be <NA> for every WC2026 output row."""
135	    _, wc = integration_frames
136	    assert wc["home_goals"].isna().all(), "Some WC2026 home_goals are not <NA>"
137	    assert wc["away_goals"].isna().all(), "Some WC2026 away_goals are not <NA>"
138	
139	
140	def test_when_integration_frames_built_then_historical_played_rows_have_numeric_goals(
141	    integration_frames: tuple[pd.DataFrame, pd.DataFrame],
142	) -> None:
143	    """Played rows in the historical frame must have non-NA integer goals."""
144	    hist, _ = integration_frames
145	    played = hist[hist["home_goals"].notna()]
146	    assert len(played) == 3, f"Expected 3 played rows, got {len(played)}"
147	
