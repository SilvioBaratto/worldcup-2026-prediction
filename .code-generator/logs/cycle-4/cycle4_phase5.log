52	def _mixed_df(n_played: int = 8, n_unplayed: int = 2) -> pd.DataFrame:
53	    """Played rows followed by unplayed (NA-goals) rows."""
54	    played = _played_df(n_played)
55	    unplayed_rows = [
56	        {
57	            "date": f"2030-06-{j + 1:02d}",
58	            "home_team": "Team C",
59	            "away_team": "Team D",
60	            "home_goals": NA,
61	            "away_goals": NA,
62	            "home_elo": 1480.0,
63	            "away_elo": 1490.0,
64	            "elo_diff": -10.0,
65	        }
66	        for j in range(n_unplayed)
67	    ]
68	    unplayed = pd.DataFrame(unplayed_rows)
69	    unplayed["home_goals"] = unplayed["home_goals"].astype("Int64")
70	    unplayed["away_goals"] = unplayed["away_goals"].astype("Int64")
71	    return pd.concat([played, unplayed], ignore_index=True)
