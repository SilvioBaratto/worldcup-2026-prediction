112	    """
113	    Criterion 1: compute_elo → fit_dixon_coles → build_features → build_dataset →
114	    HybridModel.fit produces a model that returns a valid prediction.
115	
116	    Corrected from source-blind draft: uses UPPERCASE martj42 schema, calls
117	    add_targets before build_dataset, uses HybridModel(random_seed=…).fit(dataset).
118	    """
119	    ds = _make_dataset()
120	    model = HybridModel(random_seed=0).fit(ds)
121	    h, a = model.predict_goals(_SAMPLE_FEATS)
122	    assert isinstance(h, float) and isinstance(a, float)
