47	def _make_match_df(n: int = 30, seed: int = 0) -> pd.DataFrame:
48	    """Return n chronologically ordered played-match rows.
49	
50	    Only _FEATURE_COLS are included as feature columns; forbidden columns such
51	    as home_goals and away_goals appear in the frame but must not enter the
52	    design matrix (criterion AC6).
53	    """
54	    rng = np.random.default_rng(seed)
55	    months = (np.arange(n) // 28) + 1
56	    days = (np.arange(n) % 28) + 1
57	    rows = [
58	        {
59	            "date": f"2020-{months[i]:02d}-{days[i]:02d}",
60	            "home_team": "Alpha",
61	            "away_team": "Beta",
62	            "home_goals": int(rng.poisson(1.5)),
63	            "away_goals": int(rng.poisson(1.2)),
64	            "elo_diff": float(rng.normal(50.0, 100.0)),
65	            "home_elo": float(rng.normal(1500.0, 100.0)),
66	            "away_elo": float(rng.normal(1450.0, 100.0)),
67	        }
68	        for i in range(n)
69	    ]
70	    df = pd.DataFrame(rows)
71	    df["home_goals"] = df["home_goals"].astype("Int64")
72	    df["away_goals"] = df["away_goals"].astype("Int64")
73	    return df
74	
75	
76	def _make_dataset(n: int = 30, test_size: float = 0.2, seed: int = 0) -> MatchDataset:
77	    return build_dataset(_make_match_df(n, seed=seed), test_size=test_size, feature_cols=_FEATURE_COLS)
78	
79	
80	def _neutral_features() -> dict:
81	    """Feature dict with only allowed (non-forbidden) columns."""
82	    return {"elo_diff": 50.0, "home_elo": 1500.0, "away_elo": 1450.0}
