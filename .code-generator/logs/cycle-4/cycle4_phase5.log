64	# Acceptance criterion: same column set
65	# ---------------------------------------------------------------------------
66	
67	
68	def test_when_integration_frames_built_then_historical_and_wc2026_share_same_column_set(
69	    integration_frames: tuple[pd.DataFrame, pd.DataFrame],
70	) -> None:
71	    """
72	    The historical-features frame and the WC2026-features frame must expose
73	    the same column set.
74	
75	    AC: "assert the two frames share the same column set".
76	    """
77	    hist, wc = integration_frames
78	    hist_cols = set(hist.columns)
79	    wc_cols = set(wc.columns)
80	    assert hist_cols == wc_cols, (
81	        "Column sets differ between historical and WC2026 feature frames.\n"
82	        f"  Only in historical: {hist_cols - wc_cols}\n"
83	        f"  Only in wc2026:     {wc_cols - hist_cols}"
84	    )
