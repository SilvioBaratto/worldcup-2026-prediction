13	
14	from __future__ import annotations
15	
16	import pandas as pd
17	import pytest
18	
19	from worldcup_playoff.data.elo import compute_elo
20	from worldcup_playoff.features import build_features, wc2026_features
21	from worldcup_playoff.simulation.poisson import fit_dixon_coles
22	
