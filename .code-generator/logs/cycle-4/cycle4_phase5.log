95	# Module-level singleton to avoid re-running the pipeline in Hypothesis tests
96	_SHARED_DATASET: MatchDataset | None = None
97	
98	
99	def _shared_dataset() -> MatchDataset:
100	    global _SHARED_DATASET
101	    if _SHARED_DATASET is None:
102	        _SHARED_DATASET = _make_dataset()
103	    return _SHARED_DATASET
