309	
310	class OrderedLogitConfig(BaseModel):
311	    """Configuration for the Elo-diff ordered logit secondary/fallback model."""
312	
313	    model_config = ConfigDict(extra="ignore")
314	
315	    features: list[str] = ["elo_diff"]
316	    maxiter: int = 100
317	    test_size: float = 0.2
318	    random_seed: int = 42
319	
320	    @field_validator("test_size")
321	    @classmethod
322	    def test_size_must_be_in_open_unit_interval(cls, v: float) -> float:
323	        if not (0.0 < v < 1.0):
324	            raise ValueError("test_size must be strictly between 0 and 1")
325	        return v
