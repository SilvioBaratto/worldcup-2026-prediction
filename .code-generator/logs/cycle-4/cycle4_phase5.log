74	def _col_array(df: pd.DataFrame, col: str, sentinels: dict[str, float]) -> np.ndarray:
75	    """Convert one feature column to a (n, k) float array; impute NaN via sentinel."""
76	    if col not in df.columns:
77	        return np.full((len(df), 1), sentinels.get(col, 0.0))
78	    series = df[col]
79	    if col in _CONFED_COLS:
80	        return _one_hot_confed(series)
81	    return _numeric_col(series, sentinels.get(col, 0.0))
