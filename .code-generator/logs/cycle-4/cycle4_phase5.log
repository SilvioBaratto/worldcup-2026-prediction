246	# ---------------------------------------------------------------------------
247	# Value object
248	# ---------------------------------------------------------------------------
249	
250	
251	@dataclass(frozen=True)
252	class RankingResolution:
253	    """Result of a FIFA-ranking lookup with confederation fallback."""
254	
255	    value: float | None
256	    confederation: str | None
257	    used_fallback: bool
258	
259	
260	# ---------------------------------------------------------------------------
261	# Public API
262	# ---------------------------------------------------------------------------
263	
264	
265	def confederation_of(team: str) -> str | None:
266	    """Return the confederation code for *team*, or ``None`` when unknown."""
267	    return CONFEDERATION_MAP.get(normalize_team(team))
268	
269	
270	def _is_stale(as_of: str, staleness_cutoff: str) -> bool:
271	    """Return True when the ranking snapshot date exceeds the cutoff."""
272	    return as_of > staleness_cutoff
273	
274	
275	def resolve_ranking(
276	    team: str,
277	    ranking: Mapping[str, float] | None,
278	    as_of: str,
279	    staleness_cutoff: str,
280	    *,
281	    confed_map: dict[str, str] = CONFEDERATION_MAP,
282	) -> RankingResolution:
283	    """Return ranking value when fresh and present, else fall back to confederation.
284	
285	    Staleness: *as_of* (match date) > *staleness_cutoff* means the ranking data
286	    predates this match by more than the configured window — treat as stale.
287	    """
288	    canonical = normalize_team(team)
289	    confederation = confed_map.get(canonical)
290	
291	    if ranking is None or _is_stale(as_of, staleness_cutoff) or canonical not in ranking:
292	        return RankingResolution(value=None, confederation=confederation, used_fallback=True)
293	
294	    return RankingResolution(
295	        value=ranking[canonical],
296	        confederation=confederation,
297	        used_fallback=False,
298	    )
