429	    p1 = m1.predict(_neutral_features())
430	    p2 = m2.predict(_neutral_features())
431	    differ = (
432	        not np.isclose(p1.prob_home, p2.prob_home)
433	        or not np.isclose(p1.prob_draw, p2.prob_draw)
434	        or not np.isclose(p1.prob_away, p2.prob_away)
435	    )
436	    assert differ, (
437	        "Models with different random_seeds produced identical predictions; "
438	        "random_seed may not control the model's random state."
