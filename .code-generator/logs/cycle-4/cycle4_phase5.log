2026-06-24 03:16:44,008 DEBUG msg #145: UserMessage tool_result(toolu_012vhC1cczDMKQPGJsgfCCm5): 1	"""Time-aware match dataset utilities for Cycle-4 models.
2	
3	Provides a single source of truth for target derivation and chronological
4	train/test splitting so both the hybrid and ordered-logit models share
5	identical data conventions.
6	
7	Pure pandas/numpy only — no sklearn/statsmodels — so this module loads fast
8	in any context, including test collection.
9	
10	The feature frame produced by ``build_features`` uses lowercase column names
11	(``date``, ``home_goals``, ``away_goals``) — distinct from the martj42 raw
12	schema (``DATE``, ``HOME_GOALS``, ``AWAY_GOALS``). Sorting is applied to the
13	``date`` column directly.
14	"""
15	
16	from __future__ import annotations
17	
18	import math
19	from dataclasses import dataclass
20	
21	import pandas as pd
22	
23	__all__ = [
24	    "MatchDataset",
25	    "add_targets",
26	    "build_dataset",
27	    "chronological_split",
28	    "outcome_label",
29	    "played_only",
30	]
31	
32	
33	# ---------------------------------------------------------------------------
34	# Value object
35	# ---------------------------------------------------------------------------
36	
37	
38	@dataclass(frozen=True)
39	class MatchDataset:
40	    """Immutable container produced by ``build_dataset``.
41	
42	    Attributes
43	    ----------
44	    train:        Played matches in the chronological training slice.
45	    test:         Played matches in the chronological test slice.
46	    feature_cols: Column names to use as model inputs.
47	    """
48	
49	    train: pd.DataFrame
50	    test: pd.DataFrame
51	    feature_cols: list[str]
52	
53	
54	# ---------------------------------------------------------------------------
55	# Pure helpers
56	# ---------------------------------------------------------------------------
57	
58	
59	def outcome_label(home_goals: int, away_goals: int) -> int:
60	    """Return ordered encoding: away-win=0, draw=1, home-win=2."""
61	    if home_goals > away_goals:
62	        return 2
63	    if home_goals == away_goals:
64	        return 1
65	    return 0
66	
67	
68	def add_targets(df: pd.DataFrame) -> pd.DataFrame:
69	    """Return a copy of *df* with ``y_outcome`` (Int64) and ``y_margin`` added.
70	
71	    ``y_outcome`` uses the away<draw<home encoding from ``outcome_label``.
72	    ``y_margin`` = home_goals − away_goals (signed; used for group tiebreaks).
73	    Rows with NA goals receive NA targets.
74	    """
75	    out = df.copy()
76	    out["y_outcome"] = (
77	        out.apply(
78	            lambda r: outcome_label(int(r["home_goals"]), int(r["away_goals"]))
79	            if pd.notna(r["home_goals"]) and pd.notna(r["away_goals"])
80	            else pd.NA,
81	            axis=1,
82	        )
83	        .astype("Int64")
84	    )
85	    out["y_margin"] = (out["home_goals"] - out["away_goals"]).astype("Int64")
86	    return out
87	
88	
89	def played_only(df: pd.DataFrame) -> pd.DataFrame:
90	    """Return rows where both ``home_goals`` and ``away_goals`` are non-NA."""
91	    mask = df["home_goals"].notna() & df["away_goals"].notna()
92	    return df[mask].reset_index(drop=True)
93	
94	
95	def _sort_by_date(df: pd.DataFrame) -> pd.DataFrame:
96	    """Sort feature-frame by ``date`` ascending, NaT last. Stable, no RNG."""
97	    return (
98	        df.assign(_d=pd.to_datetime(df["date"], errors="coerce"))
99	        .sort_values("_d", kind="stable", na_position="last")
100	        .drop(columns=["_d"])
101	        .reset_index(drop=True)
102	    )
103	
104	
105	def chronological_split(
106	    df: pd.DataFrame, test_size: float = 0.2
107	) -> tuple[pd.DataFrame, pd.DataFrame]:
108	    """Split *df* positionally: last ``floor(n * test_size)`` rows → test.
109	
110	    No shuffling, no RNG — purely positional so the result is deterministic.
111	    Re-asserts chronological order by ``date`` before splitting (self-defensive).
112	
113	    Returns
114	    -------
115	    (train, test) DataFrames with reset indices.
116	    """
117	    ordered = _sort_by_date(df)
118	    n = len(ordered)
119	    n_test = math.floor(n * test_size)
120	    n_train = n - n_test
121	    train = ordered.iloc[:n_train].reset_index(drop=True)
122	    test = ordered.iloc[n_train:].reset_index(drop=True)
123	    return train, test
124	
125	
126	def build_dataset(
127	    features: pd.DataFrame,
128	    test_size: float,
129	    feature_cols: list[str],
130	) -> MatchDataset:
131	    """Apply ``played_only`` then ``chronological_split`` and return a frozen dataset.
132	
133	    ``played_only`` is applied FIRST so unplayed WC2026 fixtures (NA goals,
134	    sorted last by date) never contaminate the test slice.
135	    """
136	    played = played_only(features)
137	    train, test = chronological_split(played, test_size=test_size)
138	    return MatchDataset(train=train, test=test, feature_cols=list(feature_cols))
139	
