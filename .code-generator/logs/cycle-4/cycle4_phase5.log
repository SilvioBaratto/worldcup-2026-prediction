66	def _make_martj42(n: int = 48) -> pd.DataFrame:
67	    """Minimal martj42 UPPERCASE-schema DataFrame; all matches have known scores."""
68	    rows = [
69	        {
70	            "DATE": pd.Timestamp(f"20{18 + i // 30:02d}-01-{i % 30 + 1:02d}"),
71	            "HOME_TEAM": _TEAMS[i % len(_TEAMS)],
72	            "AWAY_TEAM": _TEAMS[(i + 1) % len(_TEAMS)],
73	            "HOME_GOALS": i % 4,
74	            "AWAY_GOALS": i % 3,
75	            "TOURNAMENT": "FIFA World Cup" if i % 7 == 0 else "Friendly",
76	            "NEUTRAL": i % 5 == 0,
77	        }
78	        for i in range(n)
79	    ]
80	    df = pd.DataFrame(rows)
81	    df["HOME_GOALS"] = df["HOME_GOALS"].astype("Int64")
82	    df["AWAY_GOALS"] = df["AWAY_GOALS"].astype("Int64")
83	    return df
84	
85	
86	def _make_dataset(n: int = 48) -> MatchDataset:
87	    """Run the full no-key pipeline and return a MatchDataset."""
88	    df = _make_martj42(n)
89	    elo = compute_elo(df)
90	    abilities = fit_dixon_coles(df)
91	    features = add_targets(build_features(df, elo, abilities))
92	    return build_dataset(features, test_size=0.2, feature_cols=_FEATURE_COLS)
93	
94	
95	# Module-level singleton to avoid re-running the pipeline in Hypothesis tests
96	_SHARED_DATASET: MatchDataset | None = None
97	
98	
99	def _shared_dataset() -> MatchDataset:
100	    global _SHARED_DATASET
101	    if _SHARED_DATASET is None:
102	        _SHARED_DATASET = _make_dataset()
103	    return _SHARED_DATASET
