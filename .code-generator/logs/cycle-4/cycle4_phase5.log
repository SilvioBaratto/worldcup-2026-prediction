2026-06-24 03:16:33,625 DEBUG msg #113: UserMessage tool_result(toolu_01RwRnjtCu8ZTx7HpjxZLUUu): 1	"""Groll-style RF/GBM goal-based hybrid model (primary predictor).
2	
3	Predicts per-match expected goals via a blended Random-Forest + Gradient-Boosting
4	regressor pair, then converts the goal pair to a W/D/L distribution via the
5	reused Dixon-Coles τ-corrected score matrix from ``simulation.poisson``.
6	
7	Design matrix conventions:
8	- Explicit allow-list: only numeric + encoded columns enter; targets/identity/metadata
9	  (home_goals, away_goals, date, home_team, away_team, tournament) are silently excluded.
10	- Confederation strings (home_confederation, away_confederation) are one-hot encoded
11	  against the fixed ``CONFEDERATIONS`` tuple — never data-dependent discovery.
12	- None/unknown confederation → all-zero one-hot row (no NaN leakage).
13	- Nullable numeric columns (rest_days, ranking) are imputed at fit time with the
14	  training-set median; sentinels are stored and reused at inference (no leakage).
15	"""
16	from __future__ import annotations
17	
18	from dataclasses import dataclass
19	
20	import numpy as np
21	import pandas as pd
22	from sklearn.ensemble import GradientBoostingRegressor, RandomForestRegressor
23	
24	from worldcup_playoff.config import HybridConfig
25	from worldcup_playoff.features.confederation import CONFEDERATIONS
26	from worldcup_playoff.models.dataset import MatchDataset
27	from worldcup_playoff.simulation.poisson import score_matrix
28	
29	__all__ = ["GoalPrediction", "HybridModel", "fit_hybrid"]
30	
31	# ─── Constants ───────────────────────────────────────────────────────────────
32	
33	_FORBIDDEN: frozenset[str] = frozenset(
34	    {"home_goals", "away_goals", "date", "home_team", "away_team", "tournament"}
35	)
36	_CONFED_COLS: frozenset[str] = frozenset({"home_confederation", "away_confederation"})
37	
38	
39	# ─── Value object ────────────────────────────────────────────────────────────
40	
41	
42	@dataclass(frozen=True)
43	class GoalPrediction:
44	    """Outcome distribution and expected goal pair for one match."""
45	
46	    prob_home: float
47	    prob_draw: float
48	    prob_away: float
49	    home_goals: float
50	    away_goals: float
51	    margin: float  # home_goals − away_goals
52	
53	
54	# ─── Pure module-level helpers ────────────────────────────────────────────────
55	
56	
57	def _one_hot_confed(series: pd.Series) -> np.ndarray:
58	    """Encode confederation strings → (n, 6) float array; None/unknown → all-zero row."""
59	    cats = list(CONFEDERATIONS)
60	    out = np.zeros((len(series), len(cats)), dtype=float)
61	    for i, val in enumerate(series):
62	        if val in cats:
63	            out[i, cats.index(val)] = 1.0
64	    return out
65	
66	
67	def _numeric_col(series: pd.Series, sentinel: float) -> np.ndarray:
68	    """Cast a numeric-or-bool Series to a (n,1) float array, filling NaN with sentinel."""
69	    if pd.api.types.is_bool_dtype(series):
70	        return series.fillna(False).astype(float).values.reshape(-1, 1)
71	    return pd.to_numeric(series, errors="coerce").fillna(sentinel).astype(float).values.reshape(-1, 1)
72	
73	
74	def _col_array(df: pd.DataFrame, col: str, sentinels: dict[str, float]) -> np.ndarray:
75	    """Convert one feature column to a (n, k) float array; impute NaN via sentinel."""
76	    if col not in df.columns:
77	        return np.full((len(df), 1), sentinels.get(col, 0.0))
78	    series = df[col]
79	    if col in _CONFED_COLS:
80	        return _one_hot_confed(series)
81	    return _numeric_col(series, sentinels.get(col, 0.0))
82	
83	
84	def build_design_matrix(
85	    df: pd.DataFrame, feature_cols: list[str], sentinels: dict[str, float] | None = None
86	) -> np.ndarray:
87	    """Return float design matrix; excludes forbidden cols, encodes categoricals, imputes NaN."""
88	    safe = [c for c in feature_cols if c not in _FORBIDDEN]
89	    if not safe:
90	        return np.zeros((len(df), 0))
91	    return np.hstack([_col_array(df, c, sentinels or {}) for c in safe])
92	
93	
94	def _fit_sentinels(df: pd.DataFrame, cols: list[str]) -> dict[str, float]:
95	    """Compute fit-time median imputation values for nullable numeric columns."""
96	    out: dict[str, float] = {}
97	    for col in cols:
98	        if col in _FORBIDDEN or col in _CONFED_COLS or col not in df.columns:
99	            continue
100	        median = float(pd.to_numeric(df[col], errors="coerce").median())
101	        out[col] = 0.0 if np.isnan(median) else median
102	    return out
103	
104	
105	def derive_outcome_probs(
106	    lh: float, la: float, *, max_goals: int, rho: float
107	) -> tuple[float, float, float]:
108	    """Return (prob_home, prob_draw, prob_away) via the τ-corrected score matrix."""
109	    mat = score_matrix(lh, la, rho=rho, max_goals=max_goals)
110	    ph = float(np.tril(mat, -1).sum())   # home score > away score
111	    pd_ = float(np.diag(mat).sum())       # equal scores (draw)
112	    pa = float(np.triu(mat, 1).sum())    # away score > home score
113	    return ph, pd_, pa
114	
115	
116	def _make_prediction(lh: float, la: float, cfg: HybridConfig) -> GoalPrediction:
117	    ph, pd_, pa = derive_outcome_probs(lh, la, max_goals=cfg.max_goals, rho=cfg.rho)
118	    return GoalPrediction(ph, pd_, pa, lh, la, lh - la)
119	
120	
121	def _new_rf(cfg: HybridConfig) -> RandomForestRegressor:
122	    return RandomForestRegressor(
123	        n_estimators=cfg.rf_n_estimators,
124	        max_depth=cfg.rf_max_depth,
125	        random_state=cfg.random_seed,
126	        n_jobs=1,
127	    )
128	
129	
130	def _new_gb(cfg: HybridConfig) -> GradientBoostingRegressor:
131	    return GradientBoostingRegressor(
132	        n_estimators=cfg.gb_n_estimators,
133	        learning_rate=cfg.gb_learning_rate,
134	        random_state=cfg.random_seed,
135	    )
136	
137	
138	def _fit_pair(
139	    cfg: HybridConfig, X: np.ndarray, y: np.ndarray
140	) -> tuple[RandomForestRegressor, GradientBoostingRegressor]:
141	    """Fit and return one (RF, GB) regressor pair for a single goal target."""
142	    return _new_rf(cfg).fit(X, y), _new_gb(cfg).fit(X, y)
143	
144	
145	# ─── Thin model class ─────────────────────────────────────────────────────────
146	
147	
148	class HybridModel:
149	    """RF+GB blended goal-regression hybrid.  Trains on ``MatchDataset.train`` only."""
150	
151	    def __init__(self, random_seed: int = 42) -> None:
152	        self._cfg = HybridConfig(random_seed=random_seed)
153	        self._feature_cols: list[str] = []
154	        self._sentinels: dict[str, float] = {}
155	        self._rf_h: RandomForestRegressor | None = None
156	        self._rf_a: RandomForestRegressor | None = None
157	        self._gb_h: GradientBoostingRegressor | None = None
158	        self._gb_a: GradientBoostingRegressor | None = None
159	
160	    def fit(self, dataset: MatchDataset) -> "HybridModel":
161	        self._feature_cols = dataset.feature_cols
162	        self._sentinels = _fit_sentinels(dataset.train, self._feature_cols)
163	        X = build_design_matrix(dataset.train, self._feature_cols, self._sentinels)
164	        y_h = dataset.train["home_goals"].astype(float).values
165	        y_a = dataset.train["away_goals"].astype(float).values
166	        self._rf_h, self._gb_h = _fit_pair(self._cfg, X, y_h)
167	        self._rf_a, self._gb_a = _fit_pair(self._cfg, X, y_a)
168	        return self
169	
170	    def predict_goals(self, features: dict) -> tuple[float, float]:
171	        X = build_design_matrix(pd.DataFrame([features]), self._feature_cols, self._sentinels)
172	        lh = max(0.0, float((self._rf_h.predict(X)[0] + self._gb_h.predict(X)[0]) / 2))  # type: ignore[union-attr]
173	        la = max(0.0, float((self._rf_a.predict(X)[0] + self._gb_a.predict(X)[0]) / 2))  # type: ignore[union-attr]
174	        return lh, la
175	
176	    def predict(self, features: dict) -> GoalPrediction:
177	        lh, la = self.predict_goals(features)
178	        return _make_prediction(lh, la, self._cfg)
179	
180	
181	# ─── Factory ──────────────────────────────────────────────────────────────────
182	
183	
184	def fit_hybrid(dataset: MatchDataset, config: HybridConfig | None = None) -> HybridModel:
185	    """Fit and return a HybridModel from a pre-split MatchDataset."""
186	    cfg = config or HybridConfig()
187	    model = HybridModel(random_seed=cfg.random_seed)
188	    model._cfg = cfg  # propagate full config (e.g. custom gb_learning_rate)
189	    return model.fit(dataset)
190	
