232	# AC5 — Deterministic: two fits on identical data give identical predictions
233	# ---------------------------------------------------------------------------
234	
235	def test_when_fit_twice_on_same_data_then_predictions_are_identical():
236	    """AC5: BFGS over a convex objective is deterministic — same data → same result."""
237	    dataset = _make_dataset(n=200, seed=42)
238	    m1 = OrderedLogitModel()
239	    m1.fit(dataset)
240	    m2 = OrderedLogitModel()
241	    m2.fit(dataset)
242	    X = pd.DataFrame({"elo_diff": [-100.0, 0.0, 100.0]})
243	    r1, r2 = m1.predict(X), m2.predict(X)
244	    for a, b in zip(r1, r2):
245	        assert abs(a.prob_home - b.prob_home) < 1e-10
246	        assert abs(a.prob_draw - b.prob_draw) < 1e-10
247	        assert abs(a.prob_away - b.prob_away) < 1e-10
