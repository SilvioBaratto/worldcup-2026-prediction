143	def test_when_hybrid_model_is_refit_with_same_seed_then_predictions_are_identical():
144	    """Criterion 4: identical random_seed → identical HybridModel.predict_goals."""
145	    ds = _shared_dataset()
146	    h1, a1 = HybridModel(random_seed=42).fit(ds).predict_goals(_SAMPLE_FEATS)
147	    h2, a2 = HybridModel(random_seed=42).fit(ds).predict_goals(_SAMPLE_FEATS)
