31	def _played_df(n: int = 10) -> pd.DataFrame:
32	    """Chronologically ordered frame of n played matches."""
33	    rows = [
34	        {
35	            "date": f"2020-{(i // 28) + 1:02d}-{(i % 28) + 1:02d}",
36	            "home_team": "Team A",
37	            "away_team": "Team B",
38	            "home_goals": i % 3,
39	            "away_goals": (i + 1) % 3,
40	            "home_elo": 1500.0,
41	            "away_elo": 1450.0,
42	            "elo_diff": 50.0,
43	        }
44	        for i in range(n)
45	    ]
46	    df = pd.DataFrame(rows)
47	    df["home_goals"] = df["home_goals"].astype("Int64")
48	    df["away_goals"] = df["away_goals"].astype("Int64")
49	    return df
