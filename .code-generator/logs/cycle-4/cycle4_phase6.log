89	def _fitted_model(n: int = 200, seed: int = 42) -> OrderedLogitModel:
90	    """Return an OrderedLogitModel already fitted on synthetic data."""
91	    dataset = _make_dataset(n=n, seed=seed)
92	    model = OrderedLogitModel()
93	    model.fit(dataset)
94	    return model
