2026-06-24 03:28:15,652 DEBUG msg #81: UserMessage tool_result(toolu_016GR3sQX7WbSXtv4htVGvmr): 1	"""Elo-diff ordered logit — secondary/fallback W/D/L predictor.
2	
3	Lightweight safety net when the goal hybrid cannot fit (e.g. too few
4	played rows). Predicts W/D/L probabilities only — no goal output, so it
5	does not feed goal-difference tiebreaks.
6	
7	Lazy-imports ``OrderedModel`` inside ``OrderedLogitModel.fit`` so this
8	module loads fast at collection time even when statsmodels is absent.
9	"""
10	
11	from __future__ import annotations
12	
13	from dataclasses import dataclass
14	from typing import Any
15	
16	import numpy as np
17	import pandas as pd
18	
19	from worldcup_playoff.config import OrderedLogitConfig
20	from worldcup_playoff.models.dataset import MatchDataset
21	
22	__all__ = ["OutcomeProbabilities", "OrderedLogitModel", "fit_ordered_logit"]
23	
24	
25	# ─── Value object ────────────────────────────────────────────────────────────
26	
27	
28	@dataclass(frozen=True)
29	class OutcomeProbabilities:
30	    """Calibrated W/D/L probability triple for one match."""
31	
32	    prob_home: float
33	    prob_draw: float
34	    prob_away: float
35	
36	
37	# ─── Pure module-level helpers ────────────────────────────────────────────────
38	
39	
40	def _endog(train: pd.DataFrame) -> np.ndarray:
41	    """Cast nullable Int64 y_outcome to plain int64 array (safe after played_only)."""
42	    return np.asarray(train["y_outcome"].astype(int))
43	
44	
45	def _exog(df: pd.DataFrame, features: list[str]) -> np.ndarray:
46	    """Select features as float64 array; no constant prepended (OrderedModel uses cut-points)."""
47	    return np.asarray(df[features].astype(float), dtype=float)
48	
49	
50	def _to_outcome(row: np.ndarray) -> OutcomeProbabilities:
51	    """Map an [away, draw, home] probability row to the value object."""
52	    return OutcomeProbabilities(
53	        prob_away=float(row[0]),
54	        prob_draw=float(row[1]),
55	        prob_home=float(row[2]),
56	    )
57	
58	
59	# ─── Model class ─────────────────────────────────────────────────────────────
60	
61	
62	class OrderedLogitModel:
63	    """Ordered logit over W/D/L outcomes; trains on MatchDataset.train only.
64	
65	    Secondary/fallback predictor — predicts W/D/L, not goals.
66	    """
67	
68	    def __init__(self, config: OrderedLogitConfig | None = None) -> None:
69	        self._cfg = config or OrderedLogitConfig()
70	        self._result: Any = None  # statsmodels OrderedResultsWrapper post-fit
71	
72	    def fit(self, dataset: MatchDataset) -> "OrderedLogitModel":
73	        """Fit on dataset.train only — time-aware, no internal split/shuffle."""
74	        from statsmodels.miscmodels.ordinal_model import OrderedModel  # lazy import
75	
76	        train = dataset.train
77	        self._result = OrderedModel(
78	            _endog(train), _exog(train, self._cfg.features), distr="logit"
79	        ).fit(method="bfgs", maxiter=self._cfg.maxiter, disp=False)
80	        return self
81	
82	    def predict(self, df: pd.DataFrame) -> list[OutcomeProbabilities]:
83	        """Return OutcomeProbabilities for each row of df; no API key required."""
84	        probs: np.ndarray = self._result.predict(exog=_exog(df, self._cfg.features))
85	        return [_to_outcome(row) for row in probs]
86	
87	
88	# ─── Factory ──────────────────────────────────────────────────────────────────
89	
90	
91	def fit_ordered_logit(
92	    dataset: MatchDataset, config: OrderedLogitConfig | None = None
93	) -> OrderedLogitModel:
94	    """Fit and return an OrderedLogitModel from a pre-split MatchDataset."""
95	    return OrderedLogitModel(config).fit(dataset)
