30	def _synthetic_df(n: int = 200, seed: int = 0) -> pd.DataFrame:
31	    """
32	    Minimal DataFrame matching the model's expected training schema:
33	      - elo_diff   : numeric feature (config-driven; sole feature per AC1)
34	      - y_outcome  : ordinal target — 0 = away-win, 1 = draw, 2 = home-win
35	                     (away < draw < home, per AC1)
36	    A simple sigmoid correlation makes the ordered-logit identifiable:
37	    higher elo_diff → more likely home win.
38	    """
39	    rng = np.random.default_rng(seed)
40	    elo_diff = rng.uniform(-400.0, 400.0, size=n)
41	    prob_home = 1.0 / (1.0 + np.exp(-elo_diff / 200.0))
42	    prob_away = 1.0 / (1.0 + np.exp(elo_diff / 200.0))
43	    prob_draw = np.full(n, 0.25)
44	    total = prob_home + prob_away + prob_draw
45	    prob_home /= total
46	    prob_away /= total
47	    prob_draw /= total
48	    outcomes = np.array(
49	        [rng.choice([0, 1, 2], p=[prob_away[i], prob_draw[i], prob_home[i]]) for i in range(n)]
50	    )
51	    return pd.DataFrame({"elo_diff": elo_diff, "y_outcome": outcomes})
52	
