129	def _third_sort_key(group: str, row: dict) -> tuple:
130	    """FIFA tiebreak key for third-placed teams (lower = better rank)."""
131	    return (
132	        -row.get("points", 0),
133	        -row.get("goalDifference", 0),
134	        -row.get("goalsFor", 0),
135	        group,  # alphabetical as the final, deterministic tiebreaker
136	    )
