106	│   ├── ordered_logit.py      # NEW — Elo-diff ordered logit (secondary)
107	│   ├── classifiers.py        # legacy SVM/RF/NB (backtest baseline only)
108	│   └── evaluation.py         # EXTEND — RPS / log-loss / Brier + backtest vs bookmakers
109	├── simulation/
