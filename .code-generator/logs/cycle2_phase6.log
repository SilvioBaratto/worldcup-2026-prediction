81	def _bipartite_match(
82	    qualifying: frozenset[str],
83	    slots: tuple[tuple[str, frozenset[str]], ...],
84	) -> dict[str, str] | None:
85	    """Return slot→group assignment via augmenting paths, or None if impossible."""
86	    groups = sorted(qualifying)
87	    g_idx = {g: i for i, g in enumerate(groups)}
88	    adj = [[g_idx[g] for g in cands if g in qualifying] for _, cands in slots]
89	    match: list[int] = [-1] * len(groups)
90	    n = sum(_augment(s, adj, match, [False] * len(groups)) for s in range(len(slots)))
91	    if n < len(slots):
92	        return None
93	    slot_map = {match[i]: groups[i] for i in range(len(groups)) if match[i] != -1}
94	    return {slots[s][0]: slot_map[s] for s in range(len(slots))}
