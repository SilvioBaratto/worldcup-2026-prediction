65	def _augment(
66	    slot: int,
67	    adj: list[list[int]],
68	    match: list[int],
69	    seen: list[bool],
70	) -> bool:
71	    """Try to find an augmenting path for *slot*; update *match* in-place."""
72	    for g in adj[slot]:
73	        if not seen[g]:
74	            seen[g] = True
75	            if match[g] == -1 or _augment(match[g], adj, match, seen):
76	                match[g] = slot
77	                return True
78	    return False
79	
