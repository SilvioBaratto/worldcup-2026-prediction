250	            "elo_diff": 50.0,
251	        }
252	        for i in range(n)
253	    ]
254	    df = pd.DataFrame(rows)
255	    df["home_goals"] = df["home_goals"].astype("Int64")
256	    df["away_goals"] = df["away_goals"].astype("Int64")
257	    return df
