30	            "AWAY_GOALS": pd.array([r.get("away_goals", pd.NA) for r in rows], dtype="Int64"),
31	            "TOURNAMENT": [r.get("tournament", "Friendly") for r in rows],
32	            "NEUTRAL": [r.get("neutral", False) for r in rows],
33	        }
34	    )
