446	
447	def test_when_feature_cols_contain_no_forbidden_columns_then_fit_succeeds():
448	    """
449	    The design matrix must exclude home_goals, away_goals, date, home_team, away_team.
450	    Asserting that _FEATURE_COLS has no overlap with _FORBIDDEN_COLS and that
451	    fit() on such a dataset succeeds is a direct check of the criterion.
452	    """
453	    overlap = set(_FEATURE_COLS) & _FORBIDDEN_COLS
454	    assert not overlap, f"Test setup error — forbidden cols in feature list: {overlap}"
455	
456	    ds = _make_dataset()
457	    assert not (set(ds.feature_cols) & _FORBIDDEN_COLS), (
458	        f"MatchDataset.feature_cols contains forbidden columns: "
459	        f"{set(ds.feature_cols) & _FORBIDDEN_COLS}"
460	    )
461	    HybridModel(random_seed=0).fit(ds)  # must not raise
