64	        m = _matches([{"home": "Brazil", "away": "Germany", "home_goals": 1, "away_goals": 0}])
65	        result = FeatureBuilder(_CFG).build(m, _elo([{}]), _BRA_GER)
66	        assert set(result.columns) == set(FEATURE_COLUMNS)
