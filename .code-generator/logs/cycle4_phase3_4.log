54	
55	    Columns: date, home_team, away_team, home_score, away_score,
56	             tournament, city, country, neutral.
57	    home_team != away_team by construction ((i%8) != ((i+1)%8) for all i).
58	    """
59	    rows = [
60	        {
61	            "date": _DATES[i % len(_DATES)],
62	            "home_team": _TEAMS[i % len(_TEAMS)],
63	            "away_team": _TEAMS[(i + 1) % len(_TEAMS)],
64	            "home_score": i % 4,
65	            "away_score": i % 3,
66	            "tournament": "FIFA World Cup" if i % 5 == 0 else "Friendly",
67	            "city": "City",
68	            "country": "United States",
69	            "neutral": i % 3 == 0,
70	        }
71	        for i in range(n_rows)
72	    ]
73	    df = pd.DataFrame(rows)
74	    df["date"] = pd.to_datetime(df["date"])
75	    return df.sort_values("date").reset_index(drop=True)
