257	    lam_home=st.floats(min_value=0.1, max_value=5.0, allow_nan=False, allow_infinity=False),
258	    lam_away=st.floats(min_value=0.1, max_value=5.0, allow_nan=False, allow_infinity=False),
259	)
260	def test_when_score_matrix_called_for_any_valid_lambdas_then_draw_mass_is_positive(
261	    lam_home: float, lam_away: float
262	) -> None:
263	    """Non-zero draw mass is an invariant for all positive rate pairs (AC3)."""
264	    assert float(np.diag(score_matrix(lam_home, lam_away)).sum()) > 0.0
265	
