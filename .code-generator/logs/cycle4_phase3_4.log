54	class _FakeMatchDataset:
55	    """
56	    Protocol-minimal stand-in for MatchDataset.
57	
58	    Satisfies the interface implied by AC4: the model's fit() must use
59	    .train only and must never touch .test.  Access is recorded so the
60	    test can assert the correct property was (or was not) read.
61	    """
62	
63	    def __init__(self, train_df: pd.DataFrame, test_df: pd.DataFrame) -> None:
64	        self._train = train_df
65	        self._test = test_df
66	        self.train_accessed: bool = False
67	        self.test_accessed: bool = False
68	
69	    @property
70	    def train(self) -> pd.DataFrame:
71	        self.train_accessed = True
72	        return self._train
73	
74	    @property
75	    def test(self) -> pd.DataFrame:
76	        self.test_accessed = True
77	        return self._test
78	
79	
80	def _make_dataset(n: int = 200, seed: int = 42) -> _FakeMatchDataset:
81	    df = _synthetic_df(n=n, seed=seed)
82	    split = n // 2
83	    return _FakeMatchDataset(
84	        train_df=df.iloc[:split].copy(),
85	        test_df=df.iloc[split:].copy(),
86	    )
87	
88	
89	def _fitted_model(n: int = 200, seed: int = 42) -> OrderedLogitModel:
90	    """Return an OrderedLogitModel already fitted on synthetic data."""
91	    dataset = _make_dataset(n=n, seed=seed)
92	    model = OrderedLogitModel()
93	    model.fit(dataset)
94	    return model
