31	def _played_df(n: int = 10) -> pd.DataFrame:
32	    """Chronologically ordered frame of n played matches."""
33	    rows = [
34	        {
35	            "date": f"2020-{(i // 28) + 1:02d}-{(i % 28) + 1:02d}",
36	            "home_team": "Team A",
37	            "away_team": "Team B",
38	            "home_goals": i % 3,
39	            "away_goals": (i + 1) % 3,
40	            "home_elo": 1500.0,
41	            "away_elo": 1450.0,
42	            "elo_diff": 50.0,
43	        }
44	        for i in range(n)
45	    ]
46	    df = pd.DataFrame(rows)
47	    df["home_goals"] = df["home_goals"].astype("Int64")
48	    df["away_goals"] = df["away_goals"].astype("Int64")
49	    return df
50	
51	
52	def _mixed_df(n_played: int = 8, n_unplayed: int = 2) -> pd.DataFrame:
53	    """Played rows followed by unplayed (NA-goals) rows."""
54	    played = _played_df(n_played)
55	    unplayed_rows = [
56	        {
57	            "date": f"2030-06-{j + 1:02d}",
58	            "home_team": "Team C",
59	            "away_team": "Team D",
60	            "home_goals": NA,
61	            "away_goals": NA,
62	            "home_elo": 1480.0,
63	            "away_elo": 1490.0,
64	            "elo_diff": -10.0,
65	        }
66	        for j in range(n_unplayed)
67	    ]
68	    unplayed = pd.DataFrame(unplayed_rows)
69	    unplayed["home_goals"] = unplayed["home_goals"].astype("Int64")
70	    unplayed["away_goals"] = unplayed["away_goals"].astype("Int64")
71	    return pd.concat([played, unplayed], ignore_index=True)
