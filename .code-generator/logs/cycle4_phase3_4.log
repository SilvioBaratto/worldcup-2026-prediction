267	# ---------------------------------------------------------------------------
268	# AC4 — fit trains on MatchDataset.train only (time-aware, no re-split)
269	# ---------------------------------------------------------------------------
270	
271	
272	def test_when_fit_called_with_match_dataset_then_model_can_predict_without_error():
273	    """
274	    fit() accepts a pre-split MatchDataset and produces a usable model.
275	
276	    The MatchDataset API is the architectural enforcement: the model receives only
277	    the split object (with .train and .test), never the raw pre-split data, so it
278	    cannot internally re-split or shuffle the chronological order.
279	    """
280	    ds = _make_dataset()
281	    model = HybridModel(random_seed=0)
282	    model.fit(ds)
283	    assert isinstance(model.predict(_neutral_features()), GoalPrediction)
284	
285	
286	def test_when_train_split_is_larger_then_predictions_differ_from_smaller_train():
287	    """
288	    If the model uses dataset.train, shrinking .train must shift its predictions.
289	    Two identical models trained on the same raw data but different chronological
290	    split sizes must produce different predictions — proving the model is actually
291	    learning from .train rather than ignoring it.
292	
293	    Assumption (from criterion): train-only learning means training size influences output.
294	    """
295	    df = _make_match_df(n=40, seed=7)
296	    ds_large = build_dataset(df, test_size=0.1, feature_cols=_FEATURE_COLS)
297	    ds_small = build_dataset(df, test_size=0.5, feature_cols=_FEATURE_COLS)
298	    assert len(ds_large.train) > len(ds_small.train)
299	
300	    m_large = HybridModel(random_seed=42)
301	    m_small = HybridModel(random_seed=42)
302	    m_large.fit(ds_large)
303	    m_small.fit(ds_small)
304	
305	    feats = _neutral_features()
306	    p_large = m_large.predict(feats)
307	    p_small = m_small.predict(feats)
308	
309	    predictions_differ = not (
310	        np.isclose(p_large.prob_home, p_small.prob_home, atol=1e-8)
311	        and np.isclose(p_large.prob_draw, p_small.prob_draw, atol=1e-8)
312	        and np.isclose(p_large.prob_away, p_small.prob_away, atol=1e-8)
313	    )
314	    assert predictions_differ, (
315	        "Models trained on different .train sizes produced identical predictions; "
316	        "model may not be using dataset.train at all."
317	    )
318	
319	
320	def test_when_train_dominated_by_home_wins_then_prob_home_exceeds_prob_away():
321	    """
322	    Home-dominant training data must produce prob_home > prob_away on home-favoured
323	    match features — verifying that the model generalises from .train to predictions.
324	
325	    First 24 rows (= .train with test_size=0.2) → home always wins 3-0.
326	    Last 6 rows  (= .test)                       → away always wins 0-3.
327	    Same elo_diff across all rows so the RF cannot split by feature; train-only
328	    fitting therefore produces a pure home-win learner.
329	    """
330	    rows: list[dict] = []
331	    for i in range(25):
332	        rows.append(
333	            {
334	                "date": f"2019-{i // 28 + 1:02d}-{i % 28 + 1:02d}",
335	                "home_team": "A",
336	                "away_team": "B",
337	                "home_goals": 3,
338	                "away_goals": 0,
339	                "elo_diff": 50.0,
340	                "home_elo": 1550.0,
341	                "away_elo": 1500.0,
342	            }
343	        )
344	    for j in range(5):
345	        rows.append(
346	            {
347	                "date": f"2025-01-{j + 1:02d}",
348	                "home_team": "A",
349	                "away_team": "B",
350	                "home_goals": 0,
351	                "away_goals": 3,
352	                "elo_diff": 50.0,  # identical features, opposite outcome
353	                "home_elo": 1550.0,
354	                "away_elo": 1500.0,
355	            }
356	        )
357	    df = pd.DataFrame(rows)
358	    df["home_goals"] = df["home_goals"].astype("Int64")
359	    df["away_goals"] = df["away_goals"].astype("Int64")
360	    # test_size=0.2 → floor(30 * 0.2) = 6 rows in .test, 24 in .train
361	    ds = build_dataset(df, test_size=0.2, feature_cols=_FEATURE_COLS)
362	    assert len(ds.train) == 24  # all home-win rows in train
363	
364	    model = HybridModel(random_seed=0)
365	    model.fit(ds)
366	    pred = model.predict({"elo_diff": 50.0, "home_elo": 1550.0, "away_elo": 1500.0})
367	    assert pred.prob_home > pred.prob_away, (
368	        f"Expected prob_home > prob_away when training only on home-win data "
369	        f"(prob_home={pred.prob_home:.3f}, prob_away={pred.prob_away:.3f})."
370	    )
371	
