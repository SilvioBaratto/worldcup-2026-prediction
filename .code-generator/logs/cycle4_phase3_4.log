2026-06-24 03:04:31,985 DEBUG msg #37: UserMessage tool_result(toolu_01VNWGiUq7rujP7oFeo1fFBw): 1	"""Elo-diff ordered logit — secondary/fallback W/D/L predictor.
2	
3	Lightweight safety net when the goal hybrid cannot fit (e.g. too few
4	played rows). Predicts W/D/L probabilities only — no goal output, so it
5	does not feed goal-difference tiebreaks.
6	
7	Lazy-imports ``OrderedModel`` inside ``OrderedLogitModel.fit`` so this
8	module loads fast at collection time even when statsmodels is absent.
9	"""
10	from __future__ import annotations
11	
12	from dataclasses import dataclass
13	from typing import Any
14	
15	import numpy as np
16	import pandas as pd
17	
18	from worldcup_playoff.config import OrderedLogitConfig
19	from worldcup_playoff.models.dataset import MatchDataset
20	
21	__all__ = ["OutcomeProbabilities", "OrderedLogitModel", "fit_ordered_logit"]
22	
23	
24	# ─── Value object ────────────────────────────────────────────────────────────
25	
26	
27	@dataclass(frozen=True)
28	class OutcomeProbabilities:
29	    """Calibrated W/D/L probability triple for one match."""
30	
31	    prob_home: float
32	    prob_draw: float
33	    prob_away: float
34	
35	
36	# ─── Pure module-level helpers ────────────────────────────────────────────────
37	
38	
39	def _endog(train: pd.DataFrame) -> np.ndarray:
40	    """Cast nullable Int64 y_outcome to plain int64 array (safe after played_only)."""
41	    return train["y_outcome"].astype(int).values
42	
43	
44	def _exog(df: pd.DataFrame, features: list[str]) -> np.ndarray:
45	    """Select features as float64 array; no constant prepended (OrderedModel uses cut-points)."""
46	    return df[features].astype(float).values
47	
48	
49	def _to_outcome(row: np.ndarray) -> OutcomeProbabilities:
50	    """Map an [away, draw, home] probability row to the value object."""
51	    return OutcomeProbabilities(
52	        prob_away=float(row[0]),
53	        prob_draw=float(row[1]),
54	        prob_home=float(row[2]),
55	    )
56	
57	
58	# ─── Model class ─────────────────────────────────────────────────────────────
59	
60	
61	class OrderedLogitModel:
62	    """Ordered logit over W/D/L outcomes; trains on MatchDataset.train only.
63	
64	    Secondary/fallback predictor — predicts W/D/L, not goals.
65	    """
66	
67	    def __init__(self, config: OrderedLogitConfig | None = None) -> None:
68	        self._cfg = config or OrderedLogitConfig()
69	        self._result: Any = None  # statsmodels OrderedResultsWrapper post-fit
70	
71	    def fit(self, dataset: MatchDataset) -> "OrderedLogitModel":
72	        """Fit on dataset.train only — time-aware, no internal split/shuffle."""
73	        from statsmodels.miscmodels.ordinal_model import OrderedModel  # lazy import
74	
75	        train = dataset.train
76	        self._result = OrderedModel(
77	            _endog(train), _exog(train, self._cfg.features), distr="logit"
78	        ).fit(method="bfgs", maxiter=self._cfg.maxiter, disp=False)
79	        return self
80	
81	    def predict(self, df: pd.DataFrame) -> list[OutcomeProbabilities]:
82	        """Return OutcomeProbabilities for each row of df; no API key required."""
83	        probs: np.ndarray = self._result.predict(exog=_exog(df, self._cfg.features))  # type: ignore[union-attr]
84	        return [_to_outcome(row) for row in probs]
85	
86	
87	# ─── Factory ──────────────────────────────────────────────────────────────────
88	
89	
90	def fit_ordered_logit(
91	    dataset: MatchDataset, config: OrderedLogitConfig | None = None
92	) -> OrderedLogitModel:
93	    """Fit and return an OrderedLogitModel from a pre-split MatchDataset."""
94	    return OrderedLogitModel(config).fit(dataset)
