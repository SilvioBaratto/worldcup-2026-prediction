510	def test_when_data_package_reloaded_then_football_client_is_not_constructed(monkeypatch):
511	    """FootballClient.__init__ must not be called as a side-effect of importing."""
512	    import importlib
513	
514	    constructed: list[bool] = []
515	    try:
516	        from worldcup_playoff.data import client as _client_mod
517	
518	        _original_init = _client_mod.FootballClient.__init__
519	
520	        def _spy_init(self, *args, **kwargs):
521	            constructed.append(True)
522	            return _original_init(self, *args, **kwargs)
523	
524	        monkeypatch.setattr(_client_mod.FootballClient, "__init__", _spy_init)
525	    except (ImportError, AttributeError):
526	        return  # client module absent — purity is guaranteed by absence
527	
528	    import worldcup_playoff.data
529	
530	    importlib.reload(worldcup_playoff.data)
531	    assert not constructed, "FootballClient was instantiated during package import"
