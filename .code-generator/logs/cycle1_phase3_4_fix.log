484	def test_when_data_package_reloaded_then_no_http_request_is_initiated(monkeypatch):
485	    """No HTTP request (via requests.Session or requests.get) must fire on import."""
486	    import importlib
487	
488	    import requests
489	
490	    blocked: list[tuple] = []
491	
492	    def _forbid_get(*args, **kwargs):
493	        blocked.append(args)
494	        raise AssertionError(f"HTTP GET called during import: {args}")
495	
496	    def _forbid_post(*args, **kwargs):
497	        blocked.append(args)
498	        raise AssertionError(f"HTTP POST called during import: {args}")
499	
500	    monkeypatch.setattr(requests, "get", _forbid_get)
501	    monkeypatch.setattr(requests, "post", _forbid_post)
502	
503	    import worldcup_playoff.data
504	
505	    importlib.reload(worldcup_playoff.data)  # must not trigger _forbid_get/_forbid_post
506	
507	    assert not blocked, f"HTTP call(s) made on import: {blocked}"
508	
