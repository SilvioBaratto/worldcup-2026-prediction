271	# 7. ScorelineSampler.sample
272	#    Criterion: returns int array (size, 2) with goals in [0, max_goals];
273	#    reproducible with same seed; divergent across seeds;
274	#    default seed comes from PoissonConfig.
275	# ─────────────────────────────────────────────────────────────────────────────
276	
277	class TestScorelineSampler:
278	    @pytest.fixture
279	    def abilities(self):
280	        return DixonColesEstimator().fit(_played_df())
281	
282	    @pytest.fixture
283	    def sampler(self, abilities):
284	        return ScorelineSampler(abilities=abilities, config=PoissonConfig())
285	
286	    def test_when_sample_called_then_result_shape_is_size_by_two(self, sampler):
287	        result = sampler.sample("Alpha", "Beta", size=100, random_state=0)
288	        assert result.shape == (100, 2)
289	
290	    def test_when_sample_called_then_dtype_is_integer(self, sampler):
291	        result = sampler.sample("Alpha", "Beta", size=50, random_state=1)
292	        assert np.issubdtype(result.dtype, np.integer)
293	
294	    def test_when_sample_called_then_goals_are_within_zero_and_max_goals(self, sampler):
295	        max_g = PoissonConfig().max_goals
296	        result = sampler.sample("Alpha", "Beta", size=500, random_state=2)
297	        assert int(result.min()) >= 0
298	        assert int(result.max()) <= max_g
299	
300	    def test_when_same_random_state_used_then_output_is_reproducible(self, sampler):
301	        r1 = sampler.sample("Alpha", "Beta", size=50, random_state=42)
302	        r2 = sampler.sample("Alpha", "Beta", size=50, random_state=42)
303	        np.testing.assert_array_equal(r1, r2)
304	
305	    def test_when_different_random_states_used_then_outputs_diverge(self, sampler):
306	        r1 = sampler.sample("Alpha", "Beta", size=300, random_state=0)
307	        r2 = sampler.sample("Alpha", "Beta", size=300, random_state=9999)
308	        assert not np.array_equal(r1, r2)
309	
310	    def test_when_no_random_state_given_then_default_seed_comes_from_poisson_config(self, sampler):
311	        """Assumption: PoissonConfig exposes a `random_seed` field used as the default."""
312	        cfg = PoissonConfig()
313	        r_default = sampler.sample("Alpha", "Beta", size=50)
314	        r_explicit = sampler.sample("Alpha", "Beta", size=50, random_state=cfg.random_seed)
315	        np.testing.assert_array_equal(r_default, r_explicit)
