119	
120	class TestWhenExpectationMathThenValuesAreExact:
121	    def test_when_equal_ratings_on_neutral_then_delta_implies_we_is_0_5(self):
122	        """Equal ratings + neutral → We=0.5 → ΔR = k_friendly × 1.0 × 0.5."""
123	        config = EloConfig()
124	        result = EloEngine(config).run(_one_match(home_goals=1, away_goals=0, neutral=True))
125	        expected_delta = config.k_friendly * 0.5
126	        assert result.final_ratings["TeamA"] == pytest.approx(
127	            config.initial_rating + expected_delta
128	        )
129	
130	    def test_when_dr_400_via_home_advantage_then_delta_implies_we_approx_0_909(self):
131	        """home_advantage=400, equal initial ratings, non-neutral → dr=400 → We=10/11.
132	
133	        ΔR = k_friendly × G=1.0 × (1 − 10/11) = k_friendly / 11.
134	        """
135	        config = EloConfig(home_advantage=400.0)
136	        result = EloEngine(config).run(_one_match(home_goals=1, away_goals=0, neutral=False))
137	        expected_we = 1.0 / (1.0 + 10.0 ** (-400.0 / 400.0))  # ≈ 0.90909
138	        expected_delta = config.k_friendly * 1.0 * (1.0 - expected_we)
139	        assert result.final_ratings["TeamA"] == pytest.approx(
140	            config.initial_rating + expected_delta, rel=1e-5
141	        )
