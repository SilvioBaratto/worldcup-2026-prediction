2	
3	Consumes the DataFrame produced by ``Martj42Loader.load_results()``.  The module
4	is I/O-free and network-free so tests can build DataFrames in-memory.
5	
6	Design notes
7	------------
8	* ``elo_diff`` in ``MatchEloDiff`` is ``home_elo − away_elo`` without the
9	  ``home_advantage`` term so the emitted covariate is venue-agnostic.
10	* Rows are sorted by ``(date, HOME_TEAM, AWAY_TEAM, HOME_GOALS, AWAY_GOALS)``
11	  giving a total content-based order.  Rows that are equal on all five keys are
12	  truly identical matches; swapping them does not change any rating.  ``NaT``
13	  dates and ``NA`` goals sort last by pandas convention.
14	"""
15	
16	from __future__ import annotations
17	
18	import logging
19	from dataclasses import dataclass
20	from typing import Iterable
21	
22	import pandas as pd
23	
24	from worldcup_playoff.config import EloConfig
25	
26	logger = logging.getLogger(__name__)
27	
28	# ---------------------------------------------------------------------------
29	# Value objects
30	# ---------------------------------------------------------------------------
31	
32	_SORT_COLS = ["_d", "HOME_TEAM", "AWAY_TEAM", "HOME_GOALS", "AWAY_GOALS"]
33	
34	
35	@dataclass(frozen=True)
36	class EloRating:
37	    """Per-team, per-date Elo snapshot (post-match)."""
38	
39	    team: str
40	    date: str
41	    rating: float
42	
43	
44	@dataclass(frozen=True)
45	class MatchEloDiff:
46	    """Pre-match Elo state for a single fixture.
47	
48	    ``elo_diff = home_elo − away_elo`` is venue-agnostic (excludes home_advantage).
49	    """
50	
51	    date: str
52	    home_team: str
53	    away_team: str
54	    home_elo: float
55	    away_elo: float
56	    elo_diff: float
57	    neutral: bool
58	
59	
60	@dataclass(frozen=True)
61	class EloResult:
62	    """Outcome of ``EloEngine.run``.
63	
64	    Attributes
65	    ----------
66	    history:       Ordered per-team, per-date snapshots.
67	    match_diffs:   One entry per input row (incl. unplayed fixtures).
68	    final_ratings: Latest rating for every team that appeared.
69	    initial_rating: Default start rating — used by ``seed_wc2026`` for absent teams.
70	    """
71	
72	    history: list[EloRating]
73	    match_diffs: list[MatchEloDiff]
74	    final_ratings: dict[str, float]
75	    initial_rating: float
76	
77	    def history_frame(self) -> pd.DataFrame:
78	        """Return history as a tidy DataFrame (team / date / rating)."""
79	        if not self.history:
80	            return pd.DataFrame(columns=["team", "date", "rating"])
81	        return pd.DataFrame(
82	            [{"team": r.team, "date": r.date, "rating": r.rating} for r in self.history]
83	        )
84	
85	    def latest_ratings_frame(self) -> pd.DataFrame:
86	        """Return final_ratings as a tidy DataFrame (team / rating)."""
87	        if not self.final_ratings:
88	            return pd.DataFrame(columns=["team", "rating"])
89	        return pd.DataFrame(
90	            [{"team": t, "rating": r} for t, r in self.final_ratings.items()]
91	        )
92	
93	
94	# ---------------------------------------------------------------------------
95	# Module-level pure math helpers
96	# ---------------------------------------------------------------------------
97	
98	
99	def _we(dr: float) -> float:
100	    """Win expectation from Elo rating difference *dr*."""
101	    return 1.0 / (1.0 + 10.0 ** (-dr / 400.0))
102	
103	
104	def _g(margin: int) -> float:
105	    """Goal-margin multiplier (World-Football-Elo convention)."""
106	    if margin <= 1:
107	        return 1.0
108	    if margin == 2:
109	        return 1.5
110	    return (11 + margin) / 8.0
111	
112	
113	def _outcome(home_goals: int, away_goals: int) -> float:
114	    """W value: 1.0 home win / 0.5 draw / 0.0 home loss."""
115	    if home_goals > away_goals:
116	        return 1.0
117	    return 0.5 if home_goals == away_goals else 0.0
118	
119	
120	# ---------------------------------------------------------------------------
121	# Engine
122	# ---------------------------------------------------------------------------
123	
124	
125	class EloEngine:
126	    """Compute World Football Elo ratings chronologically from a martj42 DataFrame."""
127	
128	    def __init__(self, config: EloConfig) -> None:
129	        self._config = config
130	
131	    def run(self, df: pd.DataFrame) -> EloResult:
132	        """Process *df* and return per-team ratings + per-match diffs."""
133	        ratings: dict[str, float] = {}
134	        history: list[EloRating] = []
135	        diffs: list[MatchEloDiff] = []
136	        for _, row in self._sort(df).iterrows():
137	            self._process(row, ratings, history, diffs)
138	        return EloResult(
139	            history=history,
140	            match_diffs=diffs,
141	            final_ratings={t: float(r) for t, r in ratings.items()},
142	            initial_rating=self._config.initial_rating,
143	        )
144	
145	    def _sort(self, df: pd.DataFrame) -> pd.DataFrame:
146	        return (
147	            df.assign(_d=pd.to_datetime(df["DATE"], errors="coerce"))
148	            .sort_values(_SORT_COLS, kind="stable", na_position="last")
149	            .drop(columns=["_d"])
150	            .reset_index(drop=True)
151	        )
152	
153	    def _process(self, row: pd.Series, ratings: dict, history: list, diffs: list) -> None:
154	        home, away = str(row["HOME_TEAM"]), str(row["AWAY_TEAM"])
155	        date, neutral = str(row["DATE"]), bool(row["NEUTRAL"])
156	        h_elo = ratings.get(home, self._config.initial_rating)
157	        a_elo = ratings.get(away, self._config.initial_rating)
158	        diffs.append(MatchEloDiff(date, home, away, h_elo, a_elo, h_elo - a_elo, neutral))
159	        if pd.isna(row["HOME_GOALS"]) or pd.isna(row["AWAY_GOALS"]):
160	            ratings.setdefault(home, self._config.initial_rating)
161	            ratings.setdefault(away, self._config.initial_rating)
162	            history += [EloRating(home, date, ratings[home]),
163	                        EloRating(away, date, ratings[away])]
164	            return
165	        new_h, new_a = self._update(
166	            h_elo, a_elo, int(row["HOME_GOALS"]), int(row["AWAY_GOALS"]),
167	            neutral, str(row["TOURNAMENT"]),
168	        )
169	        ratings[home], ratings[away] = new_h, new_a
170	        history += [EloRating(home, date, new_h), EloRating(away, date, new_a)]
171	
172	    def _update(
173	        self,
174	        h_elo: float, a_elo: float,
175	        hg: int, ag: int,
176	        neutral: bool, tournament: str,
177	    ) -> tuple[float, float]:
178	        home_adv = 0.0 if neutral else self._config.home_advantage
179	        we = _we(h_elo - a_elo + home_adv)
180	        delta = self._k(tournament) * _g(abs(hg - ag)) * (_outcome(hg, ag) - we)
181	        return h_elo + delta, a_elo - delta
182	
183	    def _k(self, tournament: str) -> int:
184	        """K factor: qualifier checked before world_cup for correct precedence."""
185	        t, c = tournament.lower(), self._config
186	        if any(kw.lower() in t for kw in c.qualifier_keywords):
187	            return c.k_qualifier
188	        if any(kw.lower() in t for kw in c.continental_keywords):
189	            return c.k_continental
190	        if any(kw.lower() in t for kw in c.world_cup_keywords):
191	            return c.k_world_cup
192	        return c.k_friendly
193	
194	
195	# ---------------------------------------------------------------------------
196	# Module-level API
197	# ---------------------------------------------------------------------------
198	
199	
200	def seed_wc2026(result: EloResult, teams: Iterable[str]) -> dict[str, float]:
201	    """Return each team's latest Elo, defaulting to *result.initial_rating* if absent.
202	
203	    Pass team names explicitly so this function stays decoupled from any HTTP
204	    client or live-data adapter.
205	    """
206	    return {
207	        team: result.final_ratings.get(team, result.initial_rating)
208	        for team in teams
209	    }
210	
211	
212	def compute_elo(df: pd.DataFrame, config: EloConfig | None = None) -> EloResult:
213	    """Factory: run the Elo engine with *config* (uses defaults when ``None``)."""
214	    return EloEngine(config or EloConfig()).run(df)
