65	            "HOME_TEAM": ["Alpha", "Beta"],
66	            "AWAY_TEAM": ["Beta", "Gamma"],
67	            "HOME_GOALS": pd.array([pd.NA, pd.NA], dtype="Int64"),
68	            "AWAY_GOALS": pd.array([pd.NA, pd.NA], dtype="Int64"),
69	        }
70	    )
71	    return pd.concat([played, na_rows], ignore_index=True)
