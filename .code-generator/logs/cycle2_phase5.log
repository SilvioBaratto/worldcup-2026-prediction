198	# ─────────────────────────────────────────────────────────────────────────────
199	# 3. Time-decay weights
200	#    Criterion: reference date → 1.0; half_life_days old → 0.5;
201	#    2×half_life old → 0.25 (all pytest.approx).
202	#    Assumption: module exposes decay_weight(age_days, half_life_days) -> float.
203	# ─────────────────────────────────────────────────────────────────────────────
204	
205	class TestTimeDecayWeight:
206	    HALF_LIFE = 180.0
207	
208	    def test_when_age_is_zero_days_then_weight_is_one(self):
209	        assert decay_weight(0.0, self.HALF_LIFE) == pytest.approx(1.0)
210	
211	    def test_when_age_is_one_half_life_then_weight_is_half(self):
212	        assert decay_weight(self.HALF_LIFE, self.HALF_LIFE) == pytest.approx(0.5)
213	
214	    def test_when_age_is_two_half_lives_then_weight_is_quarter(self):
215	        assert decay_weight(2.0 * self.HALF_LIFE, self.HALF_LIFE) == pytest.approx(0.25)
216	
217	    @given(
218	        st.floats(min_value=0.0, max_value=3650.0, allow_nan=False, allow_infinity=False),
219	        st.floats(min_value=1.0, max_value=730.0, allow_nan=False, allow_infinity=False),
220	    )
221	    def test_when_age_grows_by_one_day_then_weight_is_non_increasing(self, age, half_life):
222	        """Property: exponential decay is monotonically non-increasing in age."""
223	        w_now = decay_weight(age, half_life)
224	        w_older = decay_weight(age + 1.0, half_life)
225	        assert w_older <= w_now + 1e-12
