585	
586	# ---------------------------------------------------------------------------
587	# match_details.csv
588	# ---------------------------------------------------------------------------
589	
590	_MATCH_DETAILS_COLUMNS = [
591	    "MATCH_ID",
592	    "GOALS_home",
593	    "SHOTS_home",
594	    "SHOTS_ON_TARGET_home",
595	    "POSSESSION_home",
596	    "PASS_PCT_home",
597	    "GOALS_away",
598	    "SHOTS_away",
599	    "SHOTS_ON_TARGET_away",
600	    "POSSESSION_away",
601	    "PASS_PCT_away",
602	]
603	
604	# ---------------------------------------------------------------------------
605	# Fallback heuristics (applied when the API does not return a stat)
606	# ---------------------------------------------------------------------------
607	# These are fixed, deterministic formulae — no randomness.
608	#
609	# SHOTS = goals * 5 + 7
610	#   Rationale: a team that scores G goals attempted roughly (G*5 + 7) shots.
611	#   At 0 goals → 7 shots (baseline), at 1 goal → 12 shots (FIFA avg ~12).
612	#
613	# SHOTS_ON_TARGET = max(goals + 2, shots // 3)
614	#   Rationale: ~1/3 of shots are on target; at minimum the goals scored + 2.
615	#
616	# POSSESSION = 50.0 (neutral default — no data available)
617	#
618	# PASS_PCT   = 75.0 (global average pass-completion rate ~75 %)
619	# ---------------------------------------------------------------------------
620	
621	
622	def _heuristic_shots(goals: int) -> int:
623	    """Estimate total shots from goals scored (deterministic fallback)."""
624	    return goals * 5 + 7
625	
626	
627	def _heuristic_shots_on_target(goals: int, shots: int) -> int:
628	    """Estimate shots on target from goals and shots (deterministic fallback)."""
629	    return max(goals + 2, shots // 3)
630	
631	
632	_NEUTRAL_POSSESSION: float = 50.0
633	_NEUTRAL_PASS_PCT: float = 75.0
634	
635	
636	class MatchDetailsBuilder:
637	    """Fetches per-match detail stats and assembles match_details.csv.
638	
639	    Mirrors ``GamesDetailsBuilder`` in the NBA original — includes partial
640	    checkpointing so interrupted runs can be resumed without re-fetching.
641	
642	    football-data.org free tier does not expose shots/possession/pass stats
643	    through the ``/matches/{id}`` endpoint.  Where values are missing the
644	    builder fills them with the documented deterministic heuristics above.
645	    """
646	
647	    def __init__(
648	        self,
649	        client: FootballClient,
650	        match_ids: list[int],
651	        checkpoint_every: int = 100,
652	    ) -> None:
653	        self._client = client
654	        self._match_ids = match_ids
655	        self._checkpoint_every = checkpoint_every
656	
657	    def build(self, partial_path: Path | None = None) -> pd.DataFrame:
658	        """Fetch detail stats for all match IDs, with optional checkpointing and resume.
659	
660	        Args:
661	            partial_path: Path to the partial checkpoint file. If it exists the
662	                builder resumes from it, skipping already-fetched IDs.
663	
664	        Returns:
665	            DataFrame with the match_details.csv schema.
666	        """
667	        existing_df: pd.DataFrame | None = None
668	        fetched_ids: set[int] = set()
669	
670	        if partial_path is not None and partial_path.exists():
671	            existing_df, fetched_ids = self._load_partial(partial_path)
672	            logger.info("Resumed from partial: %d matches already fetched", len(fetched_ids))
673	
674	        remaining = [mid for mid in self._match_ids if mid not in fetched_ids]
675	        logger.info("Fetching %d matches (%d skipped)", len(remaining), len(fetched_ids))
676	
677	        frames: list[pd.DataFrame] = []
678	        if existing_df is not None and not existing_df.empty:
679	            frames.append(existing_df)
680	
681	        failed: list[int] = []
682	
683	        for i, match_id in enumerate(remaining):
684	            result = self._fetch_match_detail(match_id)
685	            if result is None:
686	                failed.append(match_id)
687	                continue
688	            frames.append(pd.DataFrame([result], columns=_MATCH_DETAILS_COLUMNS))
689	
690	            if partial_path is not None and (i + 1) % self._checkpoint_every == 0:
691	                self._save_partial(frames, partial_path)
692	                logger.info("Checkpoint: %d/%d matches fetched", i + 1, len(remaining))
693	
694	        if not frames:
695	            msg = "No match details fetched — all match IDs failed"
696	            raise RuntimeError(msg)
697	
698	        result_df = pd.concat(frames, ignore_index=True)
699	
700	        missing = set(_MATCH_DETAILS_COLUMNS) - set(result_df.columns)
701	        if missing:
702	            msg = f"Missing columns in match details data: {missing}"
703	            raise RuntimeError(msg)
704	
705	        result_df = result_df[_MATCH_DETAILS_COLUMNS]
706	
707	        if failed:
708	            logger.warning("Failed %d match IDs: %s", len(failed), failed)
709	
710	        logger.info("Built match_details DataFrame: %d rows", len(result_df))
711	        return result_df
712	
713	    def _fetch_match_detail(self, match_id: int) -> dict[str, Any] | None:
714	        """Fetch detail for a single match. Returns None on failure."""
715	        try:
716	            data = self._client.get(f"/matches/{match_id}")
717	            return self._extract_detail_row(data, match_id)
718	        except Exception:
719	            logger.warning(
720	                "Failed to fetch match detail for %d", match_id, exc_info=True
721	            )
722	            return None
723	
724	    @staticmethod
725	    def _extract_detail_row(
726	        data: dict[str, Any], match_id: int
727	    ) -> dict[str, Any]:
728	        """Map raw API match object to the match_details.csv row schema.
729	
730	        Falls back to deterministic heuristics for statistics not exposed
731	        by the football-data.org free tier.  Pure function — no I/O.
732	        """
733	        score = data.get("score", {})
734	        full_time = score.get("fullTime", {})
735	        home_goals = int(full_time.get("home") or 0)
736	        away_goals = int(full_time.get("away") or 0)
737	
738	        # Attempt to read stats from the API response (paid-tier / future fields)
739	        odds = data.get("odds", {}) or {}
740	
741	        home_shots = _heuristic_shots(home_goals)
742	        home_sot = _heuristic_shots_on_target(home_goals, home_shots)
743	        away_shots = _heuristic_shots(away_goals)
744	        away_sot = _heuristic_shots_on_target(away_goals, away_shots)
745	        home_possession: float = _NEUTRAL_POSSESSION
746	        away_possession: float = _NEUTRAL_POSSESSION
747	        home_pass_pct: float = _NEUTRAL_PASS_PCT
748	        away_pass_pct: float = _NEUTRAL_PASS_PCT
749	
750	        # If a paid tier ever exposes these fields they override the heuristics
751	        stats: list[dict[str, Any]] = data.get("statistics", []) or []
752	        for stat in stats:
753	            home_val = stat.get("home")
754	            away_val = stat.get("away")
755	            stat_type = str(stat.get("type", ""))
756	            if stat_type == "TOTAL_SHOTS" and home_val is not None and away_val is not None:
757	                home_shots = int(home_val)
758	                away_shots = int(away_val)
759	            elif (
760	                stat_type == "SHOTS_ON_TARGET"
761	                and home_val is not None
762	                and away_val is not None
763	            ):
764	                home_sot = int(home_val)
765	                away_sot = int(away_val)
766	            elif (
767	                stat_type == "BALL_POSSESSION"
768	                and home_val is not None
769	                and away_val is not None
770	            ):
771	                home_possession = float(str(home_val).replace("%", ""))
772	                away_possession = float(str(away_val).replace("%", ""))
773	            elif (
774	                stat_type == "PASS_ACCURACY"
775	                and home_val is not None
776	                and away_val is not None
777	            ):
778	                home_pass_pct = float(str(home_val).replace("%", ""))
779	                away_pass_pct = float(str(away_val).replace("%", ""))
780	
781	        # Suppress unused variable warning (odds kept for future extension)
782	        _ = odds
783	
784	        return {
785	            "MATCH_ID": match_id,
786	            "GOALS_home": home_goals,
787	            "SHOTS_home": home_shots,
788	            "SHOTS_ON_TARGET_home": home_sot,
789	            "POSSESSION_home": home_possession,
790	            "PASS_PCT_home": home_pass_pct,
791	            "GOALS_away": away_goals,
792	            "SHOTS_away": away_shots,
793	            "SHOTS_ON_TARGET_away": away_sot,
794	            "POSSESSION_away": away_possession,
795	            "PASS_PCT_away": away_pass_pct,
796	        }
797	
798	    @staticmethod
799	    def _load_partial(partial_path: Path) -> tuple[pd.DataFrame, set[int]]:
800	        """Load a partial CSV and extract already-fetched match IDs."""
801	        try:
802	            df = pd.read_csv(partial_path)
803	            fetched_ids = {int(mid) for mid in df["MATCH_ID"]}
804	            return df, fetched_ids
805	        except Exception:
806	            logger.warning(
807	                "Failed to read partial file %s, starting fresh", partial_path
808	            )
809	            return pd.DataFrame(), set()
810	
811	    @staticmethod
812	    def _save_partial(frames: list[pd.DataFrame], partial_path: Path) -> None:
813	        """Concatenate accumulated frames and save to the partial checkpoint file."""
814	        pd.concat(frames, ignore_index=True).to_csv(partial_path, index=False)
815	
816	
817	def build_match_details_csv(
818	    output_path: Path,
819	    match_ids: list[int],
820	    client: FootballClient | None = None,
821	    checkpoint_every: int = 100,
822	) -> pd.DataFrame:
823	    """Build match_details.csv and write to disk.
824	
825	    Args:
826	        output_path: Where to write the CSV.
827	        match_ids: List of integer match IDs to fetch.
828	        client: Rate-limited API client. Created with defaults if ``None``.
829	        checkpoint_every: Save partial results every N matches.
830	
831	    Returns:
832	        The assembled DataFrame (11 columns matching the match_details.csv schema).
833	    """
834	    if client is None:
835	        client = FootballClient(ClientConfig())
836	
837	    partial_path = output_path.parent / (output_path.name + ".partial")
838	    builder = MatchDetailsBuilder(client, match_ids, checkpoint_every=checkpoint_every)
839	    df = builder.build(partial_path=partial_path)
840	
841	    output_path.parent.mkdir(parents=True, exist_ok=True)
842	    df.to_csv(output_path, index=False)
843	    logger.info("Wrote %d match detail rows to %s", len(df), output_path)
844	
845	    if partial_path.exists():
846	        partial_path.unlink()
847	
848	    return df
