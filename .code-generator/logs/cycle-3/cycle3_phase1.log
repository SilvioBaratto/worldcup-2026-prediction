559	def build_players_csv(
560	    output_path: Path,
561	    client: FootballClient | None = None,
562	    competition: str = "WC",
563	) -> pd.DataFrame:
564	    """Build players.csv and write to disk.
565	
566	    Args:
567	        output_path: Where to write the CSV.
568	        client: Rate-limited API client. Created with defaults if ``None``.
569	        competition: Competition code (e.g. ``"WC"``).
570	
