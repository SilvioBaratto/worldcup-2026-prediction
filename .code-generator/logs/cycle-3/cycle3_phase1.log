164	
165	class MatchesBuilder:
166	    """Fetches match results per competition per season and assembles matches.csv.
167	
168	    Mirrors ``GamesBuilder`` in the NBA original.
169	    """
170	
171	    def __init__(
172	        self,
173	        client: FootballClient,
174	        start_year: int = 2006,
175	        end_year: int | None = None,
176	        competition_codes: list[str] | None = None,
177	    ) -> None:
178	        self._client = client
179	        self._start_year = start_year
180	        self._end_year = end_year if end_year is not None else datetime.date.today().year
181	        self._competition_codes = competition_codes or _MATCH_COMPETITION_CODES
182	
183	    def build(self) -> pd.DataFrame:
184	        """Fetch all competitions × seasons, returning the matches DataFrame."""
185	        frames: list[pd.DataFrame] = []
186	
187	        for code in self._competition_codes:
188	            for year in range(self._start_year, self._end_year + 1):
189	                df = self._fetch_season(code, year)
190	                if df is not None:
191	                    frames.append(df)
192	
193	        if not frames:
194	            msg = "All match fetches failed — no data to build matches.csv"
195	            raise RuntimeError(msg)
196	
197	        result = pd.concat(frames, ignore_index=True)
198	
199	        # Remove duplicate match IDs (same match may appear under multiple codes)
200	        result = result.drop_duplicates(subset=["MATCH_ID"]).reset_index(drop=True)
201	
202	        missing = set(_MATCHES_COLUMNS) - set(result.columns)
203	        if missing:
204	            msg = f"Missing columns after assembly: {missing}"
205	            raise RuntimeError(msg)
206	
207	        logger.info(
208	            "Built matches DataFrame: %d rows across %d competition-season combos",
209	            len(result),
210	            len(frames),
211	        )
212	        return result
213	
214	    def _fetch_season(self, code: str, year: int) -> pd.DataFrame | None:
215	        """Fetch all finished matches for one competition-season. Returns None on failure."""
216	        try:
217	            data = self._client.get(
218	                f"/competitions/{code}/matches",
219	                params={"season": str(year), "status": "FINISHED"},
220	            )
221	            matches: list[dict[str, Any]] = data.get("matches", [])
222	            if not matches:
223	                return None
224	            rows = [self._extract_match_row(m, code, year) for m in matches]
225	            # Drop rows where team names could not be resolved
226	            valid = [r for r in rows if r is not None]
227	            if not valid:
228	                return None
229	            df = pd.DataFrame(valid, columns=_MATCHES_COLUMNS)
230	            logger.info(
231	                "Fetched %d matches for %s/%d", len(df), code, year
232	            )
233	            return df
234	        except Exception:
235	            logger.warning(
236	                "Failed to fetch matches for %s/%d", code, year, exc_info=True
237	            )
238	            return None
239	
240	    @staticmethod
241	    def _extract_match_row(
242	        match: dict[str, Any],
243	        code: str,
244	        year: int,
245	    ) -> dict[str, Any] | None:
246	        """Map a single API match object to the matches.csv row schema.
247	
248	        Pure transformation — no I/O.
249	        """
250	        try:
251	            home_team = (
252	                match.get("homeTeam", {}).get("name", "")
253	                or match.get("homeTeam", {}).get("shortName", "")
254	            )
255	            away_team = (
256	                match.get("awayTeam", {}).get("name", "")
257	                or match.get("awayTeam", {}).get("shortName", "")
258	            )
259	            if not home_team or not away_team:
260	                return None
261	
262	            score = match.get("score", {})
263	            full_time = score.get("fullTime", {})
264	            home_goals = full_time.get("home")
265	            away_goals = full_time.get("away")
266	            if home_goals is None or away_goals is None:
267	                return None
268	
269	            utc_date = str(match.get("utcDate", ""))
270	            date_str = utc_date[:10] if utc_date else ""  # "YYYY-MM-DD"
271	
272	            return {
273	                "MATCH_ID": int(match.get("id", 0)),
274	                "DATE": date_str,
275	                "HOME_TEAM": str(home_team),
276	                "AWAY_TEAM": str(away_team),
277	                "HOME_GOALS": int(home_goals),
278	                "AWAY_GOALS": int(away_goals),
279	                "COMPETITION": code,
280	                "SEASON": year,
281	            }
282	        except Exception:
283	            logger.debug("Skipping malformed match record: %s", match, exc_info=True)
284	            return None
285	
286	
287	def build_matches_csv(
288	    output_path: Path,
289	    client: FootballClient | None = None,
290	    start_year: int = 2006,
291	    end_year: int | None = None,
292	) -> pd.DataFrame:
293	    """Build matches.csv and write to disk.
294	
295	    Args:
296	        output_path: Where to write the CSV.
297	        client: Rate-limited API client. Created with defaults if ``None``.
298	        start_year: First season year to query (e.g. 2006).
299	        end_year: Last season year to query. Defaults to the current year.
300	
301	    Returns:
302	        The assembled DataFrame (8 columns matching the matches.csv schema).
303	    """
304	    if client is None:
305	        client = FootballClient(ClientConfig())
306	
307	    builder = MatchesBuilder(client, start_year=start_year, end_year=end_year)
308	    df = builder.build()
309	
310	    output_path.parent.mkdir(parents=True, exist_ok=True)
311	    df.to_csv(output_path, index=False)
312	    logger.info("Wrote %d matches to %s", len(df), output_path)
313	    return df
