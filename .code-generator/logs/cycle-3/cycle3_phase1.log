50	# teams.csv
51	# ---------------------------------------------------------------------------
52	
53	_TEAMS_COLUMNS = [
54	    "TEAM_ID",
55	    "NAME",
56	    "SHORT_NAME",
57	    "TLA",
58	    "COUNTRY",
59	    "COMPETITION",
60	]
