28	@dataclass(frozen=True)
29	class FittedDistribution:
30	    """Immutable record of a single fitted statistical distribution."""
31	
32	    name: str
33	    params: tuple[float, ...]
34	
35	
36	# Maps distribution names to scipy random variate samplers.
37	# Mirrors the SCIPY_GENERATORS dict in the NBA original.
38	SCIPY_GENERATORS: dict[str, Callable[..., Any]] = {
39	    "alpha": stats.alpha.rvs,
40	    "beta": stats.beta.rvs,
41	    "chi": stats.chi.rvs,
42	    "cosine": stats.cosine.rvs,
43	    "dgamma": stats.dgamma.rvs,
44	    "dweibull": stats.dweibull.rvs,
45	    "f": stats.f.rvs,
46	    "fisk": stats.fisk.rvs,
47	    "gamma": stats.gamma.rvs,
48	    "maxwell": stats.maxwell.rvs,
49	    "norm": stats.norm.rvs,
50	    "pareto": stats.pareto.rvs,
51	    "t": stats.t.rvs,
