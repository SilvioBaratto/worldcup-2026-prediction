149	_MATCHES_COLUMNS = [
150	    "MATCH_ID",
151	    "DATE",
152	    "HOME_TEAM",
153	    "AWAY_TEAM",
154	    "HOME_GOALS",
155	    "AWAY_GOALS",
156	    "COMPETITION",
157	    "SEASON",
158	]
159	
160	# Competition codes iterated when building the historical matches dataset.
161	# These are the main international tournaments available on football-data.org v4.
162	_MATCH_COMPETITION_CODES = ["WC", "EC", "CA", "CL", "PL", "BL1", "SA", "PD", "FL1"]
