25	def _make_df(rows: list[dict]) -> pd.DataFrame:
26	    """Return a DataFrame matching the martj42 results schema."""
27	    if not rows:
28	        return pd.DataFrame(
29	            columns=[
30	                "DATE",
31	                "HOME_TEAM",
32	                "AWAY_TEAM",
33	                "HOME_GOALS",
34	                "AWAY_GOALS",
35	                "TOURNAMENT",
36	                "NEUTRAL",
37	            ]
38	        )
39	    df = pd.DataFrame(rows)
40	    for col in ("HOME_GOALS", "AWAY_GOALS"):
41	        if col in df.columns:
42	            df[col] = df[col].astype("Int64")
43	    if "NEUTRAL" not in df.columns:
44	        df["NEUTRAL"] = False
45	    return df
