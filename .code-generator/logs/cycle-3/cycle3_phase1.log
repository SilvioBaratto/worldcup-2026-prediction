476	
477	class PlayersBuilder:
478	    """Fetches squad rosters for a competition and assembles players.csv.
479	
480	    Mirrors ``PlayersBuilder`` in the NBA original.
481	    """
482	
483	    def __init__(self, client: FootballClient, competition: str = "WC") -> None:
484	        self._client = client
485	        self._competition = competition
486	
487	    def build(self) -> pd.DataFrame:
488	        """Fetch teams for the competition, then squads for each team."""
489	        teams = self._fetch_teams()
490	        if not teams:
491	            msg = f"No teams found for competition {self._competition}"
492	            raise RuntimeError(msg)
493	
494	        rows: list[dict[str, Any]] = []
495	        for team in teams:
496	            team_id = int(team.get("id", 0))
497	            squad = self._fetch_squad(team_id)
498	            for player in squad:
499	                row = self._extract_player_row(player)
500	                if row is not None:
501	                    rows.append(row)
502	
503	        if not rows:
504	            msg = "No player data fetched"
505	            raise RuntimeError(msg)
506	
507	        result = pd.DataFrame(rows, columns=_PLAYERS_COLUMNS)
508	
509	        missing = set(_PLAYERS_COLUMNS) - set(result.columns)
510	        if missing:
511	            msg = f"Missing columns after transformation: {missing}"
512	            raise RuntimeError(msg)
513	
514	        logger.info(
515	            "Built players DataFrame: %d rows for competition %s",
516	            len(result),
517	            self._competition,
518	        )
519	        return result
520	
521	    def _fetch_teams(self) -> list[dict[str, Any]]:
522	        """Fetch team list for this competition. Failure is fatal."""
523	        data = self._client.get(f"/competitions/{self._competition}/teams")
524	        teams: list[dict[str, Any]] = data.get("teams", [])
525	        logger.info(
526	            "Fetched %d teams for competition %s", len(teams), self._competition
527	        )
528	        return teams
529	
530	    def _fetch_squad(self, team_id: int) -> list[dict[str, Any]]:
531	        """Fetch squad for a single team. Returns empty list on failure."""
532	        try:
533	            data = self._client.get(f"/teams/{team_id}")
534	            squad: list[dict[str, Any]] = data.get("squad", [])
535	            return squad
536	        except Exception:
537	            logger.warning("Failed to fetch squad for team %d", team_id, exc_info=True)
538	            return []
539	
540	    def _extract_player_row(
541	        self, player: dict[str, Any]
542	    ) -> dict[str, Any] | None:
543	        """Map a single squad member to the players.csv row schema. Pure function."""
544	        try:
545	            name = player.get("name", "")
546	            if not name:
547	                return None
548	            return {
549	                "PLAYER_NAME": str(name),
550	                "PLAYER_ID": int(player.get("id", 0)),                "NATIONALITY": str(player.get("nationality", "")),
551	                "POSITION": str(player.get("position", "")),
552	                "COMPETITION": self._competition,
553	            }
554	        except Exception:
555	            logger.debug("Skipping malformed player record: %s", player, exc_info=True)
556	            return None
