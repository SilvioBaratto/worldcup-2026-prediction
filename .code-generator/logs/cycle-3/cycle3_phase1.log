85	
86	
87	class TournamentState(BaseModel):
88	    """Snapshot of the WC2026 tournament as of today."""
89	
90	    model_config = ConfigDict(extra="ignore")
91	
92	    played: list[LiveMatch]
93	    remaining_group_fixtures: list[LiveMatch]
94	    standings: list[GroupStanding]
95	
96	
97	class LiveTournamentAdapter:
98	    """Fetches live WC2026 data and assembles a TournamentState."""
99	
100	    def __init__(self, client: FootballClient, competition: str = "WC") -> None:
101	        self._client = client
102	        self._competition = competition
103	
104	    def fetch_matches(self) -> list[LiveMatch]:
105	        data = self._client.get(f"/competitions/{self._competition}/matches")
106	        return [self._parse_match(m) for m in data.get("matches", [])]
107	
108	    def fetch_standings(self) -> list[GroupStanding]:
109	        data = self._client.get(f"/competitions/{self._competition}/standings")
110	        return [GroupStanding.model_validate(s) for s in data.get("standings", [])]
111	
112	    def tournament_state(self) -> TournamentState:
113	        matches = self.fetch_matches()
114	        standings = self.fetch_standings()
115	        played, remaining = self._split_played_remaining(matches)
116	        return TournamentState(
117	            played=played, remaining_group_fixtures=remaining, standings=standings
118	        )
119	
120	    def _parse_match(self, raw: dict[str, Any]) -> LiveMatch:
121	        return LiveMatch.model_validate(raw)
122	
123	    def _split_played_remaining(
124	        self, matches: list[LiveMatch]
125	    ) -> tuple[list[LiveMatch], list[LiveMatch]]:
126	        group_stage = [m for m in matches if m.stage == "GROUP_STAGE"]
127	        played = [m for m in group_stage if m.status == _FINISHED_STATUS]
128	        remaining = [m for m in group_stage if m.status != _FINISHED_STATUS]
129	        return played, remaining
130	
131	
132	def fetch_tournament_state(
133	    client: FootballClient | None = None,
134	    competition: str = "WC",
135	) -> TournamentState:
136	    """Build a TournamentState, creating a default FootballClient when none is passed."""
137	    if client is None:
138	        client = FootballClient()
139	    return LiveTournamentAdapter(client, competition=competition).tournament_state()
140	
