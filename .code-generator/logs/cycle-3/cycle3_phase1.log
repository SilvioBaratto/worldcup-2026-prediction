24	
25	def _make_df(rows: list[dict]) -> pd.DataFrame:
26	    """Return a DataFrame matching the martj42 results schema."""
27	    if not rows:
28	        return pd.DataFrame(
29	            columns=[
30	                "DATE",
31	                "HOME_TEAM",
32	                "AWAY_TEAM",
33	                "HOME_GOALS",
34	                "AWAY_GOALS",
35	                "TOURNAMENT",
36	                "NEUTRAL",
37	            ]
38	        )
39	    df = pd.DataFrame(rows)
40	    for col in ("HOME_GOALS", "AWAY_GOALS"):
41	        if col in df.columns:
42	            df[col] = df[col].astype("Int64")
43	    if "NEUTRAL" not in df.columns:
44	        df["NEUTRAL"] = False
45	    return df
46	
47	
48	def _one_match(
49	    *,
50	    home: str = "TeamA",
51	    away: str = "TeamB",
52	    home_goals: int | None = 1,
53	    away_goals: int | None = 0,
54	    date: str = "2020-06-01",
55	    tournament: str = "Friendly",
56	    neutral: bool = True,
57	) -> pd.DataFrame:
58	    return _make_df(
59	        [
60	            {
61	                "DATE": date,
62	                "HOME_TEAM": home,
63	                "AWAY_TEAM": away,
64	                "HOME_GOALS": home_goals,
65	                "AWAY_GOALS": away_goals,
66	                "TOURNAMENT": tournament,
67	                "NEUTRAL": neutral,
68	            }
69	        ]
70	    )
71	
72	
73	def _gain_for_tournament(tournament: str, neutral: bool = True) -> float:
74	    """Return TeamA's rating gain from a 1-0 home win with the given tournament string."""
75	    config = EloConfig()
76	    result = EloEngine(config).run(
77	        _one_match(home_goals=1, away_goals=0, neutral=neutral, tournament=tournament)
78	    )
79	    return result.final_ratings["TeamA"] - config.initial_rating
80	
81	
