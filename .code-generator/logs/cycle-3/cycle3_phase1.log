55	class DistributionFitter:
56	    """Fits statistical distributions to per-team football match data.
57	
58	    Unlike the NBA fitter (which pivots on ``HOME_TEAM_ID`` / ``VISITOR_TEAM_ID``
59	    and a ``SEASON`` column), this class reads from the football train_data.csv
60	    schema:
61	
62	    - Column names for home perspective: ``GOALS_home``, ``SHOTS_home``, …
63	    - Column names for away perspective: ``GOALS_away``, ``SHOTS_away``, …
64	    - Team identification columns: ``HOME_TEAM``, ``AWAY_TEAM``
65	    - No ``SEASON`` column — ``DistributionConfig.min_season`` is interpreted as
66	      the minimum calendar year extracted from an optional ``DATE`` column.  When
67	      no ``DATE`` column exists all rows are used.
68	
69	    For each team ``T`` and each of the five base statistics the fitter gathers:
70	
71	    - The ``*_home`` column values from rows where ``HOME_TEAM == T``
72	    - The ``*_away`` column values from rows where ``AWAY_TEAM == T``
73	
74	    Both slices are stacked vertically so that the fitted distribution captures
75	    the team's performance regardless of venue.
76	    """
77	
78	    def __init__(
79	        self,
80	        config: DistributionConfig,
81	        features_config: FeaturesConfig,
82	    ) -> None:
83	        self._config = config
84	        self._features = features_config
85	
86	    def fit_all_teams(
87	        self,
88	        df: pd.DataFrame,
89	    ) -> dict[str, list[FittedDistribution]]:
90	        """Fit distributions for each team found in *df*.
91	
92	        Args:
93	            df: DataFrame conforming to the train_data.csv schema.  Must contain
94	                ``HOME_TEAM``, ``AWAY_TEAM``, and the 10 feature columns listed in
95	                ``FeaturesConfig.selected``.  An optional ``DATE`` column (ISO
96	                format) is used to filter by ``DistributionConfig.min_season``.
97	
98	        Returns:
99	            Mapping of ``{team_name: [FittedDistribution per base stat]}``.
100	            The list length equals ``FeaturesConfig.per_team_count`` (5).
101	        """
102	        filtered_df = self._filter_by_season(df)
103	        team_data = self._aggregate_team_data(filtered_df)
104	
105	        result: dict[str, list[FittedDistribution]] = {}
106	        for team_name, data in team_data.items():
107	            logger.info("Fitting distributions for %s", team_name)
108	            result[team_name] = self._fit_team(data)
109	
110	        return result
111	
112	    # ------------------------------------------------------------------
113	    # Private helpers
114	    # ------------------------------------------------------------------
115	
116	    def _filter_by_season(self, df: pd.DataFrame) -> pd.DataFrame:
117	        """Return only rows at or after ``min_season``.
118	
119	        Falls back to the full DataFrame when no ``DATE`` column is present.
120	        """
121	        if "DATE" not in df.columns:
122	            logger.debug(
123	                "No DATE column found; using all %d rows for distribution fitting",
124	                len(df),
125	            )
126	            return df.reset_index(drop=True)
127	
128	        years = pd.to_datetime(df["DATE"], errors="coerce").dt.year
129	        mask = years >= self._config.min_season
130	        filtered = df.loc[mask].reset_index(drop=True)
131	        logger.debug(
132	            "Filtered to %d rows from year >= %d", len(filtered), self._config.min_season
133	        )
134	        return filtered
135	
136	    def _aggregate_team_data(
137	        self,
138	        df: pd.DataFrame,
139	    ) -> dict[str, np.ndarray]:
140	        """Build a per-team observation matrix.
141	
142	        For each unique team, combines:
143	        - Rows where the team was the home side → the five ``*_home`` columns
144	        - Rows where the team was the away side → the five ``*_away`` columns
145	
146	        Returns ``{team_name: ndarray of shape (n_observations, per_team_count)}``.
147	        """
148	        n = self._features.per_team_count
149	        selected = self._features.selected
150	        home_features: list[str] = selected[:n]   # GOALS_home … PASS_PCT_home
151	        away_features: list[str] = selected[n:]   # GOALS_away … PASS_PCT_away
152	
153	        unique_teams: np.ndarray = pd.unique(
154	            pd.concat(
155	                [df["HOME_TEAM"], df["AWAY_TEAM"]]
156	            )
157	        )
158	
159	        team_data: dict[str, np.ndarray] = {}
160	        for team in unique_teams:
161	            # Games played at home — take the _home columns directly.
162	            df_home = df.loc[df["HOME_TEAM"] == team][home_features]
163	
164	            # Games played away — take the _away columns and re-label them so
165	            # both slices share the same column names before stacking.
166	            df_away = df.loc[df["AWAY_TEAM"] == team][away_features].copy()
167	            df_away.columns = home_features
168	
169	            combined = pd.concat([df_home, df_away], axis=0)
170	            team_data[str(team)] = combined.to_numpy()
171	
172	        return team_data
173	
174	    def _fit_team(self, data: np.ndarray) -> list[FittedDistribution]:
175	        """Fit one distribution per base statistic for a single team.
176	
177	        Args:
178	            data: Array of shape ``(n_observations, per_team_count)``.
179	
180	        Returns:
181	            List of ``FittedDistribution`` with length ``per_team_count``.
182	        """
183	        distributions: list[FittedDistribution] = []
184	        n_features = self._features.per_team_count
185	
186	        for i in range(n_features):
187	            f = Fitter(data[:, i])
188	            f.distributions = self._config.candidates
189	            f.fit()
190	            best = f.get_best(method="sumsquare_error")
191	            dist_name = list(best.keys())[0]
192	            raw_params = best[dist_name]
193	            dist_params = (
194	                tuple(raw_params.values())
195	                if isinstance(raw_params, dict)
196	                else tuple(raw_params)
197	            )
198	            distributions.append(
199	                FittedDistribution(
200	                    name=dist_name,
201	                    params=tuple(float(p) for p in dist_params),
202	                )
203	            )
204	
205	        return distributions
206	
207	    @staticmethod
208	    def save(
209	        team_distributions: dict[str, list[FittedDistribution]],
210	        path: Path,
211	    ) -> None:
212	        """Serialize fitted distributions to JSON.
213	
214	        Args:
215	            team_distributions: The mapping returned by ``fit_all_teams``.
216	            path: Destination path; parent directories are created automatically.
217	        """
218	        serializable = {
219	            team: [{"name": d.name, "params": list(d.params)} for d in dists]
220	            for team, dists in team_distributions.items()
221	        }
222	        path.parent.mkdir(parents=True, exist_ok=True)
223	        with open(path, "w") as fh:
224	            json.dump(serializable, fh, indent=2)
225	        logger.info("Distributions saved to %s", path)
226	
227	    @staticmethod
228	    def load(path: Path) -> dict[str, list[FittedDistribution]]:
229	        """Deserialize fitted distributions from JSON.
230	
231	        Args:
232	            path: Path to a JSON file previously produced by ``save``.
233	
234	        Returns:
235	            Mapping of ``{team_name: [FittedDistribution per base stat]}``.
236	        """
237	        with open(path) as fh:
238	            raw = json.load(fh)
239	        return {
240	            team: [
241	                FittedDistribution(name=d["name"], params=tuple(d["params"]))
242	                for d in dists
243	            ]
244	            for team, dists in raw.items()
245	        }
246	
247	
248	class FeatureSampler:
249	    """Assembles synthetic feature vectors from two teams' fitted distributions.
250	
251	    The sampling contract mirrors the NBA ``FeatureSampler`` but is adapted for
252	    the football feature layout.  A World Cup feature vector is ordered exactly
253	    as ``FeaturesConfig.selected``:
254	
255	    ``[GOALS_home, SHOTS_home, SHOTS_ON_TARGET_home, POSSESSION_home, PASS_PCT_home,``
256	    ``GOALS_away, SHOTS_away, SHOTS_ON_TARGET_away, POSSESSION_away, PASS_PCT_away]``
257	
258	    Usage::
259	
260	        sampler = FeatureSampler(features_config)
261	        vector = sampler.assemble(home_dists, away_dists)
262	    """
263	
264	    def __init__(self, features_config: FeaturesConfig) -> None:
265	        self._features = features_config
266	
267	    def assemble(
268	        self,
269	        home_distributions: list[FittedDistribution],
270	        away_distributions: list[FittedDistribution],
271	        random_state: int | None = None,
272	    ) -> np.ndarray:
273	        """Sample one feature vector for a single knockout tie.
274	
275	        Draws one value per base statistic for the home team (first 5 positions)
276	        and one value per base statistic for the away team (last 5 positions),
277	        producing a 1-D array of length ``2 * per_team_count`` (i.e. 10).
278	
279	        Args:
280	            home_distributions: Fitted distributions for the home team, ordered
281	                by base stat index matching ``FeaturesConfig.selected[:per_team_count]``.
282	            away_distributions: Fitted distributions for the away team, ordered
283	                by base stat index matching ``FeaturesConfig.selected[per_team_count:]``.
284	            random_state: Optional seed for reproducible sampling.
285	
286	        Returns:
287	            1-D ``np.ndarray`` of shape ``(10,)`` ready for ``classifier.predict``.
288	        """
289	        home_samples = self._sample_team(home_distributions, random_state=random_state)
290	        away_samples = self._sample_team(away_distributions, random_state=random_state)
291	        return np.concatenate([home_samples, away_samples])
292	
293	    @staticmethod
294	    def sample(
295	        distributions: list[FittedDistribution],
296	        size: int = 1,
297	        random_state: int | None = None,
298	    ) -> np.ndarray:
299	        """Sample ``size`` observations for each feature from *distributions*.
300	
301	        This low-level helper mirrors the NBA ``FeatureSampler.sample`` signature
302	        exactly so that ``GamePredictor`` can share the same call site pattern.
303	
304	        Args:
305	            distributions: List of fitted distributions, one per feature.
306	            size: Number of samples to draw per feature.
307	            random_state: Optional seed for reproducibility.
308	
309	        Returns:
310	            Array of shape ``(size, n_features)``.
311	        """
312	        rng = np.random.default_rng(random_state)
313	        samples: list[Any] = []
314	        for dist in distributions:
315	            generator = SCIPY_GENERATORS[dist.name]
316	            s = generator(*dist.params, size=size, random_state=rng)
317	            samples.append(s)
318	        return np.array(samples).T
319	
320	    # ------------------------------------------------------------------
321	    # Private helpers
322	    # ------------------------------------------------------------------
323	
324	    def _sample_team(
325	        self,
326	        distributions: list[FittedDistribution],
327	        random_state: int | None = None,
328	    ) -> np.ndarray:
329	        """Return a 1-D array of one sampled value per base stat for one team."""
330	        # sample() returns shape (1, n_features); squeeze to (n_features,)
331	        return self.sample(distributions, size=1, random_state=random_state).squeeze(axis=0)
332	
