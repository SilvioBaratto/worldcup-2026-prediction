320	_RANKING_COLUMNS = [
321	    "TEAM",
322	    "COMPETITION",
323	    "SEASON",
324	    "POSITION",
325	    "PLAYED",
326	    "WON",
327	    "DRAW",
328	    "LOST",
329	    "POINTS",
330	    "GOALS_FOR",
331	    "GOALS_AGAINST",
332	]
333	
334	# Competitions with structured standings tables (group-stage tournaments)
335	_RANKING_COMPETITION_CODES = ["WC", "EC", "CA"]
336	
337	
338	class RankingBuilder:
339	    """Fetches group/league standings per season and assembles ranking.csv.
340	
341	    Mirrors ``RankingBuilder`` in the NBA original.
342	    """
343	
344	    def __init__(
345	        self,
346	        client: FootballClient,
347	        start_year: int = 2006,
348	        end_year: int | None = None,
349	        competition_codes: list[str] | None = None,
350	    ) -> None:
351	        self._client = client
352	        self._start_year = start_year
353	        self._end_year = end_year if end_year is not None else datetime.date.today().year
354	        self._competition_codes = competition_codes or _RANKING_COMPETITION_CODES
355	
356	    def build(self) -> pd.DataFrame:
357	        """Fetch standings for all competitions × years and return the DataFrame."""
358	        frames: list[pd.DataFrame] = []
359	
360	        for code in self._competition_codes:
361	            for year in range(self._start_year, self._end_year + 1):
362	                df = self._fetch_season(code, year)
363	                if df is not None:
364	                    frames.append(df)
365	
366	        if not frames:
367	            msg = "All standings fetches failed — no data to build ranking.csv"
368	            raise RuntimeError(msg)
369	
370	        result = pd.concat(frames, ignore_index=True)
371	
372	        missing = set(_RANKING_COLUMNS) - set(result.columns)
373	        if missing:
374	            msg = f"Missing columns after transformation: {missing}"
375	            raise RuntimeError(msg)
376	
377	        logger.info("Built ranking DataFrame: %d rows", len(result))
378	        return result
379	
380	    def _fetch_season(self, code: str, year: int) -> pd.DataFrame | None:
381	        """Fetch standings for one competition-season. Returns None on failure."""
382	        try:
383	            data = self._client.get(
384	                f"/competitions/{code}/standings",
385	                params={"season": str(year)},
386	            )
387	            standings: list[dict[str, Any]] = data.get("standings", [])
388	            if not standings:
389	                return None
390	            rows: list[dict[str, Any]] = []
391	            for table in standings:
392	                table_rows: list[dict[str, Any]] = table.get("table", [])
393	                for entry in table_rows:
394	                    row = self._extract_ranking_row(entry, code, year)
395	                    if row is not None:
396	                        rows.append(row)
397	            if not rows:
398	                return None
399	            df = pd.DataFrame(rows, columns=_RANKING_COLUMNS)
400	            logger.info(
401	                "Fetched %d ranking rows for %s/%d", len(df), code, year
402	            )
403	            return df
404	        except Exception:
405	            logger.warning(
406	                "Failed to fetch standings for %s/%d", code, year, exc_info=True
407	            )
408	            return None
409	
410	    @staticmethod
411	    def _extract_ranking_row(
412	        entry: dict[str, Any],
413	        code: str,
414	        year: int,
415	    ) -> dict[str, Any] | None:
416	        """Map a single standings table row to the ranking.csv schema.
417	
418	        Pure transformation — no I/O.
419	        """
420	        try:
421	            team = entry.get("team", {})
422	            team_name = team.get("name", "") or team.get("shortName", "")
423	            if not team_name:
424	                return None
425	            return {
426	                "TEAM": str(team_name),
427	                "COMPETITION": code,
428	                "SEASON": year,
429	                "POSITION": int(entry.get("position", 0)),                "PLAYED": int(entry.get("playedGames", 0)),                "WON": int(entry.get("won", 0)),                "DRAW": int(entry.get("draw", 0)),                "LOST": int(entry.get("lost", 0)),                "POINTS": int(entry.get("points", 0)),                "GOALS_FOR": int(entry.get("goalsFor", 0)),                "GOALS_AGAINST": int(entry.get("goalsAgainst", 0)),            }
430	        except Exception:
431	            logger.debug("Skipping malformed standings entry: %s", entry, exc_info=True)
432	            return None
433	
434	
435	def build_ranking_csv(
436	    output_path: Path,
437	    client: FootballClient | None = None,
438	    start_year: int = 2006,
439	    end_year: int | None = None,
440	) -> pd.DataFrame:
441	    """Build ranking.csv and write to disk.
442	
443	    Args:
444	        output_path: Where to write the CSV.
445	        client: Rate-limited API client. Created with defaults if ``None``.
446	        start_year: First season year to query.
447	        end_year: Last season year. Defaults to current year.
448	
449	    Returns:
450	        The assembled DataFrame (11 columns matching the ranking.csv schema).
451	    """
452	    if client is None:
453	        client = FootballClient(ClientConfig())
454	
455	    builder = RankingBuilder(client, start_year=start_year, end_year=end_year)
456	    df = builder.build()
457	
458	    output_path.parent.mkdir(parents=True, exist_ok=True)
459	    df.to_csv(output_path, index=False)
460	    logger.info("Wrote %d ranking rows to %s", len(df), output_path)
461	    return df
