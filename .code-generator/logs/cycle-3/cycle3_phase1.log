157	    def test_when_dr_400_via_home_advantage_then_delta_implies_we_approx_0_909(self):
158	        """home_advantage=400, equal initial ratings, non-neutral → dr=400 → We=10/11.
159	
160	        ΔR = k_friendly × G=1.0 × (1 − 10/11) = k_friendly / 11.
161	        """
162	        config = EloConfig(home_advantage=400.0)
163	        result = EloEngine(config).run(_one_match(home_goals=1, away_goals=0, neutral=False))
