62	# Competition codes whose /teams endpoint we query to harvest national-team records
63	_TEAM_COMPETITION_CODES = ["WC", "EC", "CA"]
64	
65	
66	class TeamsBuilder:
67	    """Fetches team metadata for major international competitions."""
68	
69	    def __init__(
70	        self,
71	        client: FootballClient,
72	        competition_codes: list[str] | None = None,
73	    ) -> None:
74	        self._client = client
75	        self._competition_codes = competition_codes or _TEAM_COMPETITION_CODES
76	
77	    def build(self) -> pd.DataFrame:
78	        """Fetch teams for each competition and return the deduplicated DataFrame."""
79	        rows: list[dict[str, Any]] = []
80	        seen_ids: set[int] = set()
81	
82	        for code in self._competition_codes:
83	            fetched = self._fetch_teams(code)
84	            for team in fetched:
85	                tid = int(team.get("id", 0))
86	                if tid in seen_ids:
87	                    continue
88	                seen_ids.add(tid)
89	                rows.append(
90	                    {
91	                        "TEAM_ID": tid,
92	                        "NAME": team.get("name", ""),
93	                        "SHORT_NAME": team.get("shortName", ""),
94	                        "TLA": team.get("tla", ""),
95	                        "COUNTRY": team.get("area", {}).get("name", ""),
96	                        "COMPETITION": code,
97	                    }
98	                )
99	
100	        if not rows:
101	            msg = "No teams fetched — all competition requests failed"
102	            raise RuntimeError(msg)
103	
104	        df = pd.DataFrame(rows, columns=_TEAMS_COLUMNS)
105	        logger.info("Built teams DataFrame: %d unique teams", len(df))
106	        return df
107	
108	    def _fetch_teams(self, code: str) -> list[dict[str, Any]]:
109	        """Fetch teams for a single competition. Returns empty list on failure."""
110	        try:
111	            data = self._client.get(f"/competitions/{code}/teams")
112	            teams: list[dict[str, Any]] = data.get("teams", [])
113	            logger.info("Fetched %d teams for competition %s", len(teams), code)
114	            return teams
115	        except Exception:
116	            logger.warning("Failed to fetch teams for competition %s", code, exc_info=True)
117	            return []
118	
119	
120	def build_teams_csv(
121	    output_path: Path,
122	    client: FootballClient | None = None,
123	) -> pd.DataFrame:
124	    """Build teams.csv and write to disk.
125	
126	    Args:
127	        output_path: Where to write the CSV.
128	        client: Rate-limited API client. Created with defaults if ``None``.
129	
130	    Returns:
131	        The assembled DataFrame.
132	    """
133	    if client is None:
134	        client = FootballClient(ClientConfig())
135	
136	    builder = TeamsBuilder(client)
137	    df = builder.build()
138	
139	    output_path.parent.mkdir(parents=True, exist_ok=True)
140	    df.to_csv(output_path, index=False)
141	    logger.info("Wrote %d teams to %s", len(df), output_path)
142	    return df
