248	    # ------------------------------------------------------------------
249	    # Simulation
250	    # ------------------------------------------------------------------
251	
252	    def run_simulate(
253	        self,
254	        classifier: Classifier | None = None,
255	        team_distributions: dict[str, list[FittedDistribution]] | None = None,
256	        progress_callback: Callable[[int], None] | None = None,
257	    ) -> dict[int, RoundResult]:
258	        """Run Monte Carlo knockout-bracket simulation.
259	
260	        Args:
261	            classifier: A fitted classifier satisfying the ``Classifier``
262	                Protocol.  When ``None`` the model is loaded from
263	                ``output/models/{classifier_name}.joblib``.
264	            team_distributions: Pre-loaded distribution mapping.  When ``None``
265	                distributions are loaded from ``output/distributions.json``.
266	            progress_callback: Optional callable invoked after each simulation
267	                with the 1-based iteration count (for progress bars).
268	
269	        Returns:
270	            ``{round_number: RoundResult}`` with per-team advancement counts and
271	            probabilities.  Round 0 = Round of 32, 4 = Final.
272	
273	        Raises:
274	            ValueError: If no bracket config was provided at construction.
275	        """
276	        if self._bracket_config is None:
277	            raise ValueError("Bracket config is required for simulation")
278	
279	        if classifier is None:
280	            clf_name = self._config.simulation.classifier
281	            model_path = self._root / "output" / "models" / f"{clf_name}.joblib"
282	            classifier = ClassifierTrainer.load_model(model_path)
283	
284	        if team_distributions is None:
285	            dist_path = self._root / "output" / "distributions.json"
286	            team_distributions = DistributionFitter.load(dist_path)
287	
288	        sampler = FeatureSampler(self._config.features)
289	        predictor = GamePredictor(classifier, sampler, team_distributions)
290	        simulator = TournamentSimulator(predictor, self._config.simulation)
291	
292	        rounds = simulator.simulate(
293	            self._bracket_config.matchups,
294	            self._config.simulation.n_simulations,
295	            progress_callback=progress_callback,
296	        )
297	
298	        return rounds
