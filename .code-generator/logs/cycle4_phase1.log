192	    def run_train(
193	        self,
194	        classifier_names: list[str] | None = None,
195	    ) -> dict[str, tuple[Classifier, dict[str, Any]]]:
196	        """Train classifiers and evaluate.
197	
198	        Args:
199	            classifier_names: Subset to train.  Defaults to all three:
200	                ``["svm", "random_forest", "naive_bayes"]``.
201	
202	        Returns:
203	            Mapping of ``{name: (fitted_classifier, metrics_dict)}``.
204	        """
205	        data_path = self._root / self._config.data.output_path
206	        df = pd.read_csv(data_path)
207	
208	        trainer = ClassifierTrainer(self._config.training, self._config.features)
209	        evaluator = ModelEvaluator()
210	        X_train, X_test, y_train, y_test = trainer.prepare_data(df)
211	
212	        names = classifier_names or ["svm", "random_forest", "naive_bayes"]
213	        results: dict[str, tuple[Classifier, dict[str, Any]]] = {}
214	
215	        for name in names:
216	            logger.info("Training %s...", name)
217	            clf = ClassifierFactory.create(name, self._config.training)
218	            ClassifierTrainer.train(clf, X_train, y_train)
219	            metrics = evaluator.evaluate(clf, X_test, y_test)
220	            results[name] = (clf, metrics)
221	
222	            model_dir = self._root / "output" / "models"
223	            ClassifierTrainer.save_model(clf, model_dir / f"{name}.joblib")
224	
225	        return results
