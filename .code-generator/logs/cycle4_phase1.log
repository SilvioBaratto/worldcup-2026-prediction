19	from worldcup_playoff.config import FeaturesConfig, NaiveBayesConfig, RandomForestConfig, SVMConfig, TrainingConfig
20	
21	logger = logging.getLogger(__name__)
22	
23	
24	class ClassifierFactory:
25	    """Creates configured classifier instances from config."""
26	
27	    @staticmethod
28	    def create(name: str, config: TrainingConfig) -> Any:
29	        cfg: SVMConfig | RandomForestConfig | NaiveBayesConfig
30	        match name:
31	            case "svm":
32	                cfg = config.svm
33	                return make_pipeline(
34	                    StandardScaler(),
35	                    SVC(C=cfg.C, gamma=cfg.gamma, kernel=cfg.kernel, probability=True),
36	                )
37	            case "random_forest":
38	                cfg = config.random_forest
39	                return RandomForestClassifier(
40	                    n_estimators=cfg.n_estimators,
41	                    max_features=cfg.max_features,
42	                    max_depth=cfg.max_depth,
43	                    bootstrap=cfg.bootstrap,
44	                )
45	            case "naive_bayes":
46	                cfg = config.naive_bayes
47	                return GaussianNB(var_smoothing=cfg.var_smoothing)
48	            case _:
49	                raise ValueError(
50	                    f"Unknown classifier '{name}'. "
51	                    f"Choose from: svm, random_forest, naive_bayes"
52	                )
53	
54	
55	class ClassifierTrainer:
56	    """Handles data preparation and model fitting."""
57	
58	    def __init__(self, config: TrainingConfig, features_config: FeaturesConfig) -> None:
59	        self._config = config
60	        self._features = features_config
61	
62	    def prepare_data(
63	        self, df: pd.DataFrame
64	    ) -> tuple[Any, Any, Any, Any]:
65	        """Extract features/labels and split into train/test.
66	
67	        Returns (X_train, X_test, y_train, y_test) as numpy arrays.
68	        """
69	        X = df[self._features.selected].to_numpy()
70	        y = df["HOME_WIN"].to_numpy()
71	        X_train, X_test, y_train, y_test = train_test_split(
72	            X, y,
73	            test_size=self._config.test_size,
74	            random_state=self._config.random_state,
75	            shuffle=False,
76	        )
77	        logger.info(
78	            "Data split: train=%d, test=%d", len(X_train), len(X_test)
79	        )
80	        return X_train, X_test, y_train, y_test
81	
82	    @staticmethod
83	    def train(
84	        classifier: Any,
85	        X_train: np.ndarray,
86	        y_train: np.ndarray,
87	    ) -> Any:
88	        """Fit the classifier on training data."""
89	        classifier.fit(X_train, y_train)
90	        return classifier
91	
92	    @staticmethod
93	    def save_model(classifier: Any, path: Path) -> None:
94	        path.parent.mkdir(parents=True, exist_ok=True)
95	        joblib.dump(classifier, path)
96	        logger.info("Model saved to %s", path)
97	
98	    @staticmethod
99	    def load_model(path: Path) -> Any:
100	        logger.info("Loading model from %s", path)
