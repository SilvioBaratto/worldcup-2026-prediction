20	_FORBIDDEN_SUBSTRINGS = ("gdp", "market_value", "transfer", "odds", "bookie", "wage")
21	
22	
23	def _matches(rows: list[dict]) -> pd.DataFrame:
24	    return pd.DataFrame(
25	        {
26	            "DATE": pd.to_datetime([r.get("date", "2026-01-01") for r in rows]),
27	            "HOME_TEAM": [r["home"] for r in rows],
28	            "AWAY_TEAM": [r["away"] for r in rows],
29	            "HOME_GOALS": pd.array([r.get("home_goals", pd.NA) for r in rows], dtype="Int64"),
30	            "AWAY_GOALS": pd.array([r.get("away_goals", pd.NA) for r in rows], dtype="Int64"),
31	            "TOURNAMENT": [r.get("tournament", "Friendly") for r in rows],
32	            "NEUTRAL": [r.get("neutral", False) for r in rows],
33	        }
34	    )
35	
36	
37	def _elo(rows: list[dict]) -> pd.DataFrame:
38	    return pd.DataFrame(
39	        {
40	            "home_elo": [float(r.get("home_elo", 1500)) for r in rows],
41	            "away_elo": [float(r.get("away_elo", 1500)) for r in rows],
42	        }
43	    )
44	
45	
46	_BRA_GER = TeamAbilities(
47	    attack={"Brazil": 1.5, "Germany": 1.3},
48	    defence={"Brazil": 0.8, "Germany": 0.9},
49	    home_adv=0.0,
50	    rho=-0.1,
51	    intercept=0.0,
52	)
