2026-06-24 01:38:53,363 DEBUG msg #152: UserMessage tool_result(toolu_01Lhp15bnnHyyPpASccTJPYh): 1	"""Core per-match feature assembler for the World Cup 2026 prediction model.
2	
3	Consumes a martj42 results DataFrame plus a pre-computed ``elo_df``
4	(columns ``home_elo``, ``away_elo``, aligned to ``sort_chronological(df)``)
5	and a ``TeamAbilities`` fitted by the Dixon-Coles estimator, then emits one
6	feature row per match including unplayed WC2026 fixtures.
7	
8	**Football-only** — no socioeconomic, market-value, or odds columns ever appear.
9	
10	**No forward leakage** — time-aware covariates (form, rest days, goal diff) are
11	computed via an incremental per-team rolling state updated AFTER each row is
12	assembled, so match i never sees its own or any later result.
13	
14	**O(N) performance** — a single chronological pass maintains per-team state
15	(deque of last *window* played results + last known match date), avoiding
16	the O(N²) prefix scans of the raw timeaware helpers.
17	"""
18	from __future__ import annotations
19	
20	import logging
21	from collections import deque
22	from dataclasses import asdict, dataclass
23	from typing import TYPE_CHECKING, Any
24	
25	import pandas as pd
26	
27	from worldcup_playoff.config import FeatureBuildConfig
28	from worldcup_playoff.features.confederation import (
29	    CONFEDERATION_MAP,
30	    RankingResolution,
31	    resolve_ranking,
32	)
33	from worldcup_playoff.features.timeaware import sort_chronological
34	from worldcup_playoff.simulation.poisson import TeamAbilities
35	
36	if TYPE_CHECKING:
37	    from worldcup_playoff.data.elo import EloResult
38	
39	__all__ = [
40	    "FEATURE_COLUMNS",
41	    "FeatureBuilder",
42	    "MatchFeatures",
43	    "TeamAbilities",
44	    "build_features",
45	    "to_frame",
46	]
47	
48	logger = logging.getLogger(__name__)
49	
50	# Stable, documented column order — asserted by the allow-list test.
51	FEATURE_COLUMNS: tuple[str, ...] = (
52	    "date", "home_team", "away_team", "neutral",
53	    "home_elo", "away_elo", "elo_diff",
54	    "home_attack", "home_defence", "away_attack", "away_defence",
55	    "home_form", "away_form",
56	    "home_rest_days", "away_rest_days",
57	    "home_goal_diff", "away_goal_diff",
58	    "home_confederation", "away_confederation",
59	    "home_ranking", "away_ranking",
60	    "home_goals", "away_goals",
61	)
62	
63	
64	# ---------------------------------------------------------------------------
65	# Value object — one frozen record per match
66	# ---------------------------------------------------------------------------
67	
68	
69	@dataclass(frozen=True)
70	class MatchFeatures:  # noqa: D101 — field names self-document
71	    date: str
72	    home_team: str
73	    away_team: str
74	    neutral: bool
75	    home_elo: float
76	    away_elo: float
77	    elo_diff: float
78	    home_attack: float
79	    home_defence: float
80	    away_attack: float
81	    away_defence: float
82	    home_form: float
83	    away_form: float
84	    home_rest_days: int | None
85	    away_rest_days: int | None
86	    home_goal_diff: float
87	    away_goal_diff: float
88	    home_confederation: str | None
89	    away_confederation: str | None
90	    home_ranking: float | None
91	    away_ranking: float | None
92	    home_goals: int | None
93	    away_goals: int | None
94	
95	
96	# ---------------------------------------------------------------------------
97	# O(N) incremental per-team rolling state
98	# ---------------------------------------------------------------------------
99	
100	
101	class _TeamState:
102	    """Rolling covariate state for one team, maintained chronologically."""
103	
104	    def __init__(self, window: int, half_life: float) -> None:
105	        self._half = half_life
106	        self._played: deque[tuple[float, int, pd.Timestamp]] = deque(maxlen=window)
107	        self._last: pd.Timestamp | None = None
108	
109	    def rest_days(self, ref: pd.Timestamp) -> int | None:
110	        if self._last is None or pd.isna(ref):
111	            return None
112	        return int((ref - self._last).days)
113	
114	    def form(self, ref: pd.Timestamp) -> float:
115	        if not self._played or pd.isna(ref):
116	            return 0.0
117	        weights = [float(0.5 ** ((ref - d).days / self._half)) for _, _, d in self._played]
118	        total = sum(weights)
119	        return 0.0 if total == 0.0 else sum(p * w for p, w in zip(
120	            [p for p, _, _ in self._played], weights
121	        )) / total
122	
123	    def goal_diff(self) -> float:
124	        return float(sum(gd for _, gd, _ in self._played))
125	
126	    def after_match(self, pts: float, gd: int, date: pd.Timestamp, played: bool) -> None:
127	        if played:
128	            self._played.append((pts, gd, date))
129	        if pd.notna(date):
130	            self._last = date
131	
132	
133	# ---------------------------------------------------------------------------
134	# Module-level pure helpers
135	# ---------------------------------------------------------------------------
136	
137	
138	def _pts_gd(scored: int, conceded: int) -> tuple[float, int]:
139	    """Return (points, net_goal_diff) from one team's perspective."""
140	    gd = scored - conceded
141	    if scored > conceded:
142	        return 3.0, gd
143	    return (1.0, gd) if scored == conceded else (0.0, gd)
144	
145	
146	def _date_str(raw: Any) -> str:
147	    """Coerce any DATE cell to a YYYY-MM-DD string; '' on NaT."""
148	    ts = pd.to_datetime(raw, errors="coerce")
149	    return "" if pd.isna(ts) else ts.strftime("%Y-%m-%d")
150	
151	
152	def _na_to_none(val: Any) -> int | None:
153	    return None if pd.isna(val) else int(val)
154	
155	
156	def _new_state(cfg: FeatureBuildConfig) -> _TeamState:
157	    return _TeamState(cfg.form_window, cfg.form_half_life_days)
158	
159	
160	def _check_alignment(df: pd.DataFrame, elo_df: pd.DataFrame) -> None:
161	    if len(df) != len(elo_df):
162	        raise ValueError(
163	            f"elo_df length {len(elo_df)} != matches length {len(df)}: "
164	            "elo_df must be pre-aligned to sort_chronological(matches_df)."
165	        )
166	
167	
168	def _record_match(
169	    row: pd.Series,
170	    home: str,
171	    away: str,
172	    date: pd.Timestamp,
173	    states: dict[str, _TeamState],
174	) -> None:
175	    if pd.isna(row["HOME_GOALS"]) or pd.isna(row["AWAY_GOALS"]):
176	        states[home].after_match(0.0, 0, date, False)
177	        states[away].after_match(0.0, 0, date, False)
178	        return
179	    hg, ag = int(row["HOME_GOALS"]), int(row["AWAY_GOALS"])
180	    h_pts, h_gd = _pts_gd(hg, ag)
181	    a_pts, a_gd = _pts_gd(ag, hg)
182	    states[home].after_match(h_pts, h_gd, date, True)
183	    states[away].after_match(a_pts, a_gd, date, True)
184	
185	
186	def _update_states(
187	    row: pd.Series,
188	    states: dict[str, _TeamState],
189	    cfg: FeatureBuildConfig,
190	) -> None:
191	    home, away = str(row["HOME_TEAM"]), str(row["AWAY_TEAM"])
192	    date = pd.to_datetime(_date_str(row["DATE"]), errors="coerce")
193	    for team in (home, away):
194	        states.setdefault(team, _new_state(cfg))
195	    _record_match(row, home, away, date, states)
196	
197	
198	def _make_features(
199	    row: pd.Series,
200	    elo: pd.Series,
201	    ab: TeamAbilities,
202	    h_st: _TeamState,
203	    a_st: _TeamState,
204	    h_rk: RankingResolution,
205	    a_rk: RankingResolution,
206	    date: str,
207	) -> MatchFeatures:
208	    home, away = str(row["HOME_TEAM"]), str(row["AWAY_TEAM"])
209	    ref = pd.to_datetime(date, errors="coerce")
210	    h_elo, a_elo = float(elo["home_elo"]), float(elo["away_elo"])
211	    return MatchFeatures(
212	        date=date, home_team=home, away_team=away, neutral=bool(row["NEUTRAL"]),
213	        home_elo=h_elo, away_elo=a_elo, elo_diff=h_elo - a_elo,
214	        home_attack=ab.attack.get(home, 0.0), home_defence=ab.defence.get(home, 0.0),
215	        away_attack=ab.attack.get(away, 0.0), away_defence=ab.defence.get(away, 0.0),
216	        home_form=h_st.form(ref), away_form=a_st.form(ref),
217	        home_rest_days=h_st.rest_days(ref), away_rest_days=a_st.rest_days(ref),
218	        home_goal_diff=h_st.goal_diff(), away_goal_diff=a_st.goal_diff(),
219	        home_confederation=h_rk.confederation, away_confederation=a_rk.confederation,
220	        home_ranking=h_rk.value, away_ranking=a_rk.value,
221	        home_goals=_na_to_none(row["HOME_GOALS"]), away_goals=_na_to_none(row["AWAY_GOALS"]),
222	    )
223	
224	
225	def to_frame(rows: list[MatchFeatures]) -> pd.DataFrame:
226	    """Convert a list of MatchFeatures into a tidy DataFrame (stable column order)."""
227	    if not rows:
228	        return pd.DataFrame(columns=list(FEATURE_COLUMNS))
229	    df = pd.DataFrame([asdict(r) for r in rows])[list(FEATURE_COLUMNS)]
230	    for col in ("home_goals", "away_goals"):
231	        df[col] = df[col].astype("Int64")
232	    return df
233	
234	
235	# ---------------------------------------------------------------------------
236	# Public assembler
237	# ---------------------------------------------------------------------------
238	
239	
240	class FeatureBuilder:
241	    """Assemble football-only per-match covariates from pre-computed inputs.
242	
243	    Parameters
244	    ----------
245	    config:     Feature-build settings (form window, half-life, staleness cutoff, seed).
246	    ranking:    Optional ``{team: ranking_points}`` dict; ``None`` falls back to
247	                the static confederation map for every team.
248	    confed_map: Confederation mapping (injectable for testing).
249	    """
250	
251	    def __init__(
252	        self,
253	        config: FeatureBuildConfig,
254	        *,
255	        ranking: dict[str, float] | None = None,
256	        confed_map: dict[str, str] = CONFEDERATION_MAP,
257	    ) -> None:
258	        self._cfg = config
259	        self._ranking = ranking
260	        self._confed_map = confed_map
261	
262	    def build(
263	        self,
264	        df: pd.DataFrame,
265	        elo_df: pd.DataFrame,
266	        abilities: TeamAbilities,
267	        *,
268	        ranking_df: dict[str, float] | None = None,
269	    ) -> pd.DataFrame:
270	        """Return one feature row per input match (includes unplayed WC2026 rows)."""
271	        sorted_df = sort_chronological(df)
272	        _check_alignment(sorted_df, elo_df)
273	        ranking = ranking_df if ranking_df is not None else self._ranking
274	        return to_frame(self._assemble(sorted_df, elo_df, abilities, ranking))
275	
276	    def _assemble(
277	        self,
278	        sorted_df: pd.DataFrame,
279	        elo_df: pd.DataFrame,
280	        abilities: TeamAbilities,
281	        ranking: dict[str, float] | None,
282	    ) -> list[MatchFeatures]:
283	        states: dict[str, _TeamState] = {}
284	        rows: list[MatchFeatures] = []
285	        for i, (_, row) in enumerate(sorted_df.iterrows()):
286	            rows.append(self._row(i, row, elo_df, abilities, ranking, states))
287	            _update_states(row, states, self._cfg)
288	        return rows
289	
290	    def _row(
291	        self,
292	        i: int,
293	        row: pd.Series,
294	        elo_df: pd.DataFrame,
295	        abilities: TeamAbilities,
296	        ranking: dict[str, float] | None,
297	        states: dict[str, _TeamState],
298	    ) -> MatchFeatures:
299	        home, away, date = str(row["HOME_TEAM"]), str(row["AWAY_TEAM"]), _date_str(row["DATE"])
300	        h_st = states.get(home, _new_state(self._cfg))
301	        a_st = states.get(away, _new_state(self._cfg))
302	        return _make_features(row, elo_df.iloc[i], abilities, h_st, a_st,
303	                               self._rank(home, date, ranking),
304	                               self._rank(away, date, ranking), date)
305	
306	    def _rank(self, team: str, date: str, ranking: dict[str, float] | None) -> RankingResolution:
307	        return resolve_ranking(
308	            team, ranking, date, self._cfg.ranking_staleness_cutoff, confed_map=self._confed_map
309	        )
310	
311	
312	# ---------------------------------------------------------------------------
313	# High-level convenience factory
314	# ---------------------------------------------------------------------------
315	
316	
317	def _to_elo_df(elo_result: EloResult) -> pd.DataFrame:
318	    """Extract home_elo/away_elo per match from an EloResult (aligned to sorted df)."""
319	    return pd.DataFrame(
320	        [{"home_elo": d.home_elo, "away_elo": d.away_elo} for d in elo_result.match_diffs]
321	    )
322	
323	
324	def build_features(
325	    df: pd.DataFrame,
326	    elo: EloResult | pd.DataFrame,
327	    abilities: TeamAbilities,
328	    *,
329	    config: FeatureBuildConfig | None = None,
330	    ranking: dict[str, float] | None = None,
331	) -> pd.DataFrame:
332	    """Assemble per-match feature covariates from pre-computed Elo and abilities.
333	
334	    Parameters
335	    ----------
336	    df:         Full martj42-internal results frame (DATE/HOME_TEAM/… uppercase schema).
337	    elo:        Either an ``EloResult`` from ``compute_elo`` or a pre-built elo DataFrame
338	                with ``home_elo`` / ``away_elo`` columns aligned to ``sort_chronological(df)``.
339	    abilities:  Fitted Dixon-Coles abilities from ``fit_dixon_coles``.
340	    config:     Feature-build settings; uses ``FeatureBuildConfig()`` defaults when ``None``.
341	    ranking:    Optional ``{team: ranking_points}`` dict; falls back to the static
342	                confederation map when ``None``.
343	
344	    Returns
345	    -------
346	    DataFrame with FEATURE_COLUMNS plus a ``tournament`` metadata column (one row per match,
347	    including unplayed WC2026 fixtures with ``home_goals``/``away_goals`` as ``<NA>``).
348	    """
349	    from worldcup_playoff.data.elo import EloResult as _EloResult  # avoid circular at import time
350	
351	    cfg = config or FeatureBuildConfig()
352	    elo_df = _to_elo_df(elo) if isinstance(elo, _EloResult) else elo
353	    sorted_df = sort_chronological(df)
354	    features = FeatureBuilder(cfg, ranking=ranking).build(sorted_df, elo_df, abilities)
355	    result = features.copy()
356	    result["tournament"] = sorted_df["TOURNAMENT"].values
357	    return result
