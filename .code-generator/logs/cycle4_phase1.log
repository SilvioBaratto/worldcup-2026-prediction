227	    def run_fit_distributions(self) -> dict[str, list[FittedDistribution]]:
228	        """Fit statistical distributions per team and persist to JSON.
229	
230	        Reads train_data.csv, fits one scipy distribution per base statistic
231	        per team via ``DistributionFitter``, and saves the result to
232	        ``output/distributions.json``.
233	
234	        Returns:
235	            Mapping of ``{team_name: [FittedDistribution per base stat]}``.
236	        """
237	        data_path = self._root / self._config.data.output_path
238	        df = pd.read_csv(data_path)
239	
240	        fitter = DistributionFitter(self._config.distributions, self._config.features)
241	        team_dists = fitter.fit_all_teams(df)
242	
243	        dist_path = self._root / "output" / "distributions.json"
244	        DistributionFitter.save(team_dists, dist_path)
245	
246	        return team_dists
