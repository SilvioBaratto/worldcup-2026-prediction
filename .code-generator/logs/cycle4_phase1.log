82	def _make_chronological_df(n: int = 100) -> pd.DataFrame:
83	    """DataFrame with monotonically increasing feature values (simulates time ordering)."""
84	    features = FeaturesConfig()
85	    data: dict[str, object] = {col: np.arange(n, dtype=float) for col in features.selected}
86	    data["HOME_WIN"] = (np.arange(n) % 2).astype(int)
87	    return pd.DataFrame(data)
