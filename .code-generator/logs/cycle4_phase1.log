86	class TestEndToEndNoLeakage:
87	    """Match-2 features must use only match-1 information (no forward leakage)."""
88	
89	    def test_when_first_match_has_no_prior_history_then_home_form_is_zero(self) -> None:
90	        m = _matches(
91	            [
92	                {
93	                    "home": "Brazil",
94	                    "away": "Germany",
95	                    "date": "2026-01-01",
96	                    "home_goals": 3,
97	                    "away_goals": 0,
98	                },
99	            ]
100	        )
101	        result = FeatureBuilder(_CFG).build(m, _elo([{}]), _BRA_GER)
102	        # No prior matches → neutral default form
103	        assert result.iloc[0]["home_form"] == pytest.approx(0.0)
104	
105	    def test_when_match2_is_computed_then_home_form_equals_match1_win_points(self) -> None:
106	        """
107	        Two-match history for Brazil:
108	          match-1: Brazil beats Germany 3-0 on 2026-01-01 (Brazil earns 3 pts)
109	          match-2: Brazil vs Germany on 2026-01-10
110	
111	        At match-2, Brazil's home_form must reflect match-1's 3-0 win.
112	        With a single prior played match, PPG = 3.0 regardless of decay weight.
113	        """
114	        m = _matches(
115	            [
116	                {
117	                    "home": "Brazil",
118	                    "away": "Germany",
119	                    "date": "2026-01-01",
120	                    "home_goals": 3,
121	                    "away_goals": 0,
122	                },
123	                {
124	                    "home": "Brazil",
125	                    "away": "Germany",
126	                    "date": "2026-01-10",
127	                    "home_goals": 1,
128	                    "away_goals": 2,
129	                },
130	            ]
131	        )
132	        result = FeatureBuilder(_CFG).build(m, _elo([{}, {}]), _BRA_GER)
133	        # match-2 form for Brazil = 3.0 (single prior win; decay cancels in PPG formula)
134	        assert result.iloc[1]["home_form"] == pytest.approx(3.0)
135	
136	    def test_when_match2_result_is_a_loss_then_match2_away_form_reflects_only_match1(
137	        self,
138	    ) -> None:
139	        """
140	        Germany won match-1 as away team (Brazil 3-0 → Germany 0 pts).
141	        At match-2, Germany's away_form must show 0.0 (a prior loss), NOT be
142	        influenced by match-2's result (Germany wins 2-1, which would give 3 pts).
143	        """
144	        m = _matches(
145	            [
146	                {
147	                    "home": "Brazil",
148	                    "away": "Germany",
149	                    "date": "2026-01-01",
150	                    "home_goals": 3,
151	                    "away_goals": 0,
152	                },
153	                {
154	                    "home": "Brazil",
155	                    "away": "Germany",
156	                    "date": "2026-01-10",
157	                    "home_goals": 1,
158	                    "away_goals": 2,
159	                },
160	            ]
161	        )
162	        result = FeatureBuilder(_CFG).build(m, _elo([{}, {}]), _BRA_GER)
163	        # Germany's form at match-2 is based on match-1 only (a 3-0 loss → 0 pts)
164	        assert result.iloc[1]["away_form"] == pytest.approx(0.0)
165	
166	    def test_when_match2_goal_diff_is_read_then_it_reflects_only_match1_result(self) -> None:
167	        m = _matches(
168	            [
169	                {
170	                    "home": "Brazil",
171	                    "away": "Germany",
172	                    "date": "2026-01-01",
173	                    "home_goals": 3,
174	                    "away_goals": 1,
175	                },
176	                {
177	                    "home": "Brazil",
178	                    "away": "Germany",
179	                    "date": "2026-01-10",
180	                    "home_goals": 0,
181	                    "away_goals": 0,
182	                },
183	            ]
184	        )
185	        result = FeatureBuilder(_CFG).build(m, _elo([{}, {}]), _BRA_GER)
186	        # Brazil GD at match-2: only match-1 (3-1 → +2)
187	        assert result.iloc[1]["home_goal_diff"] == pytest.approx(2.0)
188	        # Germany GD at match-2: only match-1 (1-3 → -2)
189	        assert result.iloc[1]["away_goal_diff"] == pytest.approx(-2.0)
