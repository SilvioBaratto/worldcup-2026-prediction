90	class TestClassifierTrainer:
91	    def test_prepare_data_preserves_temporal_order(self) -> None:
92	        """Train rows must all precede test rows — no temporal leakage."""
93	        n = 100
94	        df = _make_chronological_df(n)
95	        trainer = ClassifierTrainer(TrainingConfig(test_size=0.3), FeaturesConfig())
96	        X_train, X_test, _, _ = trainer.prepare_data(df)
97	
98	        train_max = float(X_train[:, 0].max())
99	        test_min = float(X_test[:, 0].min())
100	        assert train_max < test_min, (
101	            f"Temporal leakage: latest train sample ({train_max}) >= "
102	            f"earliest test sample ({test_min}). shuffle=False must be set."
103	        )
104	
105	    def test_prepare_data_split_sizes(self) -> None:
106	        n = 100
107	        df = _make_chronological_df(n)
108	        trainer = ClassifierTrainer(TrainingConfig(test_size=0.3), FeaturesConfig())
109	        X_train, X_test, y_train, y_test = trainer.prepare_data(df)
110	        assert len(X_train) + len(X_test) == n
111	        assert len(X_train) == len(y_train)
112	        assert len(X_test) == len(y_test)
113	        assert len(X_test) == pytest.approx(n * 0.3, abs=1)
114	
115	    def test_prepare_data_reads_home_win_column(self) -> None:
116	        """HOME_WIN column must be used as target, not any other column."""
117	        df = _make_chronological_df(50)
118	        df["HOME_WIN"] = 1  # all home wins
119	        trainer = ClassifierTrainer(TrainingConfig(test_size=0.3), FeaturesConfig())
120	        _, _, y_train, y_test = trainer.prepare_data(df)
121	        assert all(y_train == 1)
122	        assert all(y_test == 1)
123	
124	    def test_train_fits_classifier(self) -> None:
125	        X = np.random.rand(60, 10)
126	        y = np.random.choice([0, 1], 60)
127	        clf = GaussianNB()
128	        ClassifierTrainer.train(clf, X, y)
129	        preds = clf.predict(X)
130	        assert len(preds) == 60
131	
132	    def test_save_and_load_model_round_trip(self, tmp_path: Path) -> None:
133	        """Model saved with save_model must be loadable and produce identical predictions."""
134	        X = np.random.rand(60, 10)
135	        y = np.random.choice([0, 1], 60)
136	        clf = GaussianNB()
137	        clf.fit(X, y)
138	        original_preds = clf.predict(X)
139	
140	        path = tmp_path / "naive_bayes.joblib"
141	        ClassifierTrainer.save_model(clf, path)
142	        assert path.exists()
143	
144	        loaded = ClassifierTrainer.load_model(path)
145	        loaded_preds = loaded.predict(X)
146	        np.testing.assert_array_equal(original_preds, loaded_preds)
147	
