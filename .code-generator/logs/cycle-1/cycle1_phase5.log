86	    groups = sorted(qualifying)
87	    g_idx = {g: i for i, g in enumerate(groups)}
88	    adj = [[g_idx[g] for g in cands if g in qualifying] for _, cands in slots]
89	    match: list[int] = [-1] * len(groups)
90	    n = sum(_augment(s, adj, match, [False] * len(groups)) for s in range(len(slots)))
91	    if n < len(slots):
92	        return None
93	    slot_map = {match[i]: groups[i] for i in range(len(groups)) if match[i] != -1}
94	    return {slots[s][0]: slot_map[s] for s in range(len(slots))}
95	
96	
97	# ---------------------------------------------------------------------------
98	# THIRD_PLACE_COMBINATIONS — computed once at import (pure, deterministic)
99	# ---------------------------------------------------------------------------
100	
101	
102	def _compute_third_place_combinations() -> dict[frozenset[str], dict[str, str]]:
103	    """Enumerate all valid 8-of-12 qualifying-third combinations via bipartite matching."""
104	    return {
105	        frozenset(combo): m
106	        for combo in combinations(GROUPS, 8)
107	        if (m := _bipartite_match(frozenset(combo), _THIRD_SLOT_CANDIDATES)) is not None
108	    }
109	
110	
111	# Official lookup: qualifying-8-groups frozenset → {placeholder: group_letter}.
112	# Covers every 8-of-12 combination that admits a valid slot assignment.
113	THIRD_PLACE_COMBINATIONS: dict[frozenset[str], dict[str, str]] = _compute_third_place_combinations()
114	
115	
116	# ---------------------------------------------------------------------------
117	# Private slot-resolution helpers
118	# ---------------------------------------------------------------------------
119	
120	
121	def _get_row_at(table: list[dict], position: int) -> dict:
122	    """Return the row whose `position` field equals *position*, or fall back by index."""
123	    return next(
124	        (r for r in table if r.get("position") == position),
125	        table[position - 1],
126	    )
127	
128	
129	def _third_sort_key(group: str, row: dict) -> tuple:
130	    """FIFA tiebreak key for third-placed teams (lower = better rank)."""
131	    return (
132	        -row.get("points", 0),
133	        -row.get("goalDifference", 0),
134	        -row.get("goalsFor", 0),
135	        group,  # alphabetical as the final, deterministic tiebreaker
136	    )
137	
138	
139	def _resolve_slot(
140	    slot: str,
141	    standings: dict[str, list[dict]],
142	    third_map: dict[str, str],
143	) -> str:
144	    """Translate a bracket slot label into a concrete team name."""
145	    group = third_map[slot] if slot.startswith("3") else slot[1]
146	    pos = 3 if slot.startswith("3") else int(slot[0])
147	    return _get_row_at(standings[group], pos)["team"]["name"]
148	
149	
150	# ---------------------------------------------------------------------------
151	# Public API
152	# ---------------------------------------------------------------------------
153	
154	
155	def rank_third_places(standings: dict[str, list[dict]]) -> list[str]:
156	    """Return the 8 qualifying third-place group letters ranked by FIFA tiebreak.
157	
158	    *standings* maps group letter → list-of-table-row dicts (football-data.org v4 schema).
159	    """
160	    ranked = sorted(
161	        standings.items(),
162	        key=lambda kv: _third_sort_key(kv[0], _get_row_at(kv[1], 3)),
163	    )
164	    return [group for group, _ in ranked[:8]]
165	
166	
167	def assign_thirds(qualified_third_groups: frozenset[str]) -> dict[str, str]:
168	    """Map each 3X placeholder to a concrete group letter via THIRD_PLACE_COMBINATIONS."""
169	    return THIRD_PLACE_COMBINATIONS[qualified_third_groups]
170	
171	
172	def resolve_r32(standings: dict[str, list[dict]]) -> list[tuple[str, str]]:
173	    """Resolve 16 R32 ties from final group standings to concrete (home, away) pairs."""
174	    third_map = assign_thirds(frozenset(rank_third_places(standings)))
175	    return [
176	        (_resolve_slot(h, standings, third_map), _resolve_slot(a, standings, third_map))
177	        for h, a in R32_SLOTS
178	    ]
179	
