12	
13	logger = logging.getLogger(__name__)
14	
15	_FINISHED_STATUS = "FINISHED"
16	
17	
18	class LiveMatch(BaseModel):
19	    """A single match from the football-data.org matches endpoint."""
20	
21	    model_config = ConfigDict(extra="ignore")
22	
23	    id: int
24	    utc_date: str = ""
25	    status: str
26	    stage: str
27	    group: Optional[str] = None
28	    home_team: Optional[str] = None
29	    away_team: Optional[str] = None
30	
31	    @model_validator(mode="before")
32	    @classmethod
33	    def _extract_fields(cls, data: Any) -> Any:
34	        if not isinstance(data, dict):
35	            return data
36	        home_name = (data.get("homeTeam") or {}).get("name")
37	        away_name = (data.get("awayTeam") or {}).get("name")
38	        return {
39	            **data,
40	            "utc_date": data.get("utcDate", ""),
41	            "home_team": normalize_team(home_name) if home_name else None,
42	            "away_team": normalize_team(away_name) if away_name else None,
43	        }
44	
45	
46	class TableRow(BaseModel):
47	    """One team's row in a group standings table."""
48	
49	    model_config = ConfigDict(extra="ignore")
50	
51	    position: int = 0
52	    team_name: Optional[str] = None
53	    played_games: int = 0
54	    won: int = 0
55	    draw: int = 0
56	    lost: int = 0
57	    points: int = 0
58	    goals_for: int = 0
59	    goals_against: int = 0
60	    goal_difference: int = 0
61	
62	    @model_validator(mode="before")
63	    @classmethod
64	    def _flatten(cls, data: Any) -> Any:
65	        if not isinstance(data, dict):
66	            return data
67	        return {
68	            **data,
69	            "team_name": (data.get("team") or {}).get("name"),
70	            "played_games": data.get("playedGames", 0),
71	            "goals_for": data.get("goalsFor", 0),
72	            "goals_against": data.get("goalsAgainst", 0),
73	            "goal_difference": data.get("goalDifference", 0),
74	        }
