2026-06-23 22:07:52,450 DEBUG msg #179: UserMessage tool_result(toolu_01Es3STvg4eeZBGumCPhPLxL): 1	"""Load raw CSV datasets into validated DataFrames."""
2	
3	from __future__ import annotations
4	
5	import difflib
6	import logging
7	from pathlib import Path
8	
9	import pandas as pd
10	
11	from worldcup_playoff.config import DataConfig
12	
13	logger = logging.getLogger(__name__)
14	
15	# ---------------------------------------------------------------------------
16	# Required column schemas (column name -> expected pandas dtype string)
17	# ---------------------------------------------------------------------------
18	
19	REQUIRED_MATCHES_COLUMNS: dict[str, str] = {
20	    "MATCH_ID": "int64",
21	    "DATE": "object",
22	    "HOME_TEAM": "object",
23	    "AWAY_TEAM": "object",
24	    "HOME_GOALS": "int64",
25	    "AWAY_GOALS": "int64",
26	    "COMPETITION": "object",
27	    "SEASON": "int64",
28	}
29	
30	REQUIRED_TEAMS_COLUMNS: dict[str, str] = {
31	    "TEAM_ID": "int64",
32	    "NAME": "object",
33	}
34	
35	
36	def _validate_dataframe(
37	    df: pd.DataFrame,
38	    required: dict[str, str],
39	    label: str,
40	) -> None:
41	    """Check column presence and dtypes, raising ``ValueError`` on mismatch.
42	
43	    Args:
44	        df: DataFrame to validate.
45	        required: Mapping of column name to expected dtype string.
46	        label: Human-readable label used in error messages (e.g. ``"matches"``).
47	
48	    Raises:
49	        ValueError: If any required column is absent or has an incompatible dtype.
50	    """
51	    missing = set(required) - set(df.columns)
52	    if missing:
53	        parts: list[str] = []
54	        for col in sorted(missing):
55	            matches = difflib.get_close_matches(col, df.columns.tolist(), n=1, cutoff=0.7)
56	            if matches:
57	                parts.append(f"  '{col}' — did you mean '{matches[0]}'?")
58	            else:
59	                parts.append(f"  '{col}'")
60	        detail = "\n".join(parts)
61	        raise ValueError(f"{label} DataFrame missing required column(s):\n{detail}")
62	
63	    _NUMERIC_DTYPES = {"int64", "float64", "int32", "float32"}
64	    # pandas 2.0+ on Python 3.14 uses the 'str' (ArrowDtype string) dtype
65	    # for string columns; treat 'str' and 'object' as interchangeable.
66	    _STRING_DTYPES = {"object", "str", "string"}
67	
68	    type_errors: list[str] = []
69	    for col, expected in required.items():
70	        actual = str(df[col].dtype)
71	        if actual != expected:
72	            # Allow numeric type compatibility (int64 <-> float64)
73	            if actual in _NUMERIC_DTYPES and expected in _NUMERIC_DTYPES:
74	                continue
75	            # Allow string type compatibility (object <-> str <-> string)
76	            if actual in _STRING_DTYPES and expected in _STRING_DTYPES:
77	                continue
78	            type_errors.append(f"  '{col}' has dtype '{actual}', expected '{expected}'")
79	
80	    if type_errors:
81	        detail = "\n".join(type_errors)
82	        raise ValueError(f"{label} DataFrame has wrong column dtype(s):\n{detail}")
83	
84	
85	def validate_matches_df(df: pd.DataFrame) -> None:
86	    """Validate that a matches DataFrame has the required schema."""
87	    _validate_dataframe(df, REQUIRED_MATCHES_COLUMNS, "matches")
88	
89	
90	def validate_teams_df(df: pd.DataFrame) -> None:
91	    """Validate that a teams DataFrame has the required schema."""
92	    _validate_dataframe(df, REQUIRED_TEAMS_COLUMNS, "teams")
93	
94	
95	class DataLoader:
96	    """Reads raw CSV files into DataFrames with column validation."""
97	
98	    def __init__(self, config: DataConfig, root: Path | None = None) -> None:
99	        self._config = config
100	        self._root = root or Path.cwd()
101	
102	    def load_matches(self) -> pd.DataFrame:
103	        """Load matches.csv into a validated DataFrame.
104	
105	        Returns:
106	            DataFrame conforming to ``REQUIRED_MATCHES_COLUMNS``.
107	
108	        Raises:
109	            ValueError: If ``matches_path`` is not configured.
110	            ValueError: If the loaded DataFrame fails schema validation.
111	        """
112	        if self._config.matches_path is None:
113	            raise ValueError(
114	                "matches_path is not configured; run 'worldcup download' first "
115	                "or set data.matches_path in your config"
116	            )
117	        path = self._root / self._config.matches_path
118	        logger.info("Loading matches from %s", path)
119	        df = pd.read_csv(path)
120	        validate_matches_df(df)
121	        return df
122	
123	    def load_teams(self) -> pd.DataFrame:
124	        """Load teams.csv into a validated DataFrame.
125	
126	        Returns:
127	            DataFrame conforming to ``REQUIRED_TEAMS_COLUMNS``.
128	
129	        Raises:
130	            ValueError: If ``teams_path`` is not configured.
131	            ValueError: If the loaded DataFrame fails schema validation.
132	        """
133	        if self._config.teams_path is None:
134	            raise ValueError(
135	                "teams_path is not configured; run 'worldcup download' first "
136	                "or set data.teams_path in your config"
137	            )
138	        path = self._root / self._config.teams_path
139	        logger.info("Loading teams from %s", path)
140	        df = pd.read_csv(path)
141	        validate_teams_df(df)
142	        return df
143	
