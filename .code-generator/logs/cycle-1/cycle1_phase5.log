2026-06-23 22:07:47,772 DEBUG msg #162: UserMessage tool_result(toolu_01GbBzq14mcr315RveRNw2Zs): 1	"""WC2026 Round-of-32 bracket-slotting rules.
2	
3	Pure data + pure functions. No network, no FootballClient, no randomness.
4	Derives concrete R32 ties from final group standings.
5	
6	Slot notation:
7	  "1X"   — group X winner
8	  "2X"   — group X runner-up
9	  "3XYZ" — best-third placeholder; letters list eligible source groups
10	"""
11	
12	from __future__ import annotations
13	
14	import logging
15	from itertools import combinations
16	
17	logger = logging.getLogger(__name__)
18	
19	# ---------------------------------------------------------------------------
20	# Module-level constants
21	# ---------------------------------------------------------------------------
22	
23	GROUPS: tuple[str, ...] = tuple("ABCDEFGHIJKL")
24	
25	# Each entry: (placeholder_name, frozenset_of_eligible_source_groups)
26	# Source: official FIFA WC2026 R32 bracket (matches 73–88).
27	_THIRD_SLOT_CANDIDATES: tuple[tuple[str, frozenset[str]], ...] = (
28	    ("3ABCDF", frozenset("ABCDF")),
29	    ("3CDFGH", frozenset("CDFGH")),
30	    ("3CEFHI", frozenset("CEFHI")),
31	    ("3EHIJK", frozenset("EHIJK")),
32	    ("3BEFIJ", frozenset("BEFIJ")),
33	    ("3AEHIJ", frozenset("AEHIJ")),
34	    ("3EFGIJ", frozenset("EFGIJ")),
35	    ("3DEIJL", frozenset("DEIJL")),
36	)
37	
38	# Official WC2026 R32 bracket template (matches 73–88, per FIFA/Wikipedia).
39	# Tuple is immutable (frozen). Each entry: (home_slot, away_slot).
40	R32_SLOTS: tuple[tuple[str, str], ...] = (
41	    ("2A", "2B"),       # M73
42	    ("1E", "3ABCDF"),   # M74  Germany (1E) vs best-3rd from A/B/C/D/F
43	    ("1F", "2C"),       # M75
44	    ("1C", "2F"),       # M76
45	    ("1I", "3CDFGH"),   # M77  France (1I) vs best-3rd from C/D/F/G/H
46	    ("2E", "2I"),       # M78
47	    ("1A", "3CEFHI"),   # M79  Mexico (1A) vs best-3rd from C/E/F/H/I
48	    ("1L", "3EHIJK"),   # M80
49	    ("1D", "3BEFIJ"),   # M81  USA (1D) vs best-3rd from B/E/F/I/J
50	    ("1G", "3AEHIJ"),   # M82
51	    ("2K", "2L"),       # M83
52	    ("1H", "2J"),       # M84
53	    ("1B", "3EFGIJ"),   # M85
54	    ("1J", "2H"),       # M86  Argentina (1J) vs runner-up H
55	    ("1K", "3DEIJL"),   # M87
56	    ("2D", "2G"),       # M88
57	)
58	
59	
60	# ---------------------------------------------------------------------------
61	# Bipartite matching (private helpers)
62	# ---------------------------------------------------------------------------
63	
64	def _augment(
65	    slot: int,
66	    adj: list[list[int]],
67	    match: list[int],
68	    seen: list[bool],
69	) -> bool:
70	    """Try to find an augmenting path for *slot*; update *match* in-place."""
71	    for g in adj[slot]:
72	        if not seen[g]:
73	            seen[g] = True
74	            if match[g] == -1 or _augment(match[g], adj, match, seen):
75	                match[g] = slot
76	                return True
77	    return False
78	
79	
80	def _bipartite_match(
81	    qualifying: frozenset[str],
82	    slots: tuple[tuple[str, frozenset[str]], ...],
83	) -> dict[str, str] | None:
84	    """Return slot→group assignment via augmenting paths, or None if impossible."""
85	    groups = sorted(qualifying)
86	    g_idx = {g: i for i, g in enumerate(groups)}
87	    adj = [[g_idx[g] for g in cands if g in qualifying] for _, cands in slots]
88	    match: list[int] = [-1] * len(groups)
89	    n = sum(_augment(s, adj, match, [False] * len(groups)) for s in range(len(slots)))
90	    if n < len(slots):
91	        return None
92	    slot_map = {match[i]: groups[i] for i in range(len(groups)) if match[i] != -1}
93	    return {slots[s][0]: slot_map[s] for s in range(len(slots))}
94	
95	
96	# ---------------------------------------------------------------------------
97	# THIRD_PLACE_COMBINATIONS — computed once at import (pure, deterministic)
98	# ---------------------------------------------------------------------------
99	
100	def _compute_third_place_combinations() -> dict[frozenset[str], dict[str, str]]:
101	    """Enumerate all valid 8-of-12 qualifying-third combinations via bipartite matching."""
102	    return {
103	        frozenset(combo): m
104	        for combo in combinations(GROUPS, 8)
105	        if (m := _bipartite_match(frozenset(combo), _THIRD_SLOT_CANDIDATES)) is not None
106	    }
107	
108	
109	# Official lookup: qualifying-8-groups frozenset → {placeholder: group_letter}.
110	# Covers every 8-of-12 combination that admits a valid slot assignment.
111	THIRD_PLACE_COMBINATIONS: dict[frozenset[str], dict[str, str]] = (
112	    _compute_third_place_combinations()
113	)
114	
115	
116	# ---------------------------------------------------------------------------
117	# Private slot-resolution helpers
118	# ---------------------------------------------------------------------------
119	
120	def _get_row_at(table: list[dict], position: int) -> dict:
121	    """Return the row whose `position` field equals *position*, or fall back by index."""
122	    return next(
123	        (r for r in table if r.get("position") == position),
124	        table[position - 1],
125	    )
126	
127	
128	def _third_sort_key(group: str, row: dict) -> tuple:
129	    """FIFA tiebreak key for third-placed teams (lower = better rank)."""
130	    return (
131	        -row.get("points", 0),
132	        -row.get("goalDifference", 0),
133	        -row.get("goalsFor", 0),
134	        group,  # alphabetical as the final, deterministic tiebreaker
135	    )
136	
137	
138	def _resolve_slot(
139	    slot: str,
140	    standings: dict[str, list[dict]],
141	    third_map: dict[str, str],
142	) -> str:
143	    """Translate a bracket slot label into a concrete team name."""
144	    group = third_map[slot] if slot.startswith("3") else slot[1]
145	    pos = 3 if slot.startswith("3") else int(slot[0])
146	    return _get_row_at(standings[group], pos)["team"]["name"]
147	
148	
149	# ---------------------------------------------------------------------------
150	# Public API
151	# ---------------------------------------------------------------------------
152	
153	def rank_third_places(standings: dict[str, list[dict]]) -> list[str]:
154	    """Return the 8 qualifying third-place group letters ranked by FIFA tiebreak.
155	
156	    *standings* maps group letter → list-of-table-row dicts (football-data.org v4 schema).
157	    """
158	    ranked = sorted(
159	        standings.items(),
160	        key=lambda kv: _third_sort_key(kv[0], _get_row_at(kv[1], 3)),
161	    )
162	    return [group for group, _ in ranked[:8]]
163	
164	
165	def assign_thirds(qualified_third_groups: frozenset[str]) -> dict[str, str]:
166	    """Map each 3X placeholder to a concrete group letter via THIRD_PLACE_COMBINATIONS."""
167	    return THIRD_PLACE_COMBINATIONS[qualified_third_groups]
168	
169	
170	def resolve_r32(standings: dict[str, list[dict]]) -> list[tuple[str, str]]:
171	    """Resolve 16 R32 ties from final group standings to concrete (home, away) pairs."""
172	    third_map = assign_thirds(frozenset(rank_third_places(standings)))
173	    return [
174	        (_resolve_slot(h, standings, third_map), _resolve_slot(a, standings, third_map))
175	        for h, a in R32_SLOTS
176	    ]
177	
