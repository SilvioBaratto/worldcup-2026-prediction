94	def _make_standings_json(n_groups: int = 12) -> dict:
95	    """Return a standings payload with *n_groups* groups (default 12 for WC2026)."""
96	    groups = [f"GROUP_{chr(65 + i)}" for i in range(n_groups)]
97	    return {
98	        "standings": [
99	            {
100	                "stage": "GROUP_STAGE",
101	                "type": "TOTAL",
102	                "group": group,
103	                "table": [
104	                    {
105	                        "position": 1,
106	                        "team": {"id": idx * 4 + 1, "name": f"Team_{group}_1"},
107	                        "playedGames": 1,
108	                        "form": "W",
109	                        "won": 1,
110	                        "draw": 0,
111	                        "lost": 0,
112	                        "points": 3,
113	                        "goalsFor": 2,
114	                        "goalsAgainst": 0,
115	                        "goalDifference": 2,
116	                    }
117	                ],
118	            }
119	            for idx, group in enumerate(groups)
120	        ]
121	    }
122	
