31	
32	def _table_row(
33	    position: int,
34	    team_name: str,
35	    points: int,
36	    gd: int,
37	    gf: int,
38	) -> dict:
39	    """Build one row of a group table matching the football-data.org v4 schema."""
40	    return {
41	        "position": position,
42	        "team": {"name": team_name},
43	        "playedGames": 3,
44	        "points": points,
45	        "goalsFor": gf,
46	        "goalsAgainst": max(gf - gd, 0),
47	        "goalDifference": gd,
48	        "won": 0,
49	        "draw": 0,
50	        "lost": 0,
51	    }
52	
53	
54	def _group_table(letter: str, pts3: int, gd3: int, gf3: int) -> list[dict]:
55	    """4-row group table; third-placed team ('Team{letter}3') has the given stats."""
56	    gf3 = max(gf3, 0)
57	    return [
58	        _table_row(1, f"Team{letter}1", 9, 6, 8),
59	        _table_row(2, f"Team{letter}2", 6, 2, 5),
60	        _table_row(3, f"Team{letter}3", pts3, gd3, gf3),
61	        _table_row(4, f"Team{letter}4", 0, -8, 1),
62	    ]
63	
64	
65	def _uniform_standings(pts3: int = 3, gd3: int = 0, gf3: int = 2) -> dict[str, list[dict]]:
66	    """All 12 groups with identical third-place statistics (ties broken by group letter)."""
67	    return {g: _group_table(g, pts3, gd3, gf3) for g in _ALL_GROUPS}
68	
69	
70	def _standings_first_n_superior(n: int = 8) -> dict[str, list[dict]]:
71	    """
72	    First *n* groups (A … nth) have clearly superior third-placed teams;
73	    the remaining (12 - n) have clearly inferior ones.
74	    """
75	    result = {}
76	    for i, g in enumerate(_ALL_GROUPS):
77	        if i < n:
78	            result[g] = _group_table(g, pts3=4, gd3=2, gf3=4)
79	        else:
80	            result[g] = _group_table(g, pts3=1, gd3=-3, gf3=1)
81	    return result
82	
83	
84	def _standings_for_first_known_combo() -> dict[str, list[dict]]:
85	    """
86	    Build standings whose top-8 thirds exactly match the first entry in
87	    THIRD_PLACE_COMBINATIONS, so resolve_r32 can always resolve the bracket.
88	    """
89	    from worldcup_playoff.data import THIRD_PLACE_COMBINATIONS
90	
91	    first_key = next(iter(THIRD_PLACE_COMBINATIONS))
92	    qualifying = frozenset(first_key)
93	    result = {}
94	    for g in _ALL_GROUPS:
95	        if g in qualifying:
96	            result[g] = _group_table(g, pts3=4, gd3=2, gf3=4)
97	        else:
98	            result[g] = _group_table(g, pts3=1, gd3=-3, gf3=1)
99	    return result
