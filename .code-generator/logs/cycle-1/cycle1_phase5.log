45	class BracketBuilder:
46	    """Fetches the competition's qualified teams and produces a ``BracketConfig``.
47	
48	    The bracket is built as a Round of 32 (16 matchups) where teams are paired
49	    by their position in the API response: position 1 vs 32, 2 vs 31, etc.
50	    If fewer than 32 teams are present the bracket is built with the available
51	    teams (power-of-two enforcement is validated and logged as a warning).
52	    """
53	
54	    def __init__(
55	        self,
56	        client: FootballClient,
57	        season: str | None = None,
58	        competition: str | None = None,
59	    ) -> None:
60	        self._client = client
61	        self._season = season or default_season()
62	        self._competition = competition or default_competition()
63	
64	    def build(self) -> BracketConfig:
65	        """Fetch teams and return a ``BracketConfig`` with Round-of-32 matchups."""
66	        team_names = self._fetch_team_names()
67	        matchups = self._pair_teams(team_names)
68	        bracket = BracketConfig(
69	            name=f"FIFA World Cup {self._season} Bracket",
70	            matchups=matchups,
71	        )
72	        self._validate_bracket(bracket)
73	        return bracket
74	
75	    def _fetch_team_names(self) -> list[str]:
76	        """Fetch qualified/registered teams for the competition.
77	
78	        Returns a list of country-name strings ordered by their API position
79	        (the API returns them in seed order when data is available).
80	        """
81	        try:
82	            data = self._client.get(
83	                f"/competitions/{self._competition}/teams",
84	                params={"season": self._season},
85	            )
86	        except Exception:
87	            logger.warning(
88	                "Failed to fetch teams for %s/%s via season param; retrying without",
89	                self._competition,
90	                self._season,
91	                exc_info=True,
92	            )
93	            data = self._client.get(f"/competitions/{self._competition}/teams")
94	
95	        teams: list[dict[str, object]] = data.get("teams", [])
96	        if not teams:
97	            msg = (
98	                f"No teams returned for competition {self._competition} "
99	                f"season {self._season}"
100	            )
101	            raise RuntimeError(msg)
102	
103	        names: list[str] = []
104	        for team in teams:
105	            name = str(team.get("name", "") or team.get("shortName", "") or "")
106	            if name:
107	                names.append(name)
108	
109	        logger.info(
110	            "Fetched %d team names for %s/%s", len(names), self._competition, self._season
111	        )
112	        return names
113	
114	    @staticmethod
115	    def _pair_teams(team_names: list[str]) -> list[Matchup]:
116	        """Create seed-based matchups from the ordered team list.
117	
118	        Seed 1 plays seed N, seed 2 plays seed N-1, etc.  If the number of
119	        teams is not a power of two the pairing still proceeds with the
120	        available teams and a warning is emitted.
121	        """
122	        n = len(team_names)
123	        import math
124	
125	        if n < 2:
126	            msg = f"Need at least 2 teams, got {n}"
127	            raise ValueError(msg)
128	
129	        if n & (n - 1) != 0:
130	            # Round down to nearest power of two to form a valid bracket
131	            n_bracket = 2 ** math.floor(math.log2(n))
132	            logger.warning(
133	                "Team count %d is not a power of two; using top %d teams for bracket",
134	                n,
135	                n_bracket,
136	            )
137	            team_names = team_names[:n_bracket]
138	            n = n_bracket
139	
140	        matchups: list[Matchup] = []
141	        for high_seed in range(1, n // 2 + 1):
142	            low_seed = n + 1 - high_seed
143	            home = team_names[high_seed - 1]
144	            away = team_names[low_seed - 1]
145	            matchups.append(Matchup(home=home, away=away, group=""))
146	        return matchups
147	
148	    @staticmethod
149	    def _validate_bracket(bracket: BracketConfig) -> None:
150	        """Verify that the bracket has the expected structure.
151	
152	        Raises:
153	            ValueError: If fewer than 2 matchups are present or team names repeat.
154	        """
155	        if len(bracket.matchups) < 2:  # noqa: PLR2004
156	            msg = f"Expected at least 2 matchups, got {len(bracket.matchups)}"
157	            raise ValueError(msg)
158	
159	        all_teams = [m.home for m in bracket.matchups] + [m.away for m in bracket.matchups]
160	        if len(all_teams) != len(set(all_teams)):
161	            duplicates = {t for t in all_teams if all_teams.count(t) > 1}
162	            msg = f"Duplicate teams in bracket: {duplicates}"
163	            raise ValueError(msg)
164	
165	
166	def _serialize_bracket_toml(bracket: BracketConfig, season: str, competition: str) -> str:
167	    """Serialize a BracketConfig to TOML format.
168	
169	    Args:
170	        bracket: The bracket configuration to serialize.
171	        season: Season label included in the header comment.
172	        competition: Competition code included in the header comment.
173	
174	    Returns:
175	        TOML-formatted string.
176	    """
177	    buf = io.StringIO()
178	    buf.write(f"# Auto-generated from {competition} {season} standings\n")
179	    buf.write(f'name = "{bracket.name}"\n')
180	
181	    for matchup in bracket.matchups:
182	        buf.write("\n[[matchups]]\n")
183	        buf.write(f'home = "{matchup.home}"\n')
184	        buf.write(f'away = "{matchup.away}"\n')
185	        buf.write(f'group = "{matchup.group}"\n')
186	
187	    return buf.getvalue()
188	
189	
190	def generate_bracket_toml(
191	    output_path: Path,
192	    *,
193	    season: str | None = None,
194	    competition: str = "WC",
195	    client: FootballClient | None = None,
196	) -> BracketConfig:
197	    """Build a World Cup bracket from qualified teams and write to a TOML file.
198	
199	    Args:
200	        output_path: Where to write the TOML file.
201	        season: World Cup year string (e.g. ``"2026"``). Inferred from date if ``None``.
202	        competition: football-data.org competition code (default ``"WC"``).
203	        client: Rate-limited API client. Created with defaults if ``None``.
204	
205	    Returns:
206	        The generated ``BracketConfig``.
207	    """
208	    if client is None:
209	        client = FootballClient(ClientConfig())
210	
211	    resolved_season = season or default_season()
212	
213	    builder = BracketBuilder(client, season=resolved_season, competition=competition)
214	    bracket = builder.build()
215	
216	    output_path.parent.mkdir(parents=True, exist_ok=True)
217	    content = _serialize_bracket_toml(bracket, resolved_season, competition)
218	    output_path.write_text(content)
219	    logger.info("Wrote bracket to %s", output_path)
220	    return bracket
221	
