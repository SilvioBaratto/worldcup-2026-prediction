2026-06-23 22:33:54,225 DEBUG msg #70: UserMessage tool_result(toolu_01McTv1vnRYrYNXitYKXJfUM): 1	"""Team-name normalization: maps alias spellings to canonical country names."""
2	
3	from __future__ import annotations
4	
5	import logging
6	import re
7	
8	import pandas as pd
9	
10	logger = logging.getLogger(__name__)
11	
12	# Alias → canonical mapping. Keys are stored in their natural casing;
13	# lookup normalizes to lowercase+stripped at call time so the dict stays compact.
14	CANONICAL_NAMES: dict[str, str] = {
15	    # Turkey
16	    "Türkiye": "Turkey",
17	    "Turkey": "Turkey",
18	    # Czech Republic
19	    "Czechia": "Czech Republic",
20	    "Czech Republic": "Czech Republic",
21	    # South Korea
22	    "South Korea": "South Korea",
23	    "Korea Republic": "South Korea",
24	    "Republic of Korea": "South Korea",
25	    # United States
26	    "United States": "United States",
27	    "USA": "United States",
28	    "United States of America": "United States",
29	    # Iran
30	    "IR Iran": "Iran",
31	    "Iran": "Iran",
32	    # China
33	    "China PR": "China",
34	    "China": "China",
35	    # DRC / Congo
36	    "DR Congo": "DR Congo",
37	    "Congo DR": "DR Congo",
38	    # Ivory Coast
39	    "Ivory Coast": "Ivory Coast",
40	    "Côte d'Ivoire": "Ivory Coast",
41	    # North Macedonia
42	    "North Macedonia": "North Macedonia",
43	    "Macedonia": "North Macedonia",
44	    # Bosnia
45	    "Bosnia and Herzegovina": "Bosnia and Herzegovina",
46	    "Bosnia & Herzegovina": "Bosnia and Herzegovina",
47	    # Trinidad and Tobago
48	    "Trinidad and Tobago": "Trinidad and Tobago",
49	    "Trinidad & Tobago": "Trinidad and Tobago",
50	    # Cabo Verde
51	    "Cabo Verde": "Cabo Verde",
52	    "Cape Verde": "Cabo Verde",
53	}
54	
55	# Reverse lookup: lowercased+stripped alias → canonical, built once at import time.
56	_LOOKUP: dict[str, str] = {
57	    re.sub(r"\s+", " ", k.strip()).lower(): v for k, v in CANONICAL_NAMES.items()
58	}
59	
60	
61	def normalize_team(name: str) -> str:
62	    """Return the canonical country name for *name*, or the cleaned input if unknown."""
63	    cleaned = re.sub(r"\s+", " ", name.strip())
64	    return _LOOKUP.get(cleaned.lower(), cleaned)
65	
66	
67	def normalize_series(s: pd.Series) -> pd.Series:
68	    """Vectorized version of *normalize_team*; preserves index and length."""
69	    return s.map(normalize_team)
70	
71	
72	def is_known(name: str) -> bool:
73	    """Return True when *name* maps to a canonical country name."""
74	    return re.sub(r"\s+", " ", name.strip()).lower() in _LOOKUP
75	
