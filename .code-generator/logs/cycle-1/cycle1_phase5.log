487	def test_when_data_package_reloaded_then_no_http_request_is_initiated(monkeypatch):
488	    """No HTTP request (via requests.Session or requests.get) must fire on import."""
489	    import importlib
490	
491	    import requests
492	
493	    blocked: list[tuple] = []
494	
495	    def _forbid_get(*args, **kwargs):
496	        blocked.append(args)
497	        raise AssertionError(f"HTTP GET called during import: {args}")
498	
499	    def _forbid_post(*args, **kwargs):
500	        blocked.append(args)
501	        raise AssertionError(f"HTTP POST called during import: {args}")
502	
503	    monkeypatch.setattr(requests, "get", _forbid_get)
504	    monkeypatch.setattr(requests, "post", _forbid_post)
505	
506	    import worldcup_playoff.data
507	
508	    importlib.reload(worldcup_playoff.data)  # must not trigger _forbid_get/_forbid_post
509	
510	    assert not blocked, f"HTTP call(s) made on import: {blocked}"
511	
512	
513	def test_when_data_package_reloaded_then_football_client_is_not_constructed(monkeypatch):
514	    """FootballClient.__init__ must not be called as a side-effect of importing."""
515	    import importlib
516	
517	    constructed: list[bool] = []
518	    try:
519	        from worldcup_playoff.data import client as _client_mod
520	
521	        _original_init = _client_mod.FootballClient.__init__
522	
523	        def _spy_init(self, *args, **kwargs):
524	            constructed.append(True)
525	            return _original_init(self, *args, **kwargs)
526	
527	        monkeypatch.setattr(_client_mod.FootballClient, "__init__", _spy_init)
528	    except (ImportError, AttributeError):
529	        return  # client module absent — purity is guaranteed by absence
530	
531	    import worldcup_playoff.data
532	
533	    importlib.reload(worldcup_playoff.data)
534	    assert not constructed, "FootballClient was instantiated during package import"
535	
