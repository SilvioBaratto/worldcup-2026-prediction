139	    if type_errors:
140	        raise ValueError(f"{label} DataFrame has wrong column dtype(s):\n" + "\n".join(type_errors))
141	
142	
143	def validate_results_df(df: pd.DataFrame) -> None:
144	    """Validate that a results DataFrame conforms to the martj42 results schema."""
145	    _validate_martj42(df, REQUIRED_MARTJ42_RESULTS_COLUMNS, "martj42_results")
146	
147	
148	def validate_shootouts_df(df: pd.DataFrame) -> None:
149	    """Validate that a shootouts DataFrame conforms to the martj42 shootouts schema."""
150	    _validate_martj42(df, REQUIRED_MARTJ42_SHOOTOUTS_COLUMNS, "martj42_shootouts")
151	
152	
153	def validate_goalscorers_df(df: pd.DataFrame) -> None:
154	    """Validate that a goalscorers DataFrame conforms to the martj42 goalscorers schema."""
155	    _validate_martj42(df, REQUIRED_MARTJ42_GOALSCORERS_COLUMNS, "martj42_goalscorers")
156	
157	
158	# ---------------------------------------------------------------------------
