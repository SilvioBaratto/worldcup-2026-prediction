125	def _project_root(config: Path) -> Path:
126	    """Derive project root from the config file path.
127	
128	    The default config lives at ``<root>/config/default.toml``, so the project
129	    root is two levels above the config file.  Using the *resolved* (absolute)
130	    path ensures the result is independent of the caller's working directory.
131	
132	    Args:
133	        config: Path to the pipeline config TOML (e.g. ``config/default.toml``).
134	
135	    Returns:
136	        Absolute path to the project root directory.
137	    """
138	    return config.resolve().parent.parent
