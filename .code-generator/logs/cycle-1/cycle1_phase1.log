62	def _make_valid_matches_df() -> pd.DataFrame:
63	    return pd.DataFrame(
64	        {
65	            "MATCH_ID": pd.array([1], dtype="int64"),
66	            "DATE": ["2022-12-18"],
67	            "HOME_TEAM": ["Brazil"],
68	            "AWAY_TEAM": ["France"],
69	            "HOME_GOALS": pd.array([2], dtype="int64"),
70	            "AWAY_GOALS": pd.array([1], dtype="int64"),
71	            "COMPETITION": ["WC"],
72	            "SEASON": pd.array([2022], dtype="int64"),
73	        }
74	    )
75	
76	
77	def _make_valid_train_df(n: int = 10) -> pd.DataFrame:
78	    """Build a valid train_data.csv DataFrame with the full schema."""
79	    rng = np.random.default_rng(0)
80	    rows = []
81	    for i in range(n):
82	        h_goals = int(rng.integers(0, 4))
83	        a_goals = int(rng.integers(0, 3))
84	        if h_goals == a_goals:
85	            h_goals += 1
86	        rows.append(
87	            {
88	                "HOME_TEAM": f"Team{i}",
89	                "AWAY_TEAM": f"Team{(i + 1) % n}",
90	                "GOALS_home": h_goals,
91	                "SHOTS_home": h_goals * 5 + 7,
92	                "SHOTS_ON_TARGET_home": max(h_goals + 2, (h_goals * 5 + 7) // 3),
93	                "POSSESSION_home": 55.0,
94	                "PASS_PCT_home": 78.0,
95	                "GOALS_away": a_goals,
96	                "SHOTS_away": a_goals * 5 + 7,
97	                "SHOTS_ON_TARGET_away": max(a_goals + 2, (a_goals * 5 + 7) // 3),
98	                "POSSESSION_away": 45.0,
99	                "PASS_PCT_away": 72.0,
100	                "HOME_WIN": int(h_goals > a_goals),
101	            }
102	        )
103	    return pd.DataFrame(rows)
104	
