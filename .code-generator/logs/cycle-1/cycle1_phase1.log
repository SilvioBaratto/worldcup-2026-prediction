549	@app.command()
550	def simulate(
551	    config: Path = typer.Option("config/default.toml", "--config", "-c"),
552	    bracket: Path = typer.Option(
553	        "config/playoff_2026.toml", "--bracket", "-b"
554	    ),
555	    n_simulations: int | None = typer.Option(None, "--n-simulations", "-n"),
556	    verbose: int = typer.Option(0, "--verbose", "-v", count=True),
557	) -> None:
558	    """Run Monte Carlo World Cup knockout simulation."""
559	    _setup_logging(verbose)
560	    cfg = load_config(config)
561	    bracket_cfg = load_bracket(bracket)
562	
563	    if n_simulations is not None:
564	        cfg = cfg.model_copy(
565	            update={
566	                "simulation": SimulationConfig.model_validate(
567	                    {**cfg.simulation.model_dump(), "n_simulations": n_simulations}
568	                )
569	            }
