58	def _print_metrics(name: str, metrics: dict) -> None:  # type: ignore[type-arg]
59	    """Pretty-print classifier evaluation metrics as a Rich table.
60	
61	    Args:
62	        name: Classifier display name used as the table title.
63	        metrics: Dict returned by ``ModelEvaluator.evaluate`` — must contain
64	            ``"classification_report"`` with per-class dicts and ``"accuracy"``.
65	    """
66	    report = metrics["classification_report"]
67	    table = Table(title=f"[bold]{name}[/bold]", show_lines=True)
68	    table.add_column("Class", style="cyan")
69	    table.add_column("Precision", justify="right")
70	    table.add_column("Recall", justify="right")
71	    table.add_column("F1-Score", justify="right")
72	    table.add_column("Support", justify="right")
73	
74	    for label in ("0", "1"):
75	        if label in report:
76	            r = report[label]
77	            table.add_row(
78	                label,
79	                f"{r['precision']:.3f}",
80	                f"{r['recall']:.3f}",
81	                f"{r['f1-score']:.3f}",
82	                str(int(r["support"])),
83	            )
84	    table.add_row("accuracy", "", "", f"{report['accuracy']:.3f}", "", style="bold")
85	    console.print(table)
