147	
148	_MATCHES_COLUMNS = [
149	    "MATCH_ID",
150	    "DATE",
151	    "HOME_TEAM",
152	    "AWAY_TEAM",
153	    "HOME_GOALS",
154	    "AWAY_GOALS",
155	    "COMPETITION",
156	    "SEASON",
157	]
158	
159	# Competition codes iterated when building the historical matches dataset.
160	# These are the main international tournaments available on football-data.org v4.
161	_MATCH_COMPETITION_CODES = ["WC", "EC", "CA", "CL", "PL", "BL1", "SA", "PD", "FL1"]
162	
163	
164	class MatchesBuilder:
165	    """Fetches match results per competition per season and assembles matches.csv.
166	
167	    Mirrors ``GamesBuilder`` in the NBA original.
168	    """
169	
170	    def __init__(
171	        self,
172	        client: FootballClient,
173	        start_year: int = 2006,
174	        end_year: int | None = None,
175	        competition_codes: list[str] | None = None,
176	    ) -> None:
177	        self._client = client
178	        self._start_year = start_year
179	        self._end_year = end_year if end_year is not None else datetime.date.today().year
180	        self._competition_codes = competition_codes or _MATCH_COMPETITION_CODES
181	
182	    def build(self) -> pd.DataFrame:
183	        """Fetch all competitions × seasons, returning the matches DataFrame."""
184	        frames: list[pd.DataFrame] = []
185	
186	        for code in self._competition_codes:
187	            for year in range(self._start_year, self._end_year + 1):
188	                df = self._fetch_season(code, year)
189	                if df is not None:
190	                    frames.append(df)
191	
192	        if not frames:
193	            msg = "All match fetches failed — no data to build matches.csv"
194	            raise RuntimeError(msg)
195	
196	        result = pd.concat(frames, ignore_index=True)
197	
198	        # Remove duplicate match IDs (same match may appear under multiple codes)
199	        result = result.drop_duplicates(subset=["MATCH_ID"]).reset_index(drop=True)
200	
201	        missing = set(_MATCHES_COLUMNS) - set(result.columns)
202	        if missing:
203	            msg = f"Missing columns after assembly: {missing}"
204	            raise RuntimeError(msg)
205	
206	        logger.info(
207	            "Built matches DataFrame: %d rows across %d competition-season combos",
208	            len(result),
209	            len(frames),
210	        )
211	        return result
212	
213	    def _fetch_season(self, code: str, year: int) -> pd.DataFrame | None:
214	        """Fetch all finished matches for one competition-season. Returns None on failure."""
215	        try:
216	            data = self._client.get(
217	                f"/competitions/{code}/matches",
218	                params={"season": str(year), "status": "FINISHED"},
219	            )
220	            matches: list[dict[str, object]] = data.get("matches", [])
221	            if not matches:
222	                return None
223	            rows = [self._extract_match_row(m, code, year) for m in matches]
224	            # Drop rows where team names could not be resolved
225	            valid = [r for r in rows if r is not None]
226	            if not valid:
227	                return None
228	            df = pd.DataFrame(valid, columns=_MATCHES_COLUMNS)
229	            logger.info(
230	                "Fetched %d matches for %s/%d", len(df), code, year
231	            )
232	            return df
233	        except Exception:
234	            logger.warning(
235	                "Failed to fetch matches for %s/%d", code, year, exc_info=True
236	            )
237	            return None
238	
239	    @staticmethod
240	    def _extract_match_row(
241	        match: dict[str, object],
242	        code: str,
243	        year: int,
244	    ) -> dict[str, object] | None:
245	        """Map a single API match object to the matches.csv row schema.
246	
247	        Pure transformation — no I/O.
248	        """
249	        try:
250	            home_team = (
251	                match.get("homeTeam", {}).get("name", "")  # type: ignore[union-attr]
252	                or match.get("homeTeam", {}).get("shortName", "")  # type: ignore[union-attr]
253	            )
254	            away_team = (
255	                match.get("awayTeam", {}).get("name", "")  # type: ignore[union-attr]
256	                or match.get("awayTeam", {}).get("shortName", "")  # type: ignore[union-attr]
257	            )
258	            if not home_team or not away_team:
259	                return None
260	
261	            score = match.get("score", {})  # type: ignore[union-attr]
262	            full_time = score.get("fullTime", {})  # type: ignore[union-attr]
263	            home_goals = full_time.get("home")
264	            away_goals = full_time.get("away")
265	            if home_goals is None or away_goals is None:
266	                return None
267	
268	            utc_date = str(match.get("utcDate", ""))
269	            date_str = utc_date[:10] if utc_date else ""  # "YYYY-MM-DD"
270	
271	            return {
272	                "MATCH_ID": int(match.get("id", 0)),  # type: ignore[call-overload]
273	                "DATE": date_str,
274	                "HOME_TEAM": str(home_team),
275	                "AWAY_TEAM": str(away_team),
276	                "HOME_GOALS": int(home_goals),
277	                "AWAY_GOALS": int(away_goals),
278	                "COMPETITION": code,
279	                "SEASON": year,
280	            }
281	        except Exception:
282	            logger.debug("Skipping malformed match record: %s", match, exc_info=True)
283	            return None
284	
285	
286	def build_matches_csv(
287	    output_path: Path,
288	    client: FootballClient | None = None,
289	    start_year: int = 2006,
290	    end_year: int | None = None,
291	) -> pd.DataFrame:
292	    """Build matches.csv and write to disk.
293	
294	    Args:
295	        output_path: Where to write the CSV.
296	        client: Rate-limited API client. Created with defaults if ``None``.
297	        start_year: First season year to query (e.g. 2006).
298	        end_year: Last season year to query. Defaults to the current year.
299	
300	    Returns:
301	        The assembled DataFrame (8 columns matching the matches.csv schema).
302	    """
303	    if client is None:
304	        client = FootballClient(ClientConfig())
305	
306	    builder = MatchesBuilder(client, start_year=start_year, end_year=end_year)
307	    df = builder.build()
308	
309	    output_path.parent.mkdir(parents=True, exist_ok=True)
310	    df.to_csv(output_path, index=False)
311	    logger.info("Wrote %d matches to %s", len(df), output_path)
312	    return df
313	
