404	@app.command(name="build-match-details")
405	def build_match_details(
406	    config: Path = typer.Option(
407	        "config/default.toml", "--config", "-c", help="Pipeline config"
408	    ),
409	    matches_csv: Path = typer.Option(
410	        "dataset/csv/matches.csv",
411	        "--matches-csv",
412	        help="Source matches.csv for MATCH_ID column.",
413	    ),
414	    skip_details: bool = typer.Option(
415	        False, "--skip-details", help="Skip this command entirely."
416	    ),
417	    checkpoint_every: int = typer.Option(
418	        100, "--checkpoint-every", help="Checkpoint interval (matches)."
419	    ),
420	    verbose: int = typer.Option(0, "--verbose", "-v", count=True),
421	) -> None:
422	    """Fetch per-match detail stats and write dataset/csv/match_details.csv."""
423	    _setup_logging(verbose)
424	
425	    if skip_details:
426	        console.print("[yellow]Skipping match_details.csv build (--skip-details)[/yellow]")
427	        return
428	
429	    cfg = load_config(config)
430	    root = _project_root(config)
431	    matches_path = root / matches_csv
432	
433	    if not matches_path.exists():
434	        console.print(
435	            f"[red]matches.csv not found at {matches_path} — build it first[/red]"
436	        )
437	        raise typer.Exit(code=1)
438	
439	    matches_df = pd.read_csv(matches_path)
440	    match_ids = [str(int(mid)) for mid in matches_df["MATCH_ID"].unique()]
441	
442	    pipeline = Pipeline(cfg, root=root)
443	
444	    with console.status(
445	        f"[bold]Building match_details.csv — {len(match_ids)} matches...[/bold]"
446	    ):
447	        output = pipeline.run_build_match_details(
448	            match_ids=match_ids,
449	            checkpoint_every=checkpoint_every,
