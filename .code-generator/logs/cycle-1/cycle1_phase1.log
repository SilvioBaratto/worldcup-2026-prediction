55	class DataCleaner:
56	    """Transforms raw match data into analysis-ready training data.
57	
58	    Pipeline steps:
59	
60	    1. Validate input DataFrames.
61	    2. Merge ``matches_df`` with ``details_df`` (when provided) to attach
62	       the 10 feature columns per row.
63	    3. Filter rows by ``min_date``.
64	    4. Drop drawn matches (``HOME_GOALS == AWAY_GOALS``).
65	    5. Apply epsilon to zero possession/pass-pct values.
66	    6. Drop rows with NaN in any feature column.
67	    7. Apply train cutoff date.
68	    8. Add ``HOME_WIN`` binary target.
69	    9. Select and order output columns to match train_data.csv schema.
70	    """
71	
72	    def __init__(self, config: DataConfig, features_config: FeaturesConfig) -> None:
73	        self._config = config
74	        self._features = features_config
75	
76	    def clean(
77	        self,
78	        matches_df: pd.DataFrame,
79	        details_df: pd.DataFrame | None = None,
80	    ) -> pd.DataFrame:
81	        """Full cleaning pipeline.
82	
83	        Args:
84	            matches_df: Raw matches DataFrame (from matches.csv).
85	            details_df: Optional match details DataFrame (from match_details.csv).
86	                When absent, feature columns are taken directly from matches_df
87	                if present, otherwise the cleaner raises an error.
88	
89	        Returns:
90	            Cleaned DataFrame with exactly the ``_OUTPUT_COLUMNS`` schema.
91	
92	        Raises:
93	            ValueError: If required feature columns cannot be assembled.
94	        """
95	        validate_matches_df(matches_df)
96	
97	        df = self._sort_by_date(matches_df)
98	        df = self._filter_by_min_date(df)
99	        df = self._drop_draws(df)
100	        df = self._attach_features(df, details_df)
101	        df = self._fix_zero_percentages(df)
102	        df = self._drop_nan_features(df)
103	        df = self._apply_train_cutoff(df)
104	        df = self._add_home_win(df)
105	        df = self._select_output_columns(df)
106	
107	        logger.info("Cleaning complete: %d rows retained", len(df))
108	        return df
109	
110	    # ------------------------------------------------------------------
111	    # Pipeline steps — each is a pure transformation on the DataFrame
112	    # ------------------------------------------------------------------
113	
114	    def _sort_by_date(self, df: pd.DataFrame) -> pd.DataFrame:
115	        return df.sort_values(by="DATE").reset_index(drop=True)
116	
117	    def _filter_by_min_date(self, df: pd.DataFrame) -> pd.DataFrame:
118	        mask = df["DATE"] >= self._config.min_date
119	        filtered = df.loc[mask].reset_index(drop=True)
120	        logger.debug(
121	            "Filtered to matches after %s: %d -> %d rows",
122	            self._config.min_date,
123	            len(df),
124	            len(filtered),
125	        )
126	        return filtered
127	
128	    def _drop_draws(self, df: pd.DataFrame) -> pd.DataFrame:
129	        """Remove drawn matches where HOME_GOALS == AWAY_GOALS.
130	
131	        A knockout tie always produces a winner (extra time + penalties are
132	        collapsed into a single win/loss), so draws in the historical dataset
133	        are regular-season group matches — irrelevant for predicting elimination
134	        outcomes and confusing for a binary classifier.
135	        """
136	        before = len(df)
137	        mask = df["HOME_GOALS"] != df["AWAY_GOALS"]
138	        filtered = df.loc[mask].reset_index(drop=True)
139	        logger.debug("Dropped %d drawn matches", before - len(filtered))
140	        return filtered
141	
142	    def _attach_features(
143	        self, df: pd.DataFrame, details_df: pd.DataFrame | None
144	    ) -> pd.DataFrame:
145	        """Merge match_details statistics onto the main DataFrame.
146	
147	        If ``details_df`` is provided it is joined on ``MATCH_ID``.  Rows
148	        without a matching detail record receive NaN feature values (these
149	        are dropped later by ``_drop_nan_features``).
150	
151	        If ``details_df`` is ``None`` the method checks whether the 10 feature
152	        columns are already present (e.g. when the caller pre-merged them)
153	        and raises ``ValueError`` otherwise.
154	        """
155	        if details_df is not None:
156	            # Keep only the columns we need from details
157	            detail_cols = [c for c in _DETAIL_COLUMNS if c in details_df.columns]
158	            merged = df.merge(
159	                details_df[detail_cols],
160	                on="MATCH_ID",
161	                how="left",
162	                suffixes=("", "_detail"),
163	            )
164	            # For GOALS the matches.csv already has HOME_GOALS / AWAY_GOALS;
165	            # the detail file duplicates them — prefer the detail version.
166	            if "GOALS_home" in merged.columns and "HOME_GOALS" in merged.columns:
167	                merged["GOALS_home"] = merged["GOALS_home"].fillna(
168	                    merged["HOME_GOALS"]
169	                )
170	            else:
171	                merged["GOALS_home"] = merged["HOME_GOALS"]
172	
173	            if "GOALS_away" in merged.columns and "AWAY_GOALS" in merged.columns:
174	                merged["GOALS_away"] = merged["GOALS_away"].fillna(
175	                    merged["AWAY_GOALS"]
176	                )
177	            else:
178	                merged["GOALS_away"] = merged["AWAY_GOALS"]
179	
180	            return merged
181	
182	        # No details_df: ensure feature columns exist on the matches DataFrame
183	        missing_features = [c for c in self._features.selected if c not in df.columns]
184	        if missing_features:
185	            raise ValueError(
186	                f"Feature columns {missing_features} not found and no details_df provided. "
187	                "Run 'worldcup download --only match-details' or supply a details DataFrame."
188	            )
189	        # Copy GOALS from goals columns if not already named
190	        if "GOALS_home" not in df.columns:
191	            df = df.copy()
192	            df["GOALS_home"] = df["HOME_GOALS"]
193	            df["GOALS_away"] = df["AWAY_GOALS"]
194	        return df
195	
196	    def _fix_zero_percentages(self, df: pd.DataFrame) -> pd.DataFrame:
197	        """Replace zero values in percentage columns with epsilon.
198	
199	        Covers ``POSSESSION_home``, ``POSSESSION_away``, ``PASS_PCT_home``,
200	        ``PASS_PCT_away`` — any selected feature whose name contains 'PCT'
201	        or 'POSSESSION'.  After patching zeros, rows that still contain NaN
202	        in any feature column are dropped so classifiers receive a clean matrix.
203	        """
204	        eps = self._config.epsilon
205	        df = df.copy()
206	        pct_cols = [
207	            c
208	            for c in self._features.selected
209	            if "PCT" in c or "POSSESSION" in c
210	        ]
211	        for col in pct_cols:
212	            if col not in df.columns:
213	                continue
214	            mask = df[col] == 0
215	            if mask.any():
216	                df.loc[mask, col] = eps
217	                logger.debug("Fixed %d zero values in %s", int(mask.sum()), col)
218	        return df
219	
220	    def _drop_nan_features(self, df: pd.DataFrame) -> pd.DataFrame:
221	        """Drop rows with NaN in any feature column."""
222	        available = [c for c in self._features.selected if c in df.columns]
223	        before = len(df)
224	        df = df.dropna(subset=available).reset_index(drop=True)
225	        dropped = before - len(df)
226	        if dropped:
227	            logger.debug("Dropped %d rows with NaN in feature columns", dropped)
228	        return df
229	
230	    def _apply_train_cutoff(self, df: pd.DataFrame) -> pd.DataFrame:
231	        """Keep only matches before the training cutoff date."""
232	        mask = df["DATE"] < self._config.train_cutoff_date
233	        filtered = df.loc[mask].reset_index(drop=True)
234	        logger.debug(
235	            "Applied cutoff %s: %d -> %d rows",
236	            self._config.train_cutoff_date,
237	            len(df),
238	            len(filtered),
239	        )
240	        return filtered
241	
242	    def _add_home_win(self, df: pd.DataFrame) -> pd.DataFrame:
243	        """Add binary HOME_WIN column: 1 if HOME_GOALS > AWAY_GOALS else 0."""
244	        df = df.copy()
245	        df["HOME_WIN"] = (df["HOME_GOALS"] > df["AWAY_GOALS"]).astype(int)
246	        return df
247	
248	    def _select_output_columns(self, df: pd.DataFrame) -> pd.DataFrame:
249	        """Rename team ID columns to HOME_TEAM / AWAY_TEAM and select output schema.
250	
251	        The matches.csv stores team names directly in HOME_TEAM / AWAY_TEAM
252	        so no ID-to-name mapping is required (unlike the NBA original which
253	        uses numeric TEAM_IDs mapped through teams.csv).
254	        """
255	        available = [c for c in _OUTPUT_COLUMNS if c in df.columns]
256	        missing = set(_OUTPUT_COLUMNS) - set(available)
257	        if missing:
258	            raise ValueError(
259	                f"Cannot produce train_data.csv — missing columns: {missing}. "
260	                "Ensure match_details.csv was built and merged correctly."
261	            )
262	        return df[_OUTPUT_COLUMNS].reset_index(drop=True)
263	
264	    def write(
265	        self,
266	        matches_df: pd.DataFrame,
267	        details_df: pd.DataFrame | None = None,
268	        root: Path | None = None,
269	    ) -> pd.DataFrame:
270	        """Clean the data and write train_data.csv to ``DataConfig.output_path``.
271	
272	        Args:
273	            matches_df: Raw matches DataFrame.
274	            details_df: Optional match details DataFrame.
275	            root: Root directory prepended to ``output_path``. Defaults to cwd.
276	
277	        Returns:
278	            The cleaned DataFrame.
279	        """
280	        cleaned = self.clean(matches_df, details_df)
281	        root = root or Path.cwd()
282	        output_path = root / self._config.output_path
283	        output_path.parent.mkdir(parents=True, exist_ok=True)
284	        cleaned.to_csv(output_path, index=False)
285	        logger.info("Wrote train_data to %s (%d rows)", output_path, len(cleaned))
286	        return cleaned
287	
