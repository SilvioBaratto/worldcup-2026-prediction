22	# Columns produced in train_data.csv (mirrors SHARED CONTRACT)
23	_OUTPUT_COLUMNS = [
24	    "HOME_TEAM",
25	    "AWAY_TEAM",
26	    "GOALS_home",
27	    "SHOTS_home",
