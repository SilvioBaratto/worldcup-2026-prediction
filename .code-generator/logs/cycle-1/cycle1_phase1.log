58	def _print_metrics(name: str, metrics: dict) -> None:  # type: ignore[type-arg]
59	    """Pretty-print classifier evaluation metrics as a Rich table.
60	
61	    Args:
62	        name: Classifier display name used as the table title.
63	        metrics: Dict returned by ``ModelEvaluator.evaluate`` — must contain
64	            ``"classification_report"`` with per-class dicts and ``"accuracy"``.
65	    """
66	    report = metrics["classification_report"]
67	    table = Table(title=f"[bold]{name}[/bold]", show_lines=True)
68	    table.add_column("Class", style="cyan")
69	    table.add_column("Precision", justify="right")
70	    table.add_column("Recall", justify="right")
71	    table.add_column("F1-Score", justify="right")
72	    table.add_column("Support", justify="right")
73	
74	    for label in ("0", "1"):
75	        if label in report:
76	            r = report[label]
77	            table.add_row(
78	                label,
79	                f"{r['precision']:.3f}",
80	                f"{r['recall']:.3f}",
81	                f"{r['f1-score']:.3f}",
82	                str(int(r["support"])),
83	            )
84	    table.add_row("accuracy", "", "", f"{report['accuracy']:.3f}", "", style="bold")
85	    console.print(table)
86	
87	
88	def _print_simulation_results(rounds: dict) -> None:  # type: ignore[type-arg]
89	    """Print simulation results as Rich tables, one per round.
90	
91	    Args:
92	        rounds: Mapping of round index to ``RoundResult`` from
93	            ``TournamentSimulator.simulate``.
94	    """
95	    round_names = {
96	        0: "Round of 32",
97	        1: "Round of 16",
98	        2: "Quarter-finals",
99	        3: "Semi-finals",
100	        4: "Final",
101	    }
102	
103	    for round_num, result in sorted(rounds.items()):
104	        probs = result.probabilities
105	        sorted_probs = sorted(
106	            ((team, p) for team, p in probs.items() if p > 0),
107	            key=lambda x: x[1],
108	            reverse=True,
109	        )
110	
111	        table = Table(
112	            title=f"[bold]{round_names.get(round_num, f'Round {round_num}')}[/bold]"
113	        )
114	        table.add_column("Team", style="cyan")
115	        table.add_column("Win Probability", justify="right")
116	
117	        for team, prob in sorted_probs:
118	            bar = "█" * int(prob * 40)
119	            table.add_row(team, f"{prob:6.1%} {bar}")
120	
121	        console.print(table)
122	        console.print()
