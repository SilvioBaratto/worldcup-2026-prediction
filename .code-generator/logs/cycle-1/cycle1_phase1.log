594	# ---------------------------------------------------------------------------
595	# match_details.csv
596	# ---------------------------------------------------------------------------
597	
598	_MATCH_DETAILS_COLUMNS = [
599	    "MATCH_ID",
600	    "GOALS_home",
601	    "SHOTS_home",
602	    "SHOTS_ON_TARGET_home",
603	    "POSSESSION_home",
604	    "PASS_PCT_home",
605	    "GOALS_away",
606	    "SHOTS_away",
607	    "SHOTS_ON_TARGET_away",
608	    "POSSESSION_away",
609	    "PASS_PCT_away",
610	]
611	
612	# ---------------------------------------------------------------------------
613	# Fallback heuristics (applied when the API does not return a stat)
614	# ---------------------------------------------------------------------------
615	# These are fixed, deterministic formulae — no randomness.
616	#
617	# SHOTS = goals * 5 + 7
618	#   Rationale: a team that scores G goals attempted roughly (G*5 + 7) shots.
619	#   At 0 goals → 7 shots (baseline), at 1 goal → 12 shots (FIFA avg ~12).
620	#
621	# SHOTS_ON_TARGET = max(goals + 2, shots // 3)
622	#   Rationale: ~1/3 of shots are on target; at minimum the goals scored + 2.
623	#
624	# POSSESSION = 50.0 (neutral default — no data available)
625	#
626	# PASS_PCT   = 75.0 (global average pass-completion rate ~75 %)
627	# ---------------------------------------------------------------------------
628	
629	
630	def _heuristic_shots(goals: int) -> int:
631	    """Estimate total shots from goals scored (deterministic fallback)."""
632	    return goals * 5 + 7
633	
634	
635	def _heuristic_shots_on_target(goals: int, shots: int) -> int:
636	    """Estimate shots on target from goals and shots (deterministic fallback)."""
637	    return max(goals + 2, shots // 3)
638	
639	
640	_NEUTRAL_POSSESSION: float = 50.0
641	_NEUTRAL_PASS_PCT: float = 75.0
642	
643	
644	class MatchDetailsBuilder:
645	    """Fetches per-match detail stats and assembles match_details.csv.
646	
647	    Mirrors ``GamesDetailsBuilder`` in the NBA original — includes partial
648	    checkpointing so interrupted runs can be resumed without re-fetching.
649	
650	    football-data.org free tier does not expose shots/possession/pass stats
651	    through the ``/matches/{id}`` endpoint.  Where values are missing the
652	    builder fills them with the documented deterministic heuristics above.
653	    """
654	
655	    def __init__(
656	        self,
657	        client: FootballClient,
658	        match_ids: list[int],
659	        checkpoint_every: int = 100,
660	    ) -> None:
661	        self._client = client
662	        self._match_ids = match_ids
663	        self._checkpoint_every = checkpoint_every
664	
665	    def build(self, partial_path: Path | None = None) -> pd.DataFrame:
666	        """Fetch detail stats for all match IDs, with optional checkpointing and resume.
667	
668	        Args:
669	            partial_path: Path to the partial checkpoint file. If it exists the
670	                builder resumes from it, skipping already-fetched IDs.
671	
672	        Returns:
673	            DataFrame with the match_details.csv schema.
674	        """
675	        existing_df: pd.DataFrame | None = None
676	        fetched_ids: set[int] = set()
677	
678	        if partial_path is not None and partial_path.exists():
679	            existing_df, fetched_ids = self._load_partial(partial_path)
680	            logger.info("Resumed from partial: %d matches already fetched", len(fetched_ids))
681	
682	        remaining = [mid for mid in self._match_ids if mid not in fetched_ids]
683	        logger.info("Fetching %d matches (%d skipped)", len(remaining), len(fetched_ids))
684	
685	        frames: list[pd.DataFrame] = []
686	        if existing_df is not None and not existing_df.empty:
687	            frames.append(existing_df)
688	
689	        failed: list[int] = []
690	
691	        for i, match_id in enumerate(remaining):
692	            result = self._fetch_match_detail(match_id)
693	            if result is None:
694	                failed.append(match_id)
695	                continue
696	            frames.append(pd.DataFrame([result], columns=_MATCH_DETAILS_COLUMNS))
697	
698	            if partial_path is not None and (i + 1) % self._checkpoint_every == 0:
699	                self._save_partial(frames, partial_path)
700	                logger.info("Checkpoint: %d/%d matches fetched", i + 1, len(remaining))
701	
702	        if not frames:
703	            msg = "No match details fetched — all match IDs failed"
704	            raise RuntimeError(msg)
705	
706	        result_df = pd.concat(frames, ignore_index=True)
707	
708	        missing = set(_MATCH_DETAILS_COLUMNS) - set(result_df.columns)
709	        if missing:
710	            msg = f"Missing columns in match details data: {missing}"
711	            raise RuntimeError(msg)
712	
713	        result_df = result_df[_MATCH_DETAILS_COLUMNS]
714	
715	        if failed:
716	            logger.warning("Failed %d match IDs: %s", len(failed), failed)
717	
718	        logger.info("Built match_details DataFrame: %d rows", len(result_df))
719	        return result_df
720	
721	    def _fetch_match_detail(self, match_id: int) -> dict[str, object] | None:
722	        """Fetch detail for a single match. Returns None on failure."""
723	        try:
724	            data = self._client.get(f"/matches/{match_id}")
725	            return self._extract_detail_row(data, match_id)
726	        except Exception:
727	            logger.warning(
728	                "Failed to fetch match detail for %d", match_id, exc_info=True
729	            )
730	            return None
731	
732	    @staticmethod
733	    def _extract_detail_row(
734	        data: dict[str, object], match_id: int
735	    ) -> dict[str, object]:
736	        """Map raw API match object to the match_details.csv row schema.
737	
738	        Falls back to deterministic heuristics for statistics not exposed
739	        by the football-data.org free tier.  Pure function — no I/O.
740	        """
741	        score = data.get("score", {})  # type: ignore[union-attr]
742	        full_time = score.get("fullTime", {})  # type: ignore[union-attr]
743	        home_goals = int(full_time.get("home") or 0)
744	        away_goals = int(full_time.get("away") or 0)
745	
746	        # Attempt to read stats from the API response (paid-tier / future fields)
747	        odds = data.get("odds", {}) or {}  # type: ignore[union-attr]
748	
749	        home_shots = _heuristic_shots(home_goals)
750	        home_sot = _heuristic_shots_on_target(home_goals, home_shots)
751	        away_shots = _heuristic_shots(away_goals)
752	        away_sot = _heuristic_shots_on_target(away_goals, away_shots)
753	        home_possession: float = _NEUTRAL_POSSESSION
754	        away_possession: float = _NEUTRAL_POSSESSION
755	        home_pass_pct: float = _NEUTRAL_PASS_PCT
756	        away_pass_pct: float = _NEUTRAL_PASS_PCT
757	
758	        # If a paid tier ever exposes these fields they override the heuristics
759	        stats: list[dict[str, object]] = data.get("statistics", []) or []  # type: ignore[assignment]
760	        for stat in stats:
761	            home_val = stat.get("home")
762	            away_val = stat.get("away")
763	            stat_type = str(stat.get("type", ""))
764	            if stat_type == "TOTAL_SHOTS" and home_val is not None and away_val is not None:
765	                home_shots = int(home_val)
766	                away_shots = int(away_val)
767	            elif (
768	                stat_type == "SHOTS_ON_TARGET"
769	                and home_val is not None
770	                and away_val is not None
771	            ):
772	                home_sot = int(home_val)
773	                away_sot = int(away_val)
774	            elif (
775	                stat_type == "BALL_POSSESSION"
776	                and home_val is not None
777	                and away_val is not None
778	            ):
779	                home_possession = float(str(home_val).replace("%", ""))
780	                away_possession = float(str(away_val).replace("%", ""))
781	            elif (
782	                stat_type == "PASS_ACCURACY"
783	                and home_val is not None
784	                and away_val is not None
785	            ):
786	                home_pass_pct = float(str(home_val).replace("%", ""))
787	                away_pass_pct = float(str(away_val).replace("%", ""))
788	
789	        # Suppress unused variable warning (odds kept for future extension)
790	        _ = odds
791	
792	        return {
793	            "MATCH_ID": match_id,
794	            "GOALS_home": home_goals,
795	            "SHOTS_home": home_shots,
796	            "SHOTS_ON_TARGET_home": home_sot,
797	            "POSSESSION_home": home_possession,
798	            "PASS_PCT_home": home_pass_pct,
799	            "GOALS_away": away_goals,
800	            "SHOTS_away": away_shots,
801	            "SHOTS_ON_TARGET_away": away_sot,
802	            "POSSESSION_away": away_possession,
803	            "PASS_PCT_away": away_pass_pct,
804	        }
805	
806	    @staticmethod
807	    def _load_partial(partial_path: Path) -> tuple[pd.DataFrame, set[int]]:
808	        """Load a partial CSV and extract already-fetched match IDs."""
809	        try:
810	            df = pd.read_csv(partial_path)
811	            fetched_ids = {int(mid) for mid in df["MATCH_ID"]}
812	            return df, fetched_ids
813	        except Exception:
814	            logger.warning(
815	                "Failed to read partial file %s, starting fresh", partial_path
816	            )
817	            return pd.DataFrame(), set()
818	
819	    @staticmethod
820	    def _save_partial(frames: list[pd.DataFrame], partial_path: Path) -> None:
821	        """Concatenate accumulated frames and save to the partial checkpoint file."""
822	        pd.concat(frames, ignore_index=True).to_csv(partial_path, index=False)
823	
824	
825	def build_match_details_csv(
826	    output_path: Path,
827	    match_ids: list[int],
828	    client: FootballClient | None = None,
829	    checkpoint_every: int = 100,
830	) -> pd.DataFrame:
831	    """Build match_details.csv and write to disk.
832	
833	    Args:
834	        output_path: Where to write the CSV.
835	        match_ids: List of integer match IDs to fetch.
836	        client: Rate-limited API client. Created with defaults if ``None``.
837	        checkpoint_every: Save partial results every N matches.
838	
839	    Returns:
840	        The assembled DataFrame (11 columns matching the match_details.csv schema).
841	    """
842	    if client is None:
843	        client = FootballClient(ClientConfig())
844	
845	    partial_path = output_path.parent / (output_path.name + ".partial")
846	    builder = MatchDetailsBuilder(client, match_ids, checkpoint_every=checkpoint_every)
847	    df = builder.build(partial_path=partial_path)
848	
849	    output_path.parent.mkdir(parents=True, exist_ok=True)
850	    df.to_csv(output_path, index=False)
851	    logger.info("Wrote %d match detail rows to %s", len(df), output_path)
852	
853	    if partial_path.exists():
854	        partial_path.unlink()
855	
856	    return df
