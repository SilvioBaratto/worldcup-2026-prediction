484	class PlayersBuilder:
485	    """Fetches squad rosters for a competition and assembles players.csv.
486	
487	    Mirrors ``PlayersBuilder`` in the NBA original.
488	    """
489	
490	    def __init__(self, client: FootballClient, competition: str = "WC") -> None:
491	        self._client = client
492	        self._competition = competition
493	
494	    def build(self) -> pd.DataFrame:
495	        """Fetch teams for the competition, then squads for each team."""
496	        teams = self._fetch_teams()
497	        if not teams:
498	            msg = f"No teams found for competition {self._competition}"
499	            raise RuntimeError(msg)
500	
501	        rows: list[dict[str, object]] = []
502	        for team in teams:
503	            team_id = int(team.get("id", 0))
504	            squad = self._fetch_squad(team_id)
505	            for player in squad:
506	                row = self._extract_player_row(player)
507	                if row is not None:
508	                    rows.append(row)
509	
510	        if not rows:
511	            msg = "No player data fetched"
512	            raise RuntimeError(msg)
513	
514	        result = pd.DataFrame(rows, columns=_PLAYERS_COLUMNS)
515	
516	        missing = set(_PLAYERS_COLUMNS) - set(result.columns)
517	        if missing:
518	            msg = f"Missing columns after transformation: {missing}"
519	            raise RuntimeError(msg)
520	
521	        logger.info(
522	            "Built players DataFrame: %d rows for competition %s",
523	            len(result),
524	            self._competition,
525	        )
526	        return result
527	
528	    def _fetch_teams(self) -> list[dict[str, object]]:
529	        """Fetch team list for this competition. Failure is fatal."""
530	        data = self._client.get(f"/competitions/{self._competition}/teams")
531	        teams: list[dict[str, object]] = data.get("teams", [])
532	        logger.info(
533	            "Fetched %d teams for competition %s", len(teams), self._competition
534	        )
535	        return teams
536	
537	    def _fetch_squad(self, team_id: int) -> list[dict[str, object]]:
538	        """Fetch squad for a single team. Returns empty list on failure."""
539	        try:
540	            data = self._client.get(f"/teams/{team_id}")
541	            squad: list[dict[str, object]] = data.get("squad", [])
542	            return squad
543	        except Exception:
544	            logger.warning("Failed to fetch squad for team %d", team_id, exc_info=True)
545	            return []
546	
547	    def _extract_player_row(
548	        self, player: dict[str, object]
549	    ) -> dict[str, object] | None:
550	        """Map a single squad member to the players.csv row schema. Pure function."""
551	        try:
552	            name = player.get("name", "")
553	            if not name:
554	                return None
555	            return {
556	                "PLAYER_NAME": str(name),
557	                "PLAYER_ID": int(player.get("id", 0)),  # type: ignore[call-overload]
558	                "NATIONALITY": str(player.get("nationality", "")),
559	                "POSITION": str(player.get("position", "")),
560	                "COMPETITION": self._competition,
561	            }
562	        except Exception:
563	            logger.debug("Skipping malformed player record: %s", player, exc_info=True)
564	            return None
565	
566	
567	def build_players_csv(
568	    output_path: Path,
569	    client: FootballClient | None = None,
570	    competition: str = "WC",
571	) -> pd.DataFrame:
572	    """Build players.csv and write to disk.
573	
574	    Args:
575	        output_path: Where to write the CSV.
576	        client: Rate-limited API client. Created with defaults if ``None``.
577	        competition: Competition code (e.g. ``"WC"``).
578	
579	    Returns:
580	        The assembled DataFrame (5 columns matching the players.csv schema).
581	    """
582	    if client is None:
583	        client = FootballClient(ClientConfig())
584	
585	    builder = PlayersBuilder(client, competition=competition)
586	    df = builder.build()
587	
588	    output_path.parent.mkdir(parents=True, exist_ok=True)
589	    df.to_csv(output_path, index=False)
590	    logger.info("Wrote %d players to %s", len(df), output_path)
591	    return df
