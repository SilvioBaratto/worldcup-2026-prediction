2026-06-23 20:55:10,057 DEBUG msg #84: UserMessage tool_result(toolu_01KP2MNk3cvXUHnUGnmGKf4Q): 1	"""Clean and preprocess raw match data into analysis-ready training data.
2	
3	Output schema (train_data.csv):
4	    HOME_TEAM, AWAY_TEAM,
5	    GOALS_home, SHOTS_home, SHOTS_ON_TARGET_home, POSSESSION_home, PASS_PCT_home,
6	    GOALS_away, SHOTS_away, SHOTS_ON_TARGET_away, POSSESSION_away, PASS_PCT_away,
7	    HOME_WIN
8	"""
9	
10	from __future__ import annotations
11	
12	import logging
13	from pathlib import Path
14	
15	import pandas as pd
16	
17	from worldcup_playoff.config import DataConfig, FeaturesConfig
18	from worldcup_playoff.data.loader import validate_matches_df
19	
20	logger = logging.getLogger(__name__)
21	
22	# Columns produced in train_data.csv (mirrors SHARED CONTRACT)
23	_OUTPUT_COLUMNS = [
24	    "HOME_TEAM",
25	    "AWAY_TEAM",
26	    "GOALS_home",
27	    "SHOTS_home",
28	    "SHOTS_ON_TARGET_home",
29	    "POSSESSION_home",
30	    "PASS_PCT_home",
31	    "GOALS_away",
32	    "SHOTS_away",
33	    "SHOTS_ON_TARGET_away",
34	    "POSSESSION_away",
35	    "PASS_PCT_away",
36	    "HOME_WIN",
37	]
38	
39	# Columns expected in match_details.csv
40	_DETAIL_COLUMNS = [
41	    "MATCH_ID",
42	    "GOALS_home",
43	    "SHOTS_home",
44	    "SHOTS_ON_TARGET_home",
45	    "POSSESSION_home",
46	    "PASS_PCT_home",
47	    "GOALS_away",
48	    "SHOTS_away",
49	    "SHOTS_ON_TARGET_away",
50	    "POSSESSION_away",
51	    "PASS_PCT_away",
52	]
