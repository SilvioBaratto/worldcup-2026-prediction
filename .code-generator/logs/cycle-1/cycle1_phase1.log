19	# football-data.org v4 base URL
20	_BASE_URL = "https://api.football-data.org/v4"
21	
22	# HTTP status codes that warrant a retry with backoff
23	_RETRYABLE_STATUS_CODES = frozenset({429, 500, 502, 503, 504})
24	
25	# Browser-style User-Agent to avoid being blocked by WAF rules
26	_DEFAULT_USER_AGENT = (
27	    "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
28	    "AppleWebKit/537.36 (KHTML, like Gecko) "
29	    "Chrome/125.0.0.0 Safari/537.36"
