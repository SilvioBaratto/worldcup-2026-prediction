141	_VALID_DATASETS = frozenset({"teams", "matches", "ranking", "players", "match_details"})
142	
143	
144	def _parse_season_range(seasons: str) -> tuple[int, int]:
145	    """Parse a ``'START-END'`` season range into ``(start_year, end_year)``.
146	
147	    Args:
148	        seasons: String of the form ``"2006-2026"``.
149	
150	    Returns:
151	        Tuple of ``(start_year, end_year)`` as integers.
152	
153	    Raises:
154	        ``typer.Exit(code=1)`` on malformed input.
155	    """
156	    parts = seasons.split("-")
157	    if len(parts) != 2:  # noqa: PLR2004
158	        console.print(
159	            f"[red]Invalid --seasons format '{seasons}'. "
160	            "Use 'START-END', e.g. '2006-2026'.[/red]"
161	        )
162	        raise typer.Exit(code=1)
163	    try:
164	        start, end = int(parts[0]), int(parts[1])
165	    except ValueError:
166	        console.print(f"[red]--seasons values must be integers, got '{seasons}'.[/red]")
167	        raise typer.Exit(code=1)
168	    if start > end:
169	        console.print(f"[red]Start year {start} must be <= end year {end}.[/red]")
170	        raise typer.Exit(code=1)
171	    return start, end
172	
173	
174	def _parse_only_filter(only: str | None) -> set[str] | None:
175	    """Parse a comma-separated ``--only`` filter into a set of dataset names.
176	
177	    Args:
178	        only: Comma-separated string such as ``"teams,matches"`` or ``None``.
179	
180	    Returns:
181	        Set of validated dataset names, or ``None`` if *only* was not supplied.
182	
183	    Raises:
184	        ``typer.Exit(code=1)`` if any name is not in ``_VALID_DATASETS``.
185	    """
186	    if only is None:
187	        return None
188	    names = {n.strip() for n in only.split(",") if n.strip()}
189	    unknown = names - _VALID_DATASETS
190	    if unknown:
191	        console.print(
192	            f"[red]Unknown dataset(s): {unknown}. "
193	            f"Valid: {sorted(_VALID_DATASETS)}[/red]"
194	        )
195	        raise typer.Exit(code=1)
196	    return names
197	
198	
199	def _should_run(name: str, only_set: set[str] | None, skip_details: bool) -> bool:
200	    """Return whether a dataset build stage should execute.
201	
202	    Args:
203	        name: Dataset name (e.g. ``"matches"`` or ``"match_details"``).
204	        only_set: Restrict to this set when not ``None``.
205	        skip_details: When ``True``, always skip ``match_details``.
206	
207	    Returns:
208	        ``True`` when the stage should run.
209	    """
210	    if name == "match_details" and skip_details:
211	        return False
212	    if only_set is not None and name not in only_set:
213	        return False
214	    return True
