237	@app.command()
238	def download(
239	    seasons: str = typer.Option(
240	        "2006-2026",
241	        "--seasons",
242	        help='Season range as START-END (4-digit years), e.g. "2006-2026".',
243	    ),
244	    output_dir: Path = typer.Option(
245	        Path("dataset/csv"),
246	        "--output-dir",
247	        help="Output directory for all generated CSVs.",
248	    ),
249	    skip_details: bool = typer.Option(
250	        False,
251	        "--skip-details",
252	        help="Skip match_details.csv (requires matches.csv).",
253	    ),
254	    only: str | None = typer.Option(
255	        None,
256	        "--only",
257	        help='Comma-separated subset to build, e.g. "matches,teams".',
258	    ),
259	    verbose: int = typer.Option(0, "--verbose", "-v", count=True),
260	) -> None:
261	    """Download the full World Cup dataset from football-data.org."""
262	    _setup_logging(verbose)
263	
264	    start_year, end_year = _parse_season_range(seasons)
265	    only_set = _parse_only_filter(only)
266	    output = Path(output_dir).resolve()
267	    output.mkdir(parents=True, exist_ok=True)
268	
269	    client = FootballClient()
270	    results: dict[str, tuple[Path, int]] = {}
271	    matches_df: pd.DataFrame | None = None
272	
273	    with Progress(
274	        SpinnerColumn(),
275	        TextColumn("[progress.description]{task.description}"),
276	        BarColumn(),
277	        TextColumn("{task.completed}/{task.total}"),
278	        console=console,
279	    ) as progress:
280	        # Stage 1: teams.csv — no season dependency
281	        if _should_run("teams", only_set, skip_details):
282	            task = progress.add_task("Building teams.csv...", total=1)
283	            df = build_teams_csv(output / "teams.csv", client=client)
284	            progress.update(task, completed=1)
285	            results["teams"] = (output / "teams.csv", len(df))
286	
287	        # Stage 2: matches.csv — depends on season range
288	        if _should_run("matches", only_set, skip_details):
289	            task = progress.add_task(
290	                f"Building matches.csv ({start_year}–{end_year})...",
291	                total=1,
292	            )
293	            matches_df = build_matches_csv(
294	                output / "matches.csv",
295	                client=client,
296	                start_year=start_year,
297	                end_year=end_year,
298	            )
299	            progress.update(task, completed=1)
300	            results["matches"] = (output / "matches.csv", len(matches_df))
301	
302	        # Stage 3: ranking.csv — independent
303	        if _should_run("ranking", only_set, skip_details):
304	            task = progress.add_task(
305	                f"Building ranking.csv ({start_year}–{end_year})...",
306	                total=1,
307	            )
308	            df = build_ranking_csv(
309	                output / "ranking.csv",
310	                client=client,
311	                start_year=start_year,
312	                end_year=end_year,
313	            )
314	            progress.update(task, completed=1)
315	            results["ranking"] = (output / "ranking.csv", len(df))
316	
317	        # Stage 4: players.csv — uses WC competition (not season-ranged)
318	        if _should_run("players", only_set, skip_details):
319	            task = progress.add_task("Building players.csv...", total=1)
320	            df = build_players_csv(
321	                output / "players.csv",
322	                client=client,
323	                competition="WC",
324	            )
325	            progress.update(task, completed=1)
326	            results["players"] = (output / "players.csv", len(df))
327	
328	        # Stage 5: match_details.csv — depends on MATCH_ID from matches.csv
329	        if _should_run("match_details", only_set, skip_details):
330	            if matches_df is None:
331	                matches_path = output / "matches.csv"
332	                if not matches_path.exists():
333	                    console.print(
334	                        "[red]match_details requires matches.csv — "
335	                        "build it first or include 'matches' in --only.[/red]"
336	                    )
337	                    raise typer.Exit(code=1)
338	                matches_df = pd.read_csv(matches_path)
339	
340	            match_ids = [int(mid) for mid in matches_df["MATCH_ID"].unique()]
341	            task = progress.add_task(
342	                f"Building match_details.csv ({len(match_ids)} matches)...",
343	                total=len(match_ids),
344	            )
345	            df = build_match_details_csv(
346	                output / "match_details.csv",
347	                match_ids,
348	                client=client,
349	                checkpoint_every=100,
350	            )
351	            progress.update(task, completed=len(match_ids))
352	            results["match_details"] = (output / "match_details.csv", len(df))
353	
354	    if results:
355	        _print_download_summary(results)
356	    else:
357	        console.print("[yellow]No datasets selected to download.[/yellow]")
358	
